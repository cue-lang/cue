      "side": 1,
      "message": "nit: a module doesn\u0027t resolve to a registry does it? I thought we always just used CUE_REGISTRY (or the default)? Is there really a mechanism for different modules to indicate they belong in different registries?",
      "range": {
        "startLine": 17,
        "startChar": 16,
        "endLine": 17,
        "endChar": 34
      },
      "revId": "6986a727dd1e91105c4c86c592f4484c9aa37ad4",
