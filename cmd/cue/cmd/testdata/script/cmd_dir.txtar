exec cue cmd ls
cmp stdout expect-stdout

# A task whose dir field fails to evaluate must surface that error
# rather than running the command in the current working directory.
# TODO: the error is silently ignored and the command succeeds.
exec cue cmd baddir

-- expect-stdout --
a.txt
b.txt

-- ls-work-dir/a.txt --
-- ls-work-dir/b.txt --

-- ls_tool.cue --
package ls

import (
    "tool/cli"
    "tool/exec"
    "encoding/json"
)

command: ls: {
    ls: exec.Run & {
		cmd:    "ls"
		dir:    "ls-work-dir"
		stdout: string
	}

	task: display: cli.Print & {
		text: ls.stdout
	}
}

command: baddir: run: exec.Run & {
	cmd: ["true"]
	dir: json.Marshal({a!: int})
}

-- cue.mod/module.cue --
module: "test.example"
language: version: "v0.9.0"
