exec cue cmd printTask
cmp stdout stdout.golden

-- cue.mod/module.cue --
module: "example.com"
language: version: "v0.9.0"

-- stdout.golden --
{"$id":"tool/exec.Run","cmd":["true"],"env":{},"stdout":"","stderr":null,"stdin":null,"success":true,"mustSucceed":true}
-- foo_tool.cue --
package foo

import (
	"encoding/json"
	"tool/cli"
	"tool/exec"
)

command: printTask: {
	task: exec.Run & {
		cmd: ["true"]
		stdout: string
	}
	print: cli.Print & {
		text: json.Marshal(task)
	}
}
