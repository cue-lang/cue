exec cue cmd http
cmp stdout cmd_http.out
-- cmd_http.out --
{"Version":"v1.0.0","Time":"2018-10-22T18:45:39Z"}


-- task_tool.cue --
package home

import (
	"tool/cli"
	h "tool/http"
	"tool/os"
)

command: http: {
	env: os.Getenv & {
        GOPROXY: string
	}
	task: http: h.Get & {
		url: env.GOPROXY + "/externalmod.test/imports/@v/v1.0.0.info"

		// Regression test for https://cuelang.org/issue/4329.
		// Setting a request header as a single string value must be allowed.
		request: header: "X-Test": "some-value"

		response: body: string // TODO: allow this to be a struct, parsing the body.
	}
	task: print: cli.Print & {
		text: task.http.response.body
	}
}
