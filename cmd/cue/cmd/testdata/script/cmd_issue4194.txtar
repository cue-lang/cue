# Verify that using a non-existent task type reports the actual CUE error
# rather than "no tasks found".

! exec cue cmd testdata
stderr 'undefined field: Mkdir'
! stderr 'no tasks found'

-- cue.mod/module.cue --
module: "mod.test/test"
language: version: "v0.9.0"
-- task_tool.cue --
package home

import "tool/cli"

command: testdata: {
	mkdirInputs: cli.Mkdir & {
		path: "input"
	}
}
