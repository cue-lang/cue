# References in cue doc: docs are not inherited through references;
# a reference to an addressable node becomes a single "also includes"
# link (rather than enumerating every field it contributes); fields
# of unaddressable (inline) nodes are documented in place; reference
# cycles terminate.
exec cue doc
cmp stdout expect-stdout

-- cue.mod/module.cue --
module: "mod.test/m"
language: version: "v0.9.0"
-- a.cue --
package p

// x's own doc, not y's.
x: y

// y holds b and c.
y: {
	// b is y's field.
	b: int
	// c is y's field too.
	c: int
}

// m mixes a direct declaration of b with a reference.
m: y
m: {
	// b is also declared directly on m.
	b: 10
}

// w embeds y.
w: {y, d: 1}

// i pulls a field out of an inline struct.
i: {h: {
	// g is documented in place: it is addressable nowhere else.
	g: int
}}.h

// pc is cyclic through an inline struct.
pc: {r: {s: r}}.r

// q references a field whose name needs quoting in links.
o="od-d": {q1: int}
q: o
-- expect-stdout --
Docs for pkg mod.test/m@v0:p
i:
    i pulls a field out of an inline struct.
    g:
        g is documented in place: it is addressable nowhere else.
m:
    m mixes a direct declaration of b with a reference.
    also includes y
    b:
        b is also declared directly on m.
        also includes y.b
"od-d":
    q references a field whose name needs quoting in links.
    q1:
pc:
    pc is cyclic through an inline struct.
    s:
q:
    also includes "od-d"
w:
    w embeds y.
    also includes y
    d:
x:
    x's own doc, not y's.
    also includes y
y:
    y holds b and c.
    b:
        b is y's field.
    c:
        c is y's field too.
