#Issue: 1509

# export
! exec cue export
cmp stderr expect-stderr1

# eval
! exec cue eval
cmp stderr expect-stderr2

-- x.cue --
package x

import "list"

x: [1, 2, 3]
// This is a fatal error, as the passed struct will never be
// able to contain `less` by making the configuration more concrete.
sortedx: list.Sort(x, {})

-- expect-stderr1 --
sortedx: error in call to list.Sort: field not found: less:
    ./x.cue:8:10
-- expect-stderr2 --
sortedx: error in call to list.Sort: field not found: less:
    ./x.cue:8:10
