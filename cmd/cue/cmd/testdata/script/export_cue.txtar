# Verify that -p and -l work when exporting as CUE.

# Case 1: only non-CUE inputs
exec cue export --out cue -p blah x.json y.json
cmp stdout stdout.golden

# Case 2: CUE input which does not declare a package (with JSON)
exec cue export --out cue -p blah nopkg.cue x.json y.json
cmp stdout stdout.golden

# Case 3: CUE input which does declare same package (with JSON)
exec cue export --out cue -p blah pkg.cue x.json y.json
cmp stdout stdout.golden

# Case 4: CUE input with mis-matched package (with JSON) clashes,
# unless --force repackages the merged result.
! exec cue export --out cue -p blah diffpkg.cue x.json y.json
cmp stderr stderr.golden
exec cue export --out cue -p blah diffpkg.cue x.json y.json --force
cmp stdout stdout.golden

# Case 5: -l places the exported CUE value at a path.
# Regression test for https://cuelang.org/issue/1485
exec cue export --out cue -p after -l 'newpath:' ./sub
cmp stdout path.golden

# Case 6: a single CUE file whose package already matches --package.
# Regression test for https://cuelang.org/issue/3671
exec cue export --out cue -p blah pkg.cue
cmp stdout stdout.golden

# Case 7: a single CUE file with a different package.
# TODO(#3671): wrongly reports a clash; with no orphan data to merge,
# --package should simply rename the output package.
! exec cue export --out cue -p blah diffpkg.cue
cmp stderr stderr.golden

-- x.json --
{
    "x": 5
}
-- y.json --
{
    "y": 4
}
-- nopkg.cue --
x: 5
y: 4
-- pkg.cue --
package blah

x: 5
y: 4
-- diffpkg.cue --
package other

x: 5
y: 4
-- stdout.golden --
package blah

x: 5
y: 4
-- stderr.golden --
"package" flag clashes with existing package name (blah vs other)
-- sub/path.cue --
package before

#X: string | int

foo: [string]: #X

foo: a: "a"
foo: b: 1
-- path.golden --
package after

newpath: foo: {
	a: "a"
	b: 1
}
