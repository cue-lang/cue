# Test that a Go field of type cue.Value is translated to top rather than
# generating CUE for the cuelang.org/go/cue package. See issue #3488.
# Marshaler types from other packages, like dep.Value, are still
# generated and referenced as usual.

# Replace cuelang.org/go with the local checkout, reusing the host's
# module cache and go.sum to avoid network access.
env GOMODCACHE=$HOST_GOMODCACHE
go mod edit -replace=cuelang.org/go=$CUE_CHECKOUT_ROOT
cp $CUE_CHECKOUT_ROOT/go.sum go.sum
go mod tidy

exec cue get go --local ./x
cmp x/x_go_gen.cue x/x_go_gen.cue.golden
exists dep/dep_go_gen.cue
! exists cue.mod/gen/cuelang.org

# Check that the resulting CUE is valid
exec cue vet -c=false ./x

-- go.mod --
module mod.test

go 1.25

require cuelang.org/go v0.0.0
-- cue.mod/module.cue --
module: "mod.test"
language: version: "v0.15.0"
-- dep/dep.go --
package dep

type Value struct {
	x int
}

func (v Value) MarshalJSON() ([]byte, error) {
	return nil, nil
}
-- x/x.go --
package x

import (
	"cuelang.org/go/cue"

	"mod.test/dep"
)

type X struct {
	Field1 int       `json:"field1"`
	Field2 cue.Value `json:"field2"`
	Field3 dep.Value `json:"field3"`
}
-- x/x_go_gen.cue.golden --
// Code generated by cue get go. DO NOT EDIT.

//cue:generate cue get go mod.test/x

package x

import "mod.test/dep"

#X: {
	field1: int        @go(Field1)
	field2: _          @go(Field2,cue.Value)
	field3: dep.#Value @go(Field3)
}
