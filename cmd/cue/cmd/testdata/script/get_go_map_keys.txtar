# Test which map key types are supported by cue get go.
# encoding/json supports keys that are strings or integers,
# or which implement encoding.TextMarshaler, encoding them as strings.
# Other key types, like pointers, cannot be marshaled. See issue #3064.

exec cue get go --local .
cmp x_go_gen.cue x_go_gen.cue.golden

# Check that the resulting CUE is valid
exec cue vet -c=false .

-- go.mod --
module mod.test

go 1.25
-- cue.mod/module.cue --
module: "mod.test"
language: version: "v0.15.0"
-- x.go --
package x

type T1 struct {
	X map[int]string
	Y map[uint8]bool
}

type T2 struct {
	X map[S]string
	Y S
}

// S implements encoding.TextMarshaler.
type S int

func (s S) MarshalText() ([]byte, error) {
	return nil, nil
}

// T3's X can never be marshaled by encoding/json.
type T3 struct {
	X map[*int]string
	Y int
}

type IntMap map[int64]string
-- x_go_gen.cue.golden --
// Code generated by cue get go. DO NOT EDIT.

//cue:generate cue get go mod.test

package x

#T1: {
	X: {[string]: string} @go(,map[int]string)
	Y: {[string]: bool}   @go(,map[uint8]bool)
}

#T2: {
	X: {[string]: string} @go(,map[S]string)
	Y: #S
}

// S implements encoding.TextMarshaler.
#S: string

// T3's X can never be marshaled by encoding/json.
#T3: Y: int

#IntMap: [string]: string
