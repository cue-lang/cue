# The module governing an explicitly loaded file comes from the current working
# directory, not from where the file resides. Imports, the module's language
# version, and @embed are exercised from a working directory inside the module
# (a file in the module, the same via stdin, and a file outside the module) and
# from a working directory with no module (a file that resides inside the
# module). The module lives in subdirectory module, and each feature uses its
# own package.

cd module

# A file within the module: an import to a sibling package resolves.
exec cue export imp.cue
cmp stdout $WORK/golden/imp
stdin imp.cue
exec cue export -
cmp stdout $WORK/golden/imp
exec cue export ../out_imp.cue
cmp stdout $WORK/golden/imp

# The module's language version (v0.11.0, before automatic commas in list
# literals) is applied, so these newline-separated lists are rejected.
! exec cue export ver/ver.cue
stderr 'before newline in list literal'
stdin ver/ver.cue
! exec cue export -
stderr 'before newline in list literal'
! exec cue export ../out_ver.cue
stderr 'before newline in list literal'

# TODO(bug): @embed should work for a file within the module, but fails in all
# three forms because command-line-arguments packages have no Module set (see
# cue/load cueFilesPackage).
! exec cue export emb.cue
stderr 'cannot embed files when not in a module'
stdin emb.cue
! exec cue export -
stderr 'cannot embed files when not in a module'
! exec cue export ../out_emb.cue
stderr 'cannot embed files when not in a module'

# Issue 4340: a file inside the module, named via a path from a working
# directory outside it. Such a file is currently loaded without its module.
#
# TODO: arguably ./module should not work in the examples below,
# because we're selecting a package through a module boundary.
cd ..

# Imports fail because the file is loaded without its module.
! exec cue export module/imp.cue
stderr 'imports are unavailable'
! exec cue export ./module:imp
stderr 'imports are unavailable'

# We apply the latest language version because the file is loaded without its module.
exec cue export module/ver/ver.cue
stdout '"list"'
exec cue export ./module/ver:ver
stdout '"list"'

# Embedding fails because the file is loaded without its module.
! exec cue export module/emb.cue
stderr 'cannot embed files when not in a module'
! exec cue export ./module:emb
stderr 'cannot embed files when not in a module'

-- module/cue.mod/module.cue --
module: "main.org@v0"
language: version: "v0.11.0"

-- module/sub/sub.cue --
package sub

Value: 42

-- module/imp.cue --
package imp

import "main.org/sub"

out: sub.Value

-- module/ver/ver.cue --
package ver

list: [
	1
	2
]

-- module/emb.cue --
@extern(embed)

package emb

embedded: _ @embed(file="data.json")

-- module/data.json --
{ "x": 1 }

-- out_imp.cue --
package imp

import "main.org/sub"

out: sub.Value

-- out_ver.cue --
package ver

list: [
	1
	2
]

-- out_emb.cue --
@extern(embed)

package emb

embedded: _ @embed(file="out_data.json")

-- out_data.json --
{ "x": 2 }

-- golden/imp --
{
    "out": 42
}
