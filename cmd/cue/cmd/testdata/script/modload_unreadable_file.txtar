# Errors for CUE files which cannot be read while resolving imports
# should mention the file just once.

# On Windows, chmod 000 does not deny reading a file.
[windows] skip 'file permissions cannot deny reads on Windows'

exec cue export .
cmp stdout want-export.txt

# An unreadable file in a dependency package directory.
# TODO(https://cuelang.org/issue/2952): the message repeats the file name.
chmod 000 $CUE_CACHE_DIR/mod/extract/example.com/e@v0.0.1/top.cue
! exec cue export .
stderr '^test.org@v0: import failed: cannot find package "example.com/e": cannot get imports: cannot read "top.cue": open top.cue: permission denied:$'
chmod 644 $CUE_CACHE_DIR/mod/extract/example.com/e@v0.0.1/top.cue

# An unreadable file in the main module.
# TODO(https://cuelang.org/issue/2952): the message repeats the file name.
chmod 000 sub/bad.cue
! exec cue mod tidy
stderr '^cannot read "sub/bad.cue": open sub/bad.cue: permission denied$'

-- want-export.txt --
{
    "x": "bar"
}
-- cue.mod/module.cue --
module: "test.org"
language: version: "v0.9.0"
deps: "example.com/e": v: "v0.0.1"
-- main.cue --
package main
import "example.com/e"

x: e.foo
-- sub/bad.cue --
package sub
-- _registry/example.com_e_v0.0.1/cue.mod/module.cue --
module: "example.com/e@v0"
language: version: "v0.9.0"
-- _registry/example.com_e_v0.0.1/top.cue --
package e
foo: "bar"
