# cue mod tidy with a cue.mod/local-module.cue file present.
# The main module imports a package provided by a module that is replaced
# by a local directory. tidy must:
#   - keep the replace directive in local-module.cue (with the dep set
#     resolved with the replacement applied), and
#   - record the published dependency (resolved from the registry, without
#     the replacement) in module.cue.

exec cue mod tidy
cmp cue.mod/module.cue want-module
cmp cue.mod/local-module.cue want-local

# The build uses the local directory's content.
exec cue export .
cmp stdout want-stdout

# tidy is idempotent.
exec cue mod tidy --check

-- want-module --
module: "main.org@v0"
language: version: "v0.17.0"
deps: "example.com/dep@v0": v: "v0.1.0"
-- want-local --
deps: "example.com/dep@v0": replace: "./local_dep"
-- want-stdout --
{
    "out": "from local directory"
}
-- cue.mod/module.cue --
module: "main.org@v0"
language: version: "v0.17.0"
-- cue.mod/local-module.cue --
deps: "example.com/dep@v0": {
	v:       "v0.1.0"
	replace: "./local_dep"
}
-- main.cue --
package main

import "example.com/dep@v0:lib"

out: lib.value
-- local_dep/cue.mod/module.cue --
module: "example.com/dep@v0"
language: version: "v0.9.0"
-- local_dep/lib.cue --
package lib

value: "from local directory"
-- _registry/example.com_dep_v0.1.0/cue.mod/module.cue --
module: "example.com/dep@v0"
language: version: "v0.9.0"
-- _registry/example.com_dep_v0.1.0/lib.cue --
package lib

value: "from registry"
