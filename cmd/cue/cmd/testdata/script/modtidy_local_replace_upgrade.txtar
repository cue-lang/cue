# Scenario: a replace directive points at example.com/target@v0.0.1, while
# another dependency (example.com/dep@v0) transitively requires
# example.com/target@v0.0.2. So the replacement target is also a regular
# dependency at a higher version.
#
# What we would hope: cue mod tidy upgrades the replace directive's target
# to v0.0.2 so that a single, consistent version of example.com/target is
# used throughout the build.
#
# This is the "MVS replacement-upgrade" case noted as not-yet-handled when
# the two-file tidy support was added. This test pins down the actual
# (arguably wrong) behavior so the eventual fix has something to flip:
#
#   - local-module.cue keeps replace pinned at target@v0.0.1; tidy does NOT
#     rewrite it to v0.0.2.
#   - module.cue (the published view, computed without the replace) records
#     target@v0.0.2, the version dep requires.
#   - At build time the replace pins example.com/target to v0.0.1 for the
#     whole build, so example.com/dep silently sees target v0.0.1 even
#     though it requires v0.0.2 (see want-stdout: fromDep is "target
#     v0.0.1", not "target v0.0.2").
#   - cue mod tidy --check nonetheless considers this state tidy.
#
# TODO fix this

exec cue mod tidy
cmp cue.mod/module.cue want-module
cmp cue.mod/local-module.cue want-local

exec cue export .
cmp stdout want-stdout

exec cue mod tidy --check

-- want-module --
module: "main.org@v0"
language: {
	version: "v0.17.0"
}
deps: {
	"example.com/dep@v0": {
		v: "v0.1.0"
	}
	"example.com/orig@v0": {
		v: "v0.1.0"
	}
	"example.com/target@v0": {
		v: "v0.0.2"
	}
}
-- want-local --
deps: {
	"example.com/dep@v0": {}
	"example.com/orig@v0": {
		replace: "example.com/target@v0.0.1"
	}
}
-- want-stdout --
{
    "fromOrig": "target v0.0.1",
    "fromDep": "target v0.0.1"
}
-- cue.mod/module.cue --
module: "main.org@v0"
language: version: "v0.17.0"
-- cue.mod/local-module.cue --
deps: "example.com/orig@v0": {
	v:       "v0.1.0"
	replace: "example.com/target@v0.0.1"
}
-- main.cue --
package main

import (
	"example.com/orig@v0:lib"
	"example.com/dep@v0:dep"
)

fromOrig: lib.value
fromDep:  dep.value
-- _registry/example.com_orig_v0.1.0/cue.mod/module.cue --
module: "example.com/orig@v0"
language: version: "v0.9.0"
-- _registry/example.com_orig_v0.1.0/lib.cue --
package lib

value: "from orig (should not see this)"
-- _registry/example.com_target_v0.0.1/cue.mod/module.cue --
module: "example.com/target@v0"
language: version: "v0.9.0"
-- _registry/example.com_target_v0.0.1/lib.cue --
package lib

value: "target v0.0.1"
-- _registry/example.com_target_v0.0.2/cue.mod/module.cue --
module: "example.com/target@v0"
language: version: "v0.9.0"
-- _registry/example.com_target_v0.0.2/lib.cue --
package lib

value: "target v0.0.2"
-- _registry/example.com_dep_v0.1.0/cue.mod/module.cue --
module: "example.com/dep@v0"
language: version: "v0.9.0"
deps: "example.com/target@v0": {
	v: "v0.0.2"
}
-- _registry/example.com_dep_v0.1.0/dep.cue --
package dep

import "example.com/target@v0:lib"

value: lib.value
