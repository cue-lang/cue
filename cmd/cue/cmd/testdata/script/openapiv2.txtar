# With the openapiv2 experiment enabled, the openapi encoding extracts and
# generates the whole OpenAPI document (via ExtractV2/GenerateV2) rather than
# only its component schemas.

env CUE_EXPERIMENT=openapiv2

# Extraction preserves the whole document, not just the schemas.
exec cue import -p test -o - openapi: openapi.json
cmp stdout expect-extract

# Generation reproduces an OpenAPI document from the extracted CUE.
exec cue import -p test -f -o extracted.cue openapi: openapi.json
exec cue export --out openapi extracted.cue
cmp stdout expect-generate

# Without the experiment, extraction only yields the component schemas.
env CUE_EXPERIMENT=
exec cue import -p test -o - openapi: openapi.json
cmp stdout expect-extract-v1

-- openapi.json --
{
  "openapi": "3.0.0",
  "info": {"title": "test", "version": "1.0"},
  "paths": {},
  "components": {
    "schemas": {
      "Foo": {
        "type": "object",
        "properties": {"name": {"type": "string"}},
        "required": ["name"]
      }
    }
  }
}
-- expect-extract --
package test

openapi: "3.0.0"
info: {
	title:   "test"
	version: "1.0"
}

#Foo: {
	name!: string
	...
}

paths: {}
-- expect-generate --
{
    "openapi": "3.0.0",
    "info": {
        "title": "test",
        "version": "1.0"
    },
    "paths": {}
}
-- expect-extract-v1 --
// test
package test

info: {
	title:   *"test" | string
	version: *"1.0" | string
}

#Foo: {
	name!: string
	...
}
