# Test the various kinds of wildcard patterns that we do not support.

# Patterns on modules other than the current module are not supported,
# even though one valid package could be matched.
! exec cue eval example.com/foo/...
cmp stderr external.stderr
exec cue eval example.com/foo
stdout -count=1 '^self: "example.com/foo"$'

# The "all", "cmd", and "std" patterns were inherited from Go,
# but they do nothing useful right now.
# TODO: decide whether to support or reject these.
! exec cue eval all
cmp stderr all.stderr
! exec cue eval cmd
cmp stderr cmd.stderr
! exec cue eval std
cmp stderr std.stderr

# A lone wildcard, perhaps equivalent to "all", is not supported for now.
# TODO: much like "all", decide whether to support or reject this.
! exec cue eval ...
cmp stderr dots.stderr

# Patterns with a leading wildcard are not supported either,
# as they could match any module ever published,
# even though one valid package could be matched.
! exec cue eval .../leaf
cmp stderr dots-prefix.stderr
exec cue eval ./alpha1/leaf
stdout -count=1 '^self: "mod.com/alpha1/leaf"$'

# A wildcard in the middle of a pattern should match only those packages
# whose path matches the pattern in full, not every package under the
# directory prefix before the wildcard. Following Go's package patterns,
# the wildcard and its neighboring slash should match at least one path
# element, so the top-level "leaf" directory should not be included.
# TODO: every package under "." is matched; see issue 3212.
exec cue eval ./.../leaf
cmp stdout dots-middle.stdout

# The directory prefix before the wildcard restricts the matches;
# as above, "beta1/leaf" itself should not be matched by "beta1/.../leaf".
# TODO: every package under "./beta1" is matched; see issue 3212.
exec cue eval ./beta1/.../leaf
cmp stdout beta1-dots-middle.stdout

# A pattern may contain multiple wildcards. All pattern elements should be
# matched: "alpha1/mid/other" lacks a "leaf" element, so only
# "alpha1/leaf/mid/other" should be included.
# TODO: every package under "." is matched; see issue 3212.
exec cue eval ./.../leaf/.../other
cmp stdout dots-middle.stdout

# A pattern with both a middle and a trailing wildcard; the trailing
# "/..." should also match "blah/foo" itself.
# TODO: every package under "." is matched; see issue 3212.
exec cue eval ./.../foo/...
cmp stdout dots-middle.stdout

# A pattern element should not consume the text matching a later element:
# the two "foo" pattern elements should match the first and last "foo"
# elements in "blah/foo/x/foo".
# TODO: every package under "." is matched; see issue 3212.
exec cue eval ./.../foo/.../foo
cmp stdout dots-middle.stdout

# Wildcards should not be restricted to whole path elements; they should
# be able to match part of an element, or span across multiple elements.
# TODO: every package under "." is matched; see issue 3212.
exec cue eval ./...1/leaf
cmp stdout dots-middle.stdout
exec cue eval ./b...2/leaf
cmp stdout dots-middle.stdout

# Text between two wildcards need not span a whole element either:
# "./...foo..." should match any package path containing "foo",
# including inside an element such as "AfooB".
# TODO: every package under "." is matched; see issue 3212.
exec cue eval ./...foo...
cmp stdout dots-middle.stdout

# A pattern which matches no packages should be an error.
# TODO: every package under "." is matched; see issue 3212.
exec cue eval ./.../nonexistent
cmp stdout dots-middle.stdout

# Directories excluded by the pattern should not affect the result,
# even when loading them would fail; here, "multi" contains
# two packages, which is an error for a wildcard match.
# TODO: the non-matching "multi" directory is an error; see issue 3212.
cd multimod
! exec cue eval ./.../leaf
cmp stderr ../multimod-dots-middle.stderr
cd ..

# TODO: Unlike other cases, this still returns a "matched no packages" error.
! exec cue eval mod.com/.../leaf
cmp stderr current-dots-middle.stderr

# A wildcard in the middle of a pattern, with a dependency module as a prefix.
! exec cue eval example.com/foo/.../bar
cmp stderr external-dots-middle.stderr

# Matching many external modules, which could mean registry requests.
! exec cue eval example.com/...
cmp stderr external-dots-multimod.stderr

-- external.stderr --
pattern not allowed in external package path "example.com/foo/..."
-- all.stderr --
cue: "all" matched no packages
-- cmd.stderr --
cue: "cmd" matched no packages
-- std.stderr --
cue: "std" matched no packages
-- dots.stderr --
pattern not allowed in external package path "..."
-- dots-prefix.stderr --
pattern not allowed in external package path ".../leaf"
-- dots-middle.stdout --
"example.com/foo"
// ---
self: "mod.com/alpha1/leaf"
// ---
self: "mod.com/alpha1/leaf/mid/other"
// ---
self: "mod.com/alpha1/mid/other"
// ---
self: "mod.com/beta1/beta2/leaf"
// ---
self: "mod.com/beta1/leaf"
// ---
self: "mod.com/blah/foo"
// ---
self: "mod.com/blah/foo/x/foo"
// ---
self: "mod.com/leaf"
// ---
self: "mod.com/y/AfooB/z"
-- beta1-dots-middle.stdout --
self: "mod.com/beta1/beta2/leaf"
// ---
self: "mod.com/beta1/leaf"
-- multimod-dots-middle.stderr --
found packages "a" (a.cue) and "b" (b.cue) in "multi"
-- current-dots-middle.stderr --
cue: "mod.com/.../leaf" matched no packages
-- external-dots-middle.stderr --
pattern not allowed in external package path "example.com/foo/.../bar"
-- external-dots-multimod.stderr --
pattern not allowed in external package path "example.com/..."
-- cue.mod/module.cue --
module: "mod.com"

language: version: "v0.9.0"

deps: "example.com/foo": v: "v0.0.1"
-- root.cue --
package root

import "example.com/foo"

foo.self
-- leaf/leaf.cue --
package leaf
self: "mod.com/leaf"
-- alpha1/leaf/leaf.cue --
package leaf
self: "mod.com/alpha1/leaf"
-- alpha1/leaf/mid/other/other.cue --
package other
self: "mod.com/alpha1/leaf/mid/other"
-- alpha1/mid/other/other.cue --
package other
self: "mod.com/alpha1/mid/other"
-- blah/foo/bar.cue --
package bar
self: "mod.com/blah/foo"
-- blah/foo/x/foo/foo.cue --
package foo
self: "mod.com/blah/foo/x/foo"
-- y/AfooB/z/z.cue --
package z
self: "mod.com/y/AfooB/z"
-- beta1/leaf/leaf.cue --
package leaf
self: "mod.com/beta1/leaf"
-- beta1/beta2/leaf/leaf.cue --
package leaf
self: "mod.com/beta1/beta2/leaf"
-- multimod/cue.mod/module.cue --
module: "multi.example"

language: version: "v0.9.0"
-- multimod/multi/a.cue --
package a
self: "a"
-- multimod/multi/b.cue --
package b
self: "b"
-- multimod/sub/leaf/leaf.cue --
package leaf
self: "multi.example/sub/leaf"
-- _registry/example.com_foo_v0.0.1/cue.mod/module.cue --
module: "example.com/foo@v0"
language: version: "v0.8.0"

-- _registry/example.com_foo_v0.0.1/foo.cue --
package foo
self: "example.com/foo"
-- _registry/example.com_foo_v0.0.1/bar/bar.cue --
package bar
self: "example.com/foo/bar"
