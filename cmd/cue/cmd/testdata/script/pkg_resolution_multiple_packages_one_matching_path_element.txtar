# Test that a relative package path functions the same as an absolute package path
# when there are multiple packages in the directory where one has a name
# that matches the final element of the import path.

exec cue eval root.cue
cmp stdout stdout.golden
exec cue eval mod.com/x
cmp stdout stdout.golden
exec cue eval mod.com/x/
cmp stdout stdout.golden
# TODO: the following two commands fail unexpectedly although they should be
# consistent with the above; note also that a trailing slash changes the error.
# See issue #3707.
! exec cue eval ./x
stderr 'found packages "x" \(x.cue\) and "y" \(y.cue\) in "\./x"'
! exec cue eval ./x/
stderr 'found packages "x" \(x.cue\) and "y" \(y.cue\) in "x"'

-- stdout.golden --
x: 5
-- cue.mod/module.cue --
module: "mod.com"
language: version: "v0.9.0"
-- root.cue --
package root

import "mod.com/x"

x
-- x/x.cue --
package x

x: 5
-- x/y.cue --
package y

y: 5
