# Test that cue plugin build uses VCS metadata from the CUE registry
# to resolve Go module versions when the Go package is local to the
# CUE module's own go.mod.

exec cue plugin build

# Verify generated files exist.
exists cue.mod/plugin/main.go
exists cue.mod/plugin/go.mod

# Verify the generated main.go matches expected output.
cmp cue.mod/plugin/main.go want-main.go

# Verify generated go.mod uses the pseudo-version (not a replace directive).
grep 'example.com/strutil v0.0.0-20240715103000-abc123def456' cue.mod/plugin/go.mod
! grep 'replace.*example.com/strutil' cue.mod/plugin/go.mod

# Verify the generated manifest matches expected output.
cmp cue.mod/plugin/manifest.json want-manifest.json

exec cue export .
cmp stdout want-export

-- want-export --
{
    "upper": "HELLO"
}
-- cue.mod/module.cue --
module: "test.example@v0"
language: version: "v0.17.0"
deps: {
	"example.com/strutil@v0": {
		v: "v0.0.1"
	}
}

-- main.cue --
package main

import "example.com/strutil"

upper: strutil.Upper("hello")

-- _registry/example.com_strutil_v0.0.1/_module_meta.json --
{
    "org.cuelang.vcs-type": "git",
    "org.cuelang.vcs-commit": "abc123def4560ab45a53021fff95f24d9ab1b79a",
    "org.cuelang.vcs-commit-time": "2024-07-15T10:30:00Z"
}
-- _registry/example.com_strutil_v0.0.1/cue.mod/module.cue --
module: "example.com/strutil@v0"
language: version: "v0.17.0"
-- _registry/example.com_strutil_v0.0.1/strutil.cue --
@extern(go)
package strutil

Upper: _ @go(Upper)
-- _registry/example.com_strutil_v0.0.1/go.mod --
module example.com/strutil
go 1.21
-- _registry/example.com_strutil_v0.0.1/util.go --
package strutil

import "strings"

func Upper(s string) string {
	return strings.ToUpper(s)
}
-- want-main.go --
// Code generated by cue plugin build; DO NOT EDIT.

package main

import (
	"os"

	"cuelang.org/go/cmd/cue/cmd"
	"cuelang.org/go/cue"
	"cuelang.org/go/cue/cuecontext"
	"cuelang.org/go/cue/inject/goplugin"

	strutil "example.com/strutil"
)

func main() {
	refs := map[goplugin.Reference]func() cue.Value{
		{
			GoPackage:        ".",
			CUEModuleVersion: "example.com/strutil@v0.0.1",
			CUEInstance:      "example.com/strutil",
			Name:             "Upper",
		}: func() cue.Value {
			return cue.NewPureFunc1(func(a0 string) (string, error) {
				return strutil.Upper(a0), nil
			})
		},
	}
	os.Exit(cmd.MainWithOptions(cuecontext.WithInjection(goplugin.Injection(refs))))
}
-- want-manifest.json --
{
	"modules": {
		"example.com/strutil@v0": {
			"instances": {
				"example.com/strutil": {
					"colocatedGoPackage": "example.com/strutil",
					"goPackages": {
						"example.com/strutil": [
							"Upper"
						]
					}
				}
			}
		}
	},
	"goPackages": {
		"example.com/strutil": {
			"path": "example.com/strutil",
			"version": "v0.0.0-20240715103000-abc123def456"
		}
	}
}
