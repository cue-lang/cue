# Test that cue plugin build-go generates correct Go injection code
# and that the generated code works in a real Go program.

env CUE_CONFIG_DIR=$WORK/.cueconfig
mkdir $CUE_CONFIG_DIR
cp allow-trust.cue $CUE_CONFIG_DIR/plugin-trust.cue

exec cue plugin build-go

# Verify generated file exists.
exists cue_plugins_gen.go

# Verify the generated Go file matches expected output.
cmp cue_plugins_gen.go testdata/want-cue_plugins_gen.go

# Verify go.mod has the required dependency.
grep 'example.com/gostrutil' go.mod

# Build and run a Go program that uses the generated plugin code
# to evaluate CUE with the plugin.
cp testdata/use-main.go main.go
exec go mod tidy
exec go run .
cmp stdout want-output

-- go.mod --
module test.example

go 1.25

-- main.go --
package main

-- cue.mod/module.cue --
module: "test.example@v0"
language: version: "v0.17.0"
deps: {
	"example.com/strutil@v0": {
		v: "v0.0.1"
	}
}

-- main.cue --
package main

import "example.com/strutil"

upper: strutil.Upper("hello")

-- testdata/use-main.go --
package main

import (
	"fmt"
	"os"

	"cuelang.org/go/cue"
	"cuelang.org/go/cue/cuecontext"
	"cuelang.org/go/cue/load"
)

func main() {
	ctx := cuecontext.New(CUEPlugins())
	insts := load.Instances([]string{"."}, &load.Config{})
	if insts[0].Err != nil {
		fmt.Fprintln(os.Stderr, insts[0].Err)
		os.Exit(1)
	}
	val := ctx.BuildInstance(insts[0])
	if err := val.Err(); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	s, err := val.LookupPath(cue.MakePath(cue.Str("upper"))).String()
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	fmt.Println(s)
}

-- want-output --
HELLO
-- testdata/want-cue_plugins_gen.go --
// Code generated by cue plugin build-go; DO NOT EDIT.

package main

import (
	"cuelang.org/go/cue"
	"cuelang.org/go/cue/cuecontext"
	"cuelang.org/go/cue/inject/goplugin"

	gostrutil "example.com/gostrutil"
)

// CUEPlugins returns a CUE context option that registers Go plugins
// provided by the following packages and their dependencies:
//
//	example.com/strutil
func CUEPlugins() cuecontext.Option {
	refs := map[goplugin.Reference]func() cue.Value{
		{
			GoPackage:        "example.com/gostrutil",
			CUEModuleVersion: "example.com/strutil@v0.0.1",
			Name:             "Upper",
		}: func() cue.Value {
			return cue.NewPureFunc1(func(a0 string) (string, error) {
				return gostrutil.Upper(a0), nil
			})
		},
	}
	return cuecontext.WithInjection(goplugin.Injection(refs))
}
-- _registry/example.com_strutil_v0.0.1/cue.mod/module.cue --
module: "example.com/strutil@v0"
language: version: "v0.17.0"
-- _registry/example.com_strutil_v0.0.1/strutil.cue --
@extern(go, import=("example.com/gostrutil"))
package strutil

Upper: _ @go(gostrutil.Upper)
-- _registry/example.com_strutil_v0.0.1/go.mod --
module example.com/strutil
go 1.21
require example.com/gostrutil v0.1.0
-- .gomodproxy/_enable_overlay --
-- .gomodproxy/example.com_gostrutil_v0.1.0/go.mod --
module example.com/gostrutil
-- .gomodproxy/example.com_gostrutil_v0.1.0/util.go --
package gostrutil

import "strings"

func Upper(s string) string {
	return strings.ToUpper(s)
}
-- allow-trust.cue --
rules: [{effect: "allow", cueModule: "..."}]
