# Test doc comment handling in cue plugin generate-go:
# - Fields with existing CUE doc comments should NOT get Go doc comments.
# - Fields without CUE doc comments should get Go doc comments.
# - Fields whose Go func has no doc should just get the signature.

exec cue plugin generate-go

cmp mypkg_signatures_gen.cue want-signatures.cue

-- want-signatures.cue --
// Code generated by cue plugin generate-go; DO NOT EDIT.

package mypkg

// func(string) -> string
HasCueDoc!: _

// GoDocOnly returns the input string unchanged.
//
// func(string) -> string
NoCueDoc!: _

// func(string) -> string
NoDocAtAll!: _
-- cue.mod/module.cue --
module: "test.example/mypkg@v0"
language: version: "v0.17.0"
-- go.mod --
module test.example/mypkg

go 1.21
-- mypkg.cue --
@extern(go)

package mypkg

// This is a CUE doc comment, Go doc should not be copied.
HasCueDoc!: _ @go(WithCueDoc)

NoCueDoc!:  _ @go(GoDocOnly)

NoDocAtAll!: _ @go(Undocumented)
-- funcs.go --
package mypkg

// WithCueDoc returns the input string.
// This Go doc should NOT appear in the generated file.
func WithCueDoc(s string) string {
	return s
}

// GoDocOnly returns the input string unchanged.
func GoDocOnly(s string) string {
	return s
}

func Undocumented(s string) string {
	return s
}
