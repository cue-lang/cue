# Test that cue plugin generate-go generates correct files
# when all references are to external Go packages.

# Ensure go.sum is populated so go/packages can load.
exec go mod tidy

exec cue plugin generate-go

# Verify both generated files.
cmp mypkg_signatures_gen.cue want-signatures.cue
cmp mypkg_imports_gen.go want-imports.go

-- want-signatures.cue --
// Code generated by cue plugin generate-go; DO NOT EDIT.

package mypkg

// Upper converts s to uppercase.
//
// func(string) -> string
Upper!: _

// Sum returns a + b.
//
// func(int, int) -> int
Sum!: _
-- want-imports.go --
//go:build cueplugin

package cueplugin_imports

import (
	_ "example.com/gomathutil"
	_ "example.com/gostrutil"
)
-- cue.mod/module.cue --
module: "test.example/mypkg@v0"
language: version: "v0.17.0"
-- go.mod --
module test.example/mypkg

go 1.21

require (
	example.com/gostrutil v0.1.0
	example.com/gomathutil v0.1.0
)
-- mypkg.cue --
@extern(go, import=(
	"example.com/gostrutil"
	"example.com/gomathutil"
))

package mypkg

Upper!: _ @go(gostrutil.Upper)
Sum!:   _ @go(gomathutil.Sum)
-- .gomodproxy/_enable_overlay --
-- .gomodproxy/example.com_gostrutil_v0.1.0/go.mod --
module example.com/gostrutil
-- .gomodproxy/example.com_gostrutil_v0.1.0/util.go --
package gostrutil

// Upper converts s to uppercase.
func Upper(s string) string {
	result := make([]byte, len(s))
	for i := 0; i < len(s); i++ {
		c := s[i]
		if c >= 'a' && c <= 'z' {
			c -= 32
		}
		result[i] = c
	}
	return string(result)
}
-- .gomodproxy/example.com_gomathutil_v0.1.0/go.mod --
module example.com/gomathutil
-- .gomodproxy/example.com_gomathutil_v0.1.0/util.go --
package gomathutil

// Sum returns a + b.
func Sum(a, b int) int {
	return a + b
}
