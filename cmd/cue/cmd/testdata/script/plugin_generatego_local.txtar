# Test that cue plugin generate-go generates correct signatures
# for local Go functions with various types and doc comments.

exec cue plugin generate-go

# Verify generated signature file.
cmp mypkg_signatures_gen.cue want-signatures.cue

# No imports file should be generated for local-only refs.
! exists mypkg_imports_gen.go

-- want-signatures.cue --
// Code generated by cue plugin generate-go; DO NOT EDIT.

package mypkg

// Upper converts a string to uppercase.
//
// func(string) -> string
Upper!: _

// Add returns the sum of two integers.
//
// func(int, int) -> int
Add!: _

// Enabled reports whether the feature is enabled.
//
// func(bool) -> bool
Enabled!: _

// Scale multiplies a float by 2.
//
// func(float) -> float
Scale!: _

// Encode encodes a byte slice.
//
// func(bytes) -> bytes
Encode!: _

// Parse parses a string and may return an error.
//
// func(string) -> int
Parse!: _
-- cue.mod/module.cue --
module: "test.example/mypkg@v0"
language: version: "v0.17.0"
-- go.mod --
module test.example/mypkg

go 1.22
-- mypkg.cue --
@extern(go)

package mypkg

Upper!:   _ @go()
Add!:     _ @go()
Enabled!: _ @go()
Scale!:   _ @go()
Encode!:  _ @go()
Parse!:   _ @go()
-- funcs.go --
package mypkg

// Upper converts a string to uppercase.
func Upper(s string) string {
	result := make([]byte, len(s))
	for i := range len(s) {
		c := s[i]
		if c >= 'a' && c <= 'z' {
			c -= 32
		}
		result[i] = c
	}
	return string(result)
}

// Add returns the sum of two integers.
func Add(a, b int) int {
	return a + b
}

// Enabled reports whether the feature is enabled.
func Enabled(b bool) bool {
	return b
}

// Scale multiplies a float by 2.
func Scale(f float64) float64 {
	return f * 2
}

// Encode encodes a byte slice.
func Encode(data []byte) []byte {
	return data
}

// Parse parses a string and may return an error.
func Parse(s string) (int, error) {
	return len(s), nil
}
