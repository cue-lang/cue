# Test that cue plugin generate-go handles a file with both
# local and external references, and optional (non-required) fields.

exec go mod tidy

exec cue plugin generate-go

cmp mypkg_signatures_gen.cue want-signatures.cue
cmp mypkg_imports_gen.go want-imports.go

-- want-signatures.cue --
// Code generated by cue plugin generate-go; DO NOT EDIT.

package mypkg

// LocalFunc does local work.
//
// func(string) -> string
LocalFunc!: _

// ExtUpper converts s to uppercase.
//
// func(string) -> string
ExtUpper!: _

// OptionalFunc is optional.
//
// func(int) -> int
OptionalFunc: _
-- want-imports.go --
//go:build cueplugin

package cueplugin_imports

import (
	_ "example.com/gostrutil"
)
-- cue.mod/module.cue --
module: "test.example/mypkg@v0"
language: version: "v0.17.0"
-- go.mod --
module test.example/mypkg

go 1.21

require example.com/gostrutil v0.1.0
-- mypkg.cue --
@extern(go, import=(
	"example.com/gostrutil"
))

package mypkg

LocalFunc!:    _ @go()
ExtUpper!:     _ @go(gostrutil.Upper)
OptionalFunc:  _ @go(OptFunc)
-- funcs.go --
package mypkg

// LocalFunc does local work.
func LocalFunc(s string) string {
	return s
}

// OptionalFunc is optional.
func OptFunc(n int) int {
	return n * 2
}
-- .gomodproxy/_enable_overlay --
-- .gomodproxy/example.com_gostrutil_v0.1.0/go.mod --
module example.com/gostrutil
-- .gomodproxy/example.com_gostrutil_v0.1.0/util.go --
package gostrutil

// ExtUpper converts s to uppercase.
func Upper(s string) string {
	result := make([]byte, len(s))
	for i := 0; i < len(s); i++ {
		c := s[i]
		if c >= 'a' && c <= 'z' {
			c -= 32
		}
		result[i] = c
	}
	return string(result)
}
