# Test that cue plugin generate-go generates separate files
# for each CUE source file with @extern(go).

exec cue plugin generate-go

# Each source file should get its own generated signature file.
cmp alpha_signatures_gen.cue want-alpha-signatures.cue
cmp beta_signatures_gen.cue want-beta-signatures.cue

# Neither should generate an imports file (all local refs).
! exists alpha_imports_gen.go
! exists beta_imports_gen.go

-- want-alpha-signatures.cue --
// Code generated by cue plugin generate-go; DO NOT EDIT.

package mypkg

// AlphaFunc is the alpha function.
//
// func(string) -> string
AlphaFunc!: _
-- want-beta-signatures.cue --
// Code generated by cue plugin generate-go; DO NOT EDIT.

package mypkg

// BetaFunc is the beta function.
//
// func(int) -> int
BetaFunc!: _
-- cue.mod/module.cue --
module: "test.example/mypkg@v0"
language: version: "v0.17.0"
-- go.mod --
module test.example/mypkg

go 1.21
-- alpha.cue --
@extern(go)

package mypkg

AlphaFunc!: _ @go()
-- beta.cue --
@extern(go)

package mypkg

BetaFunc!: _ @go()
-- funcs.go --
package mypkg

// AlphaFunc is the alpha function.
func AlphaFunc(s string) string {
	return s
}

// BetaFunc is the beta function.
func BetaFunc(n int) int {
	return n
}
