# Test that cue plugin init-go generates an @extern(go) CUE file
# from eligible exported Go functions in the current directory.

exec cue plugin init-go

cmp mypkg.cue want.cue

-- want.cue --
@extern(go)

package mypkg

Add: _ @go()
Encode: _ @go()
Parse: _ @go()
Upper: _ @go()
-- cue.mod/module.cue --
module: "test.example/mypkg@v0"
language: version: "v0.17.0"
-- go.mod --
module test.example/mypkg

go 1.22
-- funcs.go --
package mypkg

// Upper converts a string to uppercase.
func Upper(s string) string {
	return s
}

// Add returns the sum of two integers.
func Add(a, b int) int {
	return a + b
}

// Encode encodes a byte slice.
func Encode(data []byte) []byte {
	return data
}

// Parse parses a string and may return an error.
func Parse(s string) (int, error) {
	return len(s), nil
}

// unexported is not eligible.
func unexported(s string) string {
	return s
}

// TooManyReturns has too many return values.
func TooManyReturns(s string) (string, int, error) {
	return s, 0, nil
}

// NoParams has zero parameters.
func NoParams() string {
	return ""
}

// HasChan has an unsupported parameter type.
func HasChan(c chan int) string {
	return ""
}
