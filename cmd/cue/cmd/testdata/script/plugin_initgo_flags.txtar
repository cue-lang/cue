# Test that cue plugin init-go respects --output and --package flags.

exec cue plugin init-go --output custom.cue --package mypkg2

cmp custom.cue want.cue
! exists mypkg.cue

-- want.cue --
@extern(go)

package mypkg2

Hello: _ @go()
-- cue.mod/module.cue --
module: "test.example/mypkg@v0"
language: version: "v0.17.0"
-- go.mod --
module test.example/mypkg

go 1.22
-- funcs.go --
package mypkg

// Hello returns a greeting.
func Hello(name string) string {
	return "hello " + name
}
