# Test that cue plugin init-go refuses to overwrite an existing file
# unless --force is used.

! exec cue plugin init-go
stderr 'file mypkg.cue already exists'

exec cue plugin init-go --force
cmp mypkg.cue want.cue

-- want.cue --
@extern(go)

package mypkg

Hello: _ @go()
-- cue.mod/module.cue --
module: "test.example/mypkg@v0"
language: version: "v0.17.0"
-- go.mod --
module test.example/mypkg

go 1.22
-- mypkg.cue --
package mypkg

x: 42
-- funcs.go --
package mypkg

// Hello returns a greeting.
func Hello(name string) string {
	return "hello " + name
}
