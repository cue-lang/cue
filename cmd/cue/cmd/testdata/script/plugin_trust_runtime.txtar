# Test that runtime plugin evaluation respects trust configuration.
# When a trust config denies a reference, cue export should fail
# even though the plugin was built when the reference was allowed.

env CUE_CONFIG_DIR=$WORK/.cueconfig
mkdir $CUE_CONFIG_DIR

# Build with trust allowed.
cp allow-trust.cue $CUE_CONFIG_DIR/plugin-trust.cue
exec cue plugin build

# Export works while trust allows it.
exec cue export .
cmp stdout want-export

# Change trust to deny.
cp deny-trust.cue $CUE_CONFIG_DIR/plugin-trust.cue

# Export should fail now because the reference is no longer trusted.
! exec cue export .
stderr 'untrusted plugin reference'

-- allow-trust.cue --
rules: [{
	effect: "allow"
	cueModule: "..."
}]
-- deny-trust.cue --
rules: [{
	effect: "deny"
	cueModule: "..."
	description: "all plugins denied"
}]
-- want-export --
{
    "upper": "HELLO"
}
-- cue.mod/module.cue --
module: "test.example@v0"
language: version: "v0.17.0"
deps: {
	"example.com/strutil@v0": {
		v: "v0.0.1"
	}
}

-- main.cue --
package main

import "example.com/strutil"

upper: strutil.Upper("hello")

-- _registry/example.com_strutil_v0.0.1/cue.mod/module.cue --
module: "example.com/strutil@v0"
language: version: "v0.17.0"
-- _registry/example.com_strutil_v0.0.1/strutil.cue --
@extern(go, import=("example.com/gostrutil"))
package strutil

Upper: _ @go(gostrutil.Upper)
-- _registry/example.com_strutil_v0.0.1/go.mod --
module example.com/strutil
go 1.21
require example.com/gostrutil v0.1.0
-- .gomodproxy/_enable_overlay --
-- .gomodproxy/example.com_gostrutil_v0.1.0/go.mod --
module example.com/gostrutil
-- .gomodproxy/example.com_gostrutil_v0.1.0/util.go --
package gostrutil

import "strings"

func Upper(s string) string {
	return strings.ToUpper(s)
}
