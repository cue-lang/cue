# Publishing to a registry that rejects unauthenticated requests should
# produce an error mentioning the module and the registry host, so that
# the user can tell which registry was being used.

memregistry -auth=foo:bar MEMREGISTRY
env CUE_REGISTRY=$MEMREGISTRY+insecure
env DOCKER_CONFIG=$WORK/dockerconfig

cd example
! exec cue mod publish v0.0.1
stderr '^cannot put module "example.com@v0.0.1" to registry "[^"]+": 401 Unauthorized: unauthorized: authentication required: no credentials$'

-- dockerconfig/config.json --
{}
-- example/cue.mod/module.cue --
module: "example.com@v0"
language: version: "v0.9.0-alpha.0"

source: kind: "self"

-- example/top.cue --
package main

"example.com@v0": "v0.0.1"
