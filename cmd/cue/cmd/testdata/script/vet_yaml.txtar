! exec cue vet ./yaml.cue
cmp stderr expect-stderr

-- expect-stderr --
phrasesYAML.phrases.quote1.text: invalid value "phrases:\n  # A quote from Mark Twain.\n  quote1:\n    lang: en\n    attribution: Mark Twain\n\n  # A Norwegian proverb.\n  proverb:\n    lang: no\n    text: Stemmen som sier at du ikke klarer det, lyver." (does not satisfy encoding/yaml.Validate): incomplete value !="":
    ./yaml.cue:18:14
    ./yaml.cue:11:17
    ./yaml.cue:20:14
-- yaml.cue --
import "encoding/yaml"

// Phrases defines a schema for a valid phrase.
#Phrases: {
	phrases: {
		[string]: #Phrase
	}

	#Phrase: {
		lang:         #LanguageTag
		text:         !=""
		attribution?: !="" // must be non-empty when specified
	}
	#LanguageTag: =~"^[a-zA-Z0-9-_]{2,}$" | false
}

// phrasesYAML is a YAML string with a field phrases that is a map of Phrase objects.
phrasesYAML: yaml.Validate(#Phrases)

phrasesYAML: """
    phrases:
      # A quote from Mark Twain.
      quote1:
        lang: en
        attribution: Mark Twain

      # A Norwegian proverb.
      proverb:
        lang: no
        text: Stemmen som sier at du ikke klarer det, lyver.
    """
