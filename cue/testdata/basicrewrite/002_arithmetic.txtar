-- in.cue --
i1: 1 & int
i2: 2 & int

sum:     -1 + +2     // 1
div1:    2.0 / 3 * 6 // 4
div2:    2 / 3 * 6   // 4
div3:    1.00 / 1.00
divZero: 1.0 / 0
div00:   0 / 0
b:       1 != 4
add:     div1 + 1.0

idiv00: div(0, 0)
imod00: mod(0, 0)
iquo00: quo(0, 0)
irem00: rem(0, 0)

v1: 1.0T / 2.0
v2: 2.0 == 2
v3: 2.0 / 3.0
v5: div(i1, i2)

e0: 2 + "a"
// these are now all alloweed
// e1: 2.0 / i1
// e2: i1 / 2.0
// e3: 3.0 % i2
// e4: i1 % 2.0
e5: div(1.0, 2)
e6: rem(2, 2.0)
e7: quo(2, 2.0)
e8: mod(1.0, 1)
