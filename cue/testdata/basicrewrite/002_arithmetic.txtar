  i1: (1 & int)
  i2: (2 & int)
  sum: (-1 + +2)
  div1: ((2.0 / 3) * 6)
  div2: ((2 / 3) * 6)
  div3: (1.00 / 1.00)
  divZero: (1.0 / 0)
  div00: (0 / 0)
  b: (1 != 4)
  add: (〈0;div1〉 + 1.0)
  idiv00: div(0, 0)
  imod00: mod(0, 0)
  iquo00: quo(0, 0)
  irem00: rem(0, 0)
  v1: (1000000000000 / 2.0)
