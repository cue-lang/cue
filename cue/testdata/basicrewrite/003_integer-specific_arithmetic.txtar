-- in.cue --
q1:  quo(5, 2)   @test(eq, 2)
q2:  quo(5, -2)  @test(eq, -2)
q3:  quo(-5, 2)  @test(eq, -2)
q4:  quo(-5, -2) @test(eq, 2)
qe1: quo(2.0, 1) @test(err, code=eval, pos=[0:10], contains="cannot use")
qe2: quo(2, 1.0) @test(err, code=eval, pos=[0:13], contains="cannot use")

r1:  rem(5, 2)   @test(eq, 1)
r2:  rem(5, -2)  @test(eq, 1)
r3:  rem(-5, 2)  @test(eq, -1)
r4:  rem(-5, -2) @test(eq, -1)
re1: rem(2.0, 1) @test(err, code=eval, pos=[0:10], contains="cannot use")
re2: rem(2, 1.0) @test(err, code=eval, pos=[0:13], contains="cannot use")

d1:  div(5, 2)   @test(eq, 2)
d2:  div(5, -2)  @test(eq, -2)
d3:  div(-5, 2)  @test(eq, -3)
d4:  div(-5, -2) @test(eq, 3)
de1: div(2.0, 1) @test(err, code=eval, pos=[0:10], contains="cannot use")
de2: div(2, 1.0) @test(err, code=eval, pos=[0:13], contains="cannot use")

m1:  mod(5, 2)   @test(eq, 1)
m2:  mod(5, -2)  @test(eq, 1)
m3:  mod(-5, 2)  @test(eq, 1)
m4:  mod(-5, -2) @test(eq, 1)
me1: mod(2.0, 1) @test(err, code=eval, pos=[0:10], contains="cannot use")
me2: mod(2, 1.0) @test(err, code=eval, pos=[0:13], contains="cannot use")
