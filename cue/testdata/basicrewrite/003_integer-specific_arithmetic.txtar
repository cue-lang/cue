-- in.cue --
q1:  5 quo 2   @test(eq, 2)
q2:  5 quo -2  @test(eq, -2)
q3:  -5 quo 2  @test(eq, -2)
q4:  -5 quo -2 @test(eq, 2)
qe1: 2.0 quo 1 @test(err, code=eval, pos=[0:6 0:14], contains="invalid operands")
qe2: 2 quo 1.0 @test(err, code=eval, pos=[0:6 0:12], contains="invalid operands")

r1:  5 rem 2   @test(eq, 1)
r2:  5 rem -2  @test(eq, 1)
r3:  -5 rem 2  @test(eq, -1)
r4:  -5 rem -2 @test(eq, -1)
re1: 2.0 rem 1 @test(err, code=eval, pos=[0:6 0:14], contains="invalid operands")
re2: 2 rem 1.0 @test(err, code=eval, pos=[0:6 0:12], contains="invalid operands")

d1:  5 div 2   @test(eq, 2)
d2:  5 div -2  @test(eq, -2)
d3:  -5 div 2  @test(eq, -3)
d4:  -5 div -2 @test(eq, 3)
de1: 2.0 div 1 @test(err, code=eval, pos=[0:6 0:14], contains="invalid operands")
de2: 2 div 1.0 @test(err, code=eval, pos=[0:6 0:12], contains="invalid operands")

m1:  5 mod 2   @test(eq, 1)
m2:  5 mod -2  @test(eq, 1)
m3:  -5 mod 2  @test(eq, 1)
m4:  -5 mod -2 @test(eq, 1)
me1: 2.0 mod 1 @test(err, code=eval, pos=[0:6 0:14], contains="invalid operands")
me2: 2 mod 1.0 @test(err, code=eval, pos=[0:6 0:12], contains="invalid operands")
