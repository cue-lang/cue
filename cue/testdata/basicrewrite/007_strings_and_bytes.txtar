-- in.cue --
s0: "foo" + "bar" @test(eq, "foobar")
s1: 3 * "abc"     @test(eq, "abcabcabc")
s2: "abc" * 2     @test(eq, "abcabc")

b0: 'foo' + 'bar' @test(eq, 'foobar')
b1: 3 * 'abc'     @test(eq, 'abcabcabc')
b2: 'abc' * 2     @test(eq, 'abcabc')

// TODO: consider the semantics of this and perhaps allow this.
e0: "a" + ''  @test(err, code=eval)
e1: 'b' + "c" @test(err, code=eval)

// Absurdly large repeat counts are rejected rather than allocated; the
// same limit bounds the strings.Repeat and list.Repeat builtins.
e2: "a" * 200000000 @test(err, code=eval)
e3: 'a' * 200000000 @test(err, code=eval)
-- out/errors.txt --
[eval] e0: invalid operands "a" and '' to '+' (type string and bytes):
    ./in.cue:10:5
    ./in.cue:10:11
[eval] e1: invalid operands 'b' and "c" to '+' (type bytes and string):
    ./in.cue:11:5
    ./in.cue:11:11
[eval] e2: string multiplication count 200000000 exceeds limit of 1000000:
    ./in.cue:15:5
[eval] e3: bytes multiplication count 200000000 exceeds limit of 1000000:
    ./in.cue:16:5
