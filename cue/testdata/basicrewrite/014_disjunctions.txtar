-- in.cue --
o1:  1 | 2 | 3            @test(eq, 1 | 2 | 3)
o2:  (1 | 2 | 3) & 1      @test(eq, 1)
o3:  2 & (1 | *2 | 3)     @test(eq, 2)
o4:  (1 | *2 | 3) & (1 | 2 | *3) @test(eq, 1 | 2 | 3)
o5:  (1 | *2 | 3) & (3 | *2 | 1) @test(eq, *2 | 1 | 3)
o6:  (1 | 2 | 3) & (3 | 1 | 2)   @test(eq, 1 | 2 | 3)
o7:  (1 | 2 | 3) & (2 | 3)       @test(eq, 2 | 3)
o8:  (1 | 2 | 3) & (3 | 2)       @test(eq, 2 | 3)
o9:  (2 | 3) & (1 | 2 | 3)       @test(eq, 2 | 3)
o10: (3 | 2) & (1 | *2 | 3)      @test(eq, *2 | 3)

m1: (1 | (*2 | 3)) & (>=2 & <=3) @test(eq, *2 | 3)
m2: (1 | (*2 | 3)) & (2 | 3)     @test(eq, *2 | 3)
m3: (*1 | *(*2 | 3)) & (2 | 3)   @test(eq, *2 | 3)
m4: (2 | 3) & (*2 | 3)           @test(eq, *2 | 3)
m5: (*2 | 3) & (2 | 3)           @test(eq, *2 | 3)

// 2&(*2 | 3) | 3&(*2 | 3)
// (*1 | (*2 | 3)) & (2 | 3)
// *1& (2 | 3) | (*2 | 3)&(2 | 3)
// *2&(2 | 3) | 3&(2 | 3)

// (2 | 3)&(*1 | (*2 | 3))
// 2&(*1 | (*2 | 3)) | 3&(*1 | (*2 | 3))
// *1&2 | (*2 | 3)&2 | *1&3 | (*2 | 3)&3
// (*2 | 3)&2 | (*2 | 3)&3
// *2 | 3

// All errors are treated the same as per the unification model.
i1: [1, 2][3] | "c"  @test(eq, "c")
