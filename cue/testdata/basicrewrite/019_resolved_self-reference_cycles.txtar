-- in.cue --
math: p1: {
	a: b - 100
	b: a + 100
	b: 200
	@test(eq, {a: 100, b: 200})
}
math: p2: {
	a: b - 100
	b: 200
	b: a + 100
	@test(eq, {a: 100, b: 200})
}
math: p3: {
	b: a + 100
	a: b - 100
	b: 200
	@test(eq, {b: 200, a: 100})
}
math: p4: {
	b: a + 100
	b: 200
	a: b - 100
	@test(eq, {b: 200, a: 100})
}
math: p5: {
	b: 200
	b: a + 100
	a: b - 100
	@test(eq, {b: 200, a: 100})
}
math: p6: {
	b: 200
	a: b - 100
	b: a + 100
	@test(eq, {b: 200, a: 100})
}

a: 100 @test(eq, 100)

list: t0: c: [c[0]]

list: t1: p1: c: [c[1], a] @test(eq, [100, 100])
list: t1: p2: c: [a, c[0]] @test(eq, [100, 100])

nodes: t1: p1: s1: s1 & {a: 1} @test(eq, {a: 1})
nodes: t1: p2: s1: {a: 1} & s1 @test(eq, {a: 1})
nodes: t2: {
	s1: s2 & {a: 1}
	s2: s1 & {b: 2}
	@test(eq, {s1: {a: 1, b: 2}, s2: {b: 2, a: 1}})
}
nodes: t3: {
	s1: s2 & {a: 1}
	s2: s3 & {b: 2}
	s3: s1 & {c: 3}
	@test(eq, {s1: {a: 1, b: 2, c: 3}, s2: {b: 2, c: 3, a: 1}, s3: {c: 3, a: 1, b: 2}})
}

