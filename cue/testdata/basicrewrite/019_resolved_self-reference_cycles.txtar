{
  math: {
    a: (〈0;b〉 - 100)
    b: (〈0;a〉 + 100)
    b: 200
  }
  a: 100
  list: {
    t0: {
      c: [
        〈1;c〉[0],
      ]
    }
  }
  list: {
    t1: {
      p1: {
        c: [
          〈1;c〉[1],
          〈4;a〉,
        ]
      }
    }
  }
  list: {
    t1: {
      p2: {
        c: [
          〈4;a〉,
          〈1;c〉[0],
        ]
      }
    }
  }
  nodes: {
    t1: {
      p1: {
        s1: (〈0;s1〉 & {
          a: 1
        })
      }
    }
  }
  nodes: {
    t1: {
      p2: {
        s1: ({
          a: 1
        } & 〈0;s1〉)
      }
    }
  }
  nodes: {
    t2: {
      s1: (〈0;s2〉 & {
        a: 1
      })
      s2: (〈0;s1〉 & {
        b: 2
      })
    }
  }
  nodes: {
    t3: {
      s1: (〈0;s2〉 & {
        a: 1
      })
      s2: (〈0;s3〉 & {
        b: 2
      })
      s3: (〈0;s1〉 & {
        c: 3
      })
    }
  }
}
