// TODO(lang): it would be nice to be able to have attributes on list elements.
-- in.cue --
out: [
  123.45 + 987.65,
  123.45 - 987.65,
  123.45 * 987.65,
  123.45 / 987.65,

  // whole integers
  2 + 3,
  7 - 1,
  5 * 10,
  20 / 4,

  1 / 3, // fill all digits
] @test(eq, [
	1111.10,
	-864.20,
	121925.3925,
	0.1249936718473143320002025008859414,
	5,
	6,
	50,
	5.0,
	0.3333333333333333333333333333333333
])
-- out/compile --
--- in.cue
{
  out: [
    (123.45 + 987.65),
    (123.45 - 987.65),
    (123.45 * 987.65),
    (123.45 / 987.65),
    (2 + 3),
    (7 - 1),
    (5 * 10),
    (20 / 4),
    (1 / 3),
  ]
}
