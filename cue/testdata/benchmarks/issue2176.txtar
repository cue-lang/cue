  })
  output: {
    [string]: string
  }
  output: {
    "1": (〈1;datastream〉 & {
      marker: {
        length: 4
      }
    }).marker.position
    "2": (〈1;datastream〉 & {
      marker: {
        length: 14
      }
    }).marker.position
  }
}
