  _schema: {
    (matchIf((null|bool|number|string|[
      ...,
    ]|{
      "enable-beta-ecosystems"!: true
    }), _, (null|bool|number|string|[
      ...,
    ]|{
      updates?: (null|bool|number|string|[
        ...(null|bool|number|string|[
          ...,
        ]|{
          ...
        }),
      ]|{
        ...
      })
      ...
    })) & {
      updates!: [
        ...〈2;#update〉,
      ]
    })
    #update: {
      schedule!: {
        timezone?: 〈2;#timezone〉
        ...
      }
      ...
    }
    #timezone: or([
      for _, i in 〈import;list〉.Range(0, 571, 1) {
        "\(〈1;i〉)"
      },
    ])
  }
}
