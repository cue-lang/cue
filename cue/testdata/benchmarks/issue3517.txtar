# Tests that cyclic arithmetic constraints (#TimeSpan: start = end - duration
# etc.) within a task set unify and report errors correctly. The original
# issue involved a hang or very slow evaluation with interdependent tasks.
# https://cuelang.org/issue/3517
-- main.cue --
package p

#TimeSpan: {
	start:    float
	duration: float
	end:      float

	start:    end - duration
	duration: end - start
	end:      start + duration

	start: <=end
}

#Task: {
	action:   string
	timeSpan: #TimeSpan
}

#TaskSet: {
	action: string
	#tasks: [string]: #Task
	tasks: [for _, v in #tasks {v}]
	tasks: [...#Task]
	timeSpan?: #TimeSpan
}

#T1: #Task & {
	action: "Task 1"
	timeSpan: #TimeSpan & {
		duration: 4.2
	}
}

#T2: #Task & {
	action: "Task 2"
	timeSpan: #TimeSpan & {
		duration: 120.0
	}
}

ts: #TaskSet
ts: this={
	action: "Task 1 and Task 2"
	#tasks: {
		t1: #T1 & {
			timeSpan: end: this.#tasks.t2.timeSpan.start
		}
		t2: #T2 & {
			timeSpan: end: 119 // this.timeSpan.end
		}
	}
	timeSpan: start: this.#tasks.t1.timeSpan.start
}
@test(err, at=ts.#tasks.t1, code=eval, path=ts.#tasks.t2.timeSpan.end,
	contains="conflicting values %s and %s (mismatched types %s and %s)",
	args=[119, float, int, float],
	pos=[-49:12, -18:12, -6:7, -5:19],
)
@test(err, at=ts.#tasks.t2, code=eval, path=ts.#tasks.t2.timeSpan.end,
	contains="conflicting values %s and %s (mismatched types %s and %s)",
	args=[119, float, int, float],
	pos=[-54:12, -23:12, -11:7, -10:19],
)
-- out/todo.txt --
v2 showed ts.#tasks.t1 as successful (with concrete timeSpan values start=-5.2,
duration=4.2, end=-1.0), while v3 propagates the t2 error to t1 as well. v2
also reported different source positions for the error (./main.cue:17:12 and
./main.cue:35:6 instead of ./main.cue:37:12).
