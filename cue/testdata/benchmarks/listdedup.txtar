MaxRedirect:         2
-- out/compile --
--- in.cue
{
  A: 〈0;#Task〉
  B: {
    #steps: (〈1;#Script〉 & {
      mount: [
        〈3;A〉,
      ]
    })
  }
  C: {
    #steps: (〈1;#Script〉 & {
      mount: [
        〈3;B〉,
      ]
    })
  }
  #Script: {
    mount: [
      ...〈2;#Task〉,
    ]
  }
  #Task: {
    〈1;#ref〉
    〈1;#ref〉
    (_|{})
    (_|{})
    #steps: 〈1;#Script〉
    ...
  }
  #ref: ({
    a: 1
  }|{
    b: 2
  })
}
