  ]
  a: {
    [string]: {
      text: (*"default"|string)
    }
  }
  a: {
    for _, i in 〈1;list〉 {
      "\(〈1;i〉)": {
        text: string
      }
    }
  }
  b: {
    for _, x in 〈1;a〉 {
      "\(〈1;x〉.text)": {
        text: 〈2;x〉.text
      }
    }
  }
}
