# Tests for isConcrete and concreteN builtins

-- in.cue --
@experiment(reflect)

// isConcrete with concrete scalar values
concreteScalars: {
	a:      42
	b:      "hello"
	c:      true
	d:      3.14
	checkA: isConcrete(a)   @test(eq, true)
	checkB: isConcrete(b)   @test(eq, true)
	checkC: isConcrete(c)   @test(eq, true)
	checkD: isConcrete(d)   @test(eq, true)
}

// isConcrete with types (not concrete)
concreteTypes: {
	a:      int
	b:      string
	c:      bool
	checkA: isConcrete(a)   @test(eq, false)
	checkB: isConcrete(b)   @test(eq, false)
	checkC: isConcrete(c)   @test(eq, false)
}

// isConcrete with constraints (not concrete)
concreteConstraints: {
	a:      >10
	b:      =~"pattern"
	c:      int & >0
	checkA: isConcrete(a)   @test(eq, false)
	checkB: isConcrete(b)   @test(eq, false)
	checkC: isConcrete(c)   @test(eq, false)
}

// isConcrete with disjunctions
concreteDisjunctions: {
	a:      1 | 2          // no default: not concrete
	b:      *1 | 2         // single default: concrete (finalization selects it)
	c:      string | int   // no default: not concrete
	checkA: isConcrete(a)   @test(eq, false)
	checkB: isConcrete(b)   @test(eq, true)
	checkC: isConcrete(c)   @test(eq, false)
}

// isConcrete with structs
concreteStructs: {
	// fully concrete struct
	full:         {x: 1, y: "hello"}
	checkFull:    isConcrete(full)   @test(eq, true)

	// struct with non-concrete field
	partial:      {x: 1, y: string}
	checkPartial: isConcrete(partial)   @test(eq, false)

	// XXX: add tests with structs with disjunctions with a default concrete value and without.
	deep: {
		a: x: y: a: 1
		b: x: y: b: *1 | 2
		c: x: y: c: int
	}
	checkDeep1: isConcrete(deep)              @test(eq, false)
	checkDeep2: isConcrete(deep.a)            @test(eq, true)
	checkDeep3: isConcrete(deep.b)            @test(eq, true)
	checkDeep4: isConcrete(deep.c)            @test(eq, false)
	checkDeep5: isConcrete({deep.a, deep.b})  @test(eq, true)
	checkDeep6: isConcrete({deep.b, deep.c})  @test(eq, false)
	checkDeep7: isConcrete({deep.a, deep.c})  @test(eq, false)

	// open struct: closed to its concrete fields at evaluation time
	open:         {x: 1, ...}
	checkOpen:    isConcrete(open)   @test(eq, true)
}

// isConcrete with literal values
concreteLiterals: {
	checkInt:    isConcrete(42)        @test(eq, true)
	checkString: isConcrete("hello")   @test(eq, true)
	checkBool:   isConcrete(true)      @test(eq, true)
}

// concreteN: exactly 2 required, 2 currently concrete - passes
concreteNExact2: {
	a: 1
	b: int
	c: "hello"
	concreteN(2, a, b, c)
	@test(eq, {a: 1, b: int, c: "hello"})
}

// concreteN: at least 1 required, 2 currently concrete - passes
concreteNAtLeast1: {
	a: 1
	b: int
	c: "hello"
	concreteN(>=1, a, b, c)
	@test(eq, {a: 1, b: int, c: "hello"})
}

// concreteN: at most 3 required, max possible is 3 - always passes
concreteNAtMost3: {
	a: 1
	b: int
	c: "hello"
	concreteN(<=3, a, b, c)
	@test(eq, {a: 1, b: int, c: "hello"})
}

// concreteN: at most 2 required, 2 currently concrete - passes
concreteNAtMost2: {
	a: 1
	b: int
	c: "hello"
	concreteN(<=2, a, b, c)
	@test(eq, {a: 1, b: int, c: "hello"})
}

// concreteN: exactly 3 required but only 2 concrete - incomplete (b could become concrete)
concreteNIncomplete: {
	a: 1
	b: int
	c: "hello"
	concreteN(3, a, b, c)
	@test(err, code=incomplete, contains="%s", args=[concreteN], pos=[4:2, 4:12])
}

// concreteN: requires 4 but only 3 args, impossible - eval error
concreteNImpossible4: {
	a: 1
	b: int
	c: "hello"
	concreteN(4, a, b, c)
	@test(err, code=eval, contains="%s: %d matched, expected %v", args=[concreteN, 2, 4], pos=[4:2, 4:12])
}

// concreteN: requires exactly 1 but already 2 concrete, impossible - eval error
concreteNImpossible1: {
	a: 1
	b: int
	c: "hello"
	concreteN(1, a, b, c)
	@test(err, code=eval, contains="%s: %d matched, expected %v", args=[concreteN, 2, 1], pos=[4:2, 4:12])
}

// concreteN: requires <2 but already 2 concrete, impossible - eval error
concreteNImpossibleLt2: {
	a: 1
	b: int
	c: "hello"
	concreteN(<2, a, b, c)
	@test(err, code=eval, contains="%s: %d matched, expected %v", args=[concreteN, 2, <2], pos=[4:2, 4:12])
}

// concreteN embedded (protobuf-style: exactly one must be concrete)
concreteNOneOf: {
	a?: int
	b?: string
	a:  42
	concreteN(1, a, b)
	@test(eq, {a: 42, b?: string})
}
-- out/errors.txt --
[incomplete] concreteNIncomplete: concreteN: concreteN: 2 matched, expected 3:
    ./in.cue:122:2
    ./in.cue:122:12
[eval] concreteNImpossible4: concreteN: 2 matched, expected 4:
    ./in.cue:131:2
    ./in.cue:131:12
[eval] concreteNImpossible1: concreteN: 2 matched, expected 1:
    ./in.cue:140:2
    ./in.cue:140:12
[eval] concreteNImpossibleLt2: concreteN: 2 matched, expected <2:
    ./in.cue:149:2
    ./in.cue:149:12
