# Tests for exists and existsN builtins

-- in.cue --
// Field references
fieldRef: {
	a:       1
	existsA: exists(a)   @test(eq, true)
	b?:      string
	existsB: exists(b)   @test(eq, false)
}

// Selector: all intermediates exist
selector: {
	x: y: z: 1
	x: y: v?: 1
	existsXYZ: exists(x.y.z)   @test(eq, true)
	existsXYV: exists(x.y.v)   @test(eq, false)
	existsXYW: exists(x.y.w)   @test(eq, false)

	#Def: {a: 1, opt?: 2, req!: 3}
	existsDefA:   exists(#Def.a)     @test(eq, true)
	existsDefOpt: exists(#Def.opt)   @test(eq, false)
	existsDefReq: exists(#Def.req)   @test(eq, false)
	existsDefNE:  exists(#Def.ne)    @test(eq, false)


	Ref: #Def
	existsRefA:   exists(Ref.a)     @test(eq, true)
	existsRefOpt: exists(Ref.opt)   @test(eq, false)
	existsRefReq: exists(Ref.req)   @test(eq, false)
	existsRefNE:  exists(Ref.ne)    @test(eq, false)

	D: #Def & { opt: 2, req: 3 }
	existsDOpt: exists(D.opt)   @test(eq, true)
	existsDReq: exists(D.req)   @test(eq, true)

	R: Ref & { opt: _, req: _ }
	existsROpt: exists(R.opt)   @test(eq, true)
	existsRReq: exists(R.req)   @test(eq, true)
}

// Selector: optional intermediate not ? marked → error
selectorRequiredIntermediate: {
	x:         y?: z: 1
	existsXYZ: exists(x.y.z)   @test(err, code=incomplete, contains="cannot reference optional field: %s", args=[y], pos=[0:22])
}

// Index expressions - list
indexList: {
	list:    [1, 2, 3]
	c: exists0: exists(list[0])   @test(eq, true)
	c: exists2: exists(list[2])   @test(eq, true)
	c: ne1: exists(list[3])       @test(eq, false)

	open: [1, 2, 3, ...]
	o: exists0: exists(open[0])   @test(eq, true)
	o: exists2: exists(open[2])   @test(eq, true)
	o: ne1: exists(open[3])       @test(eq, false)
}

// Index expressions - struct with string key
indexStruct: {
	data:      foo: "bar"
	existsFoo: exists(data["foo"])   @test(eq, true)
	existsBaz: exists(data["baz"])   @test(eq, false)

	// Parent is an unresolved disjunction with a default: index lookup
	// follows the default, parallel to selector behavior on disjunctions.
	d: *{a: 1} | {b: 2}
	existsA: exists(d["a"])   @test(eq, true)
	existsB: exists(d["b"])   @test(eq, false)
}

invalidValues: {
	b: 1
	existsFoo: exists(1)             @test(err, code=eval, contains="%s: argument must be a field reference, selector, or index expression", args=[exists], pos=[0:13])
	existsBaz: exists(1 + b)         @test(err)
	existsBaz: exists("string")      @test(err)
	existsBaz: exists("string"[0])   @test(err, code=eval,
		suberr=(code=eval, contains="%s: argument must be a field reference, selector, or index expression", args=[exists], pos=[-2:13]),
		suberr=(code=eval, contains="%s: argument must be a field reference, selector, or index expression", args=[exists], pos=[-1:13]),
		suberr=(code=eval, contains="%s: cannot index non-struct/list value", args=[exists], pos=[0:13]))
}

// existsN - exact count (a and b exist, c does not)
existsNTest: {
	a: 1
	b: 2
	c?: string
	existsN(2, a, b, c)
	@test(eq, {a: 1, b: 2, c?: string})
}

// existsN with bound constraints (only a exists)
existsNBounds: {
	a:  1
	b?: int
	c?: int
	existsN(>=1, a, b, c)
	existsN(<=2, a, b, c)
	@test(eq, {a: 1, b?: int, c?: int})
}

// exists in conditionals
conditionalExists: {
	x?:      int   @test(err, code=incomplete, path=conditionalExists, contains="field not found: %v", args=[x], pos=[])
	y:       1
	existsY: exists(y)   @test(eq, true)
	result: {
		if exists(y) {
			hasY: true
		}
		@test(eq, {hasY: true})
	}
}

// existsN with all existing
existsNAll: {
	a: 1
	b: 2
	c: 3
	existsN(3, a, b, c)
	@test(eq, {a: 1, b: 2, c: 3})
}

// existsN with none existing (all optional, none set)
existsNNone: {
	a?: int
	b?: int
	existsN(0, a, b)
	@test(skip, why="struct has embedded existsN() that cannot be expressed in @test(eq, ...) format")
}

// List index out of bounds returns false for open and closed lists.
indexOutOfBounds: {
	list:      [1, 2, 3]
	closed10:  exists(list[10])   @test(eq, false)
	open:      [1, 2, 3, ...]
	open10:    exists(open[10])   @test(eq, false)
}

// Final component missing → false (no ? needed on final)
missingNested: {
	a:         b: {}
	existsABC: exists(a.b.c)   @test(eq, false)
}

// Intermediate missing + not ? marked → error
missingIntermediateRequired: {
	a:         {}
	existsABC: exists(a.b.c)   @test(err, code=incomplete, contains="undefined field: %s", args=[b], pos=[0:22])
}

// At most one of the optional fields can be present (protobuf oneOf)
oneOfPattern: {
	a?: int
	b?: string
	c?: bool
	existsN(<=1, a, b, c)
	@test(skip, why="struct has embedded existsN() that cannot be expressed in @test(eq, ...) format")
}

// oneOf with one field present - should pass
oneOfWithValue: {
	a?: int
	b?: string
	c?: bool
	a: 42
	existsN(<=1, a, b, c)
	@test(eq, {a: 42, b?: string, c?: bool})
}

// oneOf with two fields present - should fail
oneOfViolation: {
	a?: int
	b?: string
	c?: bool
	a: 42
	b: "hello"
	existsN(<=1, a, b, c)
	@test(err, code=eval, contains="%s: %d matched, expected %v", args=[existsN, 2, <=1])
}

// existsN failure - requires at least 2 but only 1 exists
existsNTooFew: {
	a: 1
	b?: int
	c?: int
	existsN(>=2, a, b, c)
	@test(err, code=incomplete, contains="%s", args=[existsN], pos=[4:2, 4:10])
}

// existsN failure - exact count mismatch
existsNExactFail: {
	a: 1
	b?: int
	existsN(2, a, b)
	@test(err, code=incomplete, contains="%s", args=[existsN], pos=[3:2, 3:10])
}

-- cycle.cue --
minimal: {
	a: {
		if !exists(b.port) {
			port: ""
		}
		@test(err, code=incomplete|cycle)
	}

	b: {
		if !exists(a.port) {
			port: ""
		}
		@test(err, code=incomplete|cycle)
	}
}

-- out/errors.txt --
[cycle] minimal.a: cyclic reference to field port:
    ./cycle.cue:3:16
[cycle] minimal.b: undefined field: port:
    ./cycle.cue:10:16
[incomplete] selectorRequiredIntermediate.existsXYZ: cannot reference optional field: y:
    ./in.cue:42:22
[eval] invalidValues.existsFoo: exists: argument must be a field reference, selector, or index expression:
    ./in.cue:73:13
[eval] invalidValues.existsBaz: exists: argument must be a field reference, selector, or index expression:
    ./in.cue:74:13
invalidValues.existsBaz: exists: argument must be a field reference, selector, or index expression:
    ./in.cue:75:13
invalidValues.existsBaz: exists: cannot index non-struct/list value:
    ./in.cue:76:13
[incomplete] missingIntermediateRequired.existsABC: undefined field: b:
    ./in.cue:148:22
[eval] oneOfViolation: existsN: 2 matched, expected <=1:
    ./in.cue:177:2
    ./in.cue:177:10
[incomplete] existsNTooFew: existsN: existsN: 1 matched, expected >=2:
    ./in.cue:186:2
    ./in.cue:186:10
[incomplete] existsNExactFail: existsN: existsN: 1 matched, expected 2:
    ./in.cue:194:2
    ./in.cue:194:10
-- out/compile --
--- cycle.cue
{
  minimal: {
    a: {
      if !exists(〈1;b〉.port) {
        port: ""
      }
    }
    b: {
      if !exists(〈1;a〉.port) {
        port: ""
      }
    }
  }
}
--- in.cue
