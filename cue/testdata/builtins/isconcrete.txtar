  }
  concreteConstraints: {
    a: >0
    checkA: isConcrete(〈0;a〉)
    b: =~"hello"
    checkB: isConcrete(〈0;b〉)
  }
  concreteDisjunction: {
    a: (1|2)
    checkA: isConcrete(〈0;a〉)
    b: (1|*2)
    checkB: isConcrete(〈0;b〉)
  }
  concreteNCount: {
    a: 1
    b: int
    c: "hello"
    concreteN(2, 〈0;a〉, 〈0;b〉, 〈0;c〉)
