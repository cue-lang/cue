# Tests for the isConcrete function and the concreteN validator.

-- in.cue --
@experiment(predicates)

// isConcrete with concrete scalar values.
concreteScalars: {
	a:      42
	b:      "hello"
	c:      true
	d:      3.14
	checkA: isConcrete(a) @test(eq, true)
	checkB: isConcrete(b) @test(eq, true)
	checkC: isConcrete(c) @test(eq, true)
	checkD: isConcrete(d) @test(eq, true)
}

// isConcrete on a reference to an optional field is incomplete: the field is
// not a present regular member, so its concreteness cannot be judged. A struct
// whose member references an absent optional field is likewise not concrete.
concreteOptional: {
	c?:     int
	checkC: isConcrete(c) @test(err, code=incomplete, contains="cannot reference optional field: %s", args=[c], pos=[0:21])

	d:      {e: f, f?: int}
	checkD: isConcrete(d) @test(eq, false)
}

// isConcrete with types (not concrete).
concreteTypes: {
	a:      int
	b:      string
	c:      bool
	checkA: isConcrete(a) @test(eq, false)
	checkB: isConcrete(b) @test(eq, false)
	checkC: isConcrete(c) @test(eq, false)
}

// isConcrete with constraints (not concrete).
concreteConstraints: {
	a:      >10
	b:      =~"pattern"
	c:      int & >0
	checkA: isConcrete(a) @test(eq, false)
	checkB: isConcrete(b) @test(eq, false)
	checkC: isConcrete(c) @test(eq, false)
}

// isConcrete with disjunctions: concrete only when finalization selects a
// single default.
concreteDisjunctions: {
	a:      1 | 2        // no default: not concrete
	b:      *1 | 2       // single default: concrete (finalization selects it)
	c:      1 | *2       // single default (last): concrete
	d:      string | int // no default: not concrete
	checkA: isConcrete(a) @test(eq, false)
	checkB: isConcrete(b) @test(eq, true)
	checkC: isConcrete(c) @test(eq, true)
	checkD: isConcrete(d) @test(eq, false)
}

// isConcrete with structs and lists. Only regular fields count: optional,
// hidden and definition fields do not affect concreteness.
concreteStructs: {
	full:      {x: 1, y: "hello"}
	checkFull: isConcrete(full) @test(eq, true)

	partial:      {x: 1, y: string}
	checkPartial: isConcrete(partial) @test(eq, false)

	withOptional:  {a: 1, b?: int}
	checkOptional: isConcrete(withOptional) @test(eq, true)

	withHidden:  {_a: int, #a: int}
	checkHidden: isConcrete(withHidden) @test(eq, true)

	list:      [1, 2, 3]
	checkList: isConcrete(list) @test(eq, true)

	// open struct: concrete with respect to its concrete fields
	open:      {x: 1, ...}
	checkOpen: isConcrete(open) @test(eq, true)

	deep: {
		a: x: y: a: 1
		b: x: y: b: *1 | 2
		c: x: y: c: int
	}
	checkDeep1: isConcrete(deep)             @test(eq, false)
	checkDeep2: isConcrete(deep.a)           @test(eq, true)
	checkDeep3: isConcrete(deep.b)           @test(eq, true)
	checkDeep4: isConcrete(deep.c)           @test(eq, false)
	checkDeep5: isConcrete({deep.a, deep.b}) @test(eq, true)
	checkDeep6: isConcrete({deep.b, deep.c}) @test(eq, false)
	checkDeep7: isConcrete({deep.a, deep.c}) @test(eq, false)
}

// isConcrete propagates errors: a permanent (eval) error is reported as the
// error itself, not as "not concrete".
concreteError: {
	a:      1 & "x"       @test(err, code=eval, contains="conflicting values %s and %s (mismatched types %s and %s)", args=[1, "x", int, string], pos=[0:10, 0:14])
	checkA: isConcrete(a) @test(err, code=eval, contains="conflicting values %s and %s (mismatched types %s and %s)", args=[1, "x", int, string], pos=[-1:10, -1:14])
}

// concreteN: passing count constraints (a and c are concrete, b is not).
concreteNExact2: {
	a: 1
	b: int
	c: "hello"
	concreteN(2, a, b, c)
	@test(eq, {a: 1, b: int, c: "hello"})
}

// concreteN: all arguments concrete.
concreteNAll: {
	a: 1
	b: 2
	c: 3
	concreteN(3, a, b, c)
	@test(eq, {a: 1, b: 2, c: 3})
}

// concreteN: at least 1 required, 2 currently concrete - passes.
concreteNAtLeast1: {
	a: 1
	b: int
	c: "hello"
	concreteN(>=1, a, b, c)
	@test(eq, {a: 1, b: int, c: "hello"})
}

// concreteN: at most 3 required, max possible is 3 - always passes.
concreteNAtMost3: {
	a: 1
	b: int
	c: "hello"
	concreteN(<=3, a, b, c)
	@test(eq, {a: 1, b: int, c: "hello"})
}

// concreteN: multiple bounds in one struct.
concreteNBounds: {
	a: 1
	b: int
	c: "hello"
	concreteN(>=1, a, b, c)
	concreteN(<=2, a, b, c)
	@test(eq, {a: 1, b: int, c: "hello"})
}

// concreteN: exactly 3 required but only 2 concrete - incomplete (b could
// still become concrete).
concreteNIncomplete: {
	a: 1
	b: int
	c: "hello"
	concreteN(3, a, b, c)
	@test(err, code=incomplete, contains="%s", args=[concreteN], pos=[4:2, 4:12])
}

// concreteN: impossible counts are eval errors.
concreteNImpossible4: {
	a: 1
	b: int
	c: "hello"
	concreteN(4, a, b, c)
	@test(err, code=eval, contains="%s: %d matched, expected %v", args=[concreteN, 2, 4], pos=[4:2, 4:12])
}

concreteNImpossible1: {
	a: 1
	b: int
	c: "hello"
	concreteN(1, a, b, c)
	@test(err, code=eval, contains="%s: %d matched, expected %v", args=[concreteN, 2, 1], pos=[4:2, 4:12])
}

concreteNImpossibleLt2: {
	a: 1
	b: int
	c: "hello"
	concreteN(<2, a, b, c)
	@test(err, code=eval, contains="%s: %d matched, expected %v", args=[concreteN, 2, <2], pos=[4:2, 4:12])
}

// concreteN embedded (protobuf-style: exactly one must be concrete).
concreteNOneOf: {
	a?: int
	b?: string
	a:  42
	concreteN(1, a, b)
	@test(eq, {a: 42, b?: string})
}
