Retain: 0

Unifications: 4
Conjuncts:    9
Disjuncts:    0

NumCloseIDs: 1
-- out/evalalpha --
Errors:
x: invalid value ["x","x"] (does not satisfy list.UniqueItems): equal value ("x") at position 0 and 1:
    ./in.cue:3:4
    ./in.cue:4:4
    ./in.cue:5:4

Result:
(_|_){
  // [eval]
  x: (_|_){
    // [eval] x: invalid value ["x","x"] (does not satisfy list.UniqueItems): equal value ("x") at position 0 and 1:
    //     ./in.cue:3:4
    //     ./in.cue:4:4
    //     ./in.cue:5:4
    0: (string){ "x" }
    1: (string){ "x" }
  }
}
