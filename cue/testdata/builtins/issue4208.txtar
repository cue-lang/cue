# Test that error() in a disjunction used as a pattern constraint key
# surfaces the custom error message instead of the generic "field not allowed".
#
# Issue #4208

-- in.cue --
#Environment: "sbx" | "stg" | "pro" | error("Must specify a valid environment")
#Envs: [Env=#Environment]: {}

// Valid key should work fine.
valid: #Envs
valid: sbx: {}

// Invalid key should show the custom error message.
invalid: #Envs
invalid: foo: {}

// Two pattern constraints with different error() messages.
#Color: "red" | "blue" | error("invalid color")
#Size: "s" | "m" | error("invalid size")
#TwoPatterns: {[#Color]: _} & {[#Size]: _}
twoPatterns: #TwoPatterns
twoPatterns: bad: "x"
-- out/evalalpha --
Errors:
invalid.foo: Must specify a valid environment:
    ./in.cue:1:39
    ./in.cue:10:10
twoPatterns.bad: invalid color:
    ./in.cue:13:26
    ./in.cue:17:14
twoPatterns.bad: invalid size:
    ./in.cue:14:20
    ./in.cue:17:14

Result:
(_|_){
  // [user]
  #Environment: (string){ |((string){ "sbx" }, (string){ "stg" }, (string){ "pro" }) }
  #Envs: (#struct){
  }
  valid: (#struct){
    sbx: (#struct){
    }
  }
  invalid: (_|_){
    // [user]
    foo: (_|_){
      // [user] invalid.foo: Must specify a valid environment:
      //     ./in.cue:1:39
      //     ./in.cue:10:10
    }
  }
  #Color: (string){ |((string){ "red" }, (string){ "blue" }) }
  #Size: (string){ |((string){ "s" }, (string){ "m" }) }
  #TwoPatterns: (#struct){
  }
  twoPatterns: (_|_){
    // [user]
    bad: (_|_){
      // [user] twoPatterns.bad: invalid color:
      //     ./in.cue:13:26
      //     ./in.cue:17:14
      // twoPatterns.bad: invalid size:
      //     ./in.cue:14:20
      //     ./in.cue:17:14
    }
  }
}
-- out/compile --
--- in.cue
{
  #Environment: ("sbx"|"stg"|"pro"|error("Must specify a valid environment"))
  #Envs: {
    [〈1;#Environment〉]: {}
  }
  valid: 〈0;#Envs〉
  valid: {
    sbx: {}
  }
  invalid: 〈0;#Envs〉
  invalid: {
    foo: {}
  }
  #Color: ("red"|"blue"|error("invalid color"))
  #Size: ("s"|"m"|error("invalid size"))
  #TwoPatterns: ({
    [〈1;#Color〉]: _
  } & {
    [〈1;#Size〉]: _
  })
  twoPatterns: 〈0;#TwoPatterns〉
  twoPatterns: {
    bad: "x"
  }
}
