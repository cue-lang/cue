# Tests that close() correctly rejects fields not present in the closed struct
# when the closed value is later unified with an open struct adding new fields.
# https://cuelang.org/issue/490
-- test.cue --
A: close({
	a: 1
	b: 2
})

B: A & {
	c: 3
}
	  // [eval]
	    // [eval]
	      // [eval] B.c: field not allowed:
	      //     test.cue:7:2
-- out/eval/stats --
Leaks:  0
Freed:  20
Reused: 8
Allocs: 12
Retain: 0

Unifications: 12
Conjuncts:    16
Disjuncts:    0

NumCloseIDs: 3
-- out/evalalpha --
Errors:
B.c: field not allowed:
    ./test.cue:7:2

Result:
(_|_){
  // [eval]
  A: (#struct){
    a: (int){ 1 }
    b: (int){ 2 }
  }
  B: (_|_){
    // [eval]
    c: (_|_){
      // [eval] B.c: field not allowed:
      //     ./test.cue:7:2
    }
    a: (int){ 1 }
    b: (int){ 2 }
  }
}
