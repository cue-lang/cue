    viaLet: {
      okc: {
        let X#1 = 〈2;xc〉.undefined
        let Y#2 = ({} & {
          s: [
            for _, y in 〈import;list〉.Range(0, 〈2;let X#1〉, 1) {},
          ]
        })
        if isValid(〈0;let Y#2〉) {
          〈1;let Y#2〉
        }
      }
    }
  }
}
