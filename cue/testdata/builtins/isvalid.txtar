# Tests for isValid and validN builtins

-- in.cue --
// isValid with concrete values
validConcrete: {
	a:      1
	checkA: isValid(a)   @test(eq, true)
}

// isValid with non-concrete values (types, constraints)
validNonConcrete: {
	a:      int
	checkA: isValid(a)   @test(eq, true)
	b:      >0
	checkB: isValid(b)   @test(eq, true)
}

// isValid with errors (conflicting unification)
validErrors: {
	a:      1 & 2   @test(err, code=eval, contains="conflicting values %s and %s", args=[2, 1], pos=[0:10, 0:14])
	checkA: isValid(a)   @test(eq, false)

	b: int & string   @test(err, code=eval, contains="conflicting values %s and %s (mismatched types %s and %s)", args=[int, string, int, string], pos=[0:5, 0:11])
	checkB: isValid(b)   @test(eq, false)

	c: {a: 1} & {a: 2}   @test(err, code=eval, path=a, contains="conflicting values %s and %s", args=[2, 1], pos=[0:9, 0:18])
	checkC: isValid(c)   @test(eq, false)

	d: {a: b: c: d: int} & {a: b: c: d: string}   @test(err, code=eval, path=a.b.c.d, contains="conflicting values %s and %s (mismatched types %s and %s)", args=[int, string, int, string], pos=[0:18, 0:38])
	checkD: isValid(d)   @test(eq, false)
}

// validN with count constraints
validNCount: {
	a: 1   @test(eq, 1)
	b: 2   @test(eq, 2)
	c: 1 & 2   @test(err, code=eval, contains="conflicting values %s and %s", args=[2, 1], pos=[-3:14, 0:5, 0:9])
	validN(2, a, b, c)
}

// isValid with literal
validLiteral: {
	checkInt:    isValid(42)        @test(eq, true)
	checkString: isValid("hello")   @test(eq, true)
}

// isValid with computation
validComputation: {
	checkAdd: isValid(1 + 2)   @test(eq, true)
}

// validN with bound constraints
validNBounds: {
	a: 1
	b: 2
	c: 1 & 2   @test(err, code=eval, contains="conflicting values %s and %s", args=[2, 1], pos=[0:5, 0:9])
	t1: validN(>=1, a, b, c) @test(eq, validN(>=1, 1, 2, _|_))
	t2: validN(<=2, a, b, c) @test(eq, validN(<=2, 1, 2, _|_))
}

// validN failure - requires all 3 valid but only 2 are
validNFailure: {
	a: 1
	b: 2
	c: 1 & 2   @test(err, code=eval, contains="conflicting values %s and %s", args=[2, 1], pos=[0:5, 0:9])
	// can never still have 3 valid values, as there are only 3 values total and c is always invalid.
	t1: validN(3, a, b, c) @test(err, code=eval, contains="%s: %d matched, expected %v", args=[validN, 2, 3], pos=[0:6, 0:13])
}

// validN embedded failure - requires >=3 valid but only 2 are possible (c is permanently invalid)
validNEmbedFail: {
	a: 1
	b: 2
	c: 1 & 2   @test(err, code=eval, contains="conflicting values %s and %s", args=[2, 1], pos=[0:5, 0:9])
	t1: validN(>=3, a, b, c) @test(err, code=eval, contains="%s: %d matched, expected %v", args=[validN, 2, >=3], pos=[0:6, 0:13])
}

// isValid on non-existent reference returns false (not error)
// Missing field is an evaluation error, and isValid returns false for any error
isValidMissingRef: {
	a:     b?: c: {}
	check: isValid(a.b.c)   @test(eq, false)
}

// isValid on existing but invalid reference should return false
isValidExistingInvalid: {
	a:     x: 1 & "foo"   @test(err, code=eval, contains="conflicting values %s and %s (mismatched types %s and %s)", args=[1, "foo", int, string], pos=[0:12, 0:16])
	check: isValid(a.x)   @test(eq, false)
}

-- existing.cue --
import "list"

isValidIncomplete: {
	xc: close({})
	xo: {}
	okc2: {
		if isValid({} & {s: [for y in xc.undefined {}]}) {a: 1}
		@test(eq, {})
	}
	oko2: {
		if isValid({} & {s: [for y in xo.undefined {}]}) {a: 1}
		@test(eq, {a: 1})
	}
	okc3: {
		if isValid({s: [for y in xc.undefined {}]}) {a: 1}
		@test(eq, {})
	}

	oko3: {
		if isValid({s: [for y in xo.undefined {}]}) {a: 1}
		@test(eq, {a: 1})
	}

	// Pass final error back from list argument, though comprehension, and
	// pass up.
	// https://cuelang.org/issue/1969
	viaLet: okc: {
		let X = xc.undefined
		let Y = {} & {s: [for y in list.Range(0, X, 1) {}]}

		if isValid(Y) {Y}
		@test(eq, {})
	}

}
