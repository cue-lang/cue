-- in.cue --
import (
	"encoding/json"
	"list"
	"struct"
)

// non-monotonic builtins must fail with an "incomplete" error if there
// is a possibility the constraint can get resolved by becoming more specific.
incompleteError1: {
	MyType: {
		kv: struct.MinFields(1)
	}

	foo: MyType & {
		kv: joel: "testing"
	}
	@test(eq, {
		MyType: {kv: {}}
		foo: {kv: {joel: "testing"}}
	})
}

incompleteError2: {
	MyType: {
		kv: [string]: string
		kv: struct.MinFields(1)
	}

	foo: MyType & {
		kv: joel: "testing"
	}
	@test(eq, {
		MyType: {
			kv: _|_ @test(err, code=incomplete, contains="incompleteError2.MyType.kv: invalid value {} (does not satisfy struct.MinFields(1)): len(fields) < MinFields(1) (0 < 1)", pos=[26:7, 25:7, 26:24])
		}
		foo: {kv: {joel: "testing"}}
	})
}

incompleteError3: {
	t: string
	t: json.Validate(string)
	@test(eq, {t: json.Validate(string) & string})
}

uniqueConstrains1: {
	t: string
	t: json.Validate(string)
	t: json.Validate(string)
	@test(eq, {t: json.Validate(string) & string})
}

uniqueConstrains2: {
	t: struct.MaxFields(1)
	t: struct.MaxFields(1)
	@test(eq, {t: {}})
}

violation: {
	#MyType: {
		kv: [string]: string
		kv: struct.MinFields(1)
	}

	foo: #MyType & {
		kv: joel: "testing"
		kv: tony: "testing"
	}
	@test(eq, {
		#MyType: {
			kv: _|_ @test(err, code=incomplete, contains="violation.#MyType.kv: invalid value {} (does not satisfy struct.MinFields(1)): len(fields) < MinFields(1) (0 < 1)", pos=[62:7, 61:7, 62:24])
		}
		foo: {kv: {joel: "testing", tony: "testing"}}
	})
}

conjuncts: {
	kv: struct.MinFields(1)
	kv: struct.MaxFields(3)
	@test(eq, {kv: {} & {}})
}

// TODO: stripe off conflicting pairs
// conflicting: {
//     kv: struct.MinFields(3)
//     kv: struct.MaxFields(1)
// }

// Builtins with bool return that can be used as validator.

bareBuiltin: {
	a: json.Valid
	a: json.Valid
	@test(eq, {a: json.Valid()})
}

bareBuiltinCheck: {
	a: json.Valid
	a: "3"
	@test(eq, {a: "3"})
}

builtinValidator: {
	a: json.Valid()
	a: json.Valid()
	@test(eq, {a: json.Valid()})
}

builtinValidatorCheck: {
	a: json.Valid()
	a: "3"
	@test(eq, {a: "3"})
}

callOfCallToValidator: {
	a: json.Valid
	b: a()
	e: b() // not allowed
	e: "5"
}

validatorAsFunction: {
	a: json.Valid
	b: a("3")
	c: json.Valid("3")
	@test(eq, {a: json.Valid(), b: true, c: true})
}

// issue2098: Tests that list.MinItems() does not panic when combined with list
// embedding and index access. https://cuelang.org/issue/2098
issue2098: ok1: {
	_a: [1, ...]
	_a: list.MinItems(1)
	_a[0]
	@test(eq, {_a: [1]})
}

issue2098: incomplete1: {
	_a: [...]
	_a: list.MinItems(1)
	_a[0]
}

@test(err, code=eval, at=callOfCallToValidator.e, contains="cannot call previously called validator", pos=[-26:5])
@test(err, code=incomplete, at=issue2098.incomplete1, contains="index out of range", pos=[-4:5])

-- issue3418.cue --
// issue3418: Tests that matchN correctly reports validation failures when
// combined with conflicting constraints, regardless of operand order.
// https://cuelang.org/issue/3418
issue3418: t1: "foo" & matchN(1, [1&2]) & matchN(1, [_])
issue3418: t2: "foo" & matchN(1, [_]) & matchN(1, [1&2])
issue3418: t3: {
	x: "foo"
	x: matchN(1, [_])
	x: matchN(1, [1&2])
}
issue3418: t4: {
	x: "foo"
	x: matchN(1, [1&2])
	x: matchN(1, [_])
}

@test(err, code=eval, at=issue3418.t1, contains="does not satisfy matchN", pos=[-13:24, -13:16, -13:31, -13:35, -13:37])
@test(err, code=eval, at=issue3418.t2, contains="does not satisfy matchN", pos=[-13:41, -13:16, -13:48, -13:52, -13:54])
@test(err, code=eval, at=issue3418.t3.x, contains="does not satisfy matchN", pos=[-10:5, -12:5, -11:5, -10:12, -10:16, -10:18])
@test(err, code=eval, at=issue3418.t4.x, contains="does not satisfy matchN", pos=[-7:5, -8:5, -7:12, -7:16, -7:18, -6:5])

-- issue3474.cue --
import "struct"

// issue3474: Tests that struct.MinFields/MaxFields validators correctly handle
// fields added by conditional comprehensions. https://cuelang.org/issue/3474
issue3474: structValidator: ok: {
	// Passes only after the comprehension is evaluated.
	A: struct.MinFields(1)
	A: {
		if true {B: true}
	}
	@test(eq, {A: {B: true}})
}
issue3474: structValidator: failAfter: {
	// Passes only before the comprehension is evaluated.
	A: struct.MaxFields(1)
	A: {
		C: true
		if true {B: true}
	}
}
issue3474: structValidator: incomplete: {
	// Passes neither before nor after the comprehension is evaluated.
	A: struct.MinFields(1)
	A: {
		if true {}
	}
	@test(eq, {
		A: _|_ @test(err, code=incomplete, contains="issue3474.structValidator.incomplete.A: invalid value {} (does not satisfy struct.MinFields(1)): len(fields) < MinFields(1) (0 < 1)", pos=[23:5, 23:22, 24:5])
	})
}
issue3474: structValidator: failClosed: {
	// Passes neither before nor after the comprehension is evaluated.
	#A: struct.MinFields(1)
	#A: {
		if true {}
	}
}


issue3474: topValidator: ok: {
	A: matchN(1, [>10])
	A: {
		if true {100}
	}
	@test(eq, {A: 100})
}
issue3474: topValidator: fail: {
	A: matchN(1, [>10])
	A: {
		if true {1}
	}
}
issue3474: topValidator: incomplete: {
	A: matchN(1, [>10])
	A: {
		if true {int}
	}
	@test(eq, {A: matchN(1, [>10]) & int})
}
issue3474: topValidator: failType: {
	A: matchN(1, [>10])
	A: {
		if true {C: 1}
	}
}

@test(err, code=eval, at=issue3474.structValidator.failAfter.A, contains="does not satisfy struct.MaxFields", pos=[-52:5, -52:22, -51:5])
@test(err, code=eval, at=issue3474.structValidator.failClosed.#A, contains="does not satisfy struct.MinFields", pos=[-35:6, -35:23, -34:6])
@test(err, code=eval, at=issue3474.topValidator.fail.A, contains="does not satisfy matchN", pos=[-21:5, -21:12, -20:5, -19:12])
@test(err, code=eval, at=issue3474.topValidator.failType.A, contains="does not satisfy matchN", pos=[-9:5, -9:12, -8:5])

-- validator_is_top.cue --
// issue3639: Tests that embedding a matchN validator struct alongside direct
// application does not cause "field not allowed" errors. https://cuelang.org/issue/3639
issue3639: {
	a: {#X} & #X
	a: b: 1
	#X: matchN(1, [{b: int}])
	@test(eq, {
		a: {b: 1}
		#X: matchN(1, [{
		b: int
	}])
	})
}
// issue3661: Tests that matchN with a required field validator works when
// applied via a pattern constraint. https://cuelang.org/issue/3661
issue3661: {
	#X: matchN(1, [{ b!: int }])
	a: b: 1
	a: #X
	["a"]: #X
	@test(eq, {
		#X: matchN(1, [{
		b!: int
	}])
		a: {b: 1}
	})
}
// issue3678: Tests that matchN with multiple required-field alternatives does not
// produce spurious "field not allowed" errors. https://cuelang.org/issue/3678
issue3678: {
	#X: matchN(1, [{
		a!: string
	}, {
		c!: string
	}])

	x: c: "c"

	y: #X
	y: x
	x: #X
	@test(eq, {
		#X: matchN(1, [{
		a!: string
	}, {
		c!: string
	}])
		x: {c: "c"}
		y: {c: "c"}
	})
}
// issue3981: Tests that matchN combined with close() correctly handles open
// struct arguments without topological sort regressions. https://cuelang.org/issue/3981
issue3981: matchWithClose: {
	out: {
		close({
			f1: matchN(1, [#openStruct])
		})
		#openStruct: {...}
	}
	out: f1: foo: ["bar"]
	@test(eq, {
		out: {#openStruct: {}, f1: {foo: ["bar"]}}
	})
}
