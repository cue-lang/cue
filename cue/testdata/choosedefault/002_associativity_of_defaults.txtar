--- in.cue
{
  a: (*"a"|("b"|"c"))
  b: ((*"a"|"b")|"c")
  c: (*"a"|(*"b"|"c"))
  x: (〈0;a〉 & 〈0;b〉)
  y: (〈0;b〉 & 〈0;c〉)
  s1: (*1|((*2|3) & (2|*3)))
  s2: (*1|((*2|3) & (*2|3)))
  s3: (*1|((*2|3) & 3))
  s4: (*1|((*2|3) & 2))
  s5: (*1|*(*2|3))
  e1: (*(1 & 2)|(*"x"|string))
  e2: ((*"x"|string)|*(1 & 2))
}
