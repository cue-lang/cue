-- in.cue --
package x

#PDB: {y: int}

result: resources: {
    if true {
        x: #PDB & {y: 1}
    }
}

out: ({
    cfg: resources: _
    out: {for n, _ in cfg.resources {(n): "x"}}
} & {cfg: result}).out @test(eq, {x: "x"})
