-- in.cue --
@experiment(try)

// When the source expression has an error, the error propagates
// rather than triggering the else clause.

// Error in for source - else should NOT trigger
forSourceError: {
	@test(err, code=eval, pos=[1:11], contains="cannot range")
	for x in "not-a-list" { "\(x)": x } fallback { fallbackField: true }
}

// Error in if condition - else should NOT trigger
ifConditionError: {
	@test(err, code=eval, pos=[1:6 1:14], contains="invalid operands")
	if ("not" + 1) { a: 1 } else { b: 2 }
}

// Bottom value in for source - else should NOT trigger
forSourceBottom: {
	@test(err, code=user, pos=[1:11], contains="explicit error")
	for x in _|_ { "\(x)": x } fallback { fallbackField: true }
}
-- out/compile --
--- in.cue
{
  forSourceError: {
    for _, x in "not-a-list" {
      "\(〈1;x〉)": 〈1;x〉
    } else {
      fallbackField: true
    }
  }
  ifConditionError: {
    if ("not" + 1) {
      a: 1
    } else {
      b: 2
    }
  }
  forSourceBottom: {
    for _, x in _|_(explicit error (_|_ literal) in source) {
      "\(〈1;x〉)": 〈1;x〉
    } else {
      fallbackField: true
    }
  }
}
