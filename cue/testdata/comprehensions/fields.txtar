Issue #560
# Issue #560: Tests that for comprehensions correctly iterate over struct fields,
# skipping optionals, and that missing required fields produce errors.
#todo:inline: medium — comprehension; may need @test(final) for incomplete fields
-- cue.mod/module.cue --
module: "mod.test"
language: version: "v0.9.0"
-- in.cue --
import "strings"

dynamic: {
	for _, s in ["foo"] {
		(s):       1
		"\(s)bar": 2
	}
}

ignoreOptional: {
	#x: {
		a?: string
		b?: string
		c:  string
	}

	y: {
		for k,v in #x {
			(k): "exists"
		}
	}
}

missingRequiredError:  {
	// Issue #2369
	#x: {
		a!: string
		b?: string
		c:  string
	}

	y: {
		for k,v in #x {
			(k): "exists"
		}
	}
}

// issue560: Tests that for comprehensions over definitions with interpolated
// field names correctly produce all expected output fields.
// https://cuelang.org/issue/560
issue560: {
	#User: {
		tags_str: string
		tags_map: {
			for k, v in strings.Split(tags_str, " ") {
				"\(v)": string
			}
			"{a}": string
		}
	}

	user: {
		#User
		tags_str: "b {c}"
	}
}
