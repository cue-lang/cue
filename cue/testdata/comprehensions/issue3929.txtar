        if (〈import;strings〉.HasSuffix(〈1;image〉, ":latest") == true) {
          imagePullPolicy: ("IfNotPresent"|*"Always"|"Never")
        }
        if (〈import;strings〉.HasSuffix(〈1;image〉, ":latest") != true) {
