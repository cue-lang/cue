# Tests that a comprehension guard that reads a sibling field does not cause
# conjuncts from sibling declarations that have not yet been evaluated to be
# dropped. Issue: the comprehension pushdown ran comprehension guards before
# sibling resolver tasks. In closedDef, the guard resolved the default of
# d.type and finalized the field before #D's conjuncts arrived, so closedness
# rejected type with a spurious "field not allowed". In selfInsert, resolving
# the reference to local within the comprehension body froze local's field
# set, so the body could no longer add sos_region ("field set was already
# referenced").
# https://cuelang.org/issue/4423

-- in.cue --
closedDef: {
	#D: {
		type?:  string
		fired?: bool
	}
	d: {
		type: *"x" | "y"
		if type == "x" {
			fired: true
		}
	}
	d: #D @test(eq, {type: *"x" | "y", fired: true})
}

selfInsert: {
	local: {zone: "zrh1"} @test(eq, {zone: "zrh1", sos_region: "ch-dk-2"})
	if local.zone == "zrh1" {
		local: _zones[local.zone]
	}
	_zones: zrh1: sos_region: "ch-dk-2"
}
-- out/eval/stats --
Leaks:  2
Freed:  15
Reused: 7
Allocs: 10
Retain: 0

Unifications: 15
Conjuncts:    25
Disjuncts:    2

NumCloseIDs: 6
