# Tests two regressions from the comprehension pushdown
# (https://cuelang.org/cl/1236923): a guard reading a sibling field must not
# finalize it before sibling conjuncts arrive (closedDef), and a
# comprehension body must be able to add fields to a struct it references
# (selfInsert).
# https://cuelang.org/issue/4423

-- in.cue --
closedDef: {
	#D: {
		type?:  string
		fired?: bool
	}
	d: {
		type: *"x" | "y"
		if type == "x" {
			fired: true
		}
	}
	d: #D @test(eq, {type: *"x" | "y", fired: true})
}

selfInsert: {
	local: {zone: "zrh1"} @test(eq, {zone: "zrh1", sos_region: "ch-dk-2"})
	if local.zone == "zrh1" {
		local: _zones[local.zone]
	}
	_zones: zrh1: sos_region: "ch-dk-2"
}
-- out/eval/stats --
Leaks:  2
Freed:  15
Reused: 7
Allocs: 10
Retain: 0

Unifications: 15
Conjuncts:    25
Disjuncts:    2

NumCloseIDs: 6
