-- in.cue --
a: [{a: 1}, {b: 2 & 3}] @test(err, code=eval, pos=[0:17, 0:21], contains="conflicting values")

b: [for x in a {x}] @test(err, code=eval, pos=[-2:17, -2:21], contains="conflicting values")
