issue3940: full: {
	out: #Exporter & {
		_imports: [_branch]
		#conf: global: region: "Europe"
	}

	_branch: {
		objects: branch: {
			#conf: {...}
			region: #conf.global.region
		}
		imports: [_leaf]
		#export: #Exporter & {
			_objects: objects
			_imports: imports
		}
	}
	_leaf: {
		objects: leaf: {
			#conf: {...}
			region: #conf.global.region
		}
		#export: #Exporter & {
			_objects: objects
		}
	}
	#Exporter: {
		CONF=#conf: {...}
		_objects: {...}
		_imports: [...]

		objects: [
			// local objects
			for name, obj in _objects & {[string]: #conf: CONF} {
				(name): obj
			},

			// transitively imported objects
			for import in _imports
			for obj in ({#conf: CONF} & import.#export).objects {
				obj
			},
		]
	}
	@test(eq, at=out, {
		_imports: [{
			objects: branch: {
				#conf: _ @test(ignore)
				region: _|_ @test(err, code=incomplete, contains="undefined field: global")
			}
			imports: [{
				objects: leaf: {
					#conf: _ @test(ignore)
					region: _|_ @test(err, code=incomplete, contains="undefined field: global")
				}
				#export: {
					_objects: leaf: {
						#conf: _ @test(ignore)
						region: _|_ @test(err, code=incomplete, contains="undefined field: global")
					}
					#conf: _ @test(ignore)
					_imports: []
					objects: [{
						leaf: {
							#conf: _ @test(ignore)
							region: _|_ @test(err, code=incomplete, contains="undefined field: global")
						}
					}]
				}
			}]
			#export: {
				_objects: branch: {
					#conf: _ @test(ignore)
					region: _|_ @test(err, code=incomplete, contains="undefined field: global")
				}
				_imports: [{
					objects: leaf: {
						#conf: _ @test(ignore)
						region: _|_ @test(err, code=incomplete, contains="undefined field: global")
					}
					#export: {
						_objects: leaf: {
							#conf: _ @test(ignore)
							region: _|_ @test(err, code=incomplete, contains="undefined field: global")
						}
						#conf: _ @test(ignore)
						_imports: []
						objects: [{
							leaf: {
								#conf: _ @test(ignore)
								region: _|_ @test(err, code=incomplete, contains="undefined field: global")
							}
						}]
					}
				}]
				#conf: _ @test(ignore)
				objects: [{
					branch: {
						#conf: _ @test(ignore)
						region: _|_ @test(err, code=incomplete, contains="undefined field: global")
					}
				}, {
					leaf: {
						#conf: _ @test(ignore)
						region: _|_ @test(err, code=incomplete, contains="undefined field: global")
					}
				}]
			}
		}]
		#conf: {global: {region: "Europe"}}
		_objects: {}
		objects: [{
			branch: {
				#conf: {global: {region: "Europe"}}
				region: "Europe"
			}
		}, {
			leaf: {
				#conf: {global: {region: "Europe"}}
				region: "Europe"
			}
		}]
	})
}
-- issue3990.cue --
// issue3990: Tests that nested comprehensions within struct definitions do not
// trigger "field set was already referenced" errors in evalv3.
// https://cuelang.org/issue/3990
issue3990: {
	_imports: [_noVolumes, _someVolumes]
	_noVolumes: {
		name: "noVolumes"
		exportObjs: deployment: _Deployment & {
			volumes: []
		}
	}
	_someVolumes: {
		name: "someVolumes"
		exportObjs: deployment: _Deployment & {
			volumes: [{name: "data"}]
		}
	}

	for import in _imports
	for _, obj in ({extra: "unused"} & import).exportObjs {(import.name): obj},

	_Deployment: this={
		_names: {
			for _, v in this.volumes {
				(v.name): v.name
			}
		}
		// skip volumeNames if empty
		if len(_names) > 0 {
			volumeNames: [for _, v in _names {v}]
		}
	}
	@test(eq, {
		_imports: [{
			name: "noVolumes"
			exportObjs: deployment: {volumes: [], _names: {}}
		}, {
			name: "someVolumes"
			exportObjs: deployment: {
				_names: {data: "data"}
				volumeNames: ["data"]
				volumes: [{
					name: "data"
				}]
			}
		}]
		_noVolumes: {
			name: "noVolumes"
			exportObjs: {deployment: {volumes: [], _names: {}}}
		}
		_someVolumes: {
			name: "someVolumes"
			exportObjs: {
				deployment: {
					volumes: [{ name: "data" }]
					_names: {data: "data"}
					volumeNames: ["data"]
				}
			}
		}
		_Deployment: {
			_names: _|_ @test(err, code=incomplete, contains="issue3990._Deployment._names: undefined field: volumes", pos=[24:21])
		}
		someVolumes: {
			volumes: [{ name: "data" }]
			_names: {data: "data"}
			volumeNames: ["data"]
		}
		noVolumes: {volumes: [], _names: {}}
	})
}
