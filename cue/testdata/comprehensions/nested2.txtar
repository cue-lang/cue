-- issue3940.cue --
// issue3940: Tests that chained comprehension clauses do not trigger spurious
// structural cycle errors in evalv3. https://cuelang.org/issue/3940
// Test chained comprehension clauses (without braces)
issue3940: reduced1: {
	X
	a: b: X
	a: b: a: b: {y: X}

	X: {
		a: {}

		objects: {
			for v in a
			for _ in ({} & v).objects {
			}
		}
	}

	@test(eq, {
		a: {
			b: {
				a: {b: {y: {a: {}, objects: {}}}}
				objects: _|_ @test(err, code=incomplete, contains="issue3940.reduced1.a.b.objects: undefined field: objects", pos=[14:22])
			}
		}
		X: {a: {}, objects: {}}
		objects: _|_ @test(err, code=incomplete, contains="objects: undefined field: objects", pos=[14:22])
	})
}

// Test nested comprehensions (with braces) - should work as before
issue3940: reduced2: {
	X
	a: b: X
	a: b: a: b: {y: X}

	X: {
		a: {}

		objects: {
			for v in a
			for _ in ({} & v).objects {
			}
		}
	}
	@test(eq, {
		a: {
			b: {
				a: {b: {y: {a: {}, objects: {}}}}
				objects: _|_ @test(err, code=incomplete, contains="issue3940.reduced2.a.b.objects: undefined field: objects", pos=[42:22])
			}
		}
		X: {a: {}, objects: {}}
		objects: _|_ @test(err, code=incomplete, contains="objects: undefined field: objects", pos=[42:22])
	})
}
issue3940: reduced3: {
	a: E
	a: i: x: E
	a: i: x: i: x: E
	E: {
		i: {}
		o: [for m in i for v in ({} & m).o {}]
	}
	@test(eq, {
		a: {
			i: {x: {i: {x: {i: {}, o: []}}, o: []}}
			o: []
