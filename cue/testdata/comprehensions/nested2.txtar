-- in.cue --
given: {
	INC: USD: 2.0
	USD: GBP: 3.0
	@test(eq, {INC: {USD: 2.0}, USD: {GBP: 3.0}})
}
hydrated: {
	for k, v in given {
		for k1, r in v {
			"\(k)": "\(k)":   1.0
			"\(k1)": "\(k1)": 1.0
			"\(k)": "\(k1)":  r
			"\(k1)": "\(k)":  number
		}
	}
	@test(eq, {
		INC: {INC: 1.0, USD: 2.0}
		USD: {USD: 1.0, INC: number, GBP: 3.0}
		GBP: {GBP: 1.0, USD: number}
	})
}

foo: {
	a: 10
	if a < 20 {
		if a < 50 {
			b: 20
		}
	}
	@test(eq, {a: 10, b: 20})
}

indirectlyNested: {
	a: true // must be declared outside of the nested comprehensions for test.
	if true {
		b: {
			if a {
				a
			}
		}
	}
	@test(eq, {a: true, b: true})
}

directlyNestedEmpty: {
	a: true
	if true {
		if a {
		}
	}
	@test(eq, {a: true})
}

directlyDoublyNestedEmpty: {
	a: true
	if true {
		if a {
		}
	}
	@test(eq, {a: true})
}

indirectlyDoublyNestedEmpty: {
	a: true
	b: {
		if true {
			if a {
				if a {
					a
				}
			}
			if a {
				a
			}
		}
	}
	@test(eq, {a: true, b: true})
}

indirectlyDoublyNested: {
	a: true
	if true {
		if a {
			if a {
				b: 1
			}
		}
		if a {
			c: 1
		}
	}
	@test(eq, {a: true, c: 1, b: 1})
}

// This case used to trigger an over-aggressive deduplication.
// issue1974: Tests that two-level nested for comprehensions do not lose keys
// due to over-aggressive deduplication. https://cuelang.org/issue/1974
issue1974: {
	X: {
		foo: {
			bar: ""
			baz: ""
		}
	}
	out: {
		for k, v in X for vk, vv in v {
			"\(k)": "\(vk)": vv
		}
	}
	@test(eq, {
		X: {foo: {bar: "", baz: ""}}
		out: {foo: {bar: "", baz: ""}}
	})
}
