-- issue1759.cue --
// Tests that len() and comprehensions correctly see the full struct/list value.
// https://cuelang.org/issue/1759
// Tests derived from Unity.
unity: success1: {
	#Config: {
		name: string
		type: string
	}

	#AnyConfig: {
		#Config
		...
	}

	#Env: {
		name: string
		configurations: [string]: #AnyConfig
	}

	envs: "e1": #Env & {
		configurations: c1:  #Config
	}

	envs: [string]: configurations: [string]: {
		type: "foo"
		if type == "terraform" {
			backend: {
				type: "s3"
			}
		}
	}
	@test(eq, {
		#Config: {name: string, type: string}
		#AnyConfig: {name: string, type: string}
		#Env: {name: string, configurations: {}}
		envs: {
			e1: {
				configurations: {c1: {type: "foo", name: string}}
				name: string
			}
		}
	})
}

// issue1759: Tests that len() correctly sees the full struct value when
// used as a comprehension condition. https://cuelang.org/issue/1759
issue1759: {
	_ports_map: {}
	if len(_ports_map) > 0 {
		port: _ports_map.a.port
	}
	if true {
		_ports_map: a: {port: "80"}
	}
	@test(eq, {
		_ports_map: {a: {port: "80"}}
		port: "80"
	})
}

arcAlignment: t1: {
