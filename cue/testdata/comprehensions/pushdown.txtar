# Working set of tests that unit test specifics of the aspect of the
# comprehension algorithm that pushes down evaluation to the arcs.
-- in.cue --
linkChildren: {
	w: 1
	v: {
		x: 1
		if true {
			y: 1
			if true {
				z: 1

				rw: w
				rx: x
				ry: y
				rz: z

				n1a: na: [w, x, y, z]
				n2a: n1a: na: [w, x, y, z]
				n2z: n1z: nz: z
			}
		}
	}
	@test(eq, {
		w: 1
		v: {
			x: 1
			y: 1
			z: 1
			rw: 1
			rx: 1
			ry: 1
			rz: 1
			n1a: {na: [1, 1, 1, 1]}
			n2a: {n1a: {na: [1, 1, 1, 1]}}
			n2z: {n1z: {nz: 1}}
		}
	})
}

fail: {
	a: {
		// Condition of comprehensions must still hold after its evaluation.
		//
		// `b` is not defined, causing this if comprehension to evaluate to
		// true. However, after inserting the corresponding result in curly
		// braces, the condition would be true. This is not allowed.
		if a.b == _|_ {
			b: 1
		}
	} @test(err, code=incomplete, path=b, contains="cyclic reference to field %[1]v", args=[b], pos=[6:3])
}

embed: {
	fail1: #C1 @test(err, code=eval, path=p, contains="field not allowed", pos=[9:4, 12:9])
	#C1: {
		// TODO(errors): don't include all positions of p in the normal list of
		// positions, or rather categorize the positions to show:
		// 1) position of denied fields
		// 2) position of structs that deny them
		// 3) points at which those structs where mixed in (perhaps as tree)
		// 4) conditionals that could enable allowing a field.
		if false {
			p: _
		}
	}
	fail1: p: "foo" // this should fail, as p is not present.


	success2: #C2 @test(eq, {p: "foo"})
	#C2: {
		if true {
			p: _
		}
	}
	success2: p: "foo" // this succeeds as p is present.

	success3: #C3 @test(eq, {})
	#C3: {}
	success3: {
		if false {
			// p does not exist in success3, but it is okay, as it is not added.
			p: q: 1
		}
	}

	success4: {
		#X: y: string
		x: y: string
		x: {
			for _ in ["iter-once"] {
				#X
				if false {
					y: "foo"
				}
			}
		}
	} @test(eq, {#X: {y: string}, x: {y: string}})

	fail4: #C4
	#C4: {}
	fail4: {
		if true {
			// error as p is not allowed in fail4
			p: q: 1
		}
	} @test(err, code=eval, path=p, contains="field not allowed", pos=[3:4])

	incomplete5: {
		a: bool
		if a {
			p: q: 1
		}
	} @test(err, code=incomplete, contains="incomplete %s: %s", args=[bool, bool], pos=[1:6])

	incomplete6: {
		if false {
			p: 1
		}
		p: q + 1
		q: int
	} @test(eq, {
		p: _|_ @test(err, code=incomplete, contains="embed.incomplete6.p: non-concrete value int in operand to +", pos=[117:6, 118:6])
		q: int
	})
	incomplete7: {
		p: q + 1
		q: int
		if false {
			q: 1 // do not inadvertently pick up a void arc.
		}
	} @test(eq, {
		p: _|_ @test(err, code=incomplete, contains="embed.incomplete7.p: non-concrete value int in operand to +", pos=[124:6, 125:6, 126:3])
		q: int
	})
}

// Mix of both dynamic and static fields.
mixedFieldsSuccess: {
	a: {
		for _, s in ["foo"] {
			"\(s)": 1
			X: 1
		}
	}

	b: #Def: {
		for _, s in ["foo"] {
			"\(s)": 1
			X: 1
		}
	}
	b: x: b.#Def
	b: x: X: _
	b: x: foo: _


	c: #Def: {
		X:   int
		foo: int
	}
	c: x: c.#Def
	c: x: {
		for _, s in ["foo"] {
			"\(s)": 1
			X: 1
		}
	}
	@test(eq, {
		a: {X: 1, foo: 1}
		b: {
			#Def: {X: 1, foo: 1}
			x: {X: 1, foo: 1}
		}
		c: {
			#Def: {X: int, foo: int}
			x: {X: 1, foo: 1}
		}
	})
}

// fieldMismatch tests that an embedded scalar cannot be mixed with regular
// fields, even if they are added by a comprehension.
fieldMismatch: {
	a: {
		2
		if true {
			x: 3
		}
	}
	@test(err, code=eval, at=a, contains="cannot combine regular field", pos=[4:7, 2:3])
}

// b12aStructCycle presents a case that can easily lead to stack overflow in
// a naive implementation. It corresponds to test b12a in structural.txtar.
noStackOverflowStructCycle: {
	#list: {
		tail: #list

		if tail != null {
			sum: tail.sum
		}
	}

	list: {
		tail: list

		if tail != null {
			sum: tail.sum
		}
	}
	@test(err, code=structural_cycle, at="#list.tail", contains="structural cycle", pos=[])
}


// #a is incomplete, but the missing values are provided by x.
provideIncompleteSuccess: {
	t1: {
		#a: {
			if b {
				c: 4
			}
			b: bool
		}
		x: (#a & {b: true}) & {c: 4}
		y: x
		@test(eq, {
			#a: {_|_, b: bool}
			x: {b: true, c: 4}
			y: {b: true, c: 4}
		})
	}

	t2: {
		// c should be allowed
		#a: {
			if b {
				c: 4
			}
			b: true
		} @test(eq, {c: 4, b: true})

		#c: {}
		a: {
			if b {
				c: d: 4
			}
			b: true
			// d is disallowed, even though it is added by embedding.
			// TODO: this seems right, but it may be good to clarify why.
			c: #c @test(err, code=eval, at=d, contains="field not allowed", pos=[-5:8])
		}
	}
}

// voidArcs tests that fields are dropped and reference up counts are adjusted
// appropriately under various rewrite scenario.
voidArcs: {
	scopes: {
		x: 1
		a: {
			y: 2
			if true {
				b: x
				c: d: x
				e: y
				f: g: y
			}
		}
	}

	drop: {
		x: 1
		a: {
			y: 2
			if false {
				b: x
				c: d: x
				e: y
				f: g: y
			}
		}
	}
	@test(eq, {
		scopes: {
			x: 1
			a: {y: 2, b: 1, c: {d: 1}, e: 2, f: {g: 2}}
		}
		drop: {x: 1, a: {y: 2}}
	})
}

cyclicError: {
	a: {
		x: bool @test(err, code=incomplete, path=cyclicError.a, contains="incomplete %s: %s", args=[bool, bool], pos=[0:6])
		y: bool @test(err, code=incomplete, path=cyclicError.a, contains="incomplete %s: %s", args=[bool, bool], pos=[-1:6])
		if a.x  {
			y: true
		}
		if a.y {
			x: true
		}
		b: {}
	}
	// The evaluation of `b` in `a` triggers a to be fully evaluated, which
	// is not possible because the evaluation of `a` depends on incomplete
	// values.
	c: a.b @test(err, code=incomplete, path=cyclicError.a, contains="incomplete %s: %s", args=[bool, bool], pos=[-13:6])
	@test(eq, {
		a: {
			x: _|_
			y: _|_
			b: {}
		}
		c: _|_
	})
}

midwayReferences: {
	a: {
		for i, j in {a: 1, b: 2} {
			x: y: z: (i): j
		}
		x: y: {}
	}
	b: a.x
	c: a.x.y
	d: a.x.y.z
	@test(eq, {
		a: {x: {y: {z: {a: 1, b: 2}}}}
		b: {y: {z: {a: 1, b: 2}}}
		c: {z: {a: 1, b: 2}}
		d: {a: 1, b: 2}
	})
}

// Ensure first closedness check is done after evaluation of
// comprehensions.
closedCheck: success1: {
	a: b: [string]: #D

	#D: {
		d: string
		if d != "c" {
			e: string
		}
	}

	a: b: c: {
		d: "d"
		e: "ok"
	}
	@test(eq, {
		a: {b: {c: {d: "d", e: "ok"}}}
		#D: {d: string}
	})
}

closedCheck: success2: {
	a: b: [string]: #D

	#D: {
		d: string
		if d != "c" {
			("foo"+"bar"): string
		}
	}

	a: b: c: {
		d:      "d"
		foobar: "ok"
	}
}

closedCheck: success3: {
	a: b: [string]: #D

	#D: {
		d: string
		e: {
			if d != "c" {
				string
			}
		}
	}

	a: b: c: {
		d: "d"
		e: "ok"
	}
}

emptyComprehensionIncomplete: {
	a: {}
	b: {
		// b should be an incomplete error
		if a.b {
		}
	} @test(err, code=incomplete, contains="undefined field: %s", args=[b], pos=[2:8])
	@test(eq, {
		a: {}
		b: _|_
	})
}

// voidEliminationSuccess tests that "conditional" or "void" arcs are eliminated
// if their expression does not yield any result.
voidEliminationSuccess: t1: {
	[string]: {
		b: bool
		if !b {}
	}
	if false {
		a: b: true
	}
	@test(eq, {})
}

voidEliminationSuccess: t2: {
	components: {
		sinks: [string]: #C & {
			kind: string
			configuration: {
				if kind != "source" {
					inputs: {
						required: true
					}
				}
			}
		}

		#C: {
			kind: string
			configuration: [string]: {
				required: bool
				if !required {
					common: bool
				}
			}
		}
	}

	components: sinks: blah: {
		kind: "source"
	}
	@test(eq, {
		components: {
			sinks: {
				blah: {kind: "source", configuration: {}}
			}
			#C: {kind: string, configuration: {}}
		}
	})
}

voidEliminationSuccess: derefRef1: {
	a: [string]: c: [string]: E

	a: b: c: {
		if false {
			d: e: true // resolves
		}
	}

	E: {
		e: bool
		f: !e // remains incomplete
	}
	@test(eq, {
		a: {b: {c: {}}}
		E: {
			e: bool
			f: _|_ @test(err, code=incomplete, contains="voidEliminationSuccess.derefRef1.E.f: operand e of '!' not concrete (was bool)", pos=[464:7])
		}
	})
}

voidEliminationSuccess: derefRef2: {
	a: [string]: c: [string]: E

	a: b: c: {
		if false {
			d: e: true // resolves
		}
	}

	E: #F
	#F: {
		e: bool
		f: !e // remains incomplete
	}
	@test(eq, {
		a: {b: {c: {}}}
		E: {
			e: bool
			f: _|_ @test(err, code=incomplete, contains="voidEliminationSuccess.derefRef2.#F.f: operand e of '!' not concrete (was bool)", pos=[487:7])
		}
		#F: {
			e: bool
			f: _|_ @test(err, code=incomplete, contains="voidEliminationSuccess.derefRef2.#F.f: operand e of '!' not concrete (was bool)", pos=[487:7])
		}
	})
}

voidEliminationSuccess: derefDisj1: {
	a: [string]: c: [string]: E

	a: b: c: {
		if false {
			d: e: true
		}
	}

	E: {
		e: bool
		f: !e
	} | {
		g: bool
		h: !g
	}
	@test(eq, {
		a: {b: {c: {}}}
		E: _|_ @test(err, code=incomplete, contains="voidEliminationSuccess.derefDisj1.E: 2 errors in empty disjunction: (and 2 more errors)", pos=[])
	})
}

voidEliminationSuccess: derefDisj2: {
	a: [string]: c: [string]: E & E

	a: b: c: {
		if false {
			d: e: true
		}
	}

	E: {
		e: bool
		f: !e
	} | {
		g: bool
		h: !g
	}
	@test(eq, {
		a: {b: {c: {}}}
		E: _|_ @test(err, code=incomplete, contains="voidEliminationSuccess.derefDisj2.E: 2 errors in empty disjunction: (and 2 more errors)", pos=[])
	})
}

voidEliminationSuccess: bulk1: {
	a: b: {}
	a: [string]: {
		c: {
			e: string
			if false {
				e: ""
			}
		}
		d: c.e
	}
	@test(eq, {a: {b: {c: {e: string}, d: string}}})
}

voidEliminationSuccess: opt1: {
	a: b: {}
	a: b?: {
		c: {
			e: string
			if false {
				e: ""
			}
		}
		d: c.e
	}
	@test(eq, {a: {b: {c: {e: string}, d: string}}})
}

voidEliminationSuccess: noCycle1: {
	_x: a.b
	a: {
		c: h: "stream"
		b: {
			if c.g != _|_ {}
		}
		c: {
			if false {g: _}
		}
	}
	@test(eq, {_x: {}, a: {c: {h: "stream"}, b: {}}})
}

voidEliminationSuccess: noCycle2: {
	a: {
		c: h: "stream"
		b: {
			if c.g != _|_ {}
		}
		c: {
			if false {g: _}
		}
	}
	_x: a.b
	@test(eq, {a: {c: {h: "stream"}, b: {}}, _x: {}})
}

voidLookup: {
	a: x: z: a.y.z.void

	a: y: {
		c: _
		z: {}
	}

	a: [string]: {
		c: {
			for k, v in z {
				(k): null  // don't add this arc anywhere
			}
		}
		z: {
			if false {
				err: {}
			}
		}
	}
	@test(eq, {
		a: {
			x: {
				z: _|_
				c: _|_
			}
			y: {c: _, z: {}}
		}
	})
	@test(err, at=a.x.z, code=incomplete,
		contains="undefined field: %s", args=[void], pos=[1:17])
	@test(err, at=a.x.c, code=incomplete,
		path=voidLookup.a.x.z, contains="undefined field: %s", args=[void], pos=[1:17])
}


// Eliminate the top value even if there is an error (especially incomplete
// errors).
topElimination: {
	a: int
	_
	if true {
		x: a+1
	}
	@test(eq, {
		a: int
		x: _|_
	})
	@test(err, at=x, code=incomplete, contains="non-concrete value %v in operand to %s", args=[int, +], pos=[4:6, 1:5])
}

voidEliminationSuccess: drop1: {
	// Do not include x in s.
	t: {
		#ok: *true | bool
		if #ok {
			x: int
		}
	}
	s: t & {
		#ok: false
	}
	@test(eq, {
		t: {#ok: *true | bool, x: int}
		s: {#ok: false}
	})
}

