}

// Remove arcs for with no for comprehension results.
allArcsSuccess: p1: {
	x: {
		for k, _ in y {
			(k): null
		}
	}
	y: {
		if false {
			x: {}
		}
	}
	@test(eq, {x: {}, y: {}})
}

allArcsSuccess: p2: {
