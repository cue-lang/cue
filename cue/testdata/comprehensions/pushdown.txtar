}

structShare: err1: {
	x: [string]: x.#E
	x: #E: {}
	if true {
		x: d: e: true
	}
	@test(err, code=eval, at=x.d.e, contains="field not allowed", pos=[4:9])
}

// An optional field referencing a value only a pushed-down comprehension
// materializes must stay optional, not be upgraded to a regular member.
optionalRefStaysOptional: s={
	optionalRef?: string
	optionalRef?: s.field
	if true {
		field: "value"
	}
	@test(eq, {optionalRef?: "value", field: "value"})
}

