-- issue4422.cue --
@experiment(aliasv2)

// A dynamic field whose key refers to a vertex that is still being evaluated
// (here a list element that looks up a field on itself through an embedding)
// must report an incomplete error. The pushed-down comprehension used to
// insert the arc keyed on the partial value, after which lookups during the
// expansion of the disjunction re-expanded it without bound, hanging
// evaluation. https://cuelang.org/issue/4422
issue4422: {
	settings: domain: {
		let _zero = 0
		x: _zero
	}
	components: {
		[_]: clusters: [for _ in [1, 2] {self.settings.missing}]
		comp1: {}
		comp2: {}
	}

	for _, cv in components
	for host in cv.clusters {
		hosts: (host): *settings.domain | 123
	}

	for host, _ in self.hosts {}

	@test(err, code=incomplete,
		contains="key value of dynamic field not yet known", pos=[13:11])
}
