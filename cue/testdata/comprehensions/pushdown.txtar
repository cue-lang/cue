-- issue1759.cue --
// Tests that len() and comprehensions correctly see the full struct/list value.
// https://cuelang.org/issue/1759
// Tests derived from Unity.
unity: success1: {
	#Config: {
		name: string
		type: string
	}

	#AnyConfig: {
		#Config
		...
	}

	#Env: {
		name: string
		configurations: [string]: #AnyConfig
	}

	envs: "e1": #Env & {
		configurations: c1:  #Config
	}

	envs: [string]: configurations: [string]: {
		type: "foo"
		if type == "terraform" {
			backend: {
				type: "s3"
			}
		}
	}
	@test(eq, {
		#Config: {name: string, type: string}
		#AnyConfig: {name: string, type: string}
		#Env: {name: string, configurations: {}}
		envs: {
			e1: {
				configurations: {c1: {type: "foo", name: string}}
				name: string
			}
		}
	})
}

// issue1759: Tests that len() correctly sees the full struct value when
// used as a comprehension condition. https://cuelang.org/issue/1759
issue1759: {
	_ports_map: {}
	if len(_ports_map) > 0 {
		port: _ports_map.a.port
	}
	if true {
		_ports_map: a: {port: "80"}
	}
	@test(eq, {
		_ports_map: {a: {port: "80"}}
		port: "80"
	})
}

arcAlignment: t1: {
	[string]:  {
		if true { }
	}
	if false {
		c: _
	}
	@test(eq, {})
}

-- issue2111.cue --
// Evaluator regression where circular dependency in evaluation of conditionals
// caused incorrect results. All arc types, not just regular fields, should be pushed down.
// https://cuelang.org/issue/2111
letPushdown: {
	_c: y: 1

	a: {
		for k, v in _c {
			let x = v
			if x != _|_ {
			}
		}
	}
	@test(eq, {_c: {y: 1}, a: {}})
}

-- issue2113.cue --
// Evaluator regression where a nested comprehension caused "was already used"
// errors when the enclosing value was not yet fully evaluated.
// https://cuelang.org/issue/2113
// Ensure that an enclosing Value clause of a nested comprehension is evaluated
// before the nested comprehension itself is evaluated.
nestedWithEmbeddingOK: {
	c: [1]
	a: {
		for k, v in c {
			{x: 1}
			if a.x != _|_ {
			}
		}
	}
	@test(eq, {c: [1], a: {x: 1}})
}

nestedWithDynamicFieldOK: {
	_c: y: 1

	a: {
		for k, v in _c {
			if x != _|_ {
			}
			x="\(k)": 1
		}
	}
	@test(eq, {_c: {y: 1}, a: {y: 1}})
}

// Errors in nested comprehensions should also be reported.
errorPropagation: {
	deployment: _
	for k, v in deployment {
		for k1, v2 in v.env2 { // Report this error.
			deployment: (k): x1: 1
		}
	}
	for id in ["elem"] { deployment: (id): x2: 2 }
	@test(err, code=incomplete, contains="undefined field: env2", pos=[3:19])
}

-- issue2131.cue --
// issue2131: Tests that chained for comprehensions correctly produce output
// fields when iterating over nested structs. https://cuelang.org/issue/2131
issue2131: tests: {
	windows: {
		eg1: in: #"c:\d"#
		eg2: in: #"c:\test"#
		eg3: in: #"c:\test\d"#
	}

	for os, examples in tests for k, v in examples {
		(os): (k): out: "test"
	}
	@test(eq, {
		windows: {
			eg1: {in: "c:\\d", out: "test"}
			eg2: {in: "c:\\test", out: "test"}
			eg3: {in: "c:\\test\\d", out: "test"}
		}
	})
}
-- issue3533.cue --
// issue3533: Tests that fields under two levels of comprehensions are not
// incorrectly rejected as "field not allowed" in evalv3.
// https://cuelang.org/issue/3533
issue3533: {
	#ObjectMeta: namespace?: string
	out: {
		for i, _ in ["iter-once"] {
			metadata: #ObjectMeta
			if false {
				metadata: namespace: "foo"
			}
		}
	}
	out: metadata: namespace: *"default" | string
	@test(eq, {
		#ObjectMeta: {namespace?: string}
		out: {
			metadata: {namespace: *"default" | string}
		}
	})
}
-- issue3535.cue --
// issue3535: Tests that hidden fields inside if comprehensions do not
// trigger "field not allowed" errors in evalv3.
// https://cuelang.org/issue/3535
issue3535: hidden: {
	#X: {
		kind: string
		output: {}
	}
	foo: #X & {
		kind: string
		if kind == "foo" {
			_hidden: {}
		}
	}
	foo: kind: "foo"
	@test(eq, {
		#X: {kind: string, output: {}}
		foo: {kind: "foo", _hidden: {}, output: {}}
	})
}
issue3535: regular: {
	#X: {
		kind: string
		output: {}
	}
	foo: #X & {
		kind: string
		if kind == "foo" {
			regular: {}
		}
	}
	foo: kind: "foo"
	@test(err, code=eval, at=foo.regular, contains="field not allowed", pos=[8:4])
}
issue3535: def: {
	#X: {
		kind: string
		output: {}
	}
	foo: #X & {
		kind: string
		if kind == "foo" {
			#def: {}
		}
	}
	foo: kind: "foo"
	@test(eq, {
		#X: {kind: string, output: {}}
		foo: {kind: "foo", #def: {}, output: {}}
	})
}
-- reflect.cue --
import "encoding/json"


unifyDynamicReflectSuccess: {
	for _, s in ["foo"] {
		X: {...}
		"\(s)": {
			X: {...} // cannot be _
			Y: json.Marshal(X) // cannot be yaml, X cannot be literal
		}
	}

	[string]: X: {
		if true {// must be there
			x: y: {} // at least 2 nestings needed to expose problem
		}
	}
	@test(eq, {
		X: {X: {x: {y: {}}}}
		foo: {
			X: {x: {y: {}}}
			Y: "{\"x\":{\"y\":{}}}"
		}
	})
}
-- issue3621.cue --
// issue3621: evalv3 regression producing false "cyclic reference" errors for
// comprehensions with nested field definitions and references that evalv2 handles correctly.
// https://cuelang.org/issue/3621
issue3621: reduced: t1: {
	// This test ensures that when a reference is made within a comprehension,
	// with vertices marked as "pending", that these are not completed the
	// respective pushed-down comprehension is evaluated as well.
	if true {
		a: b1.b2.b3
		b1: b2: b3: "Foo"
	}
	@test(eq, {a: "Foo", b1: {b2: {b3: "Foo"}}})
}
issue3621: reduced: t2: {
	outer: {}
	if true {
		inner: inner2: name: "Foo"
		outer: b: inner.inner2.name
	}
	@test(eq, {
		outer: {b: "Foo"}
		inner: {inner2: {name: "Foo"}}
	})
}
issue3621: full: {
	hello: "world"
	outer: [Name=string]: name: Name
	if true {
		inner: inner2: {
			name:           "Employees"
			description:    "All employees"
			privacy:        "secret"
			create_default: false
		}
		outer: outer2: {
			bar: (inner.inner2.name)
		}
	}
	@test(eq, {
		hello: "world"
		outer: {
			outer2: {bar: "Employees", name: "outer2"}
		}
		inner: {
			inner2: {
				name: "Employees"
				description: "All employees"
				privacy: "secret"
				create_default: false
			}
		}
	})
}
-- issue3708.cue --
// issue3708: evalv3 regression reporting a cyclic reference error when fields are
// accessed inside a comprehension using optional field patterns with if conditionals.
// https://cuelang.org/issue/3708
issue3708: {
	out: people.bob.kind

	// pattern constraint marks 'name' as member, which should not preclude name
	// from being futher evaluated to determine whether 'people' is pending.
	people: [string]: {
		kind:  "person"
		name?: string
	}

	if true {
		people: bob: name: "Bob"
	}
	@test(eq, {
		out: "person"
		people: {bob: {name: "Bob", kind: "person"}}
	})
}
