	#Rollout: {
		_X: _
		out: #Primary & {_Y: _X} & _X.patch
	}
	x: {
		spec: command: ["a"]
		patch: {}
	}
	out: #Rollout & {_X: x} @test(eq, at=out,{
		_Y: {spec: {command: ["a"]}, patch: {}}
		command: ["a"]
	})
}
