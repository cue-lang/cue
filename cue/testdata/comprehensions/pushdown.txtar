// issue3729: evalv3 incorrectly reports "incomplete value null" for fields typed
// as a disjunction containing null (e.g. null | #T) inside if comprehensions.
// https://cuelang.org/issue/3729
issue3729: withDisjunction: {
	#Root: sub1?: #sub2?: bool
	root?: null | #Root
	if true {
		root: sub1?: #sub2: true
	}
	@test(eq, {
		#Root: {sub1?: {#sub2?: bool}}
		root: {sub1?: {#sub2: true}}
	})
}
issue3729: withoutDisjunction: {
