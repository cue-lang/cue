    }
    withFor: {
      try x = 〈2;b〉? for i, v in [
        1,
        2,
      ] {
        "\(〈1;i〉)": (〈2;x〉 + 〈1;v〉)
      }
    }
    withIf: {
      try x = 〈2;a〉? if (〈0;x〉 > 0) {
        positive: 〈1;x〉
      }
    }
    withLet: {
      try x = 〈2;a〉? let y = (〈0;x〉 * 2) {
        doubled: 〈1;y〉
      }
    }
  }
  recursive: {
    t1: {
      try {
        for _, x in [
          〈4;b〉?,
        ] {
          〈1;x〉
        }
      }
    }
  }
  recursive: {
    t2: {
      try {
        {
          x: 〈4;b〉?
          y: 〈4;c〉?
        }
      }
    }
  }
  recursive: {
    t3: {
      try {
        {
          x: 〈4;b〉?
          y: 〈4;c〉?
        }
      } else {
        z: 23
      }
    }
  }
}
