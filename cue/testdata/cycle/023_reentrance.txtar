  fibRec: {
    nn: int
    out: (〈1;fib〉 & {
      n: 〈1;nn〉
    }).out
  }
  fib: {
    n: int
    if (〈0;n〉 >= 2) {
      out: ((〈2;fibRec〉 & {
        nn: (〈2;n〉 - 2)
      }).out + (〈2;fibRec〉 & {
        nn: (〈2;n〉 - 1)
      }).out)
    }
    if (〈0;n〉 < 2) {
      out: 〈1;n〉
    }
  }
  fib1: (〈0;fib〉 & {
    n: 1
  }).out
  fib2: (〈0;fib〉 & {
    n: 2
  }).out
  fib3: (〈0;fib〉 & {
    n: 3
  }).out
  fib7: (〈0;fib〉 & {
