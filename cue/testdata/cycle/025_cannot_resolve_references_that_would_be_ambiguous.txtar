#name: cannot resolve references that would be ambiguous
#evalFull
-- in.cue --
a1: *0 | 1
a1: a3 - a2 @test(err, code=cycle, pos=[2:10])
a2: *0 | 1
a2: a3 - a1 @test(err, code=cycle, pos=[0:10])
a3: 1 @test(eq, 1)

b1: (*0 | 1) & b2 @test(eq, 0|1)
b2: (0 | *1) & b1 @test(eq, 0|1)

c1: (*{a: 1} | {b: 1}) & c2 @test(eq, {a: 1, b: 2} | {b: 1, a: 2})
c2: (*{a: 2} | {b: 2}) & c1 @test(eq, {a: 2, b: 1} | {b: 2, a: 1})
-- out/errors.txt --
[cycle] a1: cycle with field: a2:
    ./in.cue:2:10
a1: 2 errors in empty disjunction::
    ./in.cue:4:10
a2: unresolved disjunction: a1:
    ./in.cue:4:10
[cycle] a1: cycle with field: a2:
    ./in.cue:2:10
a1: 2 errors in empty disjunction::
    ./in.cue:4:10
a2: unresolved disjunction: a1:
    ./in.cue:4:10
-- out/compile --
--- in.cue
{
  a1: (*0|1)
  a1: (〈0;a3〉 - 〈0;a2〉)
  a2: (*0|1)
  a2: (〈0;a3〉 - 〈0;a1〉)
  a3: 1
  b1: ((*0|1) & 〈0;b2〉)
  b2: ((0|*1) & 〈0;b1〉)
  c1: ((*{
    a: 1
  }|{
    b: 1
  }) & 〈0;c2〉)
  c2: ((*{
    a: 2
  }|{
    b: 2
  }) & 〈0;c1〉)
}
