#name: self-reference cycles conflicts with strings
#evalPartial
-- in.cue --
a: {
	x: y + "?"
	y: x + "!" @test(eq, "hey!")
}
a: x: "hey" @test(err, code=eval, contains="conflicting values", pos=[-3:5, 0:7])
-- out/errors.txt --
[eval] a.x: conflicting values "hey!?" and "hey":
    ./in.cue:2:5
    ./in.cue:5:7
-- out/compile --
--- in.cue
{
  a: {
    x: (〈0;y〉 + "?")
    y: (〈0;x〉 + "!")
  }
  a: {
    x: "hey"
  }
}
