# Tests that chaining existing fields through comprehensions and builtins does
# not trigger spurious cycle detection errors.
-- in.cue --
import "list"

// The following just chains existing fields and should NOT trigger a cycle
// detection error.


chain: t1: {
	#maxiter: 2

	// Trigger lookup of a.x0 before the "regular" evaluation of a.
	x: a.x0

	a: {
		for k, _ in [0, 1] {
			"x\(k)": (#DepthF & {#in: a["x\(k+1)"]}).#out
		}
	}

	a: x2: null


	#DepthF: {
		#in: _
		#out: {}
	}
	@test(eq, {
		#maxiter: 2
		x: {}
		a: {x2: null, x0: {}, x1: {}}
		#DepthF: {#in: _, #out: {}}
	})
}

chain: t2: p1: {
	X: 1

	// Reference X through x.x0 before X is inserted.
	for v in list.Concat([[0, X], []]) {
		x: "x\(v)": {}
	}

	x: _

	x.x0
	@test(eq, {X: 1, x: {x0: {}, x1: {}}})
}

chain: t2: p2: {
	// Reference X through x.x0 before X is inserted.
	for v in list.Concat([[0, X], []]) {
		x: "x\(v)": {}
	}

	x: _

	x.x0

	X: 1
	@test(eq, {x: {x0: {}, x1: {}}, X: 1})
}

chain: t3: p1: {
	X: 1

	for v in list.Range(0, X, 1) {
		x: "x\(v)": {}
	}

	x: _

	x.x0
}

chain: t3: p1: {
	for v in list.Range(0, X, 1) {
		x: "x\(v)": {}
	}

	x: _

	x.x0

	X: 1
	@test(eq, {X: 1, x: {x0: {}}})
}

-- issue2052.cue --
// Bounded recursion regression: a pattern that evaluated correctly in v0.4.3
// began failing in v0.5.0-alpha.1 with spurious unbounded recursion errors.
// https://cuelang.org/issue/2052
import (
	"list"
	"math"
)
issue2052: reduced: t1: {
	A: a: _
	Depth: {
		#maxiter: 1
		if math.Abs(#maxiter) == 1 {
			funcs: "\(0)": A
		}
		funcs: {}
		funcs["0"]
	}
	@test(eq, {
		A: {a: _}
		Depth: {
			#maxiter: 1
			funcs: {"0": {a: _}}
			a: _
		}
	})
}
issue2052: reduced: t2: {
	A: a: _
	Depth: {
		maxiter: 1
		for k, v in list.Range(0, maxiter, 1) {
			funcs: "\(0)": A
		}
		funcs: {}
		funcs["0"]
	}
	@test(eq, {
		A: {a: _}
		Depth: {maxiter: 1, funcs: {"0": {a: _}}, a: _}
	})
}
issue2052: medium: t1: {
	#Depth: {
		#maxiter: 4

		for k, v in list.Range(0, #maxiter, 1) {
			#funcs: "\(k)": (#DepthF & {#next: #funcs["\(k+1)"]}).#func
		}

		#funcs: "\(#maxiter)": null

		#funcs["0"]
	}

	#DepthF: {
		#next: _
		#func: {
			#in:    _
			#basic: string | null
			out: {
				if (#in & #basic) != _|_ {1}
				if (#in & #basic) == _|_ {
					list.Max([for k, v in #in {(#next & {#in: v}).out}]) + 1
				}
			}
		}
	}

	tree: "bar"

	d: #Depth & {#in: tree}

	@test(eq, {
		#Depth: {
			#maxiter: 4
			#funcs: {
				"4": null
				"0": {#in: _, #basic: string | null, out: 1}
				"1": {#in: _, #basic: string | null, out: 1}
				"2": {#in: _, #basic: string | null, out: 1}
				"3": {#in: _, #basic: string | null, out: 1}
			}
			#in: _
			#basic: string | null
			out: 1
		}
		#DepthF: {
			#next: _
			#func: {#in: _, #basic: string | null, out: 1}
		}
		tree: "bar"
		d: {
			#in: "bar"
			#maxiter: 4
			#funcs: {
				"4": null
				"0": {#in: _, #basic: string | null, out: 1}
				"1": {#in: _, #basic: string | null, out: 1}
				"2": {#in: _, #basic: string | null, out: 1}
				"3": {#in: _, #basic: string | null, out: 1}
			}
			#basic: string | null
			out: 1
		}
	})
}

