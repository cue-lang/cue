// Issues: #667, #695, #622

// Comparing against bottom is not officially supported by the spec.
// In practice it is used for a variety of purposes.
//
// TODO: It should really be replaced with two builtins:
//
//    - exists(reference): check if a certain field exists.
//    - isvalid(value):    check if a certain value is valid (recursively).
//
// For now it implements something in between these two: it fails if a value
// resolves to an error, but not necessarily if it does so recursively.
// Although adding a recursive check is easy, it will break existing
// configurations, as a recursive evaluation will trigger cycles where these
// are perhaps not expected.

// To verify these tests, each result should have a field
//
//     X: "user@example.com"
//
// for the large and medium examples and
//
//     X: "message: hello"
//
// for the simple example.
//
// Each test exists in two forms:
//   - <name>A uses the legacy `X != _|_` / `X == _|_` comparison.
//   - <name>B uses the new exists() builtin.
-- in.cue --
@experiment(reflect)
import "regexp"

simple: {
	#message: #"^(message: (?P<message>.*))?$"#

	p1a: {
		@test(permute, count=24)

		X: "message: hello"
		#aux: {
			if Y.message == _|_ {
				message: ""
			}
			if Y.message != _|_ {
				message: "message: " + Y.message
			}
		}

		Y: regexp.FindNamedSubmatch(#message, X)
		X: #aux.message
		@test(eq, {
			X: "message: hello"
			#aux: {message: "message: hello"}
			Y: {message: "hello"}
		})
	}
	p1b: {
		@test(permute, count=24)

		X: "message: hello"
		#aux: {
			if !exists(Y.message) {
				message: ""
			}
			if exists(Y.message) {
				message: "message: " + Y.message
			}
		}

		Y: regexp.FindNamedSubmatch(#message, X)
		X: #aux.message
		// TODO: does not handle postChecks properly across calls.
		@test(eq:todo, {
			X: "message: hello"
			#aux: {message: "message: hello"}
			Y: {message: "hello"}
		})
	}
}

mediumA: {
	#userHostPort: #"^((?P<userinfo>[[:alnum:]]*)@)?(?P<host>[[:alnum:].]+)$"#

	p1: {
		@test(permute, count=120)

		Y: {
			userinfo: "user"
			host:     "mod.test"
		}

		X: #X.userinfo + #X.host

		#X: {
			if Y.userinfo == _|_ {
				userinfo: ""
			}
			if Y.userinfo != _|_ {
				userinfo: Y.userinfo + "@"
			}

			host: Y.host
		}

		Y: {
			if #Y.userinfo != _|_ {
				userinfo: #Y.userinfo
			}

			host: #Y.host
		}

		#Y: regexp.FindNamedSubmatch(#userHostPort, X)
		@test(eq, {
			Y: {userinfo: "user", host: "mod.test"}
			X: "user@mod.test"
			#X: {userinfo: "user@", host: "mod.test"}
			#Y: {host: "mod.test", userinfo: "user"}
		})
	}
}
mediumB: {
	#userHostPort: #"^((?P<userinfo>[[:alnum:]]*)@)?(?P<host>[[:alnum:].]+)$"#

	p1: {
		@test(permute, count=120)

		Y: {
			userinfo: "user"
			host:     "mod.test"
		}

		X: #X.userinfo + #X.host

		#X: {
			if !exists(Y.userinfo) {
				userinfo: ""
			}
			if exists(Y.userinfo) {
				userinfo: Y.userinfo + "@"
			}

			host: Y.host
		}

		Y: {
			if exists(#Y.userinfo) {
				userinfo: #Y.userinfo
			}

			host: #Y.host
		}

		#Y: regexp.FindNamedSubmatch(#userHostPort, X)
		// TODO: does not handle postChecks properly across calls.
		@test(eq:todo, {
			Y: {userinfo: "user", host: "mod.test"}
			X: "user@mod.test"
			#X: {userinfo: "user@", host: "mod.test"}
			#Y: {host: "mod.test", userinfo: "user"}
		})
	}
}
-- out/eval/stats --
