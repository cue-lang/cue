-- issue3836.cue --
// evalv3 regression: a conditional checking `(foo | bar) == _|_` (comparison
// to bottom) stopped working; the branch that fires when no optional field is
// set no longer triggers correctly.
// https://cuelang.org/issue/3836
issue3836: hidden: {
	_Value: {
		foo?: _
		bar?: _
		if (foo | bar) == _|_ {
			bar: type: "bar"
		}
		out: [if bar != _|_ {"bar is set"}]
	}
	_Value.out
	@test(eq, {_Value: {foo?: _, bar?: {}, out: []}, []})
}
issue3836: exposed: {
	foo?: _
	bar?: _
	if (foo | bar) == _|_ {
		bar: type: "bar"
	}
	out: [if bar != _|_ {"bar is set"}]
	@test(err, code=cycle, contains="circular dependency in evaluation of conditionals: %v changed after evaluation", args=[(foo|bar)], pos=[3:6])
}
-- issue3838.cue --
// evalv3 regression: `if in.opt != _|_` inside a list expression stopped
// evaluating correctly; evalv2 exported cleanly but evalv3 produced wrong output.
// https://cuelang.org/issue/3838
issue3838: {
	#T: {
		subject: {
			in: opt?: foo: int
			out: [
				if in.opt != _|_ {in.opt.foo},
				0,
			][0]
		}
		_test: {
			assert: {
				pass: bool
			}
			assert: {
				notOk: _
				pass:  false
			} | {
				invoke: _
				res:    subject.out
				pass:   true
			}
		}
		results: _test.assert.pass
	}
	(#T & {
		_test: assert: invoke: "foo"
	}).results
	@test(eq, {
		true
		#T: {
			subject: {in: {opt?: {foo: int}}, out: 0}
			_test: {
				assert: {pass: false, notOk: _} | {pass: true, invoke: _, res: 0}
			}
			results: _|_ @test(err, code=incomplete, contains="issue3838.#T.results: unresolved disjunction {pass:false,notOk:_} | {pass:true,invoke:_,res:0} (type struct)", pos=[26:12])
		}
	})
}
