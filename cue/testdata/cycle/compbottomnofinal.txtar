// Issues: #667, #695, #622
-- in.cue --
import (
	"strconv"
	"regexp"
)

// In these test, it is impossible to determine the existence of some arcs due
// to mutual dependence on becoming concrete.
//
// This tests shows the essences of when an existence check cannot be resolved.
minimal: {
	a: {
		if b.port == _|_ {
			port: ""
		}
		@test(err, code=incomplete, path=port, contains="cyclic reference to field %[1]v", args=[port], pos=[1:3])
	}

	b: {
		if a.port == _|_ {
			port: ""
		}
		@test(err, code=incomplete, path=port, contains="cyclic reference to field %[1]v", args=[port], pos=[1:3])
	}
}

small: {
	#userHostPort: #"^(:(?P<port>\d+))?$"#

	p1: {
		@test(permute)
		@test(permuteCount, 2)
		#Y: regexp.FindNamedSubmatch(#userHostPort, #X.port)

		#X: {
			if #Y.port == _|_ {
				port: ""
			}
			if #Y.port != _|_ {
				port: ":" + strconv.FormatInt(#Y.port, 10)
			}
		}
		@test(eq, {
			#Y: _|_ @test(err, code=incomplete, contains="#Y: undefined field: port", pos=[32:50])
			#X: _|_ @test(err, code=incomplete, contains="#X.port: cyclic reference to field port", pos=[35:4])
		})
	}
}

medium: {
	#userHostPort: #"^(:(?P<port>\d+))?$"#

	p1: {
		@test(permute)
		@test(permuteCount, 6)

		#Y: regexp.FindNamedSubmatch(#userHostPort, #X.port)

		Y: {
			if #Y.port != _|_ {
				port: strconv.Atoi(#Y.port)
			}
		}

		#X: {
			// Can never determine whether Y.port exists as its resolution
			// depends on #Y becoming finalized, which, in turn, depends on #X
			// becoming finalized.
			if Y.port == _|_ {
				port: ""
			}
			if Y.port != _|_ {
				port: ":" + strconv.FormatInt(Y.port, 10)
			}
		}
		@test(eq, {
			#Y: _|_ @test(err, code=incomplete, contains="medium.p1.#Y: undefined field: port", pos=[56:50])
			Y: {}
			#X: _|_ @test(err, code=incomplete, contains="medium.p1.#X.port: cyclic reference to field port", pos=[68:4])
		})
	}
}

large: {
	#userHostPort: #"^((?P<userinfo>[[:alnum:]]*)@)?(?P<host>[[:alnum:].]+)(:(?P<port>\d+))?$"#

	p1: {
		@test(permute)
		@test(permuteCount, 120)

		Y: {
			userinfo: "user"
			host:     "mod.test"
		}

		X: #X.userinfo + #X.host + #X.port

		#X: {
			if Y.userinfo == _|_ {
				userinfo: ""
			}
			if Y.userinfo != _|_ {
				userinfo: Y.userinfo + "@"
			}

			host: Y.host

			if Y.port == _|_ {
				port: ""
			}
			if Y.port != _|_ {
				port: ":" + strconv.FormatInt(Y.port, 10)
			}
		}

		Y: {
			if #Y.userinfo != _|_ {
				userinfo: #Y.userinfo
			}

			host: #Y.host

			if #Y.port != _|_ {
				port: strconv.Atoi(#Y.port)
			}
		}

		#Y: regexp.FindNamedSubmatch(#userHostPort, X)
		@test(eq, {
			Y: {
				userinfo: "user"
				host: _|_ @test(err, code=incomplete, contains="large.p1.Y.host: undefined field: host", pos=[120:13])
			}
			X: _|_ @test(err, code=incomplete, contains="large.p1.X: undefined field: port", pos=[95:33])
			#X: {
				_|_
				userinfo: "user@"
				host: "mod.test"
			}
			#Y: _|_ @test(err, code=incomplete, contains="large.p1.X: undefined field: port", pos=[95:33])
		})
	}
}
-- out/errors.txt --
[incomplete] minimal.a.port: cyclic reference to field port:
    ./in.cue:12:3
[incomplete] minimal.b.port: cyclic reference to field port:
    ./in.cue:19:3
[incomplete] small.p1.#Y: undefined field: port:
    ./in.cue:32:50
[incomplete] small.p1.#X.port: cyclic reference to field port:
    ./in.cue:35:4
[incomplete] medium.p1.#Y: undefined field: port:
    ./in.cue:56:50
[incomplete] medium.p1.#X.port: cyclic reference to field port:
    ./in.cue:68:4
[incomplete] large.p1.Y.host: undefined field: host:
    ./in.cue:120:13
[incomplete] large.p1.X: undefined field: port:
    ./in.cue:95:33
[incomplete] large.p1.#X.port: cyclic reference to field port:
    ./in.cue:107:4
[incomplete] large.p1.X: undefined field: port:
    ./in.cue:95:33
-- out/todo.txt --
minimal.a/b: different error code in v2 (cycle) and v3 (incomplete).
small.p1: v2 #Y succeeds with port="", v3 #Y errors; error codes differ.
medium.p1/p2: v2 #X/#Y succeed with port="", v3 all error with incomplete.
medium.p3-p6: similar changes from cycle (v2) to incomplete (v3).
large.p1-p4: similar changes from cycle (v2) to incomplete (v3).
