// Issues: #667, #695, #622
//
// Each top-level test exists in two forms:
//   - <name>A uses the legacy `X != _|_` / `X == _|_` comparison.
//   - <name>B uses the new exists() builtin.
// Both forms exercise the same cycle scenarios and must reach the same
// resolution outcomes so the new builtin keeps the historical behavior.
-- in.cue --
@experiment(reflect)
import (
	"strconv"
	"regexp"
)

// In these test, it is impossible to determine the existence of some arcs due
// to mutual dependence on becoming concrete.
//
// This tests shows the essences of when an existence check cannot be resolved.
minimal: {
	a: {
		if b.port == _|_ {
			port: ""
		}
		// Pushdown produces cycle error instead of incomplete.
		@test(err, code=cycle|incomplete)
	}

	b: {
		if a.port == _|_ {
			port: ""
		}
		// Pushdown produces cycle error instead of incomplete.
		@test(err, code=cycle|incomplete)
	}

	ra: {
		if !exists(b.port) {
			port: ""
		}
		@test(err, code=cycle|incomplete)
	}

	rb: {
		if !exists(a.port) {
			port: ""
		}
		@test(err, code=cycle|incomplete)
	}
}

smallA: {
	#userHostPort: #"^(:(?P<port>\d+))?$"#

	p1a: {
		@test(permute, count=2)
		#Y: regexp.FindNamedSubmatch(#userHostPort, #X.port)

		#X: {
			if #Y.port == _|_ {
				port: ""
			}
			if #Y.port != _|_ {
				port: ":" + strconv.FormatInt(#Y.port, 10)
			}
		}
		// Yield-on-running heuristic: the comp's referenced node
		// #Y is not currently being processed (only scheduled), so
		// the comp does not yield and instead reports a cycle error.
		@test(eq, {
			#Y: _|_ @test(err, code=cycle|incomplete)
			#X: _|_ @test(err, code=cycle|incomplete)
		})
	}

	p1b: {
		@test(permute, count=2)
		#Y: regexp.FindNamedSubmatch(#userHostPort, #X.port) @test(err, any, code=cycle|incomplete)

		#X: {
			if !exists(#Y.port) {
				port: ""
			}
			if exists(#Y.port) {
				port: ":" + strconv.FormatInt(#Y.port, 10)
			}
		} @test(err, any, code=cycle|incomplete)
	}
}

medium: {
	#userHostPort: #"^(:(?P<port>\d+))?$"#

	p1a: {
		@test(permute, count=6)

		#Y: regexp.FindNamedSubmatch(#userHostPort, #X.port) @test(err, code=incomplete|cycle)

		// Yield-on-running heuristic: the comp's referenced node Y
		// is not currently being processed, so the comp does not
		// yield and instead reports a cycle error.

		Y: {
			if #Y.port != _|_ {
				port: strconv.Atoi(#Y.port)
			}
		} @test(err, code=incomplete|cycle)

		#X: {
			// Can never determine whether Y.port exists as its resolution
			// depends on #Y becoming finalized, which, in turn, depends on #X
			// becoming finalized.
			if Y.port == _|_ {
				port: ""
			}
			if Y.port != _|_ {
				port: ":" + strconv.FormatInt(Y.port, 10)
			}
		} @test(err, code=incomplete|cycle)
	}


	p1b: {
		@test(permute, count=6)
		#Y: regexp.FindNamedSubmatch(#userHostPort, #X.port) @test(err, any, code=incomplete|cycle)

		Y: {
			if exists(#Y.port) {
				port: strconv.Atoi(#Y.port)
			}
		} @test(err, any, code=incomplete|cycle)

		#X: {
			if !exists(Y.port) {
				port: ""
			}
			if exists(Y.port) {
				port: ":" + strconv.FormatInt(Y.port, 10)
			}
		} @test(err, any, code=incomplete|cycle)
	}
}

large: {
	#userHostPort: #"^((?P<userinfo>[[:alnum:]]*)@)?(?P<host>[[:alnum:].]+)(:(?P<port>\d+))?$"#

	p1a: {
		@test(permute, count=120)

		Y: {
			userinfo: "user"
			host:     "mod.test"
		}

		X: #X.userinfo + #X.host + #X.port @test(err, any, code=incomplete|cycle)

		#X: {
			if Y.userinfo == _|_ {
				userinfo: ""
			}
			if Y.userinfo != _|_ {
				userinfo: Y.userinfo + "@"
			}

			host: Y.host

			if Y.port == _|_ {
				port: ""
			}
			if Y.port != _|_ {
				port: ":" + strconv.FormatInt(Y.port, 10)
			}
		} @test(err, any, code=incomplete|cycle)

		Y: {
			if #Y.userinfo != _|_ {
				userinfo: #Y.userinfo
			}

			host: #Y.host

			if #Y.port != _|_ {
				port: strconv.Atoi(#Y.port)
			}
		} @test(err, any, code=incomplete|cycle)

		#Y: regexp.FindNamedSubmatch(#userHostPort, X) @test(err, any, code=incomplete|cycle)
	}

	p1b: {
		@test(permute, count=120)

		Y: {
			userinfo: "user"
			host:     "mod.test"
		}

		X: #X.userinfo + #X.host + #X.port @test(err, any, code=incomplete|cycle)

		#X: {
			if !exists(Y.userinfo) {
				userinfo: ""
			}
			if exists(Y.userinfo) {
				userinfo: Y.userinfo + "@"
			}

			host: Y.host

			if !exists(Y.port) {
				port: ""
			}
			if exists(Y.port) {
				port: ":" + strconv.FormatInt(Y.port, 10)
			}
		} @test(err, any, code=incomplete|cycle)

		Y: {
			if exists(#Y.userinfo) {
				userinfo: #Y.userinfo
			}

			host: #Y.host

			if exists(#Y.port) {
				port: strconv.Atoi(#Y.port)
			}
		} @test(err, any, code=incomplete|cycle)

		#Y: regexp.FindNamedSubmatch(#userHostPort, X) @test(err, any, code=incomplete|cycle)
	}
}
