(struct){
  #Value: (int){ |((int){ 0 }, (int){ 1 }) }
  foo: (_|_){
    // [cycle] foo: cycle across unresolved disjunction referenced by bar:
    //     ./in.cue:1:13
    //     ./in.cue:5:6
    //     ./in.cue:6:6
  }
  bar: (int){ |((int){ 0 }, (int){ 1 }) }
  Foo: (int){ 1 }
  Bar: (int){ 0 }
  cell: (struct){
    a: (int){ 0 }
    b: (int){ 1 }
  }
  a: (int){ 0 }
  b: (int){ 1 }
}
