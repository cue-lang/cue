# `!=` applied to a disjunction before structural cycle is concrete:
# CUE incorrectly reports an empty disjunction error instead of handling
# the abstract `!=` constraint between fields sharing a disjunction type.
# https://cuelang.org/issue/241
#todo:inline: hard — cycle semantics require @test(err, code=cycle) and careful scoping
-- in.cue --
#Value: 0 | 1

foo: #Value
foo: !=bar
bar: #Value
bar: !=foo

#Value: 0 | 1

Foo: #Value
Foo: !=Bar
Bar: #Value
Bar: !=Foo
Bar: 0

cell: a: 0 | 1
cell: a: !=cell.b
cell: b: 0 | 1
cell: b: !=cell.a
cell: a: 0
cell: b: _

a: cell.a
b: cell.b
