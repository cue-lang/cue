{
  #Value: (0|1)
  foo: 〈0;#Value〉
  foo: !=〈0;bar〉
  bar: 〈0;#Value〉
  bar: !=〈0;foo〉
  #Value: (0|1)
  Foo: 〈0;#Value〉
  Foo: !=〈0;Bar〉
  Bar: 〈0;#Value〉
  Bar: !=〈0;Foo〉
  Bar: 0
  cell: {
    a: (0|1)
  }
  cell: {
    a: !=〈1;cell〉.b
  }
  cell: {
    b: (0|1)
  }
  cell: {
    b: !=〈1;cell〉.a
  }
  cell: {
    a: 0
  }
  cell: {
    b: _
  }
  a: 〈0;cell〉.a
  b: 〈0;cell〉.b
}
