# The evaluator enters an infinite loop when processing a cycle involving
# struct embeddings, causing `cue eval` to hang indefinitely.
# https://cuelang.org/issue/2526
-- in.cue --
x
x: {
	y
	y: x
}
@test(err, code=structural_cycle, path=x.y, contains="structural cycle", pos=[])
-- out/errors.txt --
[structural_cycle] x.y: structural cycle
-- out/compile --
--- in.cue
{
  〈0;x〉
  x: {
    〈0;y〉
    y: 〈1;x〉
  }
}