# Structural recursion that used to loop forever now reports a structural cycle.
# https://cuelang.org/issue/3364
-- in.cue --
out: _t3.out @test(err, code=structural_cycle, path=_t3.out.a.a, contains="structural cycle", pos=[])
_t3: {
	repeater: L={L.a}
	data: M={a: a: M}
	out: repeater & data
}
-- out/errors.txt --
[incomplete] _t3.repeater: undefined field: a:
    ./in.cue:3:17
[structural_cycle] _t3.data.a.a: structural cycle
[structural_cycle] _t3.out.a.a: structural cycle
