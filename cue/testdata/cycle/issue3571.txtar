-- out/todo.txt --
v2 expands all structure-shared fields inline (no ~() references), while v3
uses structure sharing (~(path) notation) for fields that share the same
underlying vertex. Specifically, in `simplified`, v2 expands `in` and `x`
with their full #T contents, while v3 represents them as ~(simplified.#T).
Similarly in `issue3571.a`, v2 expands `in` and `#in` fully, while v3 uses
shared references like ~(issue3571.a.in.g.#in) and ~(issue3571.a.#in.g.#in).
-- out/compile --
--- in.cue
{
  simplified: {
    〈0;#T〉
    in: _
    x: 〈0;#T〉
    x: {
      x: 〈1;#T〉
    }
    #T: {
      in: 〈0;x〉
      x: _
    }
  }
  issue3571: {
    a: 〈0;#T〉
    a: {
      in: {
        f: true
      }
    }
    a: {
      #in: {
        g: 〈2;#T〉
        g: {
          #in: {
            f: 〈4;#T〉
          }
        }
        g: {
          #in: {
            f: {
              #in: {
                x: true
              }
            }
          }
        }
        f?: _
      }
    }
    #T: {
      in: 〈0;#in〉
      #in: _
    }
  }
}
