# The new evaluator (v3) produces empty output for `or(["eu-west-1", "us-east-1"])`
# when used inside a self-referential struct, while the old evaluator produces the
# correct result. Replacing `or([...])` with a plain disjunction `"a" | "b"` works
# correctly. The root cause: calls with only literal arguments were incorrectly
# deferred when evaluated from within a cyclic context, resulting in empty output.
# https://cuelang.org/issue/4230
-- in.cue --
#transform: {
	_input: {...}
	_output: [
		if _input.app != _|_ {
			_input.app.region
		},
	]
}

x: X={
	regions: (#transform & {_input: X})._output
	app: region: or(["west", "east"]) & "west"
} @test(eq, {
	regions: ["west"]
	app: {region: "west"}
})
-- out/eval/stats --
Leaks:  3
Freed:  36
Reused: 21
Allocs: 18
Retain: 0

Unifications: 19
Conjuncts:    56
Disjuncts:    12

