# Original repro from the issue: a cross-package shape where a comprehension
# iterator passes through an inline conjunction (`({shared: _} & imported)`),
# the body cycles through json.Marshal(this) inside #Name, and the OUT list
# guards on `if IN.x != _|_`. Under dependency-tracking pushdown the inline
# vertex's reclaim freed an in-progress descendant, surfacing as spurious
# `shared.prefix: conflicting values "" and "foo-"` errors and an
# `encoding/json.Marshal: ... nil pointer dereference` chain.
#
# After the fix this evaluates without errors; result[0] and result[1] are
# both `{name: "foo-", x: [{ref: "foo-"}]}`.
#
# https://cuelang.org/issue/4365
-- cue.mod/module.cue --
module: "m.test"
language: version: "v0.15.0"
-- main.cue --
package main

import "m.test/imported"

// Pre-fix: spurious `shared.prefix: conflicting values "" and "foo-"` plus
// a nil-pointer dereference in encoding/json.Marshal.
result: ({shared: _} & imported).export @test(eq, [
	{name: "foo-", x: [{ref: "foo-"}]},
	{name: "foo-", x: [{ref: "foo-"}]},
])
-- imported/imported.cue --
package imported

import "encoding/json"

shared: prefix: string | *""
shared: prefix: "foo-"

#Name: this={
	name: shared.prefix + (#h & {in: json.Marshal(this)}).out
	...
}

#h: {
	in:  string
	out: ""
}

_in: #Name & {x: [{ref: _in.name}]}

_g: {
	IN: _in
	OUT: [
		if IN.x != _|_
		for _ in IN.x {_in},
	]
}

export: [_in, for o in _g.OUT {o}]
