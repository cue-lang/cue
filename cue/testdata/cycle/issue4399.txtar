# A pattern label using or() over a cyclic reference regressed with spurious
# "conflicting values" errors when close() inserts a non-matching field (other)
# first. Matching the pattern forces the cyclic chain while cue's field set is
# not yet frozen, so the for-comprehension iterates a partial view and the
# lazily-returned or() disjunction finalized to a fatal conflict that never
# re-evaluated once the field set completed. Residual of #4397.
-- in.cue --
cue: {
	[or(tags.cue.modules)]: y: {}
}

tags: "cue": [_]: [...or([for command, _ in cue {command}])]
tags: cue: modules: ["login", "mod"]

cue: close({
	other: {} // not a member of tags.cue.modules, positioned first
	login: _
	mod:   _
})

result: {"cue": cue, "tags": tags} @test(eq, {
	cue: {other: {}, login: {y: {}}, mod: {y: {}}}
	tags: {cue: {modules: ["login", "mod"]}}
})
