-- in.cue --
@experiment(aliasv2)

import "list"

expr: error1: {
	a: 3
	a: a + 1
	@test(err, code=eval, path=a, contains="conflicting values %s and %s", args=[4, 3], pos=[1:5, 2:5])
}
expr: error2: {
	a: a + 1
	a: 3
	@test(err, code=eval, path=a, contains="conflicting values %s and %s", args=[4, 3], pos=[1:5, 2:5])
}
listConcat: error1: {
	a: ["1", "2"]
	a: list.Concat([a, ["3"]])
	@test(err, code=structural cycle, path=a, contains="error in call to %s", args=[list.Concat], pos=[2:5])
}

listConcat: error2: {
	a: list.Concat([["3"], a])
	a: ["1", "2"]
	@test(err, code=structural cycle, path=a, contains="error in call to %s", args=[list.Concat], pos=[1:5])
}

selfEmbed: ok1: {
	a: x
	Y: x
	x: {Y}
	@test(eq, {a: {}, Y: {}, x: {}})
}

selfEmbed: ok2: {
	Y: x.b
	a: x
	x: b: {Y}
	@test(eq, {Y: {}, a: {b: {}}, x: {b: {}}})
}

selfEmbed: ok3: {
	Y: x
	a: x
	x: {Y}
	@test(eq, {Y: {}, a: {}, x: {}})
}

selfEmbed: ok4: {
	a: x
	x: {Y}
	Y: x
	@test(eq, {a: {}, x: {}, Y: {}})
}

selfEmbed: ok5: {
	x: {Y}
	a: x
	Y: x
	@test(eq, {x: {}, a: {}, Y: {}})
}

selfEmbed: ok6: {
	x: b: {Y}
	Y: x.b
	a: x
	@test(eq, {x: {b: {}}, Y: {}, a: {b: {}}})
}


disjSelf: ok1: {
	#A: string | #A
	x: #A
	@test(eq, {#A: string | _, x: string | _})
}

disjSelf: ok2: {
	x: #A
	#A: string | #A
	@test(eq, {x: string | _, #A: string | _})
}

disjSelf: ok3: {
	#A: #A | string
	x: #A
	@test(eq, {#A: _ | string, x: _ | string})
}

disjSelf: ok4: {
	x: #A
	#A: #A | string
	@test(eq, {x: _ | string, #A: _ | string})
}

disjEmbed: ok1: {
	#A: string | {#A}
	x: #A
	@test(eq, {#A: string | {}, x: string | {}})
}

disjEmbed: ok2: {
	x: #A
	#A: string | {#A}
	@test(eq, {x: string | {}, #A: string | {}})
}

disjEmbed: ok3: {
	#A: {#A} | string
	x: #A
	@test(eq, {#A: {} | string, x: {} | string})
}

disjEmbed: ok4: {
	x: #A
	#A: {#A} | string
	@test(eq, {x: {} | string, #A: {} | string})
}

// x and #A should yield the same result.
disjList: _
disjList: ok1: {
	#A: string | [#A]
	x: #A

	y: x
	y: [[[[string]]]]
	@test(eq, {
		#A: string
		x: string
		y: [[[[string]]]]
	})
}

disjList: ok2: {
	x: #A
	#A: string | [#A]
	@test(eq, {x: string, #A: string})
}

disjList: ok3: {
	#A: [#A] | string
	x: #A
	@test(eq, {#A: string, x: string})
}

disjList: ok4: {
	x: #A
	#A: [#A] | string
	@test(eq, {x: string, #A: string})
}

