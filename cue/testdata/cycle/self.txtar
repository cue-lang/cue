// Issue #1729
issue1729: t1: {
	#x: { #x | {} }
	x: #x & {}
	@test(eq, {#x: {}, x: {}})
}

issue1729: t2: {
	x: #x & {}
	#x: { #x | {} }
	@test(eq, {x: {}, #x: {}})
}

-- selfnew.cue --
@experiment(aliasv2)

issue4125: t1_self: {
	let Root = self
	a: Root.a
	@test(eq, {a: _})
}
-- selfold.cue --
issue4125: t2_alias: X={
	let Y = X
	b: Y.b
	@test(eq, {b: _})
}

