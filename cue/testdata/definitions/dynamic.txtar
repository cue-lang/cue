	(a.b): "foo"
	(x.hello): "true"
	a: b: "hello"

	@test(eq, {a: b: "hello", hello: "foo"}, incorrect, hint="shouldn't foo be in here?")
	@test(eq:todo, {a: b: "hello", hello: "foo", foo: "true"})
}
