-- in.cue --
#A: {
	a:      "foo"
	"\(a)": 3

	@test(eq, {
		a:   "foo"
		foo: 3
	})
}
#B: a: b: {
	c: string
	d: 2
} @test(eq, {
	c: string
	d: 2
})

#C: a: b: {
	c: *"d" | string
	(c): 2
} @test(eq, {
	c: *"d" | string
	d: 2
})

x: #B & #C @test(eq, {
	a: b: {
		c: *"d" | string
		d: 2
	}
})

-- evalv3regress.cue --
chained: x: {
	// TODO: add this once the todo is fixed.
