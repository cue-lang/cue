// Treat fields of different files as belonging to the same struct.
// This means that a closed embedding in one file should not restrict the
// fields of another.
#todo:inline: medium — disjunctions; use @test(final) for default selection
-- in.cue --
package foo

#theme: {
	color:   string
	ctermbg: string
}
dark: #theme & {
	color:   "dark"
	ctermbg: "239"
}
light: #theme & {
	color:   "light"
	ctermbg: "254"
}
#Config: {
	console: dark | *light
}
-- box.cue --
package foo

#Config & {
	console: dark
}
