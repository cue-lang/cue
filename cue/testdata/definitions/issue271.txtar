# Tests that a struct combining an open pattern constraint with close() correctly
# rejects fields not allowed by the close() constraint when unified with a value.
# https://cuelang.org/issue/271
#todo:inline: medium — definitions with closedness; check @test(closed) support
-- in.cue --
#T: [_]: _
#T: close({"a": string})
x:  #T
x: {
	a: "hello"
	b: "foo"
}
-- out/eval/stats --
Leaks:  0
Freed:  14
Reused: 5
Allocs: 9
Retain: 0

Unifications: 10
Conjuncts:    20
Disjuncts:    0

NumCloseIDs: 3
-- out/evalalpha --
Errors:
x.b: field not allowed:
    ./in.cue:1:5
    ./in.cue:6:2

Result:
(_|_){
  // [eval]
  #T: (#struct){
    a: (string){ string }
  }
  x: (_|_){
    // [eval]
    a: (string){ "hello" }
    b: (_|_){
      // [eval] x.b: field not allowed:
      //     ./in.cue:1:5
      //     ./in.cue:6:2
    }
  }
}
