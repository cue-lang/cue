# Tests that Fill() followed by Validate(concrete) succeeds for complex disjunction
# definitions under dynamic (interpolated) keys, as it does for static keys.
# https://cuelang.org/issue/342
-- in.cue --
X: {
	#Simple: {
		ref: string
	} @test(shareID=SIMPLE)

	#Complex: {
		{
			ref: string
		} | {
			local: string
		}
	} @test(eq, {ref: string} | {local: string}) @test(shareID=COMPLEX)


	var: "bar"

	// Validate(concrete) after Fill() on Complex.ref from a "static" key will succeed
	"test_1": #Complex @test(shareID=COMPLEX) @test(eq, {
			ref: string
		} | {
			local: string
		})

	// Validate(concrete) after Fill() on "#Simple.ref" from a "dynamic" key will succeed
	"test_2_\(var)": #Simple
	@test(shareID=SIMPLE, at=test_2_bar)
	@test(eq, at=test_2_bar, { ref: string })

	// Validate(concrete) after Fill() on Complex.ref from a "dynamic" key will fail
	"test_3_\(var)": #Complex

	test_3_bar: ref: "FOO"
	@test(eq, at=test_3_bar, { ref: "FOO" })
}

Z: X.test_3_bar.ref @test(eq, "FOO")
-- out/compile --
--- in.cue
{
  X: {
    #Simple: {
      ref: string
    }
    #Complex: {
      ({
        ref: string
      }|{
        local: string
      })
    }
    var: "bar"
    test_1: 〈0;#Complex〉
    "test_2_\(〈0;var〉)": 〈0;#Simple〉
    "test_3_\(〈0;var〉)": 〈0;#Complex〉
    test_3_bar: {
      ref: "FOO"
    }
  }
  Z: 〈0;X〉.test_3_bar.ref
}
