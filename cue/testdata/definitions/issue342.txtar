# Tests that Fill() followed by Validate(concrete) succeeds for complex disjunction
# definitions under dynamic (interpolated) keys, as it does for static keys.
# https://cuelang.org/issue/342
#todo:inline: medium — disjunctions; use @test(final) for default selection
-- in.cue --
X: {
	#Simple: {
		ref: string
	}

	#Complex: {
		{
			ref: string
		} | {
			local: string
		}
	}

	var: "bar"

	// Validate(concrete) after Fill() on Complex.ref from a "static" key will succeed
	"test_1": #Complex

	// Validate(concrete) after Fill() on "#Simple.ref" from a "dynamic" key will succeed
	"test_2_\(var)": #Simple

	// Validate(concrete) after Fill() on Complex.ref from a "dynamic" key will fail
	"test_3_\(var)": #Complex

	test_3_bar: ref: "FOO"
}

Z: X.test_3_bar.ref
-- out/eval/stats --
Leaks:  2
Freed:  18
Reused: 5
Allocs: 15
Retain: 0

Unifications: 14
Conjuncts:    23
Disjuncts:    4

NumCloseIDs: 5
-- out/evalalpha --
(struct){
  X: (struct){
    #Simple: (#struct){
      ref: (string){ string }
    }
    #Complex: (#struct){ |((#struct){
        ref: (string){ string }
      }, (#struct){
        local: (string){ string }
      }) }
    var: (string){ "bar" }
    test_1: (#struct){ |((#struct){
        ref: (string){ string }
      }, (#struct){
        local: (string){ string }
      }) }
    test_3_bar: (#struct){
      ref: (string){ "FOO" }
    }
    test_2_bar: ~(X.#Simple)
  }
  Z: (string){ "FOO" }
}
