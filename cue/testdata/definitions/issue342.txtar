--- in.cue
{
  X: {
    #Simple: {
      ref: string
    }
    #Complex: {
      ({
        ref: string
      }|{
        local: string
      })
    }
    var: "bar"
    test_1: 〈0;#Complex〉
    "test_2_\(〈0;var〉)": 〈0;#Simple〉
    "test_3_\(〈0;var〉)": 〈0;#Complex〉
