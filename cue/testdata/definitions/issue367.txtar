-- in.cue --
#def1: l1: ["l2"]: {l3: int, l4: 26}
#special1: #def1 & {l1: l2: l3:     <100} @test(eq, {
	l1: l2: {
		l3: int & <100
		l4: 26
	}
})
instance:  #special1 & {l1: l2: l3: 34} @test(eq, {l1: {l2: {l3: 34, l4: 26}}})
