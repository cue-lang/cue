Retain: 0

Unifications: 11
Conjuncts:    25
Disjuncts:    0

NumCloseIDs: 12
-- out/evalalpha --
(struct){
  #C1: (#struct){
    name: (string){ string }
  }
  #C2: (#struct){
    age: (int){ int }
    name: (string){ string }
  }
  c1: (#struct){
    name: (string){ "cueckoo" }
  }
  c2: (#struct){
    age: (int){ 5 }
    name: (string){ "cueckoo" }
  }
}
