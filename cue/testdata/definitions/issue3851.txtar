# Tests that a nested optional field structure combined with let bindings and
# disjunctions (#Output: null | #App) evaluates correctly without false errors.
# https://cuelang.org/issue/3851
-- in.cue --
#App: {
	name?: string
	sub1?: sub2?: null | _
}
#Output: null | #App @test(pass)
out: #Output & {
	name: "foo"
	sub1: sub2: {} | _
	sub1: sub2: {
		sub3: {
			let _let = "bar"
			foo: _let
		}
	}
} @test(eq, {name: "foo", sub1: {sub2: {sub3: {foo: "bar"}}}})
