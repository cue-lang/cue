# Tests that a list constrained with [...#X] where #X is a disjunction of
# definitions correctly accepts values matching either branch of the disjunction.
# https://cuelang.org/issue/419
-- in.cue --
#A: {
	a: string
}

#B: {
	b: string
}

#X: #A | #B

l: [...#X]

l: [
	{b: "bar"},
]
-- out/eval/stats --
Leaks:  2
Freed:  16
Reused: 8
Allocs: 10
Retain: 0

Unifications: 12
Conjuncts:    24
Disjuncts:    4

NumCloseIDs: 5
-- out/evalalpha --
(struct){
  #A: (#struct){
    a: (string){ string }
  }
  #B: (#struct){
    b: (string){ string }
  }
  #X: (#struct){ |((#struct){
      a: (string){ string }
    }, (#struct){
      b: (string){ string }
    }) }
  l: (#list){
    0: (#struct){
      b: (string){ "bar" }
    }
  }
}
-- out/compile --
--- in.cue
{
  #A: {
    a: string
  }
  #B: {
    b: string
  }
  #X: (〈0;#A〉|〈0;#B〉)
  l: [
    ...〈1;#X〉,
  ]
  l: [
    {
      b: "bar"
    },
  ]
}
