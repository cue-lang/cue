(struct){
  #a: (#struct){ |((#struct){
      name: (string){ string }
      age: (int){ int }
    }, (#struct){
      name: (string){ string }
      address: (string){ string }
    }) }
  #a1: (#struct){
    name: (string){ string }
    age: (int){ int }
  }
  #a2: (#struct){
    name: (string){ string }
    address: (string){ string }
  }
  #c: (#struct){
    name: (string){ string }
    age: (int){ int }
  }
  #d: (#struct){
    name: (string){ string }
    address: (string){ string }
  }
}
