# Tests that nested fields within a definition unified with #A: _ are accepted
# and do not produce spurious "field not allowed" errors on the nested structure.
# https://cuelang.org/issue/497
-- in.cue --
#A: _

#N: #A & {
	f: j: {
		n: "hi"
	}
} @test(shareID=lN) @test(eq, {f: {j: {n: "hi"}}})

l: #N @test(shareID=lN)
-- out/compile --
--- in.cue
{
  #A: _
  #N: (〈0;#A〉 & {
    f: {
      j: {
        n: "hi"
      }
    }
  })
  l: 〈0;#N〉
}
