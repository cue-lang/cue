# Tests that nested fields within a definition unified with #A: _ are accepted
# and do not produce spurious "field not allowed" errors on the nested structure.
# https://cuelang.org/issue/497
#todo:inline: medium — definitions with closedness; check @test(closed) support
-- in.cue --
#A: _

#N: #A & {
	f: j: {
		n: "hi"
	}
}

l: #N
-- out/eval/stats --
Leaks:  0
Freed:  7
Reused: 0
Allocs: 7
Retain: 0

Unifications: 7
Conjuncts:    9
Disjuncts:    0

NumCloseIDs: 1
-- out/evalalpha --
(struct){
  #A: (_){ _ }
  #N: (#struct){
    f: (#struct){
      j: (#struct){
        n: (string){ "hi" }
      }
    }
  }
  l: ~(#N)
}
-- diff/-out/evalalpha<==>+out/eval --
diff old new
--- old
+++ new
@@ -7,11 +7,5 @@
       }
     }
   }
-  l: (#struct){
-    f: (#struct){
-      j: (#struct){
-        n: (string){ "hi" }
-      }
-    }
-  }
+  l: ~(#N)
 }
-- out/eval --
(struct){
  #A: (_){ _ }
  #N: (#struct){
    f: (#struct){
      j: (#struct){
        n: (string){ "hi" }
      }
    }
  }
  l: (#struct){
    f: (#struct){
      j: (#struct){
        n: (string){ "hi" }
      }
    }
  }
}
-- out/compile --
--- in.cue
{
  #A: _
  #N: (〈0;#A〉 & {
    f: {
      j: {
        n: "hi"
      }
    }
  })
  l: 〈0;#N〉
}
