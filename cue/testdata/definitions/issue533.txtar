# Tests that hidden definitions (_#x) enforce closedness the same way regular
# definitions (#x) do, rejecting extra fields not declared in the definition.
# https://cuelang.org/issue/533
-- in.cue --
package x

#x: {
	Name: string
}

_#x: {
	Name: string
}

x1: #x & {
	Name: "hello"
	Age:  50 @test(err, code=eval, contains="field not allowed", pos=[])
}

x2: _#x & {
	Name: "hello"
	Age:  50 @test(err, code=eval, contains="field not allowed", pos=[])
}
-- out/errors.txt --
-- out/eval/stats --
Leaks:  0
Freed:  11
Reused: 4
Allocs: 7
Retain: 0

Unifications: 11
Conjuncts:    17
Disjuncts:    0

NumCloseIDs: 2
-- out/compile --
--- in.cue
{
  #x: {
    Name: string
  }
  _#x(:x): {
    Name: string
  }
  x1: (〈0;#x〉 & {
    Name: "hello"
    Age: 50
  })
  x2: (〈0;_#x(:x)〉 & {
    Name: "hello"
    Age: 50
  })
}
