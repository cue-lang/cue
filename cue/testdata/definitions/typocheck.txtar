	#Output: { #Embedded }
	#Embedded: {
		name: string
		#Unused | #Used
	}
	#Unused: {}
	#Used: {}

	@test(eq, {
		#Output: {name: string}
		#Embedded: {name: string}
		#Unused: {}
		#Used: {}
	})
}
issue3964: full: {
	out: #Output & {
		name: "oauth2"
		used: "bar"
	}
	#Output: { #Embedded }
	#Embedded: {
		name: string
		#Unused | #Used
	}
	#Unused: unused: string
	#Used: used: string

	@test(eq, {
		out: {name: "oauth2", used: "bar"}
		#Output: {name: string, unused: string} | {name: string, used: string}
		#Embedded: {name: string, unused: string} | {name: string, used: string}
		#Unused: {unused: string}
		#Used: {used: string}
	})
}
-- cycle.cue --
// evalv3 stack overflow due to latest closedness changes; mutually recursive
// definitions that embed each other caused infinite recursion during evaluation.
// https://cuelang.org/issue/4006
issue4006: {
	#A: {
		#B
		fieldA: string
	}
	#B: { #A }
	#C: #A & {}
	out: #C & #B

	@test(eq, {
		#A: {fieldA: string}
		#B: {fieldA: string}
		#C: {fieldA: string}
		out: {fieldA: string}
	})
}
