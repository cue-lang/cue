-- in.cue --
embed: simple: {
	#A: b: 1
	a: { #A }
	a: err: 1 @test(err, code=eval, contains="field not allowed", pos=[0:5])
}
embed: andInStruct: {
	#Foo: a: int
	a: { #Foo & { err: 2 } }

	@test(err, at=a.err, code=eval, contains="field not allowed", pos=[2:16])
}
embed: embedDefWithEmbedding: {
	#Foo: {{a: int}}
	a: { #Foo & { err: 2 } } // not allowed

	@test(err, at=a.err, code=eval, contains="field not allowed", pos=[2:16])
}
embed: embedComprehension: {
	#Foo: {if true {a: int}}
	a: { #Foo & { err: 2 } } // not allowed

	@test(err, at=a.err, code=eval, contains="field not allowed", pos=[2:16])
}
embed: fieldWithAnd: {
	#A: {}
	{ a: #A & {err: 3 } }

	@test(err, at=a.err, code=eval, contains="field not allowed", pos=[2:13])
}
embed: embedAndRecursive: {
	#A: a: int
	B: x: #A
	B & { x: err: 2 }

	@test(err, at=x.err, code=eval, contains="field not allowed", pos=[3:11])
}
embed: andEmbed: {
	#A: b: int
	#B: b: int
	#D: {#A & #B}
	d: #D & {err: 3}

	@test(err, at=d.err, code=eval, contains="field not allowed", pos=[4:11])
}
and: transitive: ok: {
	Z: {a: string} @test(shareID:todo=Z)
	#Y: Z          @test(shareID:todo=Z)
	#X: #Y & Z
	out: #X & {
		a: "foo"
	}

	@test(eq, {
		Z: {a: string}
		#Y: {a: string}
		#X: {a: string}
		out: {a: "foo"}
	})
}
and: transitive: err: {
	Z: a: string
	#Y: Z
	#X: #Y & Z
	out: #X & {
		err: "foo"
	} @test(err, at=err, code=eval, contains="field not allowed", pos=[1:3])
}
and: transitiveWithEmbed: ok: {
	Z: a: string
	#X: #Y & Z
	#Y: {Z}
	out: #X & {
		a: "foo"
	}

	@test(eq, {
		Z: {a: string}
		#X: {a: string}
		#Y: {a: string}
		out: {a: "foo"}
	})
}
and: transitiveWithEmbed: err: {
	Z: a: string
	#X: #Y & Z
	#Y: {Z}
	out: #X & {
		err: "foo"
	}

	@test(err, at=out.err, code=eval, contains="field not allowed", pos=[5:3])
}
embed: nonDef: t1: {
	X: a: string
	#Y: #Z & X
	#Z: {
		X
		b?:    string
	}

	@test(eq, {
		X: {a: string}
		#Y: {b?: string, a: string}
		#Z: {b?: string, a: string}
	})
}
embed: defAndHidden: full: {
	_stepCommon: Name: string
	#Step: #Command & _stepCommon
	#Command: {
		_stepCommon
		Path?:    string
	}
	out: #Step & {
		Name: "foo"
	}

	@test(eq, {
		_stepCommon: {Name: string}
		#Step: {Path?: string, Name: string}
		#Command: {Path?: string, Name: string}
		out: {Name: "foo", Path?: string}
	})
}
embed: withIndirect: {
	A: #B
	#B: b: int
	A & { err: 2 } // not allowed

	@test(err, at=err, code=eval, contains="field not allowed", pos=[3:8])
}
-- validators.cue --
import (
	"struct"
	"list"
)

embed: normalValidator: {
	#X: {
		struct.MaxFields(1)
		a?: int
		b?: int
	}
	x: #X
	x: err: 1 @test(err, code=eval, contains="field not allowed", pos=[-5:3, 0:5])
}
embed: openValidator: t1: {
	#X: {
		matchN(0, [])
		a?: int
		b?: int
	}
	x: #X
	x: err: 1

	@test(eq, {
		#X: {matchN(0, []), a?: int, b?: int}
		x: {err: 1, a?: int, b?: int}
	})
}
embed: openValidator: t2: {
	Y: matchN(1, [X])
	X: b?: Y
	a: X
	a: b: 1 @test(err, suberr=(code=eval, contains="conflicting values"),
		suberr=(code=eval, contains="does not satisfy matchN", pos=[-3:5, -3:12, -2:9, 0:8]),
	)
}
disjunction: withErr: t1: {
	params: {}
	out: #Schema1 & {
		b1: b2: b3: params.mayExistLater
	}
	#Schema1: b1?: null | #Schema2
	#Schema2: b2?: null | {b3?: string}

	@test(eq, {
		params: {}
		out: {b1: {b2: {b3: _}}}
		#Schema1: {b1?: null | {b2?: null | {b3?: string}}}
		#Schema2: {b2?: null | {b3?: string}}
	})
}
embed: nestedValidator: {
	#types: z?: list.UniqueItems
	x: y: z: [1]
	x: {
		#def
		y?: #types
	}
	#def: {}

	@test(eq, {
		#types: _ @test(ignore)
		x: {y: {z: [1]}}
		#def: {}
	})
}
-- inline.cue --
embedInline: {
	#Schema: {
		a: "hello"
		// do not close outer struct of 'b', as inlined value is not a schema.
		b: { {x: c: "foo"}.x }
		b: {
			c: string
			d: "never printed"
		}
	}
	out: #Schema & __no_sharing

	@test(eq, {
		#Schema: {a: "hello", b: {c: "foo", d: "never printed"}}
		out: {a: "hello", b: {c: "foo", d: "never printed"}}
	})
}
// evalv3 "field not allowed" regression involving embeddings and selectors;
// accessing a field via selector on an embedded definition should stay open.
// https://cuelang.org/issue/3853
issue3853: {
	#Schema: {
		a: "hello"
		// do not close outer struct of 'b', as inlined value is not a schema.
		b: { {x: c: "foo"}.x }
		b: {
			c: string
			d: "never printed"
		}
	}
	out: {x: (#Schema & {}).a}.x

	@test(eq, {
		#Schema: {a: "hello", b: {c: "foo", d: "never printed"}}
		out: "hello"
	})
}
-- disjunction.cue --
import "list"

// evalv3 regression: closedness errors no longer reported when default values
// are present; disallowed fields in a default disjunct should still be caught.
// https://cuelang.org/issue/3947
issue3947: full: {
	#Schema: allowed?: string
	_defaults: disallowed: _ | *"default value"
	out: #Schema & _defaults @test(err, code=eval, at=disallowed, contains="field not allowed", pos=[-1:13])
}
// evalv3 regression: #oneOf pattern disjunction; unifying a closed definition
// disjunction with a default string field caused incorrect field-not-allowed errors.
// https://cuelang.org/issue/3957
issue3957: reduced: {
	c: a: "bar"
	c: #B & {a: string | *"foo"}
	#B: b?: string

	@test(err, at=c.a, code=eval, contains="field not allowed", pos=[1:5, 2:11])
}
issue3957: full: {
	#oneof: {a: string} | {b?: [...string]}
	c: #oneof & {a: string | *"foo"}
	c: a: "bar"

	@test(eq, {
		#oneof: {a: string} | {b?: []}
		c: {a: "bar"}
	})
}
issue3957: derived: t1: {
	#Schema: {
		in: string | [...string]
		out: list.FlattenN([in], 1)
	}
	x: #Schema & {in: "foo"}

	@test(eq, {
		#Schema: {in: string | [], out: [string | []]}
		x: {in: "foo", out: ["foo"]}
	})
}
issue3957: derived: t2: {
	#Schema: {
		in: string | [...string]
		let _flat = list.FlattenN([in], 1)
		out: _flat
	}
	out: #Schema & {in: "foo"}

	@test(eq, {
		#Schema: {in: string | [], out: [string | []]}
		out: {in: "foo", out: ["foo"]}
	})
}
-- issue3833.cue --
// evalv3 "field not allowed" regression with embeddings; combining a definition
// that has an open field with another definition via embedding should be allowed.
// https://cuelang.org/issue/3833
issue3833: ok: {
	out: { #A & { a: #B } }
	#A: {
		a: {b: string, ...}
		...
	}
	#C: c: string
	#B: {
		#C & {c: "foo"}
		b: "foo"
	}

	@test(eq, {
		out: {a: {b: "foo", c: "foo"}}
		#A: {a: {b: string}}
		#C: {c: string}
		#B: {c: "foo", b: "foo"}
	})
}
issue3833: evalv2Issue:{
	out: { #A & { a: #B } }
	#A: {
		a: b: string
		...
	}
	#C: c: string
	#B: {
		#C & {c: "foo"}
		b: "foo"
	}

	@test(err, at=out.a.c, code=eval,
		contains="field not allowed", pos=[6:6, 8:9],
		hint="key positions are missing",
	)
}
-- issue3837.cue --
// evalv3 regression with embeddings, disjunctions, and extra fields; a struct
// that embeds a definition and adds extra fields should not cause spurious errors.
// https://cuelang.org/issue/3837
issue3837: reduced: {
	A: {
		#Embed
		extra: "foo"
	}
	out: {{ x: A & __no_sharing }}
	#Embed: {}

	@test(eq, {
		A: {extra: "foo"}
		out: {x: {extra: "foo"}}
		#Embed: {}
	})
}
issue3837: full: {
	#Embed: {}
	#A: {
		#Embed
		extra: "foo"
	}
	#B: (#C | {})
	#C: bar: string
	out: #B & {
		bar: "baz"
		{
			#def: (#A & __no_sharing)
		}
	}

	@test(eq, {
		#Embed: {}
		#A: {extra: "foo"}
		#B: {bar: string} | {}
		#C: {bar: string}
		out: {bar: "baz", #def: {extra: "foo"}}
	})
}
-- issue3832.cue --
// evalv3 "field not allowed" regression with a disjunction and a let field;
// a let binding inside a disjunct should not cause closedness errors.
// https://cuelang.org/issue/3832
issue3832: {
	_person: self: firstName: "Sam"

	#T: {
		_subject: {
			in:  _
			out: {
				let self = in.self
				outFirstName: self.firstName
			}
		}
		_assert: pass: _
		_assert: {
			check!: _
			pass:   "never"
		} | {
			invoke!: _
			// TODO: here, the let from _subject.out gets converted to a
			// permanent error,instead of incomplete.
			pass:    (_subject & {in: invoke}).out
		}
		results: _assert.pass
	}
	#T & {
		_assert: invoke: _person
	}

	@test(eq, {
		_person: {self: {firstName: "Sam"}}
		#T: _ @test(ignore)
		_assert: {
			invoke: {self: {firstName: "Sam"}}
			pass: {outFirstName: "Sam"}
		}
		_subject: _ @test(ignore)
		results: {outFirstName: "Sam"}
	})
}
-- issue3839.cue --
// evalv3 closedness regression with embeddings and definitions; embedding a
// definition with an ellipsis inside a non-definition should remain open.
// https://cuelang.org/issue/3839
issue3839: reduced: {
	x: { A & __no_sharing }
	x: y: 1
	#B: {
		// Note: true with both old semantics and explicitopen
		@test(closed)
		@test(allows=false, string)
	}
	A: {
		#B
		...

		// Note: true with both old semantics and explicitopen
		@test(closed)
		@test(allows, string)
	}

	@test(eq, {x: {y: 1}, #B: {}, A: {}})
}
issue3839: full: {
	_globals: glb: globalField: ""

	#GlobalContext: globalField: string
	#Context: {
		glb: #GlobalContext
		out: glb
	}
	out: {
		ingress: {
			#Ingress & {
				#def: (#Context & _globals).out
			}
		}

		ingress?: {
			foo: 1234
			bar: "http"
		}
	}
	#Embed: #def: {...}

	#Ingress: {
		#Embed
		...
	}

	@test(eq, {
		_globals: {glb: {globalField: ""}}
		#GlobalContext: {globalField: string}
		#Context: {glb: {globalField: string}, out: {globalField: string}}
		out: {ingress: {#def: {globalField: ""}, foo: 1234, bar: "http"}}
		#Embed: {#def: {}}
		#Ingress: {#def: {}}
	})
}
-- chaineddef.cue --
// evalv3 "field not allowed" regression when embedding a chain of definitions;
// chained optional-field definitions embedded in a struct should not be enforced.
// https://cuelang.org/issue/3920
// chained definitions should be handled correctly within embeddings.
issue3920: {
	out: {
		#A
		a: b: "out" // do not enforce #B
	}
	#A: a?: #B
	#B: c?: string

	@test(eq, {
		out: {a: {b: "out", c?: string}}
		#A: {a?: {c?: string}}
		#B: {c?: string}
	})
}
onlyCloseDirectStruct: {
	#foo: {}
	x: {y: {{a: #foo}}}
	x: y: b: 1

	@test(eq, {#foo: {}, x: {y: {a: {}, b: 1}}})
}
closeInEmbed: {
	x: {close({{["d"]: f: int}})}
	x: d: e: 1

	@test(eq, {x: {d: {e: 1, f: int}}})
}
-- embedelim.cue --
// evalv3 "field not allowed" regression with nested definitions; eliminating
// an embedded top value from a definition should not incorrectly close the struct.
// https://cuelang.org/issue/3921
issue3921: top: {
	#A: #B
	#A: b: string
	#B: _
	a: {#A & {}}

	@test(eq, {#A: {b: string}, #B: _, a: {b: string}})
}
issue3921: hidden: {
	#A: #B
	#A: _hidden: b: string
	#B: {}
	a: { #A & { _hidden: {} }}

	@test(eq, {
		#A: {_hidden: {b: string}}
		#B: {}
		a: {_hidden: {b: string}}
	})
}
issue3921: full: {
	out: #templateList & #defineMap
	#templateList: {
		#stepMap: [string]: _
		stepList: [for c in #stepMap {c}]
	}
	#defineMap: {
		#stepMap: foo: #Step & {
			image: "bar"
			#config: {}
		}
		stepList: _
	}
	#Step: #StepInner & {
		image: string
		#config: version:   string
	}
	#StepInner: image: string

	@test(eq, {
		out: {
			#stepMap: {foo: {
				image: "bar"
				#config: {version: string}
			}}
			stepList: [{
				image: "bar"
				#config: {version: string}
			}]
		}
		#templateList: {#stepMap: {}, stepList: []}
		#defineMap: {
			#stepMap: {foo: {
				image: "bar"
				#config: {version: string}}
			}
			stepList: _
		}
		#Step: {
			image: string
			#config: {version: string}
		}
		#StepInner: {image: string}
	})
}
-- issue3843.cue --
// Pattern is unified twice. Ensure that deduping is handled correctly.
dedupPattern: t1: p1: {
	A: {
		#Z: [string]: _
		x: #Z
		x: y: z: 1
	}
	B: A & __no_sharing
	out: A.#Z & B.x

	@test(eq, {
		A: {#Z: {}, x: {y: {z: 1}}}
		B: {#Z: {}, x: {y: {z: 1}}}
		out: {y: {z: 1}}
	})
}
dedupPattern: t1: p2: {
	A: {
		#Z: [string]: _
		x: #Z
		x: y: z: 1
	}
	B: A & __no_sharing
	out: B.x & A.#Z

	@test(eq, {
		A: {#Z: {}, x: {y: {z: 1}}}
		B: {#Z: {}, x: {y: {z: 1}}}
		out: {y: {z: 1}}
	})
}
-- issue3858.cue --
orig: t1: {
	#Image: embed: image: "foo:v1"
	#JobConfig: {
		image: #Image
		job: #Job & {
			image.embed
		}
	}
	#Job: {
		image: string
		vcs:   "git"
		args:  [...string]
		env:   [string]: string
	}

	#Output: {
		_in:  _
		out:  (_in & {})
	}
	#Output & {
		_in: (#JobConfig & {}).job
	}

	@test(eq, {
		#Image: {embed: {image: "foo:v1"}}
		#JobConfig: {
			image: {embed: {image: "foo:v1"}}
			job: {image: "foo:v1", vcs: "git", args: [], env: {}}
		}
		#Job: {image: string, vcs: "git", args: [], env: {}}
		#Output: {_in: _, out: {}}
		_in: {image: "foo:v1", vcs: "git", args: [], env: {}}
		out: {image: "foo:v1", vcs: "git", args: [], env: {}}
	})
}
reduced: t1: {
	Y: {
		a: e: "foo"
