-- issue3934.cue --
// evalv3 "field not allowed" regression with disjunctions and a comprehension;
// a false-branch comprehension inside a disjunct should not trigger closedness errors.
// https://cuelang.org/issue/3934
issue3934: {
	out: #Foo & {
		foo: {
			if false {
				extra: nested: 123
			}
		}
	}
	#Foo: foo?: null | #Bar | *{bar: 3}
	#Bar: {
		bar?:   int
		extra?: null | {...}
	}

	@test(eq, {
		out: {foo: *{bar: 3} | {extra?: null | {}, bar?: int} | null}
		#Foo: {foo?: *{bar: 3} | {bar?: int, extra?: null | {}} | null}
		#Bar: {bar?: int, extra?: null | {}}
	})
}
-- large.cue --
full: {
	#Resource: {
		someMsg: string
		obs: {} | *{missing: true}

		let pickMsg = [
			if obs.missing {msg: "\(someMsg)"},
			{msg: "bar"},
		][0]
		patches: [{
			op:    "add"
			path:  "/metadata"
			value: pickMsg.msg
		}]
	}

	#Patches: [string]: _
	#JSONPatch: {
		namespace?: string
		patch: [...#JSONOp]
		output: #Patches & {(namespace): patch}
	}
	#JSONOp: {
		op:    "add"
		path:  string
		value: _
	} | {
		op:   "remove"
		path: string
	}

	#Main: {
		NS=namespace: string

		output: jsonPatch.output

		let jsonPatch = #JSONPatch & {
			let base = #Resource & {}
			let withMsg = base & {someMsg: "foo"}

			namespace: NS

			patch: withMsg.patches
		}
	}
	out: (#Main & {namespace: "ns1"}).output

	@test(eq, {
		#Resource: _ @test(ignore)
		#Patches: _ @test(ignore)
		#JSONPatch: _ @test(ignore)
		#JSONOp: _ @test(ignore)
		#Main: _ @test(ignore)
		out: {ns1: [{op: "add", path: "/metadata", value: "foo"}]}
	})
}
-- ellipsis.cue --
nestedEllipsis: minimal: {
	out: #Schema & { extra: "foo" }
	#Schema: {
		#meta
		...
	}
	#meta: {}

	@test(eq, {out: {extra: "foo"}, #Schema: {}, #meta: {}})
}
nestedEllipsis: nestedWithPatterns: {
	out: #Schema & {
		objs: obj1: extra: "foo"
	}
	#Schema: {
		[_]: [_]: {
			#meta
			...
		}
		#meta: name?: int
		objs?: _
	}

	@test(eq, {
		out: {
			objs: {obj1: {extra: "foo", name?: int}}
			#meta: {name?: int}
		}
		#Schema: {#meta: {name?: int}, objs?: {}}
	})
}
// evalv3 "field not allowed" regression with ellipses since v0.13.0; embedding
// a schema with `...` alongside additional fields should not close the struct.
// https://cuelang.org/issue/4015
issue4015: reduced: {
	#X: { ... }
	out: {
		// Embedded schema allows `a: _`. Adding `a` below should not change that.
		#X
