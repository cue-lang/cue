preserveClosedness: small: p1: {
	#A: #B & {a: string}
	#B: {
		*{} | {a: string}
		*{} | {b: int}
	}
	@test(eq, {
		#A: *{a: string} | {a: string, b: int}
		#B: *{} | {b: int} | {a: string} | {a: string, b: int}
	})
}

preserveClosedness: small: p2: {
	#A: #B & {a: string}
	#B: {
		{a: string} | *{}
		*{} | {b: int}
	}
	@test(eq, {
		#A: *{a: string} | {a: string, b: int}
		#B: *{} | {a: string, b: int} | {a: string} | {b: int}
	})
}

preserveClosedness: medium: p1: {
	#A: #B & {a: string}
	#B: {
		*{} | {a: string} | {b: string}
		*{} | {c: int} | {d: string}
	}
	@test(eq, {
		#A: *{a: string} | {a: string, c: int} | {a: string, d: string}
		#B: *{} | {c: int} | {d: string} | {a: string} | {a: string, c: int} | {a: string, d: string} | {b: string} | {b: string, c: int} | {b: string, d: string}
	})
}

preserveClosedness: medium: p2: {
	#A: #B & {a: string}
	#B: {
		{a: string} | *{} | {b: string}
		*{} | {c: int} | {d: string}
	}
	@test(eq, {
		#A: *{a: string} | {a: string, c: int} | {a: string, d: string}
		#B: *{} | {a: string, c: int} | {a: string, d: string} | {a: string} | {c: int} | {d: string} | {b: string} | {b: string, c: int} | {b: string, d: string}
	})
}

preserveClosedness: medium: p3: {
	#A: #B & {a: string}
	#B: {
		{a: string} | {b: string} | *{}
		*{} | {c: int} | {d: string}
	}
	@test(eq, {
		#A: *{a: string} | {a: string, c: int} | {a: string, d: string}
		#B: *{} | {a: string, c: int} | {a: string, d: string} | {b: string} | {b: string, c: int} | {b: string, d: string} | {a: string} | {c: int} | {d: string}
	})
}

// If an error occurred in the last disjunction, it may sometimes be propagated
// to parent nodes. This, in turn, could lead to references to such field
// to fail with that error.
noChildError: _
noChildError: issue1608: {
	myValue: #type & {fieldName: "some string"}
	#type: fieldName: #subtype

	#subtype: string | {foo: string} | {bar: #subtype}
	@test(eq, {
		myValue: {fieldName: "some string"}
		#type: {fieldName: string | {foo: string}}
		#subtype: string | {foo: string}
	})
}

noChildError: t1: {
	#D: {b: string} | {c: #D }
	o: #D & {b: "test"}
	@test(eq, {#D: {b: string}, o: {b: "test"}})
}

noChildError: t2: {
	o: #D & {b: "test"}
	#D: {b: string} | {c: #D }
	@test(eq, {o: {b: "test"}, #D: {b: string}})
}

noChildError: t3: {
	#D: {a: null} | {b: string} | {c: #D }
	o: #D & {b: "test"}
	@test(eq, {
		#D: {a: null} | {b: string}
		o: {b: "test"}
	})
}

noChildError: t4: {
	o: #D & {b: "test"}
	#D: {a: null} | {b: string} | {c: #D }
	@test(eq, {
		o: {b: "test"}
		#D: {a: null} | {b: string}
	})
}


issue1924: t1: {
	m: a: 2
	x: *[m.b] | 2
	@test(eq, {m: {a: 2}, x: 2})
}
issue1924: t2: {
	m: a: 2
	x: *{v: m.b} | 3
	@test(eq, {m: {a: 2}, x: 3})
}
issue1924: t3: {
	m: a: 2
	x: *m.b | 1
	@test(eq, {m: {a: 2}, x: 1})
}

// should eliminate erroneous comprehension and pass
issue1838: t1: {
	p?: []
	a: [for k in p {k}] | null
	@test(eq, {p?: [], a: null})
}
issue1838: t2: {
	p?: []
	a: null | [for k in p {k}]
	@test(eq, {p?: [], a: null})
}

noHang: {
	// This should terminate.
	#T: ["a", #T] | ["d", ...#T]

	x: #T

	#X: x
	#X: #T
	@test(eq, {#T: ["d"], x: ["d"], #X: ["d"]})
}

issue1940: {
	#T: ["a", #T] | ["b", #T] | ["c", #T] | ["d", [...#T]]

	#A: type: #T

	#B: [string]: #A

	#C: #B & {
		x: #A
	}
	@test(eq, {
		#T: ["d", []]
		#A: {type: ["d", []]}
		#B: {}
		#C: {x: {type: ["d", []]}}
	})
}

-- issue2209full.cue --
@experiment(reflect)
// Evaluator 0.5 regression where disjunctions combined with comprehensions
// produced incorrect results or spurious errors.
// https://cuelang.org/issue/2209
// TODO: fix

issue2209: simplified: t1A: {
	#SpecFoo: foo: min: 1
	#SpecBar: bar: min: 1
	spec: bar: {}
	spec:  #SpecFoo | #SpecBar
	out: {
		{nullFoo: null} | {nullBar: null}
		{minFoo: int} | {minBar: int}
		if X.bar != _|_ {
			minBar: X.bar.min
		}
		X: spec
	}
	@test(eq, {
		#SpecFoo: {foo: {min: 1}}
		#SpecBar: {bar: {min: 1}}
		spec: {bar: {min: 1}}
		out: {
			minBar: 1
			X: {bar: {min: 1}}
			nullFoo: null
			minFoo: int
		} | {
			minBar: 1
			X: {bar: {min: 1}}
			nullFoo: null
		} | {
			minBar: 1
			X: {bar: {min: 1}}
			nullBar: null,
			minFoo: int
		} | {
			minBar: 1
			X: {bar: {min: 1}}
			nullBar: null
		}
	})
}
issue2209: simplified: t1B: {
	#SpecFoo: foo: min: 1
	#SpecBar: bar: min: 1
	spec: bar: {}
	spec:  #SpecFoo | #SpecBar
	out: {
		{nullFoo: null} | {nullBar: null}
		{minFoo: int} | {minBar: int}
		if exists(X.bar) {
			minBar: X.bar.min
		}
		X: spec
	}
	@test(eq, {
		#SpecFoo: {foo: {min: 1}}
		#SpecBar: {bar: {min: 1}}
		spec: {bar: {min: 1}}
		out: {
			minBar: 1
			X: {bar: {min: 1}}
			nullFoo: null
			minFoo: int
		} | {
			minBar: 1
			X: {bar: {min: 1}}
			nullFoo: null
		} | {
			minBar: 1
			X: {bar: {min: 1}}
			nullBar: null,
			minFoo: int
		} | {
			minBar: 1
			X: {bar: {min: 1}}
			nullBar: null
		}
	})
}

issue2209: simplified: t2A: {
	#SpecFoo: foo: {}
	#SpecBar: bar: x: 1
	spec: bar: {}
	spec: *#SpecFoo | #SpecBar
	if spec.bar != _|_ {
		BAZ: spec.bar.x
	}
	{f1: int} | {b2: int}
	{f2: int} | {b2: int}
	@test(eq, {
		#SpecFoo: {foo: {}}
		#SpecBar: {bar: {x: 1}}
		spec: {bar: {x: 1}}
		BAZ: 1
		f1: int
		f2: int
	} | {
		#SpecFoo: {foo: {}}
		#SpecBar: {bar: {x: 1}}
		spec: {bar: {x: 1}}
		BAZ: 1
		f1: int
		b2: int
	} | {
		#SpecFoo: {foo: {}}
		#SpecBar: {bar: {x: 1}}
		spec: {bar: {x: 1}}
		BAZ: 1
		b2: int
		f2: int
	} | {
		#SpecFoo: {foo: {}}
		#SpecBar: {bar: {x: 1}}
		spec: {bar: {x: 1}}
		BAZ: 1
		b2: int
	})
}
issue2209: simplified: t2B: {
	#SpecFoo: foo: {}
	#SpecBar: bar: x: 1
	spec: bar: {}
	spec: *#SpecFoo | #SpecBar
	if exists(spec.bar) {
		BAZ: spec.bar.x
	}
	{f1: int} | {b2: int}
	{f2: int} | {b2: int}
	@test(eq, {
