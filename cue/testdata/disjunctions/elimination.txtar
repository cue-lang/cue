-- issue3784.cue --
// evalv3 regressions with "conflicting values" and "field not allowed" errors
// when evaluating schemas similar to the GitHub Terraform provider schema.
// https://cuelang.org/issue/3784
issue3784: reduced: {
	#Schema: a: {
		kind: "A"
		b: c?: string
		b: {}
	} | {
		kind: "B"
	}

	out: #Schema
	out: a: {
		kind: "A"
		b: c: "x"
	}
	@test(eq, {
		#Schema: {
			a: {kind: "A", b: {c?: string}} | {kind: "B"}
		}
		out: {a: {kind: "A", b: {c: "x"}}}
	})
}
issue3784: full: {
	#Schema: {
		pages?: {
			build_type?: "legacy" | "workflow"
			source?: {
				branch?: string
				path?:   string
			}
			cname?: string
		}
		pages?: {
			build_type!: "legacy"
			source!: {
				branch!: _
			}
		} | close({
			build_type!: "workflow"
			cname?:      _
		})
	}
	out: #Schema & {
		pages: {
			cname:      "foo.com"
			build_type: "legacy"
			source: {
				branch: "main"
				path:   "/"
			}
		}
	}
	@test(eq, {
		#Schema: {
			pages?: {build_type!: "legacy", source!: {branch!: string, path?: string}, cname?: string} | {build_type!: "workflow", source?: {branch?: string, path?: string}, cname?: string}
		}
		out: {
			pages: {
				cname: "foo.com"
				build_type: "legacy"
				source: {branch: "main", path: "/"}
			}
		}
	})
}
issue3784: variant1: {
	#Schema: {
		pages: {
			build_type?: "legacy" | "workflow"
			source: {
				branch?: string
				path?:   string
			}
			cname?: string
		}
		pages?: {
			build_type!: "legacy"
			source!: {
				branch!: _
			}
		} | close({
			build_type!: "workflow"
			cname?:      _
		})
	}
	@test(eq, {
		#Schema: {
			pages: {
				build_type!: "legacy"
				source: {branch!: string, path?: string}
				cname?: string
			}
		}
	})
}
issue3784: variant2: {
	#Schema: {
		build_type!: "legacy"
		source!: {
			branch!: _
		}
	} | close({
		build_type!: "workflow"
		cname?:      _
	})
	a: #Schema
	a: {
		build_type?: "legacy" | "workflow"
		source: {
			branch?: string
			path?:   string
		}
		cname?: string
	}
	@test(eq, {
		#Schema: {build_type!: "legacy", source!: {branch!: _}} | {build_type!: "workflow", cname?: _}
		a: {
			build_type!: "legacy"
			source: {
				branch!: string
				path?: _|_ @test(err, code=eval, contains="issue3784.variant2.a.source.path: field not allowed", pos=[15:4])
			}
			cname?: _|_ @test(err, code=eval, contains="issue3784.variant2.a.cname: field not allowed", pos=[17:3])
		}
	})
}
-- issue3958.cue --
// evalv3 regression where unifying an odd number of default disjunctions no
// longer produced an error as expected.
// https://cuelang.org/issue/3958
issue3958: t1: {
	#schema: int | *1
	#schema: int | *3

	test1: #schema & {int | *2}
	test2: #schema & {int | *4}
	@test(eq, {
		#schema: int | 3 | 1
		test1: int | 3 | 1 | 2
		test2: int | 3 | 1 | 4
	})
}
issue3958: t2: {
 	a: (int | *4) & (int | *1) & (int | *3) & (int | *8)
	b: (int | *4) & (int | *1) & (int | *3)
	@test(eq, {
		a: int | 8 | 3 | 1 | 4
		b: int | 3 | 1 | 4
	})
}
-- issue2685.cue --
// Nested definition with a default value incorrectly took the default value
// even when a concrete value was provided via unification.
// https://cuelang.org/issue/2685
issue2685: {
	#Foo: {
		bar: int
		opt?: int
	} | *{
		opt: int
	}

	foo: #Foo
	foo: bar: 0

	{
		foo: #Foo
	}
	@test(eq, {
		#Foo: *{opt: int} | {bar: int, opt?: int}
		foo: {bar: 0, opt?: int}
	})
}
