issue2209: simplified: t3: {
	#A: v: 1
	{f1: int} | {b2: int}
	{f2: int} | {b2: int}
	BAZ: S.y
	S: *#A | #B
	#B: {x: 1, y: 1}
	S: x: 1
	@test(eq, {
		#A: {v: 1}
		BAZ: 1
		S: {x: 1, y: 1}
		#B: {x: 1, y: 1}
		f1: int
		f2: int
	} | {
		#A: {v: 1}
		BAZ: 1
		S: {x: 1, y: 1}
		#B: {x: 1, y: 1}
		f1: int
		b2: int
	} | {
		#A: {v: 1}
		BAZ: 1
		S: {x: 1, y: 1}
		#B: {x: 1, y: 1}
		b2: int
		f2: int
	} | {
		#A: {v: 1}
		BAZ: 1
		S: {x: 1, y: 1}
		#B: {x: 1, y: 1}
		b2: int
	})
}

issue2209: full: {
	Foo: #Abstract & {spec: foo: {}}
	@test(shareID=FooSpec, at=Foo.spec)
	@test(shareID=FooSpec, at=Foo.resource._X.spec)
	@test(eq, at=Foo, {
		spec: {foo: {min: *10 | int, max: *20 | int}}
		resource: {
			_X: spec: {foo: {min: *10 | int, max: *20 | int}}
			spec: *{
				minFoo: *10 | int
				maxFoo: *20 | int
				minBar?: null
				maxBar?: null
				hoge?: null | bool
				fuga?: null
			} | {
				minFoo: *10 | int
				maxFoo: *20 | int
				minBar?: null
				maxBar?: null
				hoge?: null
				fuga?: null | bool
			}
		}
	})

	Bar: #Abstract & {spec: bar: {}}
	@test(shareID=BarSpec, at=Bar.spec)
	@test(shareID=BarSpec, at=Bar.resource._X.spec)

	#Abstract: X={
		spec: _#Spec

		resource: _Thing & {_X: spec: X.spec}
	}

	_#Spec: *_#SpecFoo | _#SpecBar

	_#SpecFoo: {
		foo: {
			min: int | *10
			max: int | *20
		}
	}

	_#SpecBar: {
		bar: {
			min: int | *30
			max: int | *40
		}
	}

	_Thing: #Constrained & {
		_X: _

		spec: {
			if _X.spec.foo != _|_ {
				minFoo: _X.spec.foo.min
				maxFoo: _X.spec.foo.max
			}

			if _X.spec.bar != _|_ {
				minBar: _X.spec.bar.min
				maxBar: _X.spec.bar.max
			}
		}
	}

	#Constrained: #Base & {
		spec: {
			minFoo:  int | *10
			maxFoo:  int | *20
			minBar?: null
			maxBar?: null
		} | {
			minBar:  int | *30
			maxBar:  int | *40
			minFoo?: null
			maxFoo?: null
		}

		spec: *{
			fuga?: null
		} | {
			hoge?: null
		}
	}

	#Base: {
		spec: {
			minFoo?: null | int
			maxFoo?: null | int
			minBar?: null | int
			maxBar?: null | int

			hoge?: null | bool
			fuga?: null | bool
		}
	}

	@test(eq, at=Bar, {
		spec: {bar: {min: *30 | int, max: *40 | int}}
		resource: {
			_X: spec: {bar: {min: *30 | int, max: *40 | int}}
			spec: *{
				minFoo?: null
				maxFoo?: null
				minBar: *30 | int
				maxBar: *40 | int
				hoge?: null | bool
				fuga?: null
			} | {
				minFoo?: null
				maxFoo?: null
				minBar: *30 | int
				maxBar: *40 | int
				hoge?: null
				fuga?: null | bool
			}
		}
	})
	// 	#Abstract: {
	// 		spec: *{
	// 			foo: {min: *10 | int, max: *20 | int}
	// 		} | {
	// 			bar: {min: *30 | int, max: *40 | int}
	// 		}
	// 		resource: {
	// 			_X: {
	// 				spec: *{
	// 					foo: {min: *10 | int, max: *20 | int}
	// 					} | {
	// 						bar: {min: *30 | int, max: *40 | int}
	// 					}
	// 			}
	// 			spec: *{
	// 				minFoo: *10 | int
	// 				maxFoo: *20 | int
	// 				minBar?: null
	// 				maxBar?: null
	// 				hoge?: null | bool
	// 				fuga?: null
	// 			} | {
	// 				minFoo: *10 | int
	// 				maxFoo: *20 | int
	// 				minBar?: null
	// 				maxBar?: null
	// 				hoge?: null
	// 				fuga?: null | bool
	// 			}
	// 		}
	// 	}
	// 	_#Spec: *{
	// 		foo: {min: *10 | int, max: *20 | int}
	// 	} | {
	// 		bar: {min: *30 | int, max: *40 | int}
	// 	}
	// 	_#SpecFoo: {foo: {min: *10 | int, max: *20 | int}}
	// 	_#SpecBar: {bar: {min: *30 | int, max: *40 | int}}
	// 	_Thing: {
	// 		_X: _
	// 		spec: *{
	// 			minFoo: *10 | int
	// 			maxFoo: *20 | int
	// 			minBar?: null
