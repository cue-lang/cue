-- issue2246.cue --
// Evaluator regression where repeated use of an embedded disjunction resulted
// in spurious "field not allowed" errors.
// https://cuelang.org/issue/2246
issue2246: simplified: {
	#FormFoo: fooID: string
	#FormBar: barID: string
	#Form: { #FormFoo | #FormBar }

	data: {fooID: "123"}
	out1: #Form & data
	out2: #Form & out1
	@test(eq, {
		#FormFoo: {fooID: string}
		#FormBar: {barID: string}
		#Form: {fooID: string} | {barID: string}
		data: {fooID: "123"}
		out1: {fooID: "123"}
		out2: {fooID: "123"}
	})
}
issue2246: full: {
	data: forms: [{
		fooID: "00-0000001"
	}]

	form1040: (#compute & {in: data}).out

	#K1: {
		#_base: common: 3
		#FormFoo: {
			#_base
			fooID: string
		}
		#FormBar: {
			#_base
			barID: string
		}
		#Form: {
			#FormFoo | #FormBar
		}
	}

	#Input: {
		forms: [...#K1.#Form]
	}

	#summarizeReturn: {
		in:  #Input
		out: [for k in in.forms { k.common }]
	}

	#compute: {
		in:  #Input
		out: (#summarizeReturn & {"in": in}).out
	}
	@test(eq, {
		data: {forms: [{
		fooID: "00-0000001"
	}]}
		form1040: [3]
		#K1: {
			#_base: {common: 3}
			#FormFoo: {fooID: string, common: 3}
			#FormBar: {barID: string, common: 3}
			#Form: {fooID: string, common: 3} | {barID: string, common: 3}
		}
		#Input: {forms: []}
		#summarizeReturn: {in: {forms: []}, out: []}
		#compute: {in: {forms: []}, out: []}
	})
}

-- issue2263.cue --
// Disjunction regression in v0.5.0-beta.5 where multiple embedded disjunctions
// in a definition were not evaluated correctly.
// https://cuelang.org/issue/2263
issue2263: simplified: {
	metrics: #Metric
	#Metric: {
		#IDSource | {}
		#TargetAverage | {}
	}

	metrics: {
		id:  "foo"
		avg: 60
	}

	#IDSource: id: string
	#TargetAverage: avg: number
	@test(eq, {
		metrics: {id: "foo", avg: 60}
		#Metric: {id: string, avg: number} | {id: string} | {avg: number} | {}
		#IDSource: {id: string}
		#TargetAverage: {avg: number}
	})
}
issue2263: full: {
	metrics: [...#Metric]

	metrics: [{
		id:  "foo"
		avg: 60
	}, {
		id:    "bar"
		value: 80
	}, {
		uri: "baz"
		avg: 70
	}, {
		uri:   "qux"
		value: 90
	}]

	#Metric: {
		#Source
		#Target
	}

	#Source:
		#IDSource |
		#URISource

	#Target:
		#TargetAverage |
		#TargetValue

	#IDSource: {
		id: string
	}

	#URISource: {
		uri: string
	}

	#TargetAverage: {
		avg: number
	}

	#TargetValue: {
		value: number
	}
	@test(eq, {
		metrics: [{
		avg: 60
		id:  "foo"
	}, {
		id:    "bar"
		value: 80
	}, {
		avg: 70
		uri: "baz"
	}, {
		uri:   "qux"
		value: 90
	}]
		#Metric: {id: string, avg: number} | {id: string, value: number} | {uri: string, avg: number} | {uri: string, value: number}
		#Source: {id: string} | {uri: string}
		#Target: {avg: number} | {value: number}
		#IDSource: {id: string}
		#URISource: {uri: string}
		#TargetAverage: {avg: number}
		#TargetValue: {value: number}
	})
}
-- issue1417.cue --
// Regression where disjuncts sometimes behaved like conjuncts, causing
// incorrect unification of disjunction members.
// https://cuelang.org/issue/1417
issue1417: {
	#ID: !~"^a" | =~"^ab$" | =~"^aB$"
	#ID: =~"^a" | !~"[A-Z]"
	ids: [...#ID] & ["xyz", "ab", "aB"]
	@test(eq, {
		#ID: !~"^a" & =~"^a" | !~"^a" & !~"[A-Z]" | =~"^ab$" & =~"^a" | =~"^ab$" & !~"[A-Z]" | =~"^aB$" & =~"^a" | =~"^aB$" & !~"[A-Z]"
		ids: ["xyz", "ab", "aB"]
	})
}
-- issue3149.cue --
// Evaluator regression where unifying disjunctions incorrectly failed to
// validate a fixed value that satisfied the constraint.
// https://cuelang.org/issue/3149
issue3149: {
	#valid: {
		name!: ( (=~"^Foo") | "an exception") & ( (=~"Foo$") | "an exception")
	}
	list: [...#valid]
	list: [
		{name: "FooBarFoo"},
		{name: "FooBazFoo"},
		{name: "FooQuuxFoo"},
		{name: "an exception"},
	]
	@test(eq, {
		#valid: {
			name!: =~"^Foo" & =~"Foo$" | "an exception"
		}
		list: [{
		name: "FooBarFoo"
	}, {
		name: "FooBazFoo"
	}, {
		name: "FooQuuxFoo"
	}, {
		name: "an exception"
	}]
	})
}
-- issue770.cue --
// Default value resolution issue where chained pattern constraints with default
// disjunctions did not propagate defaults correctly.
// https://cuelang.org/issue/770
issue770: {
	#A: {
		v: "a" | "b" | "c"
	}
	h: [string]: #A
	h: a: {
		v: *"a" | string
	}
	h: [=~"^b"]: {
		v: *h.a.v | string
	}
	h: [=~"^c"]: {
		v: *h.b.v | string
	}
	h: b:   _
	h: boo: _
	h: c:   _
	h: coo: _
	@test(eq, {
		#A: {v: "a" | "b" | "c"}
		h: {
			a: {v: *"a" | "b" | "c"}
			b: {v: *"a" | "b" | "c"}
			boo: {v: *"a" | "b" | "c"}
			c: {v: *"a" | "b" | "c"}
			coo: {v: *"a" | "b" | "c"}
		}
	})
}
-- issue3528.cue --
// evalv3 "incDependent: already closed" panic with repeated disjunctions
// and definitions in workflow container schemas.
// https://cuelang.org/issue/3528
issue3528: original: {
	workflows: [...#Workflow]
	workflows: [test]

	test: #Workflow & {}

	#Workflow: {
		container: [string]: string | #container
		#container: string | {volumes?: [...string]}
	}
	@test(eq, {
		workflows: [
			{container: {}, #container: string | {volumes?: []}},
		]
		test: {
			container: {}
			#container: string | {volumes?: []}
		}
		#Workflow: {
			container: {}
			#container: string | {volumes?: []}
		}
	})
}
