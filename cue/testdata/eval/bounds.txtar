// Tests bound expression evaluation and simplification including binary bound
// simplification (incompatible bounds), simplifyExpr with non-concrete bound
// arguments, and struct equality bounds (== / !=). Also covers issue 4142
// (struct equality in definitions) and issue 4251 (SimplifyBounds panic on ==
// bounds combined with other bound types).
//
// Issue 4388: == / != bounds are valid on bool, ordered bounds are not. The !=
// and ordered cases are in bool.cue; the == cases need the structcmp
// experiment to parse, so they are in equalScalar (equals.cue).
-- cue.mod/module.cue --
module: "x.test"
language: version: "v0.14.0"
-- in.cue --
x0: 5       @test(eq, 5)
x1: b5 & 30 @test(eq, 30)

b0: <x0 & >0        @test(eq, >0 & <5)
b1: b0 & int        @test(eq, >0 & <5 & int)
b2: int & <5.5      @test(eq, <5.5 & int)
b3: <10 & <=5       @test(eq, <=5)
b4: >=20 & >20      @test(eq, >20)
b5: >=21 & >20      @test(eq, >=21)
b6: int & >5 & <=6  @test(eq, >5 & <=6 & int)

simplifyExpr: {
	// TODO: fill out later.
	less1: <(<3)   @test(err, code=incomplete, contains="non-concrete value <3", pos=[0:11])
	less2: <(<=3)  @test(err, code=incomplete, contains="non-concrete value <=3", pos=[0:11])
	less3: <=(<3)  @test(err, code=incomplete, contains="non-concrete value <3", pos=[0:12])
	less4: <=(<=3) @test(err, code=incomplete, contains="non-concrete value <=3", pos=[0:12])
	less5: <(!=3)  @test(err, code=incomplete, contains="non-concrete value !=3", pos=[0:11])
	less6: <=(!=3) @test(err, code=incomplete, contains="non-concrete value !=3", pos=[0:12])

	gtr1: >(>3)   @test(err, code=incomplete, contains="non-concrete value >3", pos=[0:10])
	gtr2: >(>=3)  @test(err, code=incomplete, contains="non-concrete value >=3", pos=[0:10])
	gtr3: >=(>3)  @test(err, code=incomplete, contains="non-concrete value >3", pos=[0:11])
	gtr4: >=(>=3) @test(err, code=incomplete, contains="non-concrete value >=3", pos=[0:11])
	gtr5: >(!=3)  @test(err, code=incomplete, contains="non-concrete value !=3", pos=[0:10])
	gtr6: >=(!=3) @test(err, code=incomplete, contains="non-concrete value !=3", pos=[0:11])

	lg1: <(>3)   @test(err, code=incomplete, contains="non-concrete value >3", pos=[0:9])
	lg2: <(>=3)  @test(err, code=incomplete, contains="non-concrete value >=3", pos=[0:9])
	lg3: <=(>3)  @test(err, code=incomplete, contains="non-concrete value >3", pos=[0:10])
	lg4: <=(>=3) @test(err, code=incomplete, contains="non-concrete value >=3", pos=[0:10])

	gl1: >(<3)   @test(err, code=incomplete, contains="non-concrete value <3", pos=[0:9])
	gl2: >(<=3)  @test(err, code=incomplete, contains="non-concrete value <=3", pos=[0:9])
	gl3: >=(<3)  @test(err, code=incomplete, contains="non-concrete value <3", pos=[0:10])
	gl4: >=(<=3) @test(err, code=incomplete, contains="non-concrete value <=3", pos=[0:10])

	ne1: !=(!=3) @test(err, code=incomplete, contains="non-concrete value !=3", pos=[0:10])
	ne2: !=(<3)  @test(err, code=incomplete, contains="non-concrete value <3", pos=[0:10])
	ne3: !=(<=3) @test(err, code=incomplete, contains="non-concrete value <=3", pos=[0:10])
	ne4: !=(>3)  @test(err, code=incomplete, contains="non-concrete value >3", pos=[0:10])
	ne5: !=(>=3) @test(err, code=incomplete, contains="non-concrete value >=3", pos=[0:10])

	s:      string
	n:      number
	i:      int
	f:      float
	b:      bytes
	basic1: <(i)  @test(err, code=incomplete, contains="non-concrete value %s for bound %s", args=[i, <], pos=[0:12])
	basic2: >(n)  @test(err, code=incomplete, contains="non-concrete value %s for bound %s", args=[n, >], pos=[0:12])
	basic3: >=(s) @test(err, code=incomplete, contains="non-concrete value %s for bound %s", args=[s, >=], pos=[0:13])
	basic4: <=(f) @test(err, code=incomplete, contains="non-concrete value %s for bound %s", args=[f, <=], pos=[0:13])
	basic5: <=(b) @test(err, code=incomplete, contains="non-concrete value %s for bound %s", args=[b, <=], pos=[0:13])

	// Do NOT interpret this the same as `!= type`.
	bne1: !=(s) @test(err, code=incomplete, contains="non-concrete value %s for bound %s", args=[s, !=], pos=[0:11])
	bne2: !=(n) @test(err, code=incomplete, contains="non-concrete value %s for bound %s", args=[n, !=], pos=[0:11])
	bne3: !=(n) @test(err, code=incomplete, contains="non-concrete value %s for bound %s", args=[n, !=], pos=[0:11])
	bne4: !=(i) @test(err, code=incomplete, contains="non-concrete value %s for bound %s", args=[i, !=], pos=[0:11])
	bne5: !=(b) @test(err, code=incomplete, contains="non-concrete value %s for bound %s", args=[b, !=], pos=[0:11])

	e1: <(=~"foo") @test(err, code=incomplete, contains="non-concrete value =~", pos=[0:8])
	e2: >(null)    @test(err, code=eval, contains="cannot use null for bound", pos=[0:8])
}
-- binarystring.cue --
simplifyBinary: strings: {
  err1: {
    p1: <"a" & >"b" @test(err, code=eval, contains="incompatible string bounds", pos=[0:16, 0:9])
    p2: >"b" & <"a" @test(err, code=eval, contains="incompatible string bounds", pos=[0:16, 0:9])
  }
  err2: {
    p1: >"b" & <="a" @test(err, code=eval, contains="incompatible string bounds", pos=[0:16, 0:9])
    p2: <="a" & >"b" @test(err, code=eval, contains="incompatible string bounds", pos=[0:17, 0:9])
  }
  err3: {
    p1: >="b" & <"b" @test(err, code=eval, contains="incompatible string bounds", pos=[0:17, 0:9])
    p2: <"b" & >="b" @test(err, code=eval, contains="incompatible string bounds", pos=[0:16, 0:9])
    p3: >"b" & <="b" @test(err, code=eval, contains="incompatible string bounds", pos=[0:16, 0:9])
    p4: <="b" & >"b" @test(err, code=eval, contains="incompatible string bounds", pos=[0:17, 0:9])
  }
  ok1: {
    p1: >"a" & <"b"  @test(eq, >"a" & <"b")
    p2: <"b" & >"a"  @test(eq, >"a" & <"b")
  }
  ok2: {
    p1: >"a" & <="b"  @test(eq, >"a" & <="b")
    p2: <="b" & >"a"  @test(eq, >"a" & <="b")
    p3: >="a" & <"b"  @test(eq, >="a" & <"b")
    p4: <"b" & >="a"  @test(eq, >="a" & <"b")
  }
  ok3: {
    p1: >="b" & <="c"  @test(eq, >="b" & <="c")
    p2: <="c" & >="b"  @test(eq, >="b" & <="c")
  }
  ok4: {
    p1: >="b" & <="b"  @test(eq, >="b" & <="b")
  }
}
simplifyBinary: byte: {
  err1: {
    p1: <'a' & >'b' @test(err, code=eval, contains="incompatible bytes bounds", pos=[0:16, 0:9])
    p2: >'b' & <'a' @test(err, code=eval, contains="incompatible bytes bounds", pos=[0:16, 0:9])
  }
  err2: {
    p1: >'b' & <='a' @test(err, code=eval, contains="incompatible bytes bounds", pos=[0:16, 0:9])
    p2: <='a' & >'b' @test(err, code=eval, contains="incompatible bytes bounds", pos=[0:17, 0:9])
  }
  err3: {
    p1: >='b' & <'b' @test(err, code=eval, contains="incompatible bytes bounds", pos=[0:17, 0:9])
    p2: <'b' & >='b' @test(err, code=eval, contains="incompatible bytes bounds", pos=[0:16, 0:9])
    p3: >'b' & <='b' @test(err, code=eval, contains="incompatible bytes bounds", pos=[0:16, 0:9])
    p4: <='b' & >'b' @test(err, code=eval, contains="incompatible bytes bounds", pos=[0:17, 0:9])
  }
  ok1: {
    p1: >'a' & <'b'  @test(eq, >'a' & <'b')
    p2: <'b' & >'a'  @test(eq, >'a' & <'b')
  }
  ok2: {
    p1: >'a' & <='b'  @test(eq, >'a' & <='b')
    p2: <='b' & >'a'  @test(eq, >'a' & <='b')
    p3: >='a' & <'b'  @test(eq, >='a' & <'b')
    p4: <'b' & >='a'  @test(eq, >='a' & <'b')
  }
  ok3: {
    p1: >='b' & <='c'  @test(eq, >='b' & <='c')
    p2: <='c' & >='b'  @test(eq, >='b' & <='c')
  }
  ok4: {
    p1: >='b' & <='b'  @test(eq, >='b' & <='b')
  }
}
-- binary.cue --
simplifyBinary: float: {
  err1: {
    p1: <1 & >2 @test(err, code=eval, contains="incompatible number bounds", pos=[0:14, 0:9])
    p2: >2 & <1 @test(err, code=eval, contains="incompatible number bounds", pos=[0:14, 0:9])
  }
  err2: {
    p1: >2 & <=1 @test(err, code=eval, contains="incompatible number bounds", pos=[0:14, 0:9])
    p2: <=1 & >2 @test(err, code=eval, contains="incompatible number bounds", pos=[0:15, 0:9])
  }
  err3: {
    p1: >=2 & <2 @test(err, code=eval, contains="incompatible number bounds", pos=[0:15, 0:9])
    p2: <2 & >=2 @test(err, code=eval, contains="incompatible number bounds", pos=[0:14, 0:9])
    p3: >2 & <=2 @test(err, code=eval, contains="incompatible number bounds", pos=[0:14, 0:9])
    p4: <=2 & >2 @test(err, code=eval, contains="incompatible number bounds", pos=[0:15, 0:9])
  }
  ok1: {
    p1: >1 & <2  @test(eq, >1 & <2)
    p2: <2 & >1  @test(eq, >1 & <2)
  }
  ok2: {
    p1: >=2 & <=2 @test(eq, >=2 & <=2)
    p2: <=2 & >=2 @test(eq, >=2 & <=2)
  }
}

simplifyBinary: integer: {
  [_]: [_]: int
  err1: {
    p1: <1 & >2 @test(err, code=eval, contains="incompatible integer bounds", pos=[0:14, 0:9])
    p2: >2 & <1 @test(err, code=eval, contains="incompatible integer bounds", pos=[0:14, 0:9])
  }
  err2: {
    p1: >2 & <=1 @test(err, code=eval, contains="incompatible integer bounds", pos=[0:14, 0:9])
    p2: <=1 & >2 @test(err, code=eval, contains="incompatible integer bounds", pos=[0:15, 0:9])
  }
  err3: {
    p1: >=2 & <2 @test(err, code=eval, contains="incompatible integer bounds", pos=[0:15, 0:9])
    p2: <2 & >=2 @test(err, code=eval, contains="incompatible integer bounds", pos=[0:14, 0:9])
    p3: >2 & <=2 @test(err, code=eval, contains="incompatible integer bounds", pos=[0:14, 0:9])
    p4: <=2 & >2 @test(err, code=eval, contains="incompatible integer bounds", pos=[0:15, 0:9])
  }
  err4: {
    p1: >1 & <2 @test(err, code=eval, contains="incompatible integer bounds", pos=[0:14, 0:9])
    p2: <2 & >1 @test(err, code=eval, contains="incompatible integer bounds", pos=[0:14, 0:9])
  }
  ok1: {
    p1: >=2 & <=3 @test(eq, >=2 & <=3 & int)
    p2: <=3 & >=2 @test(eq, >=2 & <=3 & int)
  }
  ok2: {
    p1: >=2 & <=2 @test(eq, >=2 & <=2 & int)
    p2: <=2 & >=2 @test(eq, >=2 & <=2 & int)
  }
  ok3: {
    p1: >=2 & <3 @test(eq, >=2 & <3 & int)
    p2: >2 & <=3 @test(eq, >2 & <=3 & int)
    p3: <3 & >=2 @test(eq, >=2 & <3 & int)
    p4: <=3 & >2 @test(eq, >2 & <=3 & int)
  }
}
-- equals.cue --
@experiment(structcmp)

equalScalar: {
	ok1: ==1  @test(eq, 1)
	ok1: 1

	ok2: [1, 2]
	ok2: ==[1, 2] @test(eq, [1, 2])

	err1: ==1
	err1: 2    @test(err, code=eval, contains="out of bound ==1", pos=[-1:8, 0:8])

	err2: [1, 2]
	err2: !=[1, 2] @test(err, code=eval, contains="out of bound !=", pos=[0:8, -1:8])

	// == bounds are valid on bool too (issue 4388).
	ok3: ==true
	ok3: true  @test(eq, true)

	err3: ==true
	err3: false @test(err, code=eval, contains="out of bound ==true", pos=[-1:8, 0:8])
}
equalStruct: {
	ok1: =={} @test(eq, {})
	ok1: {}

	ok2: {a: 1, b: 2}
	ok2: =={a: 1, b: 2} @test(eq, {a: 1, b: 2})

	err1: =={}
	err1: {a: 1, b: 2} @test(err, code=eval, contains="out of bound ==", pos=[-1:8, 0:8])

	err2: {a: 1, b: 2}
	err2: !={a: 1, b: 2} @test(err, code=eval, contains="out of bound !=", pos=[0:8, -1:8])
}
nonConcrete: {
	ok0: =="foo" @test(eq, =="foo")

	_int: int

	iErr1: ==_int @test(err, code=incomplete, contains="non-concrete value", pos=[0:11])

	iErr2: !=_int @test(err, code=incomplete, contains="non-concrete value", pos=[0:11])

	iErr3: ==_int
	iErr3: == 1 @test(err, code=incomplete, contains="non-concrete value", pos=[-1:11])

	ok4: ==1
	ok4: _int @test(eq, ==1 & int) // v3: ==1 & int is not an error

	eErr5: =="foo"
	eErr5: _int @test(err, code=eval, contains="conflicting values", pos=[-13:8, -1:9, 0:9])

	eErr6: ==_int
	eErr6: "foo" @test(err, code=incomplete|eval,
		hint="incompatible types, so this SHOULD be a permanent error",
		contains="non-concrete value", pos=[-1:11]) @test(err:todo, code=eval)
}
-- issue4142.cue --
@experiment(structcmp)

inDefinitions: ok1: {
	#X: =={ name: "X" }
	x: #X & { name: "X" }
	@test(eq, {#X: {=={ name: "X" }}, x: {name: "X"}})
}
inDefinitions: ok2: {
	x: #X & { name: "Y" }
	#X: !={ name: "X" }
	@test(eq, {x: {name: "Y"}, #X: {!={name: "X"}}})
}
inDefinitions: err1: {
	#X: =={ name: "X" }
	x: #X & { name: "Y" }
	@test(err, code=eval, at=x, contains="out of bound ==", pos=[1:6, 2:5])
}
inDefinitions: err2: {
	#X: !={ name: "X" }
	x: #X & { name: "X" }
	@test(err, code=eval, at=x, contains="out of bound !=", pos=[1:6, 2:5])
}
-- issue4251-panic.cue --
@experiment(structcmp)

// SimplifyBounds should handle EqualOp bounds
// without panicking, including in combination
// with other bound types.
// Regression: SimplifyBounds panicked on == bounds combined with other bound types.
// https://cuelang.org/issue/4251
issue4251: ok: {
	a: !="c" & =="a" & "a" @test(eq, "a")
	b: =="b" & !="c" & "b" @test(eq, "b")
	c: =="x" & >="a" & "x" @test(eq, "x")
	d: <="z" & =="y" & "y" @test(eq, "y")
}
issue4251: fail: {
	b: =="b" & !="b" & "b" @test(err, code=eval, contains="out of bound !=", pos=[0:13, 0:5, 0:21])
}
-- bool.cue --
boolBound: notEqual: {
	ok1: !=true
	ok1: false  @test(eq, false)

	ok2: !=false
	ok2: true   @test(eq, true)

	err1: !=true
	err1: true  @test(err, code=eval, contains="out of bound !=true", pos=[-1:8, 0:8])
}
// Ordered bounds are rejected on bool, as bool is not an ordered type.
boolBound: ordered: {
	gtr: >true   @test(err, code=eval, contains="cannot use bool for bound >", pos=[0:8])
	geq: >=true  @test(err, code=eval, contains="cannot use bool for bound >=", pos=[0:9])
	lss: <false  @test(err, code=eval, contains="cannot use bool for bound <", pos=[0:8])
	leq: <=false @test(err, code=eval, contains="cannot use bool for bound <=", pos=[0:9])
}
