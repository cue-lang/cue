-- in.cue --
@experiment(reflect)
issue4011: fullA: {
	let _hugoEnvironments = {
		default:    "_default"
		production: "production"
	}

	site: cls: _
	site: [_]: {
		fs: {
			Create: {
				for envID, envName in _hugoEnvironments
				let envConfig = hugo[envID]
				if envConfig != _|_ {
					config: Contents: envConfig
				}
			}
		}

		hugo: _
	}

	site: [_]: hugo: production: {}
	@test(eq, {site: cls: {
		fs: Create: config: Contents: {}
		hugo: production: {}
	}})
}
issue4011: fullB: {
	let _hugoEnvironments = {
		default:    "_default"
		production: "production"
	}

	site: cls: _
	site: [_]: {
		fs: {
			Create: {
				for envID, envName in _hugoEnvironments
				let envConfig = hugo[envID]
				if isValid(envConfig) {
					config: Contents: envConfig
				}
			}
		}

		hugo: _
	}

	site: [_]: hugo: production: {}
	@test(eq, {site: cls: {
		fs: Create: config: Contents: {}
		hugo: production: {}
	}})
}
issue4011: reducedA: {
	@test(eq, {result: foo: true, envs: foo: {}})
	result: {
		for envName in ["foo"]
		let env = envs[envName]
		if env != _|_ {
			(envName): true
		}
	}
	envs: foo: {}
}
issue4011: reducedB: {
	@test(eq, {result: foo: true, envs: foo: {}})
	result: {
		for envName in ["foo"]
		let env = envs[envName]
		if isValid(env) {
			(envName): true
		}
	}
	envs: foo: {}
}
