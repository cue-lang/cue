This test tests a case where a child node needs to be evaluated
before evaluating a parent has completed.
-- in.cue --
a: [for c in foo.bar.baz {
	c
}]

a: [{name: "http"}] @test(eq, [{name: "http", port: 8080}])

foo: {
	x.D

	bar: baz: [{port: 8080}]
	@test(eq, {bar: {baz: [{port: 8080}]}})
}

x: {
	D: bar: DSpec
	DSpec: {}
	@test(eq, {D: bar: {}, DSpec: {}})
}
-- out/compile --
--- in.cue
{
  a: [
    for _, c in 〈1;foo〉.bar.baz {
      〈1;c〉
    },
  ]
  a: [
    {
      name: "http"
    },
  ]
  foo: {
    〈1;x〉.D
    bar: {
      baz: [
        {
          port: 8080
        },
      ]
    }
  }
  x: {
    D: {
      bar: 〈1;DSpec〉
    }
    DSpec: {}
  }
}
