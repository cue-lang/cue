    t1: "foo"
    t2: "bar"
    〈0;t1〉?: {
      〈1;t2〉!: 3
    }
  }
}
--- in.cue
{
  a: "foo"
  "\(〈0;a〉)": {
    b: {
      c: {
        d: 〈3;e〉
      }
    }
  }
  e: 2
  b: "bar"
  "\(〈0;b〉)": {
    a: 1
  }
  c: 〈0;("\(〈0;b〉)")〉
  withError: {
    issue799: ({
      key: &(int, >=-2147483648, <=2147483647)
    } & {
      "\((1 & 2))": 123
    })
  }
  parenExprRefParent: {
    a: {
      〈1;x〉: {}
    }
    x: "foo"
  }
  parenExprRefEqual: {
    〈0;x〉: {}
    x: "foo"
  }
  chainedResolution: {
    x: {
      〈1;x〉.baz: "bar"
      〈1;x〉.foo: "baz"
      baz: "foo"
    }
  }
  noCycleError: {
    foo: {
      [_]: {
        #ID: "\(string)"
      }
    }
    foo: {
      bar: {
        entries: {
          〈3;foo〉.baz.#ID: true
        }
      }
    }
    foo: {
      baz: {}
    }
  }
}
--- issue3828.cue
{
  issue3828: {
    reduced: {
      a: {
        b: {}
      }
      a: {
        [_]: {
          if true let x = 〈2;str〉 {
            〈1;x〉: true
          }
        }
      }
      str: "foobot1"
    }
  }
  issue3828: {
    full: {
      orgs: {
        org1: {
          repos: {
            repo1: {}
          }
        }
      }
      botUser: "bot1"
      orgs: {
        [_]: {
          for repo_name, _ in 〈1〉.repos let orgBotUser = 〈3;botUser〉 {
            collaborators: {
              〈3;repo_name〉: {
                〈3;orgBotUser〉: true
              }
            }
          }
        }
      }
    }
  }
}
-- out/todo.txt --
c: v3 uses structure sharing (~(bar)), v2 expands it.
noCycleError: v3 adds extra error message about key value; v2 only reports invalid interpolation.
