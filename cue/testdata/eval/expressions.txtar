-- cue.mod/module.cue --
module: "test.com"
language: version: "v0.15.0"
-- in.cue --
a: 1         @test(eq, 1)
b: 1 + 2     @test(eq, 3)
c: 3 - 1     @test(eq, 2)
d: rem(5, 3) @test(eq, 2)

// StructCmp examples - now that the experiment is accepted
structComparison: {
    equalStructs:     {a: 1, b: 2} == {a: 1, b: 2} @test(eq, true)
    differentStructs: {a: 1} == {a: 2}             @test(eq, false)
    emptyStructs:     {} == {}                     @test(eq, true)
}

mixedComparison: {
    structVsNumber: {a: 1} == 1      @test(eq, false)
    listVsStruct:   [1, 2] == {a: 1} @test(eq, false)
    stringVsNumber: "hello" == 42    @test(eq, false)
}
-- out/eval/stats --
Leaks:  0
Freed:  5
Reused: 3
Allocs: 2
Retain: 0

Unifications: 5
Conjuncts:    5
Disjuncts:    5
-- out/compile --
--- in.cue
{
  a: 1
  b: (1 + 2)
  c: (3 - 1)
  d: rem(5, 3)
  structComparison: {
    equalStructs: ({
      a: 1
      b: 2
    } == {
      a: 1
      b: 2
    })
    differentStructs: ({
      a: 1
    } == {
      a: 2
    })
    emptyStructs: ({} == {})
  }
  mixedComparison: {
    structVsNumber: ({
      a: 1
    } == 1)
    listVsStruct: ([
      1,
      2,
    ] == {
      a: 1
    })
    stringVsNumber: ("hello" == 42)
  }
}
