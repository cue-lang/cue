// Issue #742
// Issue #405
#todo:inline: medium — disjunctions; use @test(final) for default selection
-- in.cue --
// Issue #129
permanentlyIncompleteOperands: {
	a: string + ":" + string
	a: "golang/go:1.13.5"
}

permanentlyIncompleteOperandsNested: {
	a: (int + 1) + (int + 1)
}

permanentlyIncompleteOperandsDisjunct: {
	a: (int + 1) | (int + 1)
}

// Wrong result for `meet`: multiplying a bound by a concrete value should
// yield an error when the result contradicts the bound.
// https://cuelang.org/issue/680
issue680: (>10 * 2) & 0

// In a definition, 'size: >=100 <=200' should be a compile error since
// applying <= to a bound (>=100) is not valid arithmetic.
// https://cuelang.org/issue/405
issue405: >=100 <= 200
