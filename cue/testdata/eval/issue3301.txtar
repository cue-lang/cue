# Tests that closedness is correctly propagated through multiple levels of
# embedded definitions with optional fields and conditional comprehensions.
# #Leaf embeds #Mid (which embeds #Base), all with optional fields. The nested
# if comprehensions inside #Leaf reference optional fields without triggering
# spurious closedness errors.
-- in.cue --
@experiment(predicates)
objectA: #LeafA & {} @test(eq, {extra?: {}, more?: int}) @test(closed)
objectB: #LeafB & {} @test(eq, {extra?: {}, more?: int}) @test(closed)

#Base: {
	extra?: {...}
	@test(eq, {extra?: {}})
	@test(closed)
}

#Mid: {
	#Base
	@test(eq, {extra?: {}})
	@test(closed)
}

#LeafA: {
	#Mid
	extra?:  {...}
	more?: int
	if extra.foo != _|_ {
		if more != _|_ {
			foo: "bar"
		}
	}
	@test(eq, {extra?: {}, more?: int})
	@test(closed)
}

#LeafB: {
	#Mid
	extra?:  {...}
	more?: int
	if exists(extra.foo) {
		if exists(more) {
			foo: "bar"
		}
	}
	@test(eq, {extra?: {}, more?: int})
	@test(closed)
}
-- out/errors.txt --
[incomplete] objectB: cannot reference optional field: extra:
    ./in.cue:34:12
[incomplete] #LeafB: cannot reference optional field: extra:
    ./in.cue:34:12
-- out/eval/stats --
