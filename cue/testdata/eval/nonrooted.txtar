# Tests non-rooted inline expressions and let bindings where the inline
# expression conflicts with a definition constraint. The evaluation should
# use the local context (overriding the definition's value), even when
# that creates a conflict detectable from the root.
# https://cuelang.org/issue/3977
-- in.cue --
issue3977: inlineExpr: {
	#NetworkID: 1
	#fn: {
		x:   #NetworkID
		out: x + 1
	}

	err: (#fn & {x: 2}).out @test(eq, 3, incorrect) @test(err:todo, p=1, code=eval,
		contains="conflicting values", args=[1, 2])
}
issue3977: inlineDisj1: {
	#NetworkID: "2" | "3" | "4"
	#fn: {
		x:   #NetworkID
		out: "value=\(x)"
	}

	err: (#fn & {x: "invalid"}).out @test(eq, "value=invalid", incorrect) @test(err:todo, p=1, code=eval, contains="conflicting values")
}
issue3977: inlineDisj2: {
	#NetworkID: 1
	#fn: {
		x:   #NetworkID
		out: x + 10
	}

	err: (#fn & {x: *2 | 4}).out @test(err, code=eval,
		suberr=(contains="conflicting values", args=[1, 2]),
		suberr=(contains="conflicting values", args=[4, 1]))
}
issue3977: inlineDisj3: {
	#NetworkID: 1
	#fn: {
		x:   #NetworkID
		out: x + 10
	}

	ok: (#fn & {x: *2 | int}).out @test(eq, 11)
}
issue3977: inlineLet: {
	#NetworkID: 1
	let p = {
		x:   #NetworkID
		out: x + 10
	} & {
		x: 2
	}

	err: p.out @test(eq, 12, incorrect) @test(err:todo, p=1, code=eval,
		contains="conflicting values", args=[1, 2])
}
