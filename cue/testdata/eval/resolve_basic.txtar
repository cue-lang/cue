-- in.cue --
a: 1     @test(eq, 1)
b: a + 1 @test(eq, 2)
d: {
	x: _
	y: b + x @test(err, code=incomplete, contains="non-concrete value", pos=[0:5, -1:5])
}
e: d & {
	x: 5
} @test(eq, {x: 5, y: 7})
-- out/errors.txt --
[incomplete] d.y: non-concrete value _ in operand to +:
    ./in.cue:5:5
    ./in.cue:4:5
