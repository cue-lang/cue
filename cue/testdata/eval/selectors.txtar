-- in.cue --
a: 1     @test(eq, 1)
b: a + 1 @test(eq, 2)
d: {
	x: _
	y: b + x @test(err, code=incomplete, pos=[0:5 -1:5], contains="non-concrete value")
}
e: d & {
	x: 5
} @test(eq, {x: 5, y: 7})
f: {
	a: "foo-bar": 3
	b: a."foo-bar"
} @test(eq, {a: {"foo-bar": 3}, b: 3})
g: {
	a: "foo-bar": c: 3
	b: a."foo-bar".c
} @test(eq, {a: {"foo-bar": {c: 3}}, b: 3})
-- out/errors.txt --
[incomplete] d.y: non-concrete value _ in operand to +:
    in.cue:5:5
    in.cue:4:5
