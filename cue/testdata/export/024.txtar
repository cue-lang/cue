raw: true
eval: true
noOpt: true
#inlinetest:exclude skip — tests export format, not evaluator semantics
-- in.cue --
{
	reg: {foo: 1, bar: {baz: 3}}
	#def: {
		a: 1

		sub: reg
	}
	val: #def
	#def2: {
		a: {b: int}
	}
	val2: #def2
}
-- out/compile --
--- in.cue
{
  {
    reg: {
      foo: 1
      bar: {
        baz: 3
      }
    }
    #def: {
      a: 1
      sub: 〈1;reg〉
    }
    val: 〈0;#def〉
    #def2: {
      a: {
        b: int
      }
    }
    val2: 〈0;#def2〉
  }
}
