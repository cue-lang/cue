-- in.cue --
import (
	"encoding/yaml"
	"regexp"
)

simplified: {
	x: d: R={
		".*"
		[R+""][0]
	}
	out: yaml.Marshal(x)
	@test(leq, {x: {d: ".*"}, out: string})
}

original: {
	#testableRegexp: R={
		string

		#test: close({
			in:  string
			out: regexp.FindSubmatch("^"+R+"$", in)[1]
		})
	}

	rule: {
		#patterns: {
			bar: #testableRegexp & {
				"(.*)"
				#test: {in: "testcontent", out: "testcontent"}
			}
		}
	}
	out: yaml.Marshal(rule)
	// TODO(inline): support multi-line strings.
	@test(leq, {out: string})
}
