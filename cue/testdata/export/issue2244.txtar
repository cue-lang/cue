-- in.cue --
package x

import (
	"strings"
)

_#matchPattern: {
	#pattern: string
	[
		// can't remove this builtin call
		if strings.HasSuffix(#pattern, "*") {

			// this let is required _within_ the if block
			// i.e. it can't be "inlined" with the if that
			// currently contains it
			let prefix = strings.TrimSuffix(#pattern, "*")

			prefix
		},
		"'\(#pattern)'",
	][0]
}

_#isReleaseTag: _#matchPattern & {#pattern: "refs/tags/v*", _}

#step: {
	if: number | string
}

m: #step & {
	if: _#isReleaseTag
}
@test(eq, {
	_#matchPattern$x: {_|_, #pattern: string}
	_#isReleaseTag$x: {
		"refs/tags/v"
		#pattern: "refs/tags/v*"
	}
	#step: {if: number | string}
	m: {
		if: {
			"refs/tags/v"
			#pattern: "refs/tags/v*"
		}
	}
})
