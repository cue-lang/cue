-- in.cue --

for x in [
	{a: "A", b: "B"},
	{a: "C", b: "D"},
	{a: "E", b: "F"},
] {
	a: "\(x.a)": b: "\(x.b)": x
}

for x in [
	{a: "A", b: "B"},
	{a: "C", b: "D"},
	{a: "E", b: "F"},
] {
	"\(x.a)": "\(x.b)": x
}

@test(eq, {
	a: {
		A: b: B: {a: "A", b: "B"}
		C: b: D: {a: "C", b: "D"}
		E: b: F: {a: "E", b: "F"}
	}
	A: B: {a: "A", b: "B"}
	C: D: {a: "C", b: "D"}
	E: F: {a: "E", b: "F"}
})
