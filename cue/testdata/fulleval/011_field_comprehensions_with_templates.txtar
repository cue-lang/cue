num: 1
a: {
	if num < 5 {
		[A=string]: [B=string]: {
			name: A
			kind: B
		}
	}
} @test(eq, {
	b: c: {
		d:    "bar"
		name: "b"
		kind: "c"
	}
})
a: b: c: d: "bar"
