#name: recursive evaluation within list
#evalFull
-- in.cue --
l: [a]          @test(eq, [{c: "t", d: "t"}]) @test(shareID=L, at=0)
a: b & {c: "t"} @test(eq, {c: "t", d: "t"})  @test(shareID=L)
b: {
	d: c
	c: string
} @test(eq, {d: string, c: string})
l1: [a1] @test(eq, [{c: "t", d: "st"}]) @test(shareID=L1, at=0)
a1: b1 & {c: "t"} @test(eq, {c: "t", d: "st"}) @test(shareID=L1)
b1: {
	d: "s" + c @test(err, code=incomplete)
	c: string
}
-- out/errors.txt --
[incomplete] b1.d: non-concrete value string in operand to +:
    ./in.cue:10:5
    ./in.cue:11:5
-- out/compile --
--- in.cue
{
  l: [
    〈1;a〉,
  ]
  a: (〈0;b〉 & {
    c: "t"
  })
  b: {
    d: 〈0;c〉
    c: string
  }
  l1: [
    〈1;a1〉,
  ]
  a1: (〈0;b1〉 & {
    c: "t"
  })
  b1: {
    d: ("s" + 〈0;c〉)
    c: string
  }
}
