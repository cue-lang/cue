#name: complex groundness  2
#evalFull
-- in.cue --
r1: f1 & {y: "c"} @test(eq, {
	y: "c"
	res: {d: "c", s: "ac"}
})

f1: {y: string, res: a.b.c & {d: y}} @test(eq, {
	y: string
	res: {
		d: string
		s: _|_ @test(err, code=incomplete,
			pos=[15:25, 6:34, 15:14, 20:23, 21:13])
	}
})

a: b: c: {d: string, s: "a" + d} @test(eq, {
	d: string
	s: _|_ @test(err, code=incomplete,
		pos=[15:25, 15:14, 20:23, 21:13])
})
a: b: [C=string]: {d: string, s: "a" + d}
a: b: c: d: string
-- out/errors.txt --
[incomplete] f1.res.s: non-concrete value string in operand to +:
    ./in.cue:15:25
