Retain: 0

Unifications: 10
Conjuncts:    17
Disjuncts:    0

NumCloseIDs: 5
-- out/evalalpha --
(struct){
  #Workflow: (#struct){
    jobs: (#struct){
    }
    #JobID: (_|_){
      // [incomplete] #Workflow.#JobID: error in call to or: empty list in call to or:
      //     ./in.cue:6:10
    }
  }
  foo: (#struct){
    jobs: (#struct){
      foo: (#struct){
      }
    }
    #JobID: (string){ "foo" }
  }
}
-- out/compile --
--- in.cue
{
  #Workflow: {
    jobs: {
      [string]: {}
    }
    #JobID: or([
      for k, _ in 〈1;jobs〉 {
        〈1;k〉
      },
    ])
  }
  foo: (〈0;#Workflow〉 & {
    jobs: {
      foo: {}
    }
  })
}
