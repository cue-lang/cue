#name: label and field aliases
#evalFull
-- in.cue --
p: [ID=string]: {name: ID}
p: q: _              @test(eq, {name: "q"})
A="foo=bar": "str"   @test(eq, "str")
a:           A       @test(eq, "str")
B=bb:        4       @test(eq, 4)
b1:          B       @test(eq, 4)
b1:          bb
C="\(a)":    5
c:           C       @test(eq, 5)
-- out/compile --
--- in.cue
{
  p: {
    [string]: {
      name: 〈1;-〉
    }
  }
  p: {
    q: _
  }
  "foo=bar": "str"
  a: 〈0;"foo=bar"〉
  bb: 4
  b1: 〈0;bb〉
  b1: 〈0;bb〉
  "\(〈0;a〉)": 5
  c: 〈0;("\(〈0;a〉)")〉
}
