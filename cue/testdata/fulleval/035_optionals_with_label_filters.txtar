#name: optionals with label filters
#evalFull
# Tests that optional fields with label filters enforce their constraints:
# fields not matching the pattern or constraint fail with "field not allowed"
# or bound violations. jobs is the happy path; jobs1, jobs2, jobs3 are faulty.
-- in.cue --
#JobID: =~"^[a-zA-Z]*$"
#Job: {
	name: string
	cmd:  string
}
#Jobs: {
	{[#JobID]: #Job}

	{[=~"Test$"]: name: =~"^test"}// Must work without ...
}

jobs: foo: name: "allGood"
jobs: foo: name: "allGood"

jobs1:          #Jobs
jobs1: foo1: {} // faulty

jobs2: #Jobs
jobs2: fooTest: name: "badName" // faulty

jobs3: #Jobs
jobs3: [string]: #Job
jobs3: fooTest1: name: "badName" // faulty

@test(err, code=eval, at=jobs1.foo1, contains="field not allowed", pos=[-9:8])
@test(err, code=eval, at=jobs3.fooTest1, contains="field not allowed", pos=[-4:8, -3:8])
@test(err, code=eval, at=jobs2.fooTest.name, contains="invalid value", pos=[-18:22, -24:8, -8:23])
-- out/errors.txt --
[eval] jobs1.foo1: field not allowed:
    ./in.cue:16:8
[eval] jobs2.fooTest.name: invalid value "badName" (out of bound =~"^test"):
    ./in.cue:9:22
    ./in.cue:3:8
    ./in.cue:19:23
[eval] jobs3.fooTest1: field not allowed:
    ./in.cue:22:8
    ./in.cue:23:8
-- out/todo.txt --
v2 reports additional error positions for jobs1.foo1 and jobs3.fooTest1 (extra positions for pattern/optional constraints); v3 only reports the direct definition position.
-- out/compile --
