# Tests non-structural direct cycles where a struct is unified with one of its own
# fields. c1 resolves successfully (bar.baz is merged), c2 conflicts because bar:1
# (int) cannot unify with the struct c2.bar.
-- in.cue --
c1: {bar: baz: 2} & c1.bar @test(eq, {bar: {baz: 2}, baz: 2})
c2: {bar:      1} & c2.bar @test(err, code=eval,
	contains="conflicting values",
	args=[{bar:1}, 1, struct, int],
	pos=[0:5, 0:16, 0:21])
-- out/errors.txt --
[eval] c2: conflicting values {bar:1} and 1 (mismatched types struct and int):
    ./in.cue:2:5
    ./in.cue:2:16
    ./in.cue:2:21
-- out/todo.txt --
v3 error message for c2 says "conflicting values {bar:1} and 1 (mismatched types struct and int)"
while v2 says "conflicting values 1 and {bar:1} (mismatched types int and struct)" (operand order swapped).
v3 also reports an extra position (in.cue:2:21) not present in v2.
-- out/eval/stats --
Leaks:  0
Freed:  7
Reused: 3
Allocs: 4
Retain: 2

Unifications: 7
Conjuncts:    10
Disjuncts:    8
-- out/compile --
--- in.cue
{
  c1: ({
    bar: {
      baz: 2
    }
  } & 〈0;c1〉.bar)
  c2: ({
    bar: 1
  } & 〈0;c2〉.bar)
}
