#name: json Marshaling detects incomplete
#evalFull
-- in.cue --
import "encoding/json"

a: json.Marshal({a: string}) @test(err, code=incomplete)

foo: {
	a: 3     @test(eq, 3)
	b: foo.c @test(err, code=incomplete)
}
b: json.Marshal(foo) @test(err, code=incomplete)
-- out/errors.txt --
[incomplete] a: error in call to encoding/json.Marshal: cannot convert incomplete value "string" to JSON:
    ./in.cue:3:4
    ./in.cue:3:21
[incomplete] foo.b: undefined field: c:
    ./in.cue:7:9
[incomplete] b: error in call to encoding/json.Marshal: undefined field: c:
    ./in.cue:9:4
    ./in.cue:7:9
-- out/eval/stats --
Leaks:  0
Freed:  16
Reused: 12
Allocs: 4
Retain: 5

Unifications: 16
Conjuncts:    24
Disjuncts:    21
-- out/compile --
--- in.cue
{
  a: 〈import;"encoding/json"〉.Marshal({
    a: string
  })
  foo: {
    a: 3
    b: 〈1;foo〉.c
  }
  b: 〈import;"encoding/json"〉.Marshal(〈0;foo〉)
}
