-- in.cue --
eq0: [] == []           @test(eq, true)
eq1: [...] == []        @test(eq, true)
eq2: [] == [...]        @test(eq, true)
eq3: [...] == [...]     @test(eq, true)

eq4: [1] == [1]           @test(eq, true)
eq5: [1, ...] == [1]      @test(eq, true)
eq6: [1] == [1, ...]      @test(eq, true)
eq7: [1, ...] == [1, ...] @test(eq, true)

eq8:  [1, 2] == [1, 2]           @test(eq, true)
eq9:  [1, 2, ...] == [1, 2]      @test(eq, true)
eq10: [1, 2] == [1, 2, ...]      @test(eq, true)
eq11: [1, 2, ...] == [1, 2, ...] @test(eq, true)

ne0: [] != []           @test(eq, false)
ne1: [...] != []        @test(eq, false)
ne2: [] != [...]        @test(eq, false)
ne3: [...] != [...]     @test(eq, false)

ne4: [1] != [1]           @test(eq, false)
ne5: [1, ...] != [1]      @test(eq, false)
ne6: [1] != [1, ...]      @test(eq, false)
ne7: [1, ...] != [1, ...] @test(eq, false)

ne8:  [1, 2] != [1, 2]           @test(eq, false)
ne9:  [1, 2, ...] != [1, 2]      @test(eq, false)
ne10: [1, 2] != [1, 2, ...]      @test(eq, false)
ne11: [1, 2, ...] != [1, 2, ...] @test(eq, false)

feq0: [] == [1]          @test(eq, false)
feq1: [...] == [1]       @test(eq, false)
feq2: [] == [1, ...]     @test(eq, false)
feq3: [...] == [1, ...]  @test(eq, false)

feq4: [1] == []         @test(eq, false)
feq5: [1, ...] == []    @test(eq, false)
feq6: [1] == [...]      @test(eq, false)
feq7: [1, ...] == [...] @test(eq, false)

feq8:  [1, 2] == [1]           @test(eq, false)
feq9:  [1, ...] == [1, 2]      @test(eq, false)
feq10: [1, 2] == [1, ...]      @test(eq, false)
feq11: [1, ...] == [1, 2, ...] @test(eq, false)

fne0: [] != [1]            @test(eq, true)
fne1: [...] != [1]         @test(eq, true)
fne2: [] != [1, ...]       @test(eq, true)
fne3: [1, ...] != [1, ...] @test(eq, false)

fne4: [1] != []         @test(eq, true)
fne5: [1, ...] != []    @test(eq, true)
fne6: [1] != [...]      @test(eq, true)
fne7: [1, ...] != [...] @test(eq, true)

fne8:  [1, 2] != [1]           @test(eq, true)
fne9:  [1, ...] != [1, 2]      @test(eq, true)
fne10: [1, 2] != [1, ...]      @test(eq, true)
fne11: [1, ...] != [1, 2, ...] @test(eq, true)

eqIncomplete1: [1] == [string]  @test(err, code=incomplete, contains="invalid right-hand value to '=='", pos=[0:16])

neIncomplete1: [1] != [string]  @test(err, code=incomplete, contains="invalid right-hand value to '!='", pos=[0:16])
