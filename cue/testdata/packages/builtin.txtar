#inlinetest:exclude imports an undefined package "x/y"; the inline runner cannot
# compile the source when package resolution fails.
-- x.cue --
import "x/y"

foo: [
	y,
]
-- out/evalalpha --
builtin package "x/y" undefined:
    ./x.cue:1:8
-- out/compile --
--- x.cue
{
  foo: [
    〈import;"x/y"〉,
  ]
}
