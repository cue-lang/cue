  opt?: {
    a: 1
    b: 〈1;opt〉
  }
  def: ({
    b: 2
    c: 〈1;def〉.b
  }|{
    b: 3
  })
  pattern3: {
    [string]: {
      labelName: 〈1;-〉
    }
    test: {}
  }
  pattern4: {
    [string]: {
      fieldRef: 〈1;(〈0;-〉)〉.x
    }
    test: {
      x: 99
    }
  }
  same: {
    a: 1
    b: 2
    c: (〈0;a〉 + 〈0;b〉)
  }
  chain: {
    a: 1
  }
  chain2: {
    ref: 〈1;chain〉.a
  }
  result2: 〈0;chain2〉.ref
  list: [
    1,
    2,
    3,
  ]
  b7: (〈0;list〉[0] + 〈0;list〉[1])
  disj: (1|2|3)
  b8: 〈0;disj〉
  deep: {
    [string]: {
      [string]: {
        outer: 〈2;-〉
        inner: 〈1;-〉
        value: 〈1;(〈0;-〉)〉.x
      }
      foo: {
        x: 1
      }
    }
    bar: {}
  }
  #Def: {
    field: 42
  }
  usedef: 〈0;#Def〉.field
}
