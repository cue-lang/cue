-- in.cue --
comprehensions: {
	a: {}
	b: {
		if a.b {
		}
	}
	c: {
		for x in a.b {x}
	}
	@test(eq, {
		a: {}
		b: _|_ @test(err, code=incomplete, contains="comprehensions.b: undefined field: b", pos=[4:8])
		c: _|_ @test(err, code=incomplete, contains="comprehensions.c: undefined field: b", pos=[8:14])
	})
}

openStruct: {
	a: {}
	b: a.c
	@test(eq, {
		a: {}
		b: _|_ @test(err, code=incomplete, contains="openStruct.b: undefined field: c", pos=[19:7])
	})
}

selectFromTop: {
	top: _
	a:   top.foo
	@test(eq, {
		top: _
		a: _|_ @test(err, code=incomplete, contains="selectFromTop.a: top.foo undefined as top is incomplete (type _)", pos=[28:7])
	})
}

indexOnTop: {
	top: _
	a:   top[2]
	@test(eq, {
		top: _
		a: _|_ @test(err, code=incomplete, contains="indexOnTop.a: top[2] undefined as top is incomplete (type _)", pos=[37:7])
	})
}

incompleteIndex: {
	top: _
	a:   [1][top] @test(err, code=eval, contains="invalid index top (invalid type _)", pos=[0:7, 0:11])
}
-- out/errors.txt --
[incomplete] comprehensions.b: undefined field: b:
    ./in.cue:4:8
[incomplete] comprehensions.c: undefined field: b:
    ./in.cue:8:14
[incomplete] openStruct.b: undefined field: c:
    ./in.cue:19:7
[incomplete] selectFromTop.a: top.foo undefined as top is incomplete (type _):
    ./in.cue:28:7
[incomplete] indexOnTop.a: top[2] undefined as top is incomplete (type _):
    ./in.cue:37:7
[eval] incompleteIndex.a: invalid index top (invalid type _):
    ./in.cue:46:7
    ./in.cue:46:11
