-- in.cue --
structShorthand: X={b: 3, c: X.b} @test(eq, {b: 3, c: 3})

// Note that X and Y are subtly different, as they have different bindings:
// one binds to the field, the other to the value. In this case, that does not
// make a difference.
fieldAndValue: X=foo: Y={3, #sum: X + Y} @test(eq, {3, #sum: 6})

valueCycle: b: X=3 + X @test(err, code=cycle, contains="cycle with field", pos=[0:22])

// Issue #1003
listValueAlias: X = [1, 2, X[0]] @test(eq, [1, 2, 1])

-- err.cue --
@experiment(structcmp)

cycleErr: X={
	err3: == (X + 1)
	err3: 4
	@test(err, code=eval, contains="invalid operands", pos=[1:12, 0:13, 1:16])
}
-- out/errors.txt --
[eval] cycleErr.err3: invalid operands {err3:_|_(cycleErr.err3: invalid operands value at path 'cycleErr' and 1 to '+' (type struct and int))} and 1 to '+' (type struct and int):
    ./err.cue:4:12
    ./err.cue:3:13
    ./err.cue:4:16
[cycle] valueCycle.b: cycle with field: X:
    ./in.cue:8:22
-- out/todo.txt --
v2 does not include cycleErr (no @experiment(structcmp) support).
v2 cycle error message: "[cycle] cycle error" vs v3 "cycle with field: X".
