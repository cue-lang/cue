cpct: cp & ct @test(eq, {x: int}) @test(closed) // closed({x: int})
ctcp: ct & cp @test(eq, {x: int}) @test(closed) // closed({x: int})
ctct: ct & ct @test(eq, {x: int}) @test(closed) @test(shareID=ctct) // {x: int, ...}
