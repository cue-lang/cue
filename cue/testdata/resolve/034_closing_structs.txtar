cpop: cp & op @test(eq, {x: int}) @test(closed) // closed({x: int})
opct: op & ct @test(eq, {x: int}) @test(closed) // {x: int, ...}
ctop: ct & op @test(eq, {x: int}) @test(closed) // {x: int, ...}
otcp: ot & cp @test(eq, {x: int}) @test(closed) // closed({x: int})
cpot: cp & ot @test(eq, {x: int}) @test(closed) // closed({x: int})
