-- in.cue --
// with concrete values
a1: >=1 & <=5 & 3 @test(eq, 3)
a2: >=1 & <=5 & 1 @test(eq, 1)
a3: >=1 & <=5 & 5 @test(eq, 5)
a4: >=1 & <=5 & 6 @test(err, code=eval, contains="invalid value 6", pos=[0:11, 0:17])
a5: >=1 & <=5 & 0 @test(err, code=eval, contains="invalid value 0", pos=[0:5, 0:17])

a6:  3 & >=1 & <=5 @test(eq, 3)
a7:  1 & >=1 & <=5 @test(eq, 1)
a8:  5 & >=1 & <=5 @test(eq, 5)
a9:  6 & >=1 & <=5 @test(err, code=eval, contains="invalid value 6", pos=[0:16, 0:6])
a10: 0 & >=1 & <=5 @test(err, code=eval, contains="invalid value 0", pos=[0:10, 0:6])

// with ranges
b1: >=1 & <=5 & >=1 & <=5 @test(eq, >=1 & <=5)
b2: >=1 & <=5 & >=1 & <=1 @test(eq, >=1 & <=1)
b3: >=1 & <=5 & >=5 & <=5 @test(eq, >=5 & <=5)
b4: >=1 & <=5 & >=2 & <=3 @test(eq, >=2 & <=3)
b5: >=1 & <=5 & >=3 & <=9 @test(eq, >=3 & <=5)
b6: >=1 & <=5 & >=5 & <=9 @test(eq, >=5 & <=5)
b7: >=1 & <=5 & >=6 & <=9 @test(err, code=eval, contains="incompatible number bounds", pos=[0:17, 0:11])

b8:  >=1 & <=5 & >=1 & <=5 @test(eq, >=1 & <=5)
b9:  >=1 & <=1 & >=1 & <=5 @test(eq, >=1 & <=1)
b10: >=5 & <=5 & >=1 & <=5 @test(eq, >=5 & <=5)
b11: >=2 & <=3 & >=1 & <=5 @test(eq, >=2 & <=3)
b12: >=3 & <=9 & >=1 & <=5 @test(eq, >=3 & <=5)
b13: >=5 & <=9 & >=1 & <=5 @test(eq, >=5 & <=5)
b14: >=6 & <=9 & >=1 & <=5 @test(err, code=eval, contains="incompatible number bounds", pos=[0:24, 0:6])

// ranges with more general types
c1: int & >=1 & <=5 @test(eq, >=1 & <=5 & int)
c2: >=1 & <=5 & int @test(eq, >=1 & <=5 & int)
c3: string & >=1 & <=5 @test(err, code=eval, contains="conflicting values string and >=1", pos=[0:5, 0:14])
c4: >=1 & <=5 & string @test(err, code=eval, contains="conflicting values string and >=1", pos=[0:5, 0:17])

// other types
s1: >="d" & <="z" & "e" @test(eq, "e")
s2: >="d" & <="z" & "ee" @test(eq, "ee")

n1: number & >=1 & <=2 @test(eq, >=1 & <=2)
n2: int & >=1.1 & <=1.3 @test(err, code=eval, contains="incompatible integer bounds", pos=[0:19, 0:11])
n3: >=1.0 & <=3.0 & 2 @test(eq, 2)
n4: >=0.0 & <=0.1 & 0.09999 @test(eq, 0.09999)
n5: >=1 & <=5 & 2.5 @test(eq, 2.5)
