#inlinetest:exclude skip — tests the debug printer, not evaluator semantics
-- in.cue --
k1: int8
k1: 44

k2: int64
k2: -8_000_000_000

s1: int8
s2: uint16
s3: float32
s4: uint
-- out/evalalpha --
(struct){
  k1: (int){ 44 }
  k2: (int){ -8000000000 }
  s1: (int){ &(>=-128, <=127, int) }
  s2: (int){ &(>=0, <=65535, int) }
  s3: (number){ &(>=-340282346638528859811704183484516925440, <=340282346638528859811704183484516925440) }
  s4: (int){ &(>=0, int) }
}
-- out/compile --
--- in.cue
{
  k1: &(int, >=-128, <=127)
  k1: 44
  k2: &(int, >=-9223372036854775808, <=9223372036854775807)
  k2: -8000000000
  s1: &(int, >=-128, <=127)
  s2: &(int, >=0, <=65535)
  s3: &(>=-340282346638528859811704183484516925440, <=340282346638528859811704183484516925440)
  s4: &(int, >=0)
}
