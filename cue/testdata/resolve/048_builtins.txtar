-- in.cue --
import (
	"list"
	"strings"
)

a1: {
	a: and([b, c])
	b: =~"oo"
	c: =~"fo"
} @test(eq, {
	a: =~"oo" & =~"fo"
	b: =~"oo"
	c: =~"fo"
})
a2: a1 & {a: "foo"} @test(eq, {a: "foo", b: =~"oo", c: =~"fo"})
a3: a1 & {a: "bar"} @test(err, code=eval, suberr=(code=eval, contains="invalid value \"bar\"", pos=[-8:5, -9:5, 0:14]), suberr=(code=eval, contains="invalid value \"bar\"", pos=[-7:5, -9:5, 0:14]))

o1: {
	a: or([b, c])
	b: string
	c: "bar"
} @test(eq, {a: string | "bar", b: string, c: "bar"})
o2: o1 & {a: "foo"} @test(eq, {a: "foo", b: string, c: "bar"})
o3: o1 & {a: "foo", b: "baz"} @test(err, code=eval, suberr=(code=eval, contains="conflicting values", pos=[-5:12, -3:5, 0:5, 0:14]), suberr=(code=eval, contains="conflicting values", pos=[-5:9, 0:5, 0:14, 0:24]))

// Issue #585
stringListErrors: {
	a: {
		x: [string, ...string]
		result: strings.Join(x, " ")
	}

	b: {
		x: [int, ...string]
		result: strings.Join(x, " ")
	}

	c: {
		x: []
		result: strings.Join(x, int)
	}
	@test(err, code=eval)
}

decimalListErrors: {
	a: {
		x: [string]
		result: list.Avg(x)
	}

	b: {
		x: [int, ...string]
		result: list.Avg(x)
	}
	@test(err, code=eval)
}
