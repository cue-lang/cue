-- issue3648.cue --
// Fully finalize values before passing them to builtins.

// "not properly initialized" error regression in evalv3 involving builtins:
// list.Concat received an unfinalized value when called from a pattern constraint.
// https://cuelang.org/issue/3648
import "list"

issue3648: reduced: {
	[string]: {
		a: list.Concat([b])
		b: [{}]
	}
	foo: {}
}
issue3648: full: {
	#Redirect: path?: string

	[string]: {
		// Note that this bug disappears if the order of the fields below is swapped.
		allRedirects: list.Concat([redirects])
		redirects:    [...#Redirect]
	}
	foo: {}
} @test(eq, {
	#Redirect: {path?: string}
	foo: {allRedirects: [], redirects: []}
})
