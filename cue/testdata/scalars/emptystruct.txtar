    }|{
      string
      #foo: string
    })
    check1a: (〈0;test1〉 & 〈0;#Def1〉)
    check1b: (〈0;test2〉 & 〈0;#Def1〉)
    #Def2: {
      ...
      #foo: string
      _
    }
    check2a: (〈0;test1〉 & 〈0;#Def2〉)
    check2b: (〈0;test2〉 & 〈0;#Def2〉)
  }
}
