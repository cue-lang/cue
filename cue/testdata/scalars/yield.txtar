    if 〈0;_#cond〉 {
      5
    }
  }
  ifScalarConflict: {
    _#cond: true
    if 〈0;_#cond〉 {
      5
    }
    "soo"
  }
  ifScalarNested: {
    _#cond: true
    if 〈0;_#cond〉 {
      {
        {
          5
        }
      }
    }
  }
}
