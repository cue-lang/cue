# Tests for closedness with recursive references.
-- test.cue --
package test

t01?: #Tree
t02?: #A
t03?: #Expr
t04?: _node
t05?: #WrapsNode
t06?: #ClosedLeft

#Tree: {
	value?: int
	children?: [...#Tree]
}

#A: {
	x?: int
	b?: #B
}

#B: {
	y?: string
	a?: #A
}

#Expr: int | {
	op?: string
	left?: #Expr
	right?: #Expr
}

_node: {
	value?: int
	next?: _node
}

#WrapsNode: _node

_left: {
	value?: int
	right?: _right
}

_right: {
	value?: string
	left?: _left
}

#ClosedLeft: _left

-- datatest/testdata.cue --
package datatest
treeValid: {
	data: {t01: {value: 1, children: [{value: 2}]}}
}
treeExtra: {
	data: {t01: {value: 1, extra: true}}
	error: true
}
treeNestedExtra: {
	data: {t01: {value: 1, children: [{value: 2, extra: true}]}}
	error: true
}
mutualValid: {
	data: {t02: {x: 1, b: {y: "hello", a: {x: 2}}}}
}
mutualExtra: {
	data: {t02: {x: 1, extra: true}}
	error: true
}
mutualDeepExtra: {
	data: {t02: {x: 1, b: {y: "hello", extra: true}}}
	error: true
}
exprValid: {
	data: {t03: {op: "+", left: 1, right: 2}}
}
exprExtra: {
	data: {t03: {op: "+", left: 1, right: 2, extra: true}}
	error: true
}
nodeValid: {
	data: {t04: {value: 1, next: {value: 2}}}
}
nodeExtra: {
	data: {t04: {value: 1, extra: true}}
}
wrapsNodeValid: {
	data: {t05: {value: 1, next: {value: 2}}}
}
wrapsNodeExtra: {
	data:  {t05: {value: 1, extra: true}}
	error: true
}
wrapsNodeNextExtra: {
	data: {t05: {value: 1, next: {value: 2, extra: true}}}
	error: true
}
closedLeftValid: {
	data: {t06: {value: 1, right: {value: "hello", left: {value: 2}}}}
}
closedLeftExtra: {
	data: {t06: {value: 1, extra: true}}
	error: true
}
closedLeftRightExtra: {
	data: {t06: {value: 1, right: {value: "hello", extra: true}}}
	error: true
}
closedLeftRightLeftExtra: {
	data: {t06: {value: 1, right: {value: "hello", left: {value: 2, extra: true}}}}
	error: true
}
-- out/generate-v3/schema --
{
	$schema: "https://json-schema.org/draft/2020-12/schema"
	$defs: {
		A: {
			type:                 "object"
			additionalProperties: false
			properties: {
				b: $ref: "#/$defs/B"
				x: type: "integer"
			}
		}
		B: {
			type:                 "object"
			additionalProperties: false
			properties: {
				a: $ref: "#/$defs/A"
				y: type: "string"
			}
		}
		ClosedLeft: {
			type:                 "object"
			additionalProperties: false
			properties: {
				right: {
					type:                 "object"
					additionalProperties: false
					properties: {
						left: $ref:  "#/$defs/ClosedLeft"
						value: type: "string"
					}
				}
				value: type: "integer"
			}
		}
		Expr: anyOf: [{
			type: "integer"
		}, {
			type:                 "object"
			additionalProperties: false
			properties: {
				left: $ref:  "#/$defs/Expr"
				op: type:    "string"
				right: $ref: "#/$defs/Expr"
			}
		}]
		Tree: {
			type:                 "object"
			additionalProperties: false
			properties: {
				children: {
					type: "array"
					items: $ref: "#/$defs/Tree"
				}
				value: type: "integer"
			}
		}
		WrapsNode: {
			type:                 "object"
			additionalProperties: false
			properties: {
				next: $ref:  "#/$defs/WrapsNode"
				value: type: "integer"
			}
		}
		"_left": {
			type: "object"
			properties: {
				right: $ref: "#/$defs/_right"
				value: type: "integer"
			}
		}
		"_node": {
			type: "object"
			properties: {
				next: $ref:  "#/$defs/_node"
				value: type: "integer"
			}
		}
		"_right": {
			type: "object"
			properties: {
				left: $ref:  "#/$defs/_left"
				value: type: "string"
			}
		}
	}
	type: "object"
	properties: {
		t01: $ref: "#/$defs/Tree"
		t02: $ref: "#/$defs/A"
		t03: $ref: "#/$defs/Expr"
		t04: $ref: "#/$defs/_node"
		t05: $ref: "#/$defs/WrapsNode"
		t06: $ref: "#/$defs/ClosedLeft"
	}
}
