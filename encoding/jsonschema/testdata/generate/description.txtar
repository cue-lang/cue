-- test.cue --
// This is the root description.
package test

// A name field.
name!: string

age?: int

// A user definition.
#User: {
	// The user's email.
	email!: string
	phone?: string
}

// The primary user.
user?: #User

-- datatest/tests.cue --
package datatest
simple: {
	data: {name: "Alice", user: {email: "alice@example.com"}}
}
missingName: {
	data: {age: 30}
	error: true
}
