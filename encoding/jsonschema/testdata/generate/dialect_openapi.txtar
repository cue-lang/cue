# Generation of the OpenAPI 3.0 schema dialect. Exercises the
# version-specific renderings: no $schema keyword, definitions under
# components/schemas with #/components/schemas refs, const rendered as a
# single-valued enum, exclusive bounds as boolean keywords accompanying
# minimum/maximum, null rendered via enum, type unions widened to anyOf,
# and tuples widened to a single items schema. The nick and fooOpt fields
# check that `T | null` is folded into a nullable: true keyword on the sole
# non-null arm (with the $ref isolated into an allOf for fooOpt), while the
# maybe field checks that a disjunction with several non-null arms keeps an
# explicit null arm (enum: [null]) rather than using nullable. The score
# field also checks
# that a reference combined with a constraint keeps the constraint in
# effect: OpenAPI 3.0 ignores keywords adjacent to $ref, so the constraint
# must be emitted as a sibling of an allOf rather than of the $ref itself.
#version: openapi
#path: root
-- test.cue --
package test

#Foo: {
	name?:   string
	age?:    int & >0 & <150
	kind?:   =="widget"
	nick?:   string | null
	either?: int | string
	maybe?:  int | string | null
	pair?:   [string, int]
	// A bug in development was triggered by the following.
	// Left in to check for regressions.
	sharedNull1?: null | string
	sharedNull2?: null | string
}
#Score: int
root: {
	foo?:    #Foo
	score?:  #Score & >0
	fooOpt?: #Foo | null
}
-- datatest/tests.cue --
package datatest

ok1: data: foo: {
	name:   "x"
	age:    30
	kind:   "widget"
	nick:   null
	either: "s"
	maybe:  null
	pair: ["a", 1]
}
ok2: data: foo: {
	nick:  "present"
	maybe: 3
}
okFooOptNull: data: fooOpt: null
okFooOpt: data: fooOpt: name:     "x"
errFooOpt: {
	data: fooOpt: name: 1
	error: true
}
errKind: {
	data: foo: kind: "other"
	error: true
}
errAgeTooBig: {
	data: foo: age: 200
	error: true
}
errAgeNotPositive: {
	data: foo: age: 0
	error: true
}
errEither: {
	data: foo: either: true
	error: true
}
okScore: data: score: 5
errScore: {
	data: score: 0
	error: true
}
-- out/generate-v3/schema --
{
	components: {
		schemas: {
			Foo: {
				type:                 "object"
				additionalProperties: false
				properties: {
					age: {
						allOf: [{
							type: "number"
						}, {
							type:             "integer"
							exclusiveMaximum: true
							exclusiveMinimum: true
							maximum:          150
							minimum:          0
						}]
					}
					either: {
						anyOf: [{
							type: "integer"
						}, {
							type: "string"
						}]
					}
					kind: {
						enum: ["widget"]
					}
					maybe: {
						anyOf: [{
							type: "integer"
						}, {
							type: "string"
						}, {
							enum: [null]
						}]
					}
					name: {
						type: "string"
					}
					nick: {
						nullable: true
						type:     "string"
					}
					pair: {
						type: "array"
						items: {
							anyOf: [{
								type: "string"
							}, {
								type: "integer"
							}]
						}
						maxItems: 2
						minItems: 2
					}
					sharedNull1: {
						nullable:    true
						type:        "string"
						description: "A bug in development was triggered by the following.\nLeft in to check for regressions."
					}
					sharedNull2: {
						nullable: true
						type:     "string"
					}
				}
			}
			Score: {
				type: "integer"
			}
		}
	}
	type: "object"
	properties: {
		foo: {
			$ref: "#/components/schemas/Foo"
		}
		fooOpt: {
			nullable: true
			allOf: [{
				$ref: "#/components/schemas/Foo"
			}]
		}
		score: {
			allOf: [{
				$ref: "#/components/schemas/Score"
			}, {
				type:             "number"
				exclusiveMinimum: true
				minimum:          0
			}]
		}
	}
}
