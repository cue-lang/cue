# The sized numeric builtin types should generate an OpenAPI format keyword
# (int32, int64, float, double) rather than being expanded to numeric bounds.
# See https://cuelang.org/issue/2529
#version: openapi
-- test.cue --
package test

i32?:    int32
i64?:    int64
f32?:    float32
f64?:    float64
i32opt?: int32 | null
-- out/generate-v3/schema --
{
	type: "object"
	properties: {
		f32: {
			type:    "number"
			maximum: 3.4028234663852886e+38
			minimum: -3.4028234663852886e+38
		}
		f64: {
			type:    "number"
			maximum: 1.7976931348623157e+308
			minimum: -1.7976931348623157e+308
		}
		i32: allOf: [{
			type: "number"
		}, {
			type:    "integer"
			maximum: 2.147483647e+09
			minimum: -2.147483648e+09
		}]
		i32opt: {
			nullable: true
			allOf: [{
				type: "number"
			}, {
				type:    "integer"
				maximum: 2.147483647e+09
				minimum: -2.147483648e+09
			}]
		}
		i64: allOf: [{
			type: "number"
		}, {
			type:    "integer"
			maximum: 9.223372036854776e+18
			minimum: -9.223372036854776e+18
		}]
	}
}
