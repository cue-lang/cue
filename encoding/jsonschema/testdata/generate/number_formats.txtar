# The sized numeric builtin types should generate an OpenAPI format keyword
# (int32, int64, float, double) rather than being expanded to numeric bounds.
# See https://cuelang.org/issue/2529
#version: openapi
-- test.cue --
package test

i32?:    int32
i64?:    int64
f32?:    float32
f64?:    float64
i32opt?: int32 | null
-- out/generate-v3/schema --
{
	type: "object"
	properties: {
		f32: {
			type:   "number"
			format: "float"
		}
		f64: {
			type:   "number"
			format: "double"
		}
		i32: {
			type:   "integer"
			format: "int32"
		}
		i32opt: {
			nullable: true
			type:     "integer"
			format:   "int32"
		}
		i64: {
			type:   "integer"
			format: "int64"
		}
	}
}
