// Main schema

import "struct"

close({
	fields?: struct.MinFields(3) & struct.MaxFields(10) & {[=~"^\\P{Lu}"]: _}
	additional?: {
		foo?: number
		bar?: number
		{[!~"^(foo|bar)$"]: string}
	}
	map?: [string]: string
	patterns?: {
		foo?: number
		bar?: number

		{[=~"^\\P{Lu}"]: string}

		{[=~"^\\P{Lo}"]: int}
		...
	}
	patternsNoProps?: {
		{[=~"^\\P{Lu}"]: string}

		{[=~"^\\P{Lo}"]: int}
		...
	}
	complex?: {
		foo?: number
		bar?: number

		{[=~"^\\P{Lu}"]: string}

		{[=~"^\\P{Lo}"]: int}
		{[!~"^\\P{Lu}" & !~"^\\P{Lo}" & !~"^(foo|bar)$"]: string}
	}
	multi?: >=7 |
	struct.MaxFields(5) & {
		foo?: number
		bar?: number
		...
	}
})
