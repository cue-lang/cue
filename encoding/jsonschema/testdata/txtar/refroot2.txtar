// This test tests the conversion and ordering of $defs.

-- schema.json --
{
  "$schema": "http://json-schema.org/draft-07/schema#",

  "properties": {
    "value": {},
    "next": { "$ref": "#" }
  }
}

-- out/decode-v3/extract --
@jsonschema(schema="http://json-schema.org/draft-07/schema#")
_schema
_schema:
	null | bool | number | string | [...] | {
		value?: _
		next?:  _schema
		...
	}
-- diff/-out/decode-v3/extract<==>+out/decode/extract --
diff old new
--- old
+++ new
@@ -1,7 +1,6 @@
 @jsonschema(schema="http://json-schema.org/draft-07/schema#")
 _schema
 _schema:
-
 	null | bool | number | string | [...] | {
 		value?: _
 		next?:  _schema
-- out/decode-v3-noshare/extract --
@jsonschema(schema="http://json-schema.org/draft-07/schema#")
_schema
_schema:
	null | bool | number | string | [...] | {
		value?: _
		next?:  _schema
		...
	}
-- diff/-out/decode-v3-noshare/extract<==>+out/decode/extract --
diff old new
--- old
+++ new
@@ -1,7 +1,6 @@
 @jsonschema(schema="http://json-schema.org/draft-07/schema#")
 _schema
 _schema:
-
 	null | bool | number | string | [...] | {
 		value?: _
 		next?:  _schema
-- out/decode/extract --
@jsonschema(schema="http://json-schema.org/draft-07/schema#")
_schema
_schema:

	null | bool | number | string | [...] | {
		value?: _
		next?:  _schema
		...
	}
