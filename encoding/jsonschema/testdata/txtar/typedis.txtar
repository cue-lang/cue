-- schema.json --
{
  "type": "object",
  "title": "Main schema",

  "properties": {
    "intOrString1": {
      "type": [ "string", "integer" ]
    },
    "intOrString2": {
      "oneOf": [
          { "type": "integer" },
          { "type": "string" }
      ]
    },
    "intOrString3": {
      "anyOf": [
          { "type": "integer" },
          { "type": "string" }
      ]
    },

    "disjunction": {
      "oneOf": [
        {
            "anyOf": [
                { "type": "integer" },
                { "type": "string" }
            ]
        },
        {
            "type": "integer",
            "minimum": 3
        }
      ]
    }
  }
}
