            "responses": {
               "200": {
                  "content": {
                     "application/json": {
                        "schema": {
                           "type": "object",
                           "additionalProperties": false,
                           "properties": {
                              "a": {
                                 "$ref": "#/components/schemas/openapi.test.a.util.Foo"
                              },
                              "b": {
                                 "$ref": "#/components/schemas/openapi.test.b.util.Foo"
                              }
                           },
                           "required": [
                              "a",
                              "b"
                           ]
                        }
                     }
                  }
               }
            }
         }
      }
   },
   "components": {
      "schemas": {
         "openapi.test.a.util.Foo": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
               "a": {
                  "type": "string"
               }
            },
            "required": [
               "a"
            ]
         },
         "openapi.test.b.util.Foo": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
               "b": {
                  "type": "string"
               }
            },
            "required": [
               "b"
            ]
         }
      }
   }
