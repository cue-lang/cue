#Config: {
	// Single bound behind a default.
	replicas: int & >=1 | *1

	// Two bounds behind a default.
	port: int & >=1 & <=65535 | *80

	// Bounded float behind a default (no int type).
	threshold: >=0.0 & <=1.0 | *0.5

	// Exclusive bounds behind a default.
	ratio: >0.0 & <1.0 | *0.5
}
