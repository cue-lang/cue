# Tests an inline schema at a position that references a components.schemas
# entry via $ref. Because all schemas are extracted together, the reference
# resolves to the shared #Item definition rather than being duplicated inline.
#extractv2
#Version: 3.0
-- in.cue --
openapi: "3.0.0"
info: {
	title:   "t"
	version: "1"
}
paths: "/x": get: responses: "200": content: "application/json": schema: {
	type: "object"
	properties: item: "$ref": "#/components/schemas/Item"
}
components: schemas: Item: {
	type:                 "object"
	additionalProperties: false
	properties: id: type: "integer"
}
-- out/TestExtractV2-v3/out.cue --
openapi: "3.0.0"
info: {
	title:   "t"
	version: "1"
}

#Item: close({id?: int})

paths: "/x": get: responses: "200": content: "application/json": schema: #: {
	item?: #Item
	...
}
-- out/TestExtractV2-v3-noshare/out.cue --
openapi: "3.0.0"
info: {
	title:   "t"
	version: "1"
}

#Item: close({id?: int})

paths: "/x": get: responses: "200": content: "application/json": schema: #: {
	item?: #Item
	...
}
