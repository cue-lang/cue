-- schema.cue --
to?:      string @xml(tag=to)
from?:    string @xml(tag=from)
heading?: string @xml(tag=heading)
body?:    string @xml(tag=body)
-- input.xml --
<note>
    <to>Tove</to>
    <from>Jani</from>
    <heading>Reminder</heading>
    <body>Don't forget me this weekend!</body>
</note>
-- out/decode --
to:      "Tove"
from:    "Jani"
heading: "Reminder"
body:    "Don't forget me this weekend!"
