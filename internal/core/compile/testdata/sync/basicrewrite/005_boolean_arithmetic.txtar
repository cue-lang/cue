-- in.cue --
a: true && true   @test(eq, true)
b: true || false  @test(eq, true)
c: false == true  @test(eq, false)
d: false != true  @test(eq, true)
e: true & true    @test(eq, true)
f: true & false   @test(err, code=eval, pos=[0:4, 0:11])
-- out/compile --
--- in.cue
{
  a: (true && true)
  b: (true || false)
  c: (false == true)
  d: (false != true)
  e: (true & true)
  f: (true & false)
}
