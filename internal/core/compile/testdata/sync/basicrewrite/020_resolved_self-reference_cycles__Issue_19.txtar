-- in.cue --
// CUE knows how to resolve the following:
x: y + 100 @test(eq, 200)
y: x - 100 @test(eq, 100)
x: 200

z1: z2 + 1 @test(eq, 11)
z2: z3 + 2 @test(eq, 10)
z3: z1 - 3 @test(eq, 8)
z3: 8

// TODO: extensive tests with disjunctions.
-- out/compile --
--- in.cue
{
  x: (〈0;y〉 + 100)
  y: (〈0;x〉 - 100)
  x: 200
  z1: (〈0;z2〉 + 1)
  z2: (〈0;z3〉 + 2)
  z3: (〈0;z1〉 - 3)
  z3: 8
}
