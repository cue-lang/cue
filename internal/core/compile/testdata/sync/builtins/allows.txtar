# Tests for the allows builtin: reports whether a given selector is
# allowed on an object. Delegates to Vertex.Accept.

-- in.cue --
// Open struct: any string label allowed.
openStruct: {
	s: {a: 1, b: 2}
	yesA:  allows(s, "a")
	yesNo: allows(s, "nope")
}

// Closed struct: only declared labels allowed.
closedStruct: {
	#Def: {a: int, b?: int}
	yesA: allows(#Def, "a")
	yesB: allows(#Def, "b")
	noC:  allows(#Def, "c")
}

// Open list: indices below length are valid, beyond are still allowed.
openList: {
	xs: [1, 2, 3, ...]
	in0: allows(xs, 0)
	in2: allows(xs, 2)
	in5: allows(xs, 5)
}

// Closed list: indices below length valid, beyond rejected.
closedList: {
	xs: [1, 2, 3]
	in0:  allows(xs, 0)
	in2:  allows(xs, 2)
	oob3: allows(xs, 3)
}
-- out/compile --
--- in.cue
{
  openStruct: {
    s: {
      a: 1
      b: 2
    }
    yesA: allows(〈0;s〉, "a")
    yesNo: allows(〈0;s〉, "nope")
  }
  closedStruct: {
    #Def: {
      a: int
      b?: int
    }
    yesA: allows(〈0;#Def〉, "a")
    yesB: allows(〈0;#Def〉, "b")
    noC: allows(〈0;#Def〉, "c")
  }
  openList: {
    xs: [
      1,
      2,
      3,
      ...,
    ]
    in0: allows(〈0;xs〉, 0)
    in2: allows(〈0;xs〉, 2)
    in5: allows(〈0;xs〉, 5)
  }
  closedList: {
    xs: [
      1,
      2,
      3,
    ]
    in0: allows(〈0;xs〉, 0)
    in2: allows(〈0;xs〉, 2)
    oob3: allows(〈0;xs〉, 3)
  }
}
