--- validator_is_top.cue
{
  issue3639: {
    a: ({
      〈1;#X〉
    } & 〈0;#X〉)
    a: {
      b: 1
    }
    #X: matchN(1, [
      {
        b: int
      },
    ])
  }
  issue3661: {
    #X: matchN(1, [
      {
        b!: int
      },
    ])
    a: {
      b: 1
    }
    a: 〈0;#X〉
    ["a"]: 〈0;#X〉
  }
  issue3678: {
    #X: matchN(1, [
      {
        a!: string
      },
      {
        c!: string
      },
    ])
    x: {
      c: "c"
    }
    y: 〈0;#X〉
    y: 〈0;x〉
    x: 〈0;#X〉
  }
  issue3981: {
    matchWithClose: {
      out: {
        close({
          f1: matchN(1, [
            〈2;#openStruct〉,
          ])
        })
        #openStruct: {
          ...
        }
      }
      out: {
        f1: {
          foo: [
            "bar",
          ]
