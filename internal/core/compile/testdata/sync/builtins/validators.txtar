      ]
      _a: 〈import;list〉.MinItems(1)
      〈0;_a〉[0]
    }
  }
}
--- issue3418.cue
{
  issue3418: {
    t1: (("foo" & matchN(1, [
      (1 & 2),
    ])) & matchN(1, [
      _,
    ]))
  }
  issue3418: {
    t2: (("foo" & matchN(1, [
      _,
    ])) & matchN(1, [
      (1 & 2),
    ]))
  }
  issue3418: {
    t3: {
      x: "foo"
      x: matchN(1, [
        _,
      ])
      x: matchN(1, [
        (1 & 2),
      ])
    }
  }
  issue3418: {
    t4: {
      x: "foo"
      x: matchN(1, [
        (1 & 2),
      ])
      x: matchN(1, [
        _,
      ])
    }
  }
}
