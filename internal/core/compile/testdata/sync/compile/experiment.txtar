-- cue.mod/module.cue --
module: "x.test"
language: version: "v0.13.0"
-- off.cue --
off: __test_experiment("off") @test(err, code=eval, contains="testing experiment disabled", pos=[0:6])

-- on.cue --
@experiment(testing)

on: __test_experiment("on") @test(eq, "on")

-- out/compile --
--- off.cue
{
  off: testExperiment("off")
}
--- on.cue
{
  on: testExperiment("on")
}
