-- cue.mod/module.cue --
module: "test.example"
language: version: "v0.15.0"

-- with_experiment.cue --
@experiment(explicitopen)

#Base: {
	x: int
}

// Test postfix ... operator with struct
a: #Base...

// Test with selector
b: foo.bar...

// Test with parentheses
c: (x & y)...

// Test with function call
d: fn()...

// As an expression
e: #Base... & {y: int}

foo: {}

x:  _
y:  _
fn: _

-- out/compile --
--- with_experiment.cue
{
  #Base: {
    x: int
  }
  a: 〈0;#Base〉...
  b: 〈0;foo〉.bar...
  c: (〈0;x〉 & 〈0;y〉)...
  d: 〈0;fn〉()...
  e: (〈0;#Base〉... & {
    y: int
  })
  foo: {}
  x: _
  y: _
  fn: _
}
