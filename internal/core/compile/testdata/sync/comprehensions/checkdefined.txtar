
Issue #1969
# Tests that undefined field comparisons with _|_ work correctly in
# comprehension conditions, including with close(), for loops, and let bindings.
# Issue #1969 and #2245.
#
# Each test exists in two forms: an "a" variant using the legacy comparison
# to bottom and a "b" variant using exists()/isValid()/isConcrete(). Both
# should remain green so the legacy surface and the new builtins are tested
# side-by-side.
-- in.cue --
@experiment(reflect)
import "list"

// All tests here should pass and the result of the okcN tests should be
// identical to those of the okoN tests.

xc: close({field: {}})
xo: field: {}

okc0a: {
	if xc.undefined == _|_ {a: 1}
}
okc0b: {
	if !exists(xc.undefined) {a: 1}
}
oko0a: {
	if xo.undefined == _|_ {a: 1}
}
oko0b: {
	if !exists(xo.undefined) {a: 1}
}

okc1a: {
	if xc.undefined != _|_ {a: 1}
}
okc1b: {
	if exists(xc.undefined) {a: 1}
}
oko1a: {
	if xo.undefined != _|_ {a: 1}
}
oko1b: {
	if exists(xo.undefined) {a: 1}
}

okc2a: {
	if ({} & {s: [for y in xc.undefined {}]}) != _|_ {a: 1}
}
okc2b: {
	if isValid({} & {s: [for y in xc.undefined {}]}) {a: 1}
}

oko2a: {
	if ({} & {s: [for y in xo.undefined {}]}) != _|_ {a: 1}
}
oko2b: {
	if isValid({} & {s: [for y in xo.undefined {}]}) {a: 1}
}

okc3a: {
	if ({s: [for y in xc.undefined {}]}) != _|_ {a: 1}
}
okc3b: {
	if isValid({s: [for y in xc.undefined {}]}) {a: 1}
}

oko3a: {
	if ({s: [for y in xo.undefined {}]}) != _|_ {a: 1}
}
oko3b: {
	if isValid({s: [for y in xo.undefined {}]}) {a: 1}
}

// Should Field s exist in okc or not? Depends on whether comparison to bottom
// is recursive or not. It probably should not.
// TODO: fix for new evaluator. But possibly address this with new builtins.
// issue1969: Tests that comparing let-bound expressions involving undefined
// fields to _|_ works correctly with list comprehensions.
// https://cuelang.org/issue/1969
issue1969: okca: {
	let X = xc.undefined
	let Y = {} & {s: [for y in list.Range(0, X, 1) {}]}

	if Y != _|_ {Y}
}
issue1969: okcb: {
	let X = xc.undefined
	let Y = {} & {s: [for y in list.Range(0, X, 1) {}]}

	if isValid(Y) {Y}
}

issue1969: okoa: {
	let X = xo.undefined
	let Y = {} & {s: [for y in list.Range(0, X, 1) {}]}

	if Y != _|_ {Y}
}
issue1969: okob: {
	let X = xo.undefined
	let Y = {} & {s: [for y in list.Range(0, X, 1) {}]}

	if isValid(Y) {Y}
}
-- issue2245.cue --
@experiment(reflect)

// Evaluator regression where comparing an incomplete struct to bottom in a
// comprehension condition produced incorrect results.
// https://cuelang.org/issue/2245
yo: {
	f: int
	g: f < 10
}
okyoa: {
	if yo != _|_ {a: 1}
}
okyob: {
	if isValid(yo) {a: 1}
}
okyoga: {
	if yo.g != _|_ {a: 1}
}
okyogb: {
	if isValid(yo.g) {a: 1}
}
-- incomplete.cue --
@experiment(reflect)

// Comparing to string is not an error. But for legacy reasons we want to still
// support this. We intend to have more clean and precise behavior with the
// builtins isdefined, isvalid, and isconcrete.
checkIncomplete: t1a: {
	f: [string]: {
		if a != _|_ {
			b: "d\(a)"
		}
		a: string
	}
	f: blah: {}
}
checkIncomplete: t1b: {
	f: [string]: {
		if isConcrete(a) {
			b: "d\(a)"
		}
		a: string
	}
	f: blah: {}
}
-- structs.cue --
@experiment(reflect)
structs: {
	bare: t1a: ({y: 2} & {x: 3}) != _|_
	bare: f2a: ({y: 2} & {x: 3}) == _|_
	bare: f3a: ({x: 1, y: 2} & {x: 3}) != _|_
	bare: t4a: ({x: 1, y: 2} & {x: 3}) == _|_

	bare: t1b: isValid({y: 2} & {x: 3})
	bare: f2b: !isValid({y: 2} & {x: 3})
	bare: f3b: isValid({x: 1, y: 2} & {x: 3})
	bare: t4b: !isValid({x: 1, y: 2} & {x: 3})

	select: t1a: ({y: 2} & {x: 3}).y != _|_
	select: f2a: ({y: 2} & {x: 3}).y == _|_
	select: f3a: ({x: 1, y: 2} & {x: 3}).y != _|_
	select: t4a: ({x: 1, y: 2} & {x: 3}).y == _|_

	// isValid only fails when the queried expression itself evaluates to
	// bottom — selecting .y from a struct that has a conflict on a sibling
	// field does not propagate the conflict to .y, so isValid sees the
	// successful selection. This is the principled distinction from
	// `!= _|_`, which is recursive on the parent struct.
	select: t1b: isValid(({y: 2} & {x: 3}).y)
	select: f2b: !isValid(({y: 2} & {x: 3}).y)
	select: f3b: isValid(({x: 1, y: 2} & {x: 3}).y)
	select: t4b: !isValid(({x: 1, y: 2} & {x: 3}).y)
}
