-- in.cue --
circularIf: {
	#list: {
		tail: #list | *null
		if tail != null {
		}
		@test(eq, {tail: null})
	}
}

circularFor: {
	#list: {
		tail: #list | *null
		for x in tail != null {
		}
		@test(err, code=eval,
			contains="cannot range over %s (found %s, want list or struct)",
			args=[tail != null, bool], pos=[2:12])
	}
}

// Print a bit more sensible error message than "empty disjunction" here.
// Issue #465
userError: {
	a: string | *_|_
	if a != "" {
	}
	@test(err, code=incomplete, contains="non-concrete value string", pos=[2:5, 1:5])
}

intField: {
	for i, _ in [1, 2] {
		(i): {
		}
	}
	@test(err, code=eval, contains="integer fields not supported", pos=[2:4])
}

// Issue #2403
conflictRangingOverSelf: {
	x: {
		name: string
		age:  int
	}

	x: {
		for k, _ in x {
			(k): k
		}
	}
	@test(err, code=eval, at=x.age,
		contains="conflicting values %s and %s (mismatched types %s and %s)",
		args=[int, "age", int, string],
		pos=[3:9, 6:5, 7:3, 8:9])
}
-- out/compile --
--- in.cue
{
  circularIf: {
    #list: {
      tail: (〈1;#list〉|*null)
      if (〈0;tail〉 != null) {}
    }
  }
  circularFor: {
    #list: {
      tail: (〈1;#list〉|*null)
      for _, x in (〈0;tail〉 != null) {}
    }
  }
  userError: {
    a: (string|*_|_(explicit error (_|_ literal) in source))
    if (〈0;a〉 != "") {}
  }
  intField: {
    for i, _ in [
      1,
      2,
    ] {
      〈1;i〉: {}
    }
  }
  conflictRangingOverSelf: {
    x: {
      name: string
      age: int
    }
    x: {
      for k, _ in 〈1;x〉 {
        〈1;k〉: 〈1;k〉
      }
    }
  }
}
