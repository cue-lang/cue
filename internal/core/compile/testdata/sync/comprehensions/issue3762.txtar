# Tests that comprehensions over intersections of hidden fields work correctly.
# Issue #3762: for comprehensions over _a & _b where both have patterns.
#
# Each test exists in two forms: an "A" variant using the legacy `!= _|_`
# comparison and a "B" variant using the exists() builtin. Both should
# produce identical results.
-- in.cue --
@experiment(reflect)
fullA: {
	kube: node: n1: {
		_CL: "l"
		_cs: (_CL): _a[(_CL)]
		_cs: (_CL): {
			opts: {}
		}
	}

	_a: "l": {
		_ba?: string
		opts: {
			if _ba != _|_ {b: (_ba)}
		}
	}

	for k, _ in _a & _b {
		x: 5
	}

	_a: [ID=_]: vms: [{name: "hello"}]
	_b: [ID=_]: vms: [{name: "again"}]
}
fullB: {
	kube: node: n1: {
		_CL: "l"
		_cs: (_CL): _a[(_CL)]
		_cs: (_CL): {
			opts: {}
		}
	}

	_a: "l": {
		_ba?: string
		opts: {
			if exists(_ba) {b: (_ba)}
		}
	}

	for k, _ in _a & _b {
		x: 5
	}

	_a: [ID=_]: vms: [{name: "hello"}]
	_b: [ID=_]: vms: [{name: "again"}]
}
reduced: p1A: {
	_cs: _a.l & {
		opts: {}
	}

	_a: l: {
		_ba?: string
		opts: {
			if _ba != _|_ {
				b: _ba
			}
		}
		vms: "hello"
	}

	_b: l: vms: "again"

	for k, _ in _a & _b {
		x: 5
	}
}
reduced: p1B: {
	_cs: _a.l & {
		opts: {}
	}

	_a: l: {
		_ba?: string
		opts: {
			if exists(_ba) {
				b: _ba
			}
		}
		vms: "hello"
	}

	_b: l: vms: "again"

	for k, _ in _a & _b {
		x: 5
	}
}
reduced: p2A: {
	for k, _ in _a & _b {
		x: 5
	}

	_cs: _a.l & {
		opts: {}
	}

	_a: l: {
		_ba?: string
		opts: {
			if _ba != _|_ {
				b: _ba
			}
		}
		vms: "hello"
	}

	_b: l: vms: "again"
}
reduced: p2B: {
	for k, _ in _a & _b {
		x: 5
	}

	_cs: _a.l & {
		opts: {}
	}

	_a: l: {
		_ba?: string
		opts: {
			if exists(_ba) {
				b: _ba
			}
		}
		vms: "hello"
	}

	_b: l: vms: "again"
}
reference: {
	_x: {
		f: true
	}

	_y: {
		f: false
	}

	for k, _ in _x & _y {
		ok: true
	}
}
-- out/compile --
