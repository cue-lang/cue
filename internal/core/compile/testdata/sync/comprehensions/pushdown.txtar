-- rework.cue --
regression1: {
	#Primary: {
		_Y: _
		let _X = _Y
		if len(_X.spec.command) > 0 {
			command: _X.spec.command
		}
	}
	#Rollout: {
		_X: _
		out: #Primary & {_Y: _X} & _X.patch
	}
	x: {
		spec: command: ["a"]
		patch: {}
	}
	out: #Rollout & {_X: x}
}
regression2: {
	#Primary: {
		_Y: _
		if len(_Y.spec.command) > 0 {
			command: _Y.spec.command
		}
	}
	#Rollout: {
		_X: _
		out: #Primary & {_Y: _X} & _X.patch
	}
	x: {
		spec: command: ["a"]
		patch: {}
	}
	out: #Rollout & {_X: x}
}
letCycleSelf: {
	#X: X={
		let this = X
