	}
}

// An optional field referencing a value only a pushed-down comprehension
// materializes must stay optional, not be upgraded to a regular member.
optionalRefStaysOptional: s={
	optionalRef?: string
	optionalRef?: s.field
	if true {
		field: "value"
	}
}
-- issue2208.cue --
// Regression where definitions that compiled correctly with 0.4.3 failed to
// compile with 0.5.0-beta.2 due to incorrect handling of void errors.
// https://cuelang.org/issue/2208
voidErrorIncomplete: {
	#Schema: [string]: {
		required: bool
		if !required {}
	}

	root: #Schema
	root: {
		if false {
			child: required: false
		}
	}
}

