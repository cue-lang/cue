-- issue1759.cue --
// Tests that len() and comprehensions correctly see the full struct/list value.
// https://cuelang.org/issue/1759
// Tests derived from Unity.
unity: success1: {
	#Config: {
		name: string
		type: string
	}

	#AnyConfig: {
		#Config
		...
	}

	#Env: {
		name: string
		configurations: [string]: #AnyConfig
	}

	envs: "e1": #Env & {
		configurations: c1: #Config
	}

	envs: [string]: configurations: [string]: {
		type: "foo"
		if type == "terraform" {
			backend: {
				type: "s3"
			}
		}
	}
}

// issue1759: Tests that len() correctly sees the full struct value when
// used as a comprehension condition. https://cuelang.org/issue/1759
issue1759: {
	_ports_map: {}
	if len(_ports_map) > 0 {
		port: _ports_map.a.port
	}
	if true {
		_ports_map: a: {port: "80"}
	}
}

arcAlignment: t1: {
	[string]: {
		if true {}
	}
	if false {
		c: _
	}
}
-- issue2111.cue --
// Evaluator regression where circular dependency in evaluation of conditionals
// caused incorrect results. All arc types, not just regular fields, should be pushed down.
// https://cuelang.org/issue/2111
letPushdown: {
	_c: y: 1

	a: {
		for k, v in _c {
			let x = v
			if x != _|_ {}
		}
	}
}
-- issue2113.cue --
// Evaluator regression where a nested comprehension caused "was already used"
// errors when the enclosing value was not yet fully evaluated.
// https://cuelang.org/issue/2113
// Ensure that an enclosing Value clause of a nested comprehension is evaluated
// before the nested comprehension itself is evaluated.
nestedWithEmbeddingOK: {
	c: [1]
	a: {
		for k, v in c {
			{x: 1}
			if a.x != _|_ {}
		}
	}
}

nestedWithDynamicFieldOK: {
	_c: y: 1

	a: {
		for k, v in _c {
			if x != _|_ {}
			x="\(k)": 1
		}
	}
}

// Errors in nested comprehensions should also be reported.
errorPropagation: {
	deployment: _
	for k, v in deployment {
		for k1, v2 in v.env2 {
			deployment: (k): x1: 1 // Report this error.
		}
	}
	for id in ["elem"] {deployment: (id): x2: 2}
}
-- issue2131.cue --
// issue2131: Tests that chained for comprehensions correctly produce output
// fields when iterating over nested structs. https://cuelang.org/issue/2131
issue2131: tests: {
	windows: {
		eg1: in: #"c:\d"#
		eg2: in: #"c:\test"#
		eg3: in: #"c:\test\d"#
	}

	for os, examples in tests for k, v in examples {
		(os): (k): out: "test"
	}
}
