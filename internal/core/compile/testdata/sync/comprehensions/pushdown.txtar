-- reflect.cue --
import "encoding/json"

unifyDynamicReflectSuccess: {
	for _, s in ["foo"] {
		X: {...}
		"\(s)": {
			X: {...} // cannot be _
			Y:       json.Marshal(X) // cannot be yaml, X cannot be literal
		}
	}

	[string]: X: {
		if true {
			x: y: {} // at least 2 nestings needed to expose problem
			// must be there
		}
	}
}
-- issue3621.cue --
// issue3621: evalv3 regression producing false "cyclic reference" errors for
// comprehensions with nested field definitions and references that evalv2 handles correctly.
// https://cuelang.org/issue/3621
issue3621: reduced: t1: {
	// This test ensures that when a reference is made within a comprehension,
	// with vertices marked as "pending", that these are not completed the
	// respective pushed-down comprehension is evaluated as well.
	if true {
		a: b1.b2.b3
		b1: b2: b3: "Foo"
	}
}
issue3621: reduced: t2: {
	outer: {}
	if true {
		inner: inner2: name: "Foo"
		outer: b: inner.inner2.name
	}
}
issue3621: full: {
	hello: "world"
	outer: [Name=string]: name: Name
	if true {
		inner: inner2: {
			name:           "Employees"
			description:    "All employees"
			privacy:        "secret"
			create_default: false
		}
		outer: outer2: {
			bar: (inner.inner2.name)
		}
	}
}
-- issue3708.cue --
// issue3708: evalv3 regression reporting a cyclic reference error when fields are
// accessed inside a comprehension using optional field patterns with if conditionals.
// https://cuelang.org/issue/3708
issue3708: {
	out: people.bob.kind

	// pattern constraint marks 'name' as member, which should not preclude name
	// from being futher evaluated to determine whether 'people' is pending.
	people: [string]: {
		kind:  "person"
		name?: string
	}

	if true {
		people: bob: name: "Bob"
	}
}
-- issue3729.cue --
// issue3729: evalv3 incorrectly reports "incomplete value null" for fields typed
// as a disjunction containing null (e.g. null | #T) inside if comprehensions.
// https://cuelang.org/issue/3729
issue3729: withDisjunction: {
	#Root: sub1?: #sub2?: bool
	root?: null | #Root
	if true {
		root: sub1?: #sub2: true
	}
}
issue3729: withoutDisjunction: {
	root?: null
	if true {
		root: #sub1?: #sub2: true
	}
}
issue3729: withoutDisjunctionWithEmbed: {
	root?: null
	if true {
		root: {_, #sub1?: #sub2: true}
	}
}
issue3729: definitionsOnly: {
	#Root: #sub1?: #sub2?: bool
	root?: null | #Root
	if true {
		root: #sub1?: #sub2: true
	}
}
issue3729: withEmbed: incomplete: {
	#Root: #sub1?: #sub2?: bool
	root?: null | #Root
	if true {
		root: {_, #sub1?: #sub2: true}
	}
}
issue3729: full: {
	#Application: spec:            #ApplicationSpec
	#ApplicationSpec: syncPolicy?: null | #SyncPolicy
	#SyncPolicy: automated?:       null | #SyncPolicyAutomated
	#SyncPolicyAutomated: {
		prune?:    bool
		selfHeal?: bool
	}
	argoApp: #Application & {
