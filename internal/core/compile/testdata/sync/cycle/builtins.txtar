          a: {
            b: "foo"
          }
        }
        #c: {
          b: string
          a: matchN(1, [
            〈2;#c〉,
          ])
        }
      }
    }
  }
  issue4037: {
    cycle: {
      _intlike: matchN(1, [
        〈import;strconv〉.Atoi(〈1〉),
      ])
      f: ("1233" & 〈0;_intlike〉)
    }
  }
}
