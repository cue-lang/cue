	}

	brokenCycleSuccess: {
		if #E.x != _|_ {
			#E: y: true
		}
		if #E.y == _|_ {
			#E: x: true
		}
		#E: [_]: bool
		#E: x:   true
	}

	doubleAddfail: {
		if #E.x == _|_ {
			#E: y: true
		}
		if #E.y == _|_ {
			#E: x: true
		}
		#E: [_]: bool
	}

	trippleSuccess: {
		if #E.x != _|_ {
			#E: y: true
		}
		if #E.y != _|_ {
			z: true
		}
		#E: x: true
	}
}
-- issue3836.cue --
// evalv3 regression: a conditional checking `(foo | bar) == _|_` (comparison
// to bottom) stopped working; the branch that fires when no optional field is
// set no longer triggers correctly.
// https://cuelang.org/issue/3836
issue3836: hidden: {
	_Value: {
		foo?: _
		bar?: _
		if (foo | bar) == _|_ {
			bar: type: "bar"
		}
		out: [if bar != _|_ {"bar is set"}]
	}
	_Value.out
	// Pushdown improvement: the comprehension guard (foo|bar) == _|_ now
	// correctly fires and sets bar, where previously (without pushdown) the
	// guard saw a spurious non-bottom value and did not fire.
}
issue3836: exposed: {
	foo?: _
	bar?: _
	if (foo | bar) == _|_ {
		bar: type: "bar"
	}
	out: [if bar != _|_ {"bar is set"}]
}
-- issue3838.cue --
// evalv3 regression: `if in.opt != _|_` inside a list expression stopped
// evaluating correctly; evalv2 exported cleanly but evalv3 produced wrong output.
// https://cuelang.org/issue/3838
issue3838: {
	#T: {
		subject: {
			in: opt?: foo: int
			out: [
				if in.opt != _|_ {in.opt.foo},
				0,
			][0]
		}
		_test: {
			assert: {
				pass: bool
			}
			assert: {
				notOk: _
				pass:  false
			} | {
				invoke: _
				res:    subject.out
				pass:   true
			}
		}
		results: _test.assert.pass
	}
	(#T & {
		_test: assert: invoke: "foo"
	}).results
}
