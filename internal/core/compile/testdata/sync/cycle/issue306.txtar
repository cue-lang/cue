# CUE panics/crashes instead of reporting a clean error when evaluating
# values with cyclic field dependencies.
# https://cuelang.org/issue/306
-- in.cue --
a: 12
#Controller: settings: {
	controller: #Controller
}
-- out/compile --
--- in.cue
{
  a: 12
  #Controller: {
    settings: {
      controller: 〈2;#Controller〉
    }
  }
}
