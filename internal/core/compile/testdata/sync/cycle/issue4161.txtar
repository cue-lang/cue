# Iterating over a file-level `let Self = self` used to report a spurious
# "structural cycle" error at a sibling dynamic field whose label is computed
# by a call whose argument list nests a let reference inside a literal list.
# Fixed by https://cuelang.org/cl/1229416, which narrowed the deferral of
# calls in cyclic contexts to calls with reference arguments; the nested
# reference below counts as literal-only, unlike the pure-literal calls
# covered by issue4230.txtar.
# https://cuelang.org/issue/4161
-- in.cue --
@experiment(aliasv2)

import "strings"

let Self = self

_all: [
	for topLevelField in Self
	for _ in topLevelField {}
]

let p = strings.ToUpper("")

f: (strings.Join([p, "test"], "")): {}
f: _
-- out/compile --
--- in.cue
{
  let Self#1 = 〈1〉
  _all: [
    for _, topLevelField in 〈1;let Self#1〉 for _, _ in 〈0;topLevelField〉 {},
  ]
  let p#2 = 〈import;strings〉.ToUpper("")
  f: {
    〈import;strings〉.Join([
      〈2;let p#2〉,
      "test",
    ], ""): {}
  }
  f: _
}
