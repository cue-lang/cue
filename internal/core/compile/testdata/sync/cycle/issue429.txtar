# `cue export` incorrectly rejects a `#Size` definition with interdependent
# bound constraints (`num: >res | *(1+res)`, `max: >=num | *num`) when a
# concrete value is provided, e.g. `a: #Size & { num: 5 }`. Expected output
# would be `{ res: 0, num: 5, max: 5 }` but instead CUE reports empty
# disjunction errors for both `num` and `max`. Works correctly in v0.2.1.
# TODO: a bound value resolving to a disjunction should probably be an error.
# In this case #Size.amx should resolve.
# https://cuelang.org/issue/429
-- in.cue --
// Range disjunction without cycle (checks only one-way).
#Size: {
	res: uint | *0
	min: >res | *(1 + res)
	max: >min | *min
}

s0: #Size & {res: 1} @test(eq, {
	res: 1
	min: *2 | >1
	max: *2 | >1 | >2
})

// This discards the default for max. This is correct, but unfortunate.
// TODO: is there a tweak to the default mechanism possible that would fix that?
//       Tread very carefully, though! Perhaps we could have a builtin that
//       discards any default, so that we can at least manually override this
//       behavior.
s1: #Size & {min: 5}  @test(eq, {
	min: 5
	res: *0 | >=0 & int
	max: *5 | >5
})
s2: #Size & {max: 5}  @test(eq, {
	max: 5
	res: *0 | >=0 & int
	min: *1 | >0
})
s3: #Size & {
	min: 5
	max: 10
} @test(eq, {min: 5, max: 10, res: *0 | >=0 & int})
es3: #Size & {
	min: 10
	max: 5
} @test(err, code=eval,
	suberr=(code=eval, path=max, contains="%d errors in empty disjunction:", args=[2], pos=[]),
	suberr=(code=eval, path=max, contains="conflicting values %s and %s", args=[1, 5], pos=[-29:16, -28:15, 0:6, 2:7]),
	suberr=(code=eval, path=max, contains="conflicting values %s and %s", args=[10, 5], pos=[-28:15, 0:6, 1:7, 2:7]),
	suberr=(code=eval, path=max, contains="invalid value %v (out of bound %s)", args=[5, >10], pos=[-28:7, 2:7]))

// Disjunctions with cycles
// TODO: improve error message here. Logic is correct, though.
#nonEmptyRange: {
	min: *1 | int
	min: <max
	max: >min
}
r1: #nonEmptyRange & {
	min: 3
} @test(eq, {
	min: _|_ @test(err, code=incomplete, contains="r1.min: non-concrete value max for bound < (and 2 more errors)", pos=[46:8])
	max: >3
})
r2: #nonEmptyRange & {
	max: 5
} @test(eq, {max: 5, min: *1 | <5 & int})
r3: #nonEmptyRange & {
	min: 3
	max: 6
} @test(eq, {min: 3, max: 6})

er3: #nonEmptyRange & {
	min: 5
	max: 5
} @test(err, code=eval,
	suberr=(code=eval, path=min, contains="conflicting values %s and %s", args=[1, 5], pos=[-18:8, 0:6, 1:7]),
	suberr=(code=eval, path=min, contains="invalid value %v (out of bound %s)", args=[5, <5], pos=[-17:7, 1:7]),
	suberr=(code=eval, path=min, contains="invalid value %v (out of bound %s)", args=[5, <5], pos=[-17:7, 1:7]))
-- out/compile --
--- in.cue
{
  #Size: {
    res: (&(int, >=0)|*0)
    min: (>〈0;res〉|*(1 + 〈0;res〉))
    max: (>〈0;min〉|*〈0;min〉)
  }
  s0: (〈0;#Size〉 & {
    res: 1
  })
  s1: (〈0;#Size〉 & {
    min: 5
  })
  s2: (〈0;#Size〉 & {
    max: 5
  })
  s3: (〈0;#Size〉 & {
    min: 5
    max: 10
  })
  es3: (〈0;#Size〉 & {
    min: 10
    max: 5
  })
  #nonEmptyRange: {
    min: (*1|int)
    min: <〈0;max〉
    max: >〈0;min〉
  }
  r1: (〈0;#nonEmptyRange〉 & {
    min: 3
  })
  r2: (〈0;#nonEmptyRange〉 & {
    max: 5
  })
  r3: (〈0;#nonEmptyRange〉 & {
    min: 3
    max: 6
  })
  er3: (〈0;#nonEmptyRange〉 & {
    min: 5
    max: 5
  })
}
