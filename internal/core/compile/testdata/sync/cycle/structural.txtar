      next: 〈1;let _schema_1#1〉
    }
    let _schema_1#1 = 〈0;schema〉
  }
  fieldsSumInfinite: {
    issue3310: {
      cheeseburger: 3.00
      fries: 2.00
      sprite: 1.00
      total: 〈import;list〉.Sum([
        for _, v in 〈2;issue3310〉 {
          〈1;v〉
        },
      ])
    }
  }
  listOptOK: {
    list: {
      head: int
      tail?: 〈1;list〉
    }
    a: (〈0;list〉 & {
      head: 3
      tail: {
        head: 2
      }
    })
  }
  issue2545: {
    #A: {
      B?: 〈1;#B〉
    }
