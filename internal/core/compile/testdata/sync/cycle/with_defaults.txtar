# Tests cycle patterns involving default values and range constraints.
-- in.cue --
range1: {
	min:   *1 | int
	range: >min
	range: 8
	@test(eq, {min: *1 | int, range: 8})
}
range2: {
	min: *1 | int
	max: int & >min
	@test(eq, {min: *1 | int, max: >1 & int})
}
rg: range2
rg: {
	//   min: 1
	max: 8
	@test(eq, {max: 8, min: *1 | int})
}
-- out/compile --
--- in.cue
{
  range1: {
    min: (*1|int)
    range: >〈0;min〉
    range: 8
  }
  range2: {
    min: (*1|int)
    max: (int & >〈0;min〉)
  }
  rg: 〈0;range2〉
  rg: {
    max: 8
  }
}
