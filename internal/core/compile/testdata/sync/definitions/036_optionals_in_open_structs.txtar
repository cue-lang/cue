-- in.cue --
A: {
	[=~"^[a-s]*$"]: int
}
B: {
	[=~"^[m-z]*$"]: int
}
#C: {A & B}
c: #C & {aaa: 3} @test(eq, {
	[=~"^[a-s]*$"]: int
	[=~"^[m-z]*$"]: int
	aaa: 3
})
-- out/compile --
--- in.cue
{
  A: {
    [=~"^[a-s]*$"]: int
  }
  B: {
    [=~"^[m-z]*$"]: int
  }
  #C: {
    (〈1;A〉 & 〈1;B〉)
  }
  c: (〈0;#C〉 & {
    aaa: 3
  })
}
