-- in.cue --
#A: {
	[=~"^[a-s]*$"]: int
}
#B: {
	[=~"^[m-z]*$"]: int
}

#C: #A & #B  @test(allows, moo) @test(allows=false, QQQ) @test(eq, {
	[=~"^[a-s]*$"]: int
	[=~"^[m-z]*$"]: int
})
c: #C
c: {aaa: 3 } @test(err, code=eval, at=aaa,
	hint="positions missing",
	contains="field not allowed", pos=[in.cue:2:2, 0:5])

#D: {#A & #B}
d: #D
d: {aaa: 3 } @test(err, code=eval, at=aaa,
	hint="positions missing",
	contains="field not allowed", pos=[in.cue:2:2, 0:5])
-- out/compile --
--- in.cue
{
  #A: {
    [=~"^[a-s]*$"]: int
  }
  #B: {
    [=~"^[m-z]*$"]: int
  }
  #C: (〈0;#A〉 & 〈0;#B〉)
  c: 〈0;#C〉
  c: {
    aaa: 3
  }
  #D: {
    (〈1;#A〉 & 〈1;#B〉)
  }
  d: 〈0;#D〉
  d: {
    aaa: 3
  }
}
