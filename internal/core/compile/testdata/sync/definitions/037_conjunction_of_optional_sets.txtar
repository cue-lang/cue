-- in.cue --
#A: {
	[=~"^[a-s]*$"]: int
}
#B: {
	[=~"^[m-z]*$"]: int
}

#C: #A & #B
c: #C
c: {aaa: 3 }

#D: {#A & #B}
d: #D
d: {aaa: 3 }
-- out/compile --
--- in.cue
{
  #A: {
    [=~"^[a-s]*$"]: int
  }
  #B: {
    [=~"^[m-z]*$"]: int
  }
  #C: (〈0;#A〉 & 〈0;#B〉)
  c: 〈0;#C〉
  c: {
    aaa: 3
  }
  #D: {
    (〈1;#A〉 & 〈1;#B〉)
  }
  d: 〈0;#D〉
  d: {
    aaa: 3
  }
}
