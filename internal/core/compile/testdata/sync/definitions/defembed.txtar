-- in.cue --
a: {
	#A
}

a: c: 1 @test(err, code=eval, contains="field not allowed", pos=[0:4])

#A: b: 1

b: {
	#A
    leaf: "leaf value"
    interpolation: "more \(leaf_ref)"
    leaf_ref: leaf

    @test(eq, {
		b:             1
		leaf:          "leaf value"
		interpolation: "more leaf value"
		leaf_ref:      "leaf value"
	})
}
-- out/compile --
--- in.cue
{
  a: {
    〈1;#A〉
  }
  a: {
    c: 1
  }
  #A: {
    b: 1
  }
  b: {
    〈1;#A〉
    leaf: "leaf value"
    interpolation: "more \(〈0;leaf_ref〉)"
    leaf_ref: 〈0;leaf〉
  }
}
