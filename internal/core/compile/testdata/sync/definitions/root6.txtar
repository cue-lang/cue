-- in.cue --
c: "foo"
a: b: int
#Schema
#Schema: close({ a: b: int}) @test(closed)

x: {
	c: "foo"
	a: b: int
	#Schema
	#Schema: close({ a: b: int})
} @test(closed)

@test(eq, {
	a: b: int
	c: "foo"
	#Schema: { a: b: int }
	x: {
		a: b: int
		c: "foo"
		#Schema: a: b: int
	}
})
-- out/compile --
--- in.cue
{
  c: "foo"
  a: {
    b: int
  }
  〈0;#Schema〉
  #Schema: close({
    a: {
      b: int
    }
  })
  x: {
    c: "foo"
    a: {
      b: int
    }
    〈0;#Schema〉
    #Schema: close({
      a: {
        b: int
      }
    })
  }
}
