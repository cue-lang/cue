-- issue3784.cue --
// evalv3 regressions with "conflicting values" and "field not allowed" errors
// when evaluating schemas similar to the GitHub Terraform provider schema.
// https://cuelang.org/issue/3784
issue3784: reduced: {
	#Schema: a: {
		kind: "A"
		b: c?: string
		b: {}
	} | {
		kind: "B"
	}

	out: #Schema
	out: a: {
		kind: "A"
		b: c: "x"
	}
}
issue3784: full: {
	#Schema: {
		pages?: {
			build_type?: "legacy" | "workflow"
			source?: {
				branch?: string
				path?:   string
			}
			cname?: string
		}
		pages?: {
			build_type!: "legacy"
			source!: {
				branch!: _
			}
		} | close({
			build_type!: "workflow"
			cname?:      _
		})
	}
	out: #Schema & {
		pages: {
			cname:      "foo.com"
			build_type: "legacy"
			source: {
				branch: "main"
				path:   "/"
			}
		}
	}
}
