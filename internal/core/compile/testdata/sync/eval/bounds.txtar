// Tests bound expression evaluation and simplification including binary bound
// simplification (incompatible bounds), simplifyExpr with non-concrete bound
// arguments, and struct equality bounds (== / !=). Also covers issue 4142
// (struct equality in definitions) and issue 4251 (SimplifyBounds panic on ==
// bounds combined with other bound types).
//
// Issue 4388: == / != bounds are valid on bool, ordered bounds are not. The !=
// and ordered cases are in bool.cue; the == cases need the structcmp
// experiment to parse, so they are in equalScalar (equals.cue).
-- cue.mod/module.cue --
module: "x.test"
language: version: "v0.14.0"
-- in.cue --
x0: 5
x1: b5 & 30

b0: <x0 & >0
b1: b0 & int
b2: int & <5.5
b3: <10 & <=5
b4: >=20 & >20
b5: >=21 & >20
b6: int & >5 & <=6

simplifyExpr: {
	// TODO: fill out later.
	less1: <(<3)
	less2: <(<=3)
	less3: <=(<3)
	less4: <=(<=3)
	less5: <(!=3)
	less6: <=(!=3)

	gtr1: >(>3)
	gtr2: >(>=3)
	gtr3: >=(>3)
	gtr4: >=(>=3)
	gtr5: >(!=3)
	gtr6: >=(!=3)

	lg1: <(>3)
	lg2: <(>=3)
	lg3: <=(>3)
	lg4: <=(>=3)

	gl1: >(<3)
	gl2: >(<=3)
	gl3: >=(<3)
	gl4: >=(<=3)

	ne1: !=(!=3)
	ne2: !=(<3)
	ne3: !=(<=3)
	ne4: !=(>3)
	ne5: !=(>=3)

	s:      string
	n:      number
	i:      int
	f:      float
	b:      bytes
	basic1: <(i)
	basic2: >(n)
	basic3: >=(s)
	basic4: <=(f)
	basic5: <=(b)

	// Do NOT interpret this the same as `!= type`.
	bne1: !=(s)
	bne2: !=(n)
	bne3: !=(n)
	bne4: !=(i)
	bne5: !=(b)

	e1: <(=~"foo")
	e2: >(null)
}
-- binarystring.cue --
simplifyBinary: strings: {
  err1: {
    p1: <"a" & >"b"
    p2: >"b" & <"a"
  }
  err2: {
    p1: >"b" & <="a"
    p2: <="a" & >"b"
  }
  err3: {
    p1: >="b" & <"b"
    p2: <"b" & >="b"
    p3: >"b" & <="b"
    p4: <="b" & >"b"
  }
  ok1: {
    p1: >"a" & <"b"
    p2: <"b" & >"a"
  }
  ok2: {
    p1: >"a" & <="b"
    p2: <="b" & >"a"
    p3: >="a" & <"b"
    p4: <"b" & >="a"
  }
  ok3: {
    p1: >="b" & <="c"
    p2: <="c" & >="b"
  }
  ok4: {
    p1: >="b" & <="b"
  }
}
simplifyBinary: byte: {
  err1: {
    p1: <'a' & >'b'
    p2: >'b' & <'a'
  }
  err2: {
    p1: >'b' & <='a'
    p2: <='a' & >'b'
  }
  err3: {
    p1: >='b' & <'b'
    p2: <'b' & >='b'
    p3: >'b' & <='b'
    p4: <='b' & >'b'
  }
  ok1: {
    p1: >'a' & <'b'
    p2: <'b' & >'a'
  }
  ok2: {
    p1: >'a' & <='b'
    p2: <='b' & >'a'
    p3: >='a' & <'b'
    p4: <'b' & >='a'
  }
  ok3: {
    p1: >='b' & <='c'
    p2: <='c' & >='b'
  }
  ok4: {
    p1: >='b' & <='b'
  }
}
-- binary.cue --
simplifyBinary: float: {
  err1: {
    p1: <1 & >2
    p2: >2 & <1
  }
  err2: {
    p1: >2 & <=1
    p2: <=1 & >2
  }
  err3: {
    p1: >=2 & <2
    p2: <2 & >=2
    p3: >2 & <=2
    p4: <=2 & >2
  }
  ok1: {
    p1: >1 & <2
    p2: <2 & >1
  }
  ok2: {
    p1: >=2 & <=2
    p2: <=2 & >=2
  }
}

simplifyBinary: integer: {
  [_]: [_]: int
  err1: {
    p1: <1 & >2
    p2: >2 & <1
  }
  err2: {
    p1: >2 & <=1
    p2: <=1 & >2
  }
  err3: {
    p1: >=2 & <2
    p2: <2 & >=2
    p3: >2 & <=2
    p4: <=2 & >2
  }
  err4: {
    p1: >1 & <2
    p2: <2 & >1
  }
  ok1: {
    p1: >=2 & <=3
    p2: <=3 & >=2
  }
  ok2: {
    p1: >=2 & <=2
    p2: <=2 & >=2
  }
  ok3: {
    p1: >=2 & <3
    p2: >2 & <=3
    p3: <3 & >=2
    p4: <=3 & >2
  }
}
-- equals.cue --
@experiment(structcmp)

equalScalar: {
	ok1: ==1
	ok1: 1

	ok2: [1, 2]
	ok2: ==[1, 2]

	err1: ==1
	err1: 2

	err2: [1, 2]
	err2: !=[1, 2]

	// == bounds are valid on bool too (issue 4388).
	ok3: ==true
	ok3: true

	err3: ==true
	err3: false
}
equalStruct: {
	ok1: =={}
	ok1: {}

	ok2: {a: 1, b: 2}
	ok2: =={a: 1, b: 2}

	err1: =={}
	err1: {a: 1, b: 2}

	err2: {a: 1, b: 2}
	err2: !={a: 1, b: 2}
}
nonConcrete: {
	ok0: =="foo"

	_int: int

	iErr1: ==_int

	iErr2: !=_int

	iErr3: ==_int
	iErr3: == 1

	ok4: ==1
	ok4: _int // v3: ==1 & int is not an error

	eErr5: =="foo"
	eErr5: _int

	eErr6: ==_int
	eErr6: "foo"
}
-- issue4142.cue --
@experiment(structcmp)

inDefinitions: ok1: {
	#X: =={ name: "X" }
	x: #X & { name: "X" }
}
inDefinitions: ok2: {
	x: #X & { name: "Y" }
	#X: !={ name: "X" }
}
inDefinitions: err1: {
	#X: =={ name: "X" }
	x: #X & { name: "Y" }
}
inDefinitions: err2: {
	#X: !={ name: "X" }
	x: #X & { name: "X" }
}
-- issue4251-panic.cue --
@experiment(structcmp)

// SimplifyBounds should handle EqualOp bounds
// without panicking, including in combination
// with other bound types.
// Regression: SimplifyBounds panicked on == bounds combined with other bound types.
// https://cuelang.org/issue/4251
issue4251: ok: {
	a: !="c" & =="a" & "a"
	b: =="b" & !="c" & "b"
	c: =="x" & >="a" & "x"
	d: <="z" & =="y" & "y"
}
issue4251: fail: {
	b: =="b" & !="b" & "b"
}
-- bool.cue --
boolBound: notEqual: {
	ok1: !=true
	ok1: false

	ok2: !=false
	ok2: true

	err1: !=true
	err1: true
}
// Ordered bounds are rejected on bool, as bool is not an ordered type.
boolBound: ordered: {
	gtr: >true
	geq: >=true
	lss: <false
	leq: <=false
}
-- out/compile --
--- binary.cue
{
  simplifyBinary: {
    float: {
      err1: {
        p1: (<1 & >2)
        p2: (>2 & <1)
      }
      err2: {
        p1: (>2 & <=1)
        p2: (<=1 & >2)
      }
      err3: {
        p1: (>=2 & <2)
        p2: (<2 & >=2)
        p3: (>2 & <=2)
        p4: (<=2 & >2)
      }
      ok1: {
        p1: (>1 & <2)
        p2: (<2 & >1)
      }
      ok2: {
        p1: (>=2 & <=2)
        p2: (<=2 & >=2)
      }
    }
  }
  simplifyBinary: {
    integer: {
      [_]: {
        [_]: int
      }
      err1: {
        p1: (<1 & >2)
        p2: (>2 & <1)
      }
      err2: {
        p1: (>2 & <=1)
        p2: (<=1 & >2)
      }
      err3: {
        p1: (>=2 & <2)
        p2: (<2 & >=2)
        p3: (>2 & <=2)
        p4: (<=2 & >2)
      }
      err4: {
        p1: (>1 & <2)
        p2: (<2 & >1)
      }
      ok1: {
        p1: (>=2 & <=3)
        p2: (<=3 & >=2)
      }
      ok2: {
        p1: (>=2 & <=2)
        p2: (<=2 & >=2)
      }
      ok3: {
        p1: (>=2 & <3)
        p2: (>2 & <=3)
        p3: (<3 & >=2)
        p4: (<=3 & >2)
      }
    }
  }
}
--- binarystring.cue
{
  simplifyBinary: {
    strings: {
      err1: {
        p1: (<"a" & >"b")
        p2: (>"b" & <"a")
      }
      err2: {
        p1: (>"b" & <="a")
        p2: (<="a" & >"b")
      }
      err3: {
        p1: (>="b" & <"b")
        p2: (<"b" & >="b")
        p3: (>"b" & <="b")
        p4: (<="b" & >"b")
      }
      ok1: {
        p1: (>"a" & <"b")
        p2: (<"b" & >"a")
      }
      ok2: {
        p1: (>"a" & <="b")
        p2: (<="b" & >"a")
        p3: (>="a" & <"b")
        p4: (<"b" & >="a")
      }
      ok3: {
        p1: (>="b" & <="c")
        p2: (<="c" & >="b")
      }
      ok4: {
        p1: (>="b" & <="b")
      }
    }
  }
  simplifyBinary: {
    byte: {
      err1: {
        p1: (<'a' & >'b')
        p2: (>'b' & <'a')
      }
      err2: {
        p1: (>'b' & <='a')
        p2: (<='a' & >'b')
      }
      err3: {
        p1: (>='b' & <'b')
        p2: (<'b' & >='b')
        p3: (>'b' & <='b')
        p4: (<='b' & >'b')
      }
      ok1: {
        p1: (>'a' & <'b')
        p2: (<'b' & >'a')
      }
      ok2: {
        p1: (>'a' & <='b')
        p2: (<='b' & >'a')
        p3: (>='a' & <'b')
        p4: (<'b' & >='a')
      }
      ok3: {
        p1: (>='b' & <='c')
        p2: (<='c' & >='b')
      }
      ok4: {
        p1: (>='b' & <='b')
      }
    }
  }
}
--- bool.cue
{
  boolBound: {
    notEqual: {
      ok1: !=true
      ok1: false
      ok2: !=false
      ok2: true
      err1: !=true
      err1: true
    }
  }
  boolBound: {
    ordered: {
      gtr: >true
      geq: >=true
      lss: <false
      leq: <=false
    }
  }
}
--- equals.cue
{
  equalScalar: {
    ok1: ==1
    ok1: 1
    ok2: [
      1,
      2,
    ]
    ok2: ==[
      1,
      2,
    ]
    err1: ==1
    err1: 2
    err2: [
      1,
      2,
    ]
    err2: !=[
      1,
      2,
    ]
    ok3: ==true
    ok3: true
    err3: ==true
    err3: false
  }
  equalStruct: {
    ok1: =={}
    ok1: {}
    ok2: {
      a: 1
      b: 2
    }
    ok2: =={
      a: 1
      b: 2
    }
    err1: =={}
    err1: {
      a: 1
      b: 2
    }
    err2: {
      a: 1
      b: 2
    }
    err2: !={
      a: 1
      b: 2
    }
  }
  nonConcrete: {
    ok0: =="foo"
    _int: int
    iErr1: ==〈0;_int〉
    iErr2: !=〈0;_int〉
    iErr3: ==〈0;_int〉
    iErr3: ==1
    ok4: ==1
    ok4: 〈0;_int〉
    eErr5: =="foo"
    eErr5: 〈0;_int〉
    eErr6: ==〈0;_int〉
    eErr6: "foo"
  }
}
--- in.cue
{
  x0: 5
  x1: (〈0;b5〉 & 30)
  b0: (<〈0;x0〉 & >0)
  b1: (〈0;b0〉 & int)
  b2: (int & <5.5)
  b3: (<10 & <=5)
  b4: (>=20 & >20)
  b5: (>=21 & >20)
  b6: ((int & >5) & <=6)
  simplifyExpr: {
    less1: <<3
    less2: <<=3
    less3: <=<3
    less4: <=<=3
    less5: <!=3
    less6: <=!=3
    gtr1: >>3
    gtr2: >>=3
    gtr3: >=>3
    gtr4: >=>=3
    gtr5: >!=3
    gtr6: >=!=3
    lg1: <>3
    lg2: <>=3
    lg3: <=>3
    lg4: <=>=3
    gl1: ><3
    gl2: ><=3
    gl3: >=<3
    gl4: >=<=3
    ne1: !=!=3
    ne2: !=<3
    ne3: !=<=3
    ne4: !=>3
    ne5: !=>=3
    s: string
    n: number
    i: int
    f: float
    b: bytes
    basic1: <〈0;i〉
    basic2: >〈0;n〉
    basic3: >=〈0;s〉
    basic4: <=〈0;f〉
    basic5: <=〈0;b〉
    bne1: !=〈0;s〉
    bne2: !=〈0;n〉
    bne3: !=〈0;n〉
    bne4: !=〈0;i〉
    bne5: !=〈0;b〉
    e1: <=~"foo"
    e2: >null
  }
}
--- issue4142.cue
{
  inDefinitions: {
    ok1: {
      #X: =={
        name: "X"
      }
      x: (〈0;#X〉 & {
        name: "X"
      })
    }
  }
  inDefinitions: {
    ok2: {
      x: (〈0;#X〉 & {
        name: "Y"
      })
      #X: !={
        name: "X"
      }
    }
  }
  inDefinitions: {
    err1: {
      #X: =={
        name: "X"
      }
      x: (〈0;#X〉 & {
        name: "Y"
      })
    }
  }
  inDefinitions: {
    err2: {
      #X: !={
        name: "X"
      }
      x: (〈0;#X〉 & {
        name: "X"
      })
    }
  }
}
--- issue4251-panic.cue
{
  issue4251: {
    ok: {
      a: ((!="c" & =="a") & "a")
      b: ((=="b" & !="c") & "b")
      c: ((=="x" & >="a") & "x")
      d: ((<="z" & =="y") & "y")
    }
  }
  issue4251: {
    fail: {
      b: ((=="b" & !="b") & "b")
    }
  }
}
