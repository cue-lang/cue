-- in.cue --
#A: {
	b?: int
	*{} | {c?: int} | {d?: int} | {e?: int}
} @test(eq, *{b?: int} | {b?: int, c?: int} | {b?: int, d?: int} | {b?: int, e?: int})

a: #A & {
	b: 3
	c: 3
} @test(eq, {b: 3, c: 3}) @test(closed)

b: #A & {
	c: 3
	d: 4
} @test(err, code=eval, contains="2 errors in empty disjunction",,
	suberr=(code=eval, contains="field not allowed", pos=[1:2]),
	suberr=(code=eval, contains="field not allowed", pos=[2:2])
)
-- out/compile --
--- in.cue
{
  #A: {
    b?: int
    (*{}|{
      c?: int
    }|{
      d?: int
    }|{
      e?: int
    })
  }
  a: (〈0;#A〉 & {
    b: 3
    c: 3
  })
  b: (〈0;#A〉 & {
    c: 3
    d: 4
  })
}
