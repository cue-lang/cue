-- in.cue --
i: int
s: string

t0: {
	v: i & s
}

t1: {
	#d1: {
		a: b: 3
	}

	#d2: {
		a: b: 4
	}

	x: #d1 & #d2
}
-- out/compile --
--- in.cue
{
  i: int
  s: string
  t0: {
    v: (〈1;i〉 & 〈1;s〉)
  }
  t1: {
    #d1: {
      a: {
        b: 3
      }
    }
    #d2: {
      a: {
        b: 4
      }
    }
    x: (〈0;#d1〉 & 〈0;#d2〉)
  }
}
