-- in.cue --
bulkToSelf: {
	a: {
		foo: [string]: int
		foo: bar:      "3" @test(err, any, code=eval, contains="conflicting values")
	}
}
intField: {
	@test(err, code=eval, contains="integer fields not supported", pos=[2:3])
	(2): string
}
-- out/compile --
--- in.cue
{
  bulkToSelf: {
    a: {
      foo: {
        [string]: int
      }
      foo: {
        bar: "3"
      }
    }
  }
  intField: {
    2: string
  }
}
