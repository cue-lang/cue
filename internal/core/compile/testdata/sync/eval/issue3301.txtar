# Tests that closedness is correctly propagated through multiple levels of
# embedded definitions with optional fields and conditional comprehensions.
# #Leaf embeds #Mid (which embeds #Base), all with optional fields. The nested
# if comprehensions inside #Leaf reference optional fields without triggering
# spurious closedness errors.
-- in.cue --
@experiment(reflect)
objectA: #LeafA & {}
objectB: #LeafB & {}

#Base: {
	extra?: {...}
}

#Mid: {
	#Base
}

#LeafA: {
	#Mid
	extra?: {...}
	more?: int
	if extra.foo != _|_ {
		if more != _|_ {
			foo: "bar"
		}
	}
}

#LeafB: {
	#Mid
	extra?: {...}
	more?: int
	if exists(extra.foo) {
		if exists(more) {
			foo: "bar"
		}
	}
}
-- out/compile --
--- in.cue
{
  objectA: (〈0;#LeafA〉 & {})
  objectB: (〈0;#LeafB〉 & {})
  #Base: {
    extra?: {
      ...
    }
  }
  #Mid: {
    〈1;#Base〉
  }
  #LeafA: {
    〈1;#Mid〉
    extra?: {
      ...
    }
    more?: int
    if (〈0;extra〉.foo != _|_(explicit error (_|_ literal) in source)) {
      if (〈1;more〉 != _|_(explicit error (_|_ literal) in source)) {
        foo: "bar"
      }
    }
  }
  #LeafB: {
    〈1;#Mid〉
    extra?: {
      ...
    }
    more?: int
    if exists(〈0;extra〉.foo) {
      if exists(〈1;more〉) {
        foo: "bar"
      }
    }
  }
}
