-- in.cue --
a: [...int]
a: [1, 2, 3, 5]
a: [1, 2, 3, d] @test(eq, [1, 2, 3, 5])

b: a[3] @test(eq, 5)
d: 5    @test(eq, 5)

c: [for x in [[1, 2]][0] {x + d}] @test(eq, [6, 7])
-- out/compile --
--- in.cue
{
  a: [
    ...int,
  ]
  a: [
    1,
    2,
    3,
    5,
  ]
  a: [
    1,
    2,
    3,
    〈1;d〉,
  ]
  b: 〈0;a〉[3]
  d: 5
  c: [
    for _, x in [
      [
        1,
        2,
      ],
    ][0] {
      (〈1;x〉 + 〈3;d〉)
    },
  ]
}
