-- in.cue --
a: {
	d: int
	b: {
		c: d
	}
	@test(eq, {
		d: int
		b: c: int
	})
}
x: {
	d: 2 @test(eq, 2)
	b: a.b.c @test(eq, int)
}
a1: y: 5
a1: a2: a3: a4: a5: a1.y
b: a1.a2.a3.a4.a5 @test(eq, 5)
-- out/compile --
--- in.cue
{
  a: {
    d: int
    b: {
      c: 〈1;d〉
    }
  }
  x: {
    d: 2
    b: 〈1;a〉.b.c
  }
  a1: {
    y: 5
  }
  a1: {
    a2: {
      a3: {
        a4: {
          a5: 〈4;a1〉.y
        }
      }
    }
  }
  b: 〈0;a1〉.a2.a3.a4.a5
}
