-- in.cue --
a: 1
b: a + 1
d: {
	x: _
	y: b + x
}
e: d & {
	x: 5
}
f: {
	a: "foo-bar": 3
	b: a."foo-bar"
}
g: {
	a: "foo-bar": c: 3
	b: a."foo-bar".c
}
-- out/compile --
--- in.cue
{
  a: 1
  b: (〈0;a〉 + 1)
  d: {
    x: _
    y: (〈1;b〉 + 〈0;x〉)
  }
  e: (〈0;d〉 & {
    x: 5
  })
  f: {
    a: {
      "foo-bar": 3
    }
    b: 〈0;a〉."foo-bar"
  }
  g: {
    a: {
      "foo-bar": {
        c: 3
      }
    }
    b: 〈0;a〉."foo-bar".c
  }
}
