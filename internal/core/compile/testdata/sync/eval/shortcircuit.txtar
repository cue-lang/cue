# Tests for @experiment(shortcircuit): short-circuit evaluation of && and ||.
# When the left operand alone determines the result, the right operand is not
# evaluated and any error or incomplete value it carries is suppressed.
-- cue.mod/module.cue --
module: "test.com"
language: version: "v0.17.0"
-- in.cue --
@experiment(shortcircuit)

// Incomplete fields used as right operands in short-circuit tests.
incompleteInt:  int
incompleteBool: bool

// Short-circuit && : false && anything = false.
// Right operand not evaluated; errors/incomplete values suppressed.
andFalseBottom:     false && _|_           @test(eq, false)
andFalseIncomplete: false && incompleteInt  @test(eq, false)
andFalseTrue:       false && true           @test(eq, false)

// No short-circuit: && falls through when left is true.
andTrueTrue:  true && true  @test(eq, true)
andTrueFalse: true && false @test(eq, false)

// Short-circuit || : true || anything = true.
// Right operand not evaluated; errors/incomplete values suppressed.
orTrueBottom:     true || _|_            @test(eq, true)
orTrueIncomplete: true || incompleteBool  @test(eq, true)
orTrueTrue:       true || true            @test(eq, true)

// No short-circuit: || falls through when left is false.
orFalseFalse: false || false @test(eq, false)
orFalseTrue:  false || true  @test(eq, true)
-- out/compile --
--- in.cue
{
  incompleteInt: int
  incompleteBool: bool
  andFalseBottom: (false && _|_(explicit error (_|_ literal) in source))
  andFalseIncomplete: (false && 〈0;incompleteInt〉)
  andFalseTrue: (false && true)
  andTrueTrue: (true && true)
  andTrueFalse: (true && false)
  orTrueBottom: (true || _|_(explicit error (_|_ literal) in source))
  orTrueIncomplete: (true || 〈0;incompleteBool〉)
  orTrueTrue: (true || true)
  orFalseFalse: (false || false)
  orFalseTrue: (false || true)
}
