raw: true
#inlinetest:exclude skip — tests export format, not evaluator semantics
-- in.cue --
{a: [1, 2], b: {for k, v in a if v > 1 {"\(k)": v}}}
-- out/compile --
--- in.cue
{
  {
    a: [
      1,
      2,
    ]
    b: {
      for k, v in 〈1;a〉 if (〈0;v〉 > 1) {
        "\(〈1;k〉)": 〈1;v〉
      }
    }
  }
}
