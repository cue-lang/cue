raw: true
eval: true
#inlinetest:exclude skip — tests export format, not evaluator semantics
-- in.cue --
{
	#Foo: {
		sgl:  #Bar
		ref:  null | #Foo
		ext:  #Bar | null
		ref:  null | #Foo
		ref2: null | #Foo.sgl
		...
	}
	#Foo: {
		"#Foo": 2
		...
	}
	#Bar: string
}
-- out/compile --
--- in.cue
{
  {
    #Foo: {
      sgl: 〈1;#Bar〉
      ref: (null|〈1;#Foo〉)
      ext: (〈1;#Bar〉|null)
      ref: (null|〈1;#Foo〉)
      ref2: (null|〈1;#Foo〉.sgl)
      ...
    }
    #Foo: {
      "#Foo": 2
      ...
    }
    #Bar: string
  }
}
