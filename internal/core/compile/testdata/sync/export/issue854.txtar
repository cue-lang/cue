-- cue.mod/module.cue --
module: "mod.test"
language: version: "v0.9.0"
-- a.cue --
package a

import "mod.test/b"

theb: b.name @test(err, code=incomplete, path=b, contains="undefined field: %s", args=[c], pos=[b/b.cue:5:6])
-- b/b.cue --
package b

import "mod.test/c"

b: c.c & {
	other: "name"
}

name: b.other
-- c/c.cue --
package c
-- out/compile --
--- a.cue
{
  theb: 〈import;"mod.test/b"〉.name
}
