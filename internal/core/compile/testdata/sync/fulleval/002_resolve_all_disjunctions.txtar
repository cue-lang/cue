-- in.cue --
service: [Name=string]: {
	name: string | *Name
	port: int | *7080
}
service: foo: _
service: bar: {port: 8000}
service: baz: {name: "foobar"}
-- out/compile --
--- in.cue
{
  service: {
    [string]: {
      name: (string|*〈1;-〉)
      port: (int|*7080)
    }
  }
  service: {
    foo: _
  }
  service: {
    bar: {
      port: 8000
    }
  }
  service: {
    baz: {
      name: "foobar"
    }
  }
}
