-- in.cue --
a: {
	{[name=_]: int}
	k: 1
  @test(eq, {k: 1})
}
b: {
	{[X=_]: {x: 0, y: *1 | int}}
	v: {}         @test(eq, {x: 0, y: *1 | int})
	w: {y: 0}     @test(eq, {y: 0, x: 0})
}
b: {[y=_]: {}} // TODO: allow different name
c: {
	{[Name=_]: {name: Name, y: 1}}
	foo: {}        @test(eq, {name: "foo", y: 1})
	bar: _         @test(eq, {name: "bar", y: 1})
}
-- out/compile --
--- in.cue
{
  a: {
    {
      [_]: int
    }
    k: 1
  }
  b: {
    {
      [_]: {
        x: 0
        y: (*1|int)
      }
    }
    v: {}
    w: {
      y: 0
    }
  }
  b: {
    [_]: {}
  }
  c: {
    {
      [_]: {
        name: 〈1;-〉
        y: 1
      }
    }
    foo: {}
    bar: _
  }
}
