#name: recursive evaluation within list
#evalFull
-- in.cue --
l: [a]
a: b & {c: "t"}
b: {
	d: c
	c: string
}
l1: [a1]
a1: b1 & {c: "t"}
b1: {
	d: "s" + c
	c: string
}
-- out/compile --
--- in.cue
{
  l: [
    〈1;a〉,
  ]
  a: (〈0;b〉 & {
    c: "t"
  })
  b: {
    d: 〈0;c〉
    c: string
  }
  l1: [
    〈1;a1〉,
  ]
  a1: (〈0;b1〉 & {
    c: "t"
  })
  b1: {
    d: ("s" + 〈0;c〉)
    c: string
  }
}
