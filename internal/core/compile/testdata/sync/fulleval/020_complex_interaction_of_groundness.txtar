-- in.cue --
res: [for x in a for y in x {y & {d: "b"}}]
res: [ a.b.c & {d: "b"}]

a: b: [C=string]: {d: string, s: "a" + d}
a: b: c: d: string
-- out/compile --
--- in.cue
{
  res: [
    for _, x in 〈1;a〉 for _, y in 〈0;x〉 {
      (〈1;y〉 & {
        d: "b"
      })
    },
  ]
  res: [
    (〈1;a〉.b.c & {
      d: "b"
    }),
  ]
  a: {
    b: {
      [string]: {
        d: string
        s: ("a" + 〈0;d〉)
      }
    }
  }
  a: {
    b: {
      c: {
        d: string
      }
    }
  }
}
