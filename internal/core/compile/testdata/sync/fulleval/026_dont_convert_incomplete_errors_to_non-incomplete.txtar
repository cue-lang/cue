#name: dont convert incomplete errors to non-incomplete
#evalFull
-- in.cue --
import "strings"

n1: {min: <max, max: >min}
n2: -num
n3: +num
n4: num + num
n5: num - num
n6: num * num
n7: num / num

b1: !is

s1: "\(str)"
s2: strings.ContainsAny("dd")
s3: strings.ContainsAny(str, "dd")

str: string
num: <4
is:  bool
-- out/compile --
--- in.cue
{
  n1: {
    min: <〈0;max〉
    max: >〈0;min〉
  }
  n2: -〈0;num〉
  n3: +〈0;num〉
  n4: (〈0;num〉 + 〈0;num〉)
  n5: (〈0;num〉 - 〈0;num〉)
  n6: (〈0;num〉 * 〈0;num〉)
  n7: (〈0;num〉 / 〈0;num〉)
  b1: !〈0;is〉
  s1: "\(〈0;str〉)"
  s2: 〈import;strings〉.ContainsAny("dd")
  s3: 〈import;strings〉.ContainsAny(〈0;str〉, "dd")
  str: string
  num: <4
  is: bool
}
