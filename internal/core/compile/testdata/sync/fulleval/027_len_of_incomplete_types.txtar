-- in.cue --
args: *[] | [...string]
v1:   len(args)         @test(eq, 0)
v2:   len([])           @test(eq, 0)
v3:   len({})           @test(eq, 0)
v4:   len({a: 3})       @test(eq, 1)
v5:   len({a: 3} | {a: 4}) @test(err, code=incomplete, contains="unresolved disjunction", pos=[0:7])
v6:   len('sf' | 'dd')     @test(err, code=incomplete, contains="unresolved disjunction", pos=[0:7])
v7:   len([2] | *[1, 2])   @test(eq, 2)
v8:   len([2] | [1, 2])    @test(err, code=incomplete, contains="unresolved disjunction", pos=[0:7])
v9:   len("😂")            @test(eq, 4,
	hint="len of strings should be deprecated and this should be an error in the future")
v10:  len("")              @test(eq, 0,
	hint="len of strings should be deprecated and this should be an error in the future")
-- out/compile --
--- in.cue
{
  args: (*[]|[
    ...string,
  ])
  v1: len(〈0;args〉)
  v2: len([])
  v3: len({})
  v4: len({
    a: 3
  })
  v5: len(({
    a: 3
  }|{
    a: 4
  }))
  v6: len(('sf'|'dd'))
  v7: len(([
    2,
  ]|*[
    1,
    2,
  ]))
  v8: len(([
    2,
  ]|[
    1,
    2,
  ]))
  v9: len("😂")
  v10: len("")
}
