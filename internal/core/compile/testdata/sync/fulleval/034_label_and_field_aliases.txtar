#name: label and field aliases
#evalFull
-- in.cue --
p: [ID=string]: {name: ID}
p: q: _
A="foo=bar": "str"   // TODO(inline): make this work @test(eq, at="foo=bar", "str")
a:           A
B=bb:        4
b1:          B
b1:          bb
C="\(a)":    5
c:           C

-- out/compile --
--- in.cue
{
  p: {
    [string]: {
      name: 〈1;-〉
    }
  }
  p: {
    q: _
  }
  "foo=bar": "str"
  a: 〈0;"foo=bar"〉
  bb: 4
  b1: 〈0;bb〉
  b1: 〈0;bb〉
  "\(〈0;a〉)": 5
  c: 〈0;("\(〈0;a〉)")〉
}
