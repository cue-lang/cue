#name: optional expanded before lookup
#evalFull
-- in.cue --
test: [ID=_]: {
	name: ID
}

test: A: {
	field1: "1"
	field2: "2"
}

B: test.A & {}
-- out/compile --
--- in.cue
{
  test: {
    [_]: {
      name: 〈1;-〉
    }
  }
  test: {
    A: {
      field1: "1"
      field2: "2"
    }
  }
  B: (〈0;test〉.A & {})
}
