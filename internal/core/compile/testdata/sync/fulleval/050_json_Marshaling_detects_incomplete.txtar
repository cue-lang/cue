#name: json Marshaling detects incomplete
#evalFull
-- in.cue --
import "encoding/json"

a: json.Marshal({a: string})

foo: {
	a: 3
	b: foo.c
}
b: json.Marshal(foo)
-- out/compile --
--- in.cue
{
  a: 〈import;"encoding/json"〉.Marshal({
    a: string
  })
  foo: {
    a: 3
    b: 〈1;foo〉.c
  }
  b: 〈import;"encoding/json"〉.Marshal(〈0;foo〉)
}
