-- in.cue --
// File-level @test(eq, ...) coexists with field-level @test attributes.
// Both assertions run. The file-level @test covers all fields, so per-field
// coverage is not required, but individual fields may still carry @test.

x: 1
y: x + 1
-- out/compile --
--- in.cue
{
  x: 1
  y: (〈0;x〉 + 1)
}
