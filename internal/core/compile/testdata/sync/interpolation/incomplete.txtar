Issue #553
-- in.cue --
a: "foo"
b: "boo"
commands: {
	#c: {
		help: "help!"
	}
}
out: """
    a is \(a)
    b is \(b)

    c is \(commands.#c.help)
    d is \(commands.#d.help)
    """
-- out/compile --
--- in.cue
{
  a: "foo"
  b: "boo"
  commands: {
    #c: {
      help: "help!"
    }
  }
  out: "a is \(〈0;a〉)
  b is \(〈0;b〉)
  
  c is \(〈0;commands〉.#c.help)
  d is \(〈0;commands〉.#d.help)"
}
