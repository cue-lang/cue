-- in.cue --
import "list"

l0: list.Repeat([int], 3)
l0: [1, 2, 3]
l2: [...{a: int}]
l2: [{a: 1}, {a: 2, b: 3}]

// TODO: work out a decent way to specify length ranges of lists.
// l3: <=10*[int]
// l3: [1, 2, 3, ...]

s1: (list.Repeat([int], 6))[2:3]
s2: [0, 2, 3][1:2]

i1: (list.Repeat([int], 6))[2]
i2: [0, 2, 3][2]

t0: [...{a: 8}]
t0: [{}]
t1: [...]
t1: [...int]

e0: list.Repeat([{}], 2)
e0: [{}]
e1: [...int]
e1: [...float]
