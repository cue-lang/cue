      field: 〈1〉.value
      value: "level1 value"
    }
  }
  listTest: {
    items: [
      1,
      2,
      〈1〉[0],
      〈1〉[1],
    ]
    first: 1
    second: 2
  }
  computed: {
    key: "test"
    value: 〈1〉["key"]
  }
  cycle: 〈1〉.cycle
}
--- letselfinline.cue
{
  letSelfInline: {
    S: {
      let this#1 = 〈1〉
      raw: string
      data: 〈0;let this#1〉.raw
      chk: 〈0;let this#1〉.data
    }
    res: (〈0;S〉 & {
      raw: "alice"
    }).chk
  }
  letSelfInlineConj: {
    #T: {
      let this#2 = 〈1〉
      raw: string
      data: 〈0;let this#2〉.raw
    }
    #T: {
      let this#3 = 〈1〉
      chk: 〈0;let this#3〉.data
    }
    res: (〈0;#T〉 & {
      raw: "alice"
    }).chk
  }
}
--- list.cue
{
  #IntStrings: {
    〈import;list〉.Repeat([
      int,
      string,
    ], div(len(〈1〉), 2))
  }
  listCheck: {
    ok1: 〈1;#IntStrings〉
  }
  listCheck: {
    ok1: [
      1,
      "foo",
      2,
      "bar",
    ]
  }
  listCheck: {
    err: 〈1;#IntStrings〉
  }
  listCheck: {
    err: [
      1,
      "foo",
      "bar",
      2,
    ]
  }
}
