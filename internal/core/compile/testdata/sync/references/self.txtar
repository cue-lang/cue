Test various self reference cases.
-- in.cue --
@experiment(aliasv2)

// Basic self usage - top level
a: self.b
b: "hello"

// Nested self usage - should refer to x struct
x: {
    y: self.z
    z: "world"
}

// Shorthand notation - self should refer to foo struct
foo: bar: self.baz
foo: baz: "greeting" // TODO(inline): reference marking does not work with "self"

// Multiple levels of nesting
nested: {
    level1: {
        field: self.value
        value: "level1 value"
    }
}

// Self in list context
listTest: {
    items: [1, 2, self[0], self[1]]
    first: 1
    second: 2
}

// Self with computed selectors
computed: {
    key: "test"
    value: self["key"]
}

// Cyclic reference detection
cycle: self.cycle

-- list.cue --
@experiment(aliasv2)
import "list"

#IntStrings: {list.Repeat([int, string], div(len(self), 2))}
listCheck: ok1: #IntStrings
listCheck: ok1: [1, "foo", 2, "bar"]

listCheck: err: #IntStrings
listCheck: err: [1, "foo", "bar", 2]

-- withlet.cue --
@experiment(try,aliasv2)

withLet: {
	let X = self
	foo: 1

	bar: {
		baz: X.foo
	}
}

// A let bound to self must capture fields produced by if/for/try
// comprehensions, not only statically declared ones.
// See https://cuelang.org/issue/4376.
withLetComprehension: {
	let X = self
	direct: "a"
	if true {
		viaIf: "b"
	}
	for k, v in {viaFor: "c"} {
		(k): v
	}
	try {
		viaTry: "d"
	}
	seeDirect: X.direct
	seeIf:     X.viaIf
	seeFor:    X.viaFor
	seeTry:    X.viaTry
}
-- validator.cue --
@experiment(structcmp)
@experiment(aliasv2)

validator: {
	err1: {{{{== (self + 1)}}}}
	err1: 2

	err2: {== (self + 1)}
	err2: 2
}

cyclicErr: {
	err3: == (self + 1)
	err3: 4
}

-- comprehension.cue --
@experiment(aliasv2)

// self inside a comprehension body resolves to the enclosing struct, not to
// the comprehension's own scope. A comprehension's for/let/try clauses and
// body are transparent to self. Issue #4422.
forComp: {
	n: 2
	for i in [1, 2] {"k\(i)": self.n}
}

// self inside a list comprehension refers to the enclosing list.
listComp: [10, 20, for _ in [1] {self[0]}]

// self inside an if comprehension.
ifComp: {
	n: 3
	if true {m: self.n}
}

// self in a nested struct resolves to that struct, not the outer one.
nestComp: {
	outer: {
		v: 5
		for i in [1] {"c\(i)": self.v}
	}
}

// self across two nested for comprehensions.
doubleComp: {
	n: 7
	for i in [1] for j in [1] {"d\(i)\(j)": self.n}
}

-- experiment_test.cue --
// Test self usage without experiment enabled (should fail)

a: {
    b: self.c
    c: 3
}

-- out/compile --
--- comprehension.cue
{
  forComp: {
    n: 2
    for _, i in [
      1,
      2,
    ] {
      "k\(〈1;i〉)": 〈3〉.n
    }
  }
  listComp: [
    10,
    20,
    for _, _ in [
      1,
    ] {
      〈3〉[0]
    },
  ]
  ifComp: {
    n: 3
    if true {
      m: 〈1〉.n
    }
  }
  nestComp: {
    outer: {
      v: 5
      for _, i in [
        1,
      ] {
        "c\(〈1;i〉)": 〈3〉.v
      }
    }
  }
  doubleComp: {
    n: 7
    for _, i in [
      1,
    ] for _, j in [
      1,
    ] {
      "d\(〈2;i〉)\(〈1;j〉)": 〈4〉.n
    }
  }
}
