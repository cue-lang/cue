--- list.cue
{
  #IntStrings: {
    〈import;list〉.Repeat([
      int,
      string,
    ], div(len(〈1〉), 2))
  }
  listCheck: {
    ok1: 〈1;#IntStrings〉
  }
  listCheck: {
    ok1: [
      1,
      "foo",
      2,
      "bar",
    ]
  }
  listCheck: {
    err: 〈1;#IntStrings〉
  }
  listCheck: {
    err: [
      1,
      "foo",
      "bar",
      2,
    ]
  }
}
--- validator.cue
{
  validator: {
    err1: {
      {
        {
          {
            ==(〈1〉 + 1)
          }
        }
      }
    }
    err1: 2
    err2: {
      ==(〈1〉 + 1)
    }
    err2: 2
  }
  cyclicErr: {
    err3: ==(〈1〉 + 1)
    err3: 4
  }
}
--- withlet.cue
{
  withLet: {
    let X#1 = 〈1〉
    foo: 1
    bar: {
      baz: 〈1;let X#1〉.foo
    }
  }
  withLetComprehension: {
    let X#2 = 〈1〉
    direct: "a"
    if true {
      viaIf: "b"
    }
    for k, v in {
      viaFor: "c"
    } {
      〈1;k〉: 〈1;v〉
    }
    try {
      viaTry: "d"
    }
    seeDirect: 〈0;let X#2〉.direct
    seeIf: 〈0;let X#2〉.viaIf
    seeFor: 〈0;let X#2〉.viaFor
    seeTry: 〈0;let X#2〉.viaTry
  }
}
