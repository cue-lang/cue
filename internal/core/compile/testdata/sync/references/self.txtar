--- withlet.cue
{
  withLet: {
    let X#4 = 〈1〉
    foo: 1
    bar: {
      baz: 〈1;let X#4〉.foo
    }
  }
  withLetComprehension: {
    let X#5 = 〈1〉
    direct: "a"
    if true {
      viaIf: "b"
    }
    for k, v in {
      viaFor: "c"
    } {
      〈1;k〉: 〈1;v〉
    }
    try {
      viaTry: "d"
    }
    seeDirect: 〈0;let X#5〉.direct
    seeIf: 〈0;let X#5〉.viaIf
    seeFor: 〈0;let X#5〉.viaFor
    seeTry: 〈0;let X#5〉.viaTry
  }
  withLetDynamicField: {
    let X#6 = 〈1〉
    h: {
      [string]: {
        c: len(〈1;(〈0;-〉)〉)
      }
    }
    h: {
      a: _
    }
    g: _
    for _, x in 〈0;let X#6〉.h {
      g: {
        "\({
          if true {
            〈4;x〉.c
          }
        })": true
      }
    }
    for k, _ in 〈0;g〉 {
      G: 〈1;k〉
    }
  }
  withLetDynamicField: {
    let Y#7 = 〈1〉
    s: true
    x: {
      if 〈1;let Y#7〉.s {
        1
      }
      if !〈1;let Y#7〉.s {
        2
      }
    }
  }
  letSelfIterate: {
    let X#8 = 〈1〉
    a: 3
    d: [
      for k, _ in 〈1;let X#8〉 {
        〈1;k〉
      },
    ]
  }
  withLetDynamicFieldRef: {
    let X#9 = 〈1〉
    h: {
      [string]: {
        c: len(〈2;h〉.a)
      }
    }
    h: {
      a: _
    }
    g: _
    for _, x in 〈0;let X#9〉.h {
      g: {
        "\({
          if true {
            〈4;x〉.c
          }
