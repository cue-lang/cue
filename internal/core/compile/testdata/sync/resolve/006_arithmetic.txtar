# Tests arithmetic operations including division producing floats and
# conflicting types (int & float).
-- in.cue --
v1: 1.0T / 2.0
v2: 2.0 == 2
n1: 1
v5: 2.0 / n1
v6: 1.0 / 1.0
e2: int & 4.0/2.0
-- out/compile --
--- in.cue
{
  v1: (1000000000000 / 2.0)
  v2: (2.0 == 2)
  n1: 1
  v5: (2.0 / 〈0;n1〉)
  v6: (1.0 / 1.0)
  e2: (int & (4.0 / 2.0))
}
