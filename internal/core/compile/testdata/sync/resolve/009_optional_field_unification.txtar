-- in.cue --
a: {foo?: string}      @test(eq, {foo?: string})
b: {foo: "foo"}        @test(eq, {foo: "foo"})
c: a & b               @test(eq, {foo: "foo"})
d: a & {"foo"?: "bar"} @test(eq, {foo?: "bar"})

e: {
	g1: 1
	"g\(1)"?: 1
	"g\(2)"?: 2
	@test(eq, {g1: 1, g2?: 2})
}
-- out/compile --
--- in.cue
{
  a: {
    foo?: string
  }
  b: {
    foo: "foo"
  }
  c: (〈0;a〉 & 〈0;b〉)
  d: (〈0;a〉 & {
    foo?: "bar"
  })
  e: {
    g1: 1
    "g\(1)"?: 1
    "g\(2)"?: 2
  }
}
