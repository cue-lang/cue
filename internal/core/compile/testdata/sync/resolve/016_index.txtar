-- in.cue --
a: [2][0]
b: {foo: "bar"}["foo"]
c: (*l | {"3": 3})["3"]
d: (*[] | [1])[0]
l: []

e1: [2][""]
e2: 2[2]
e3: [][true]
e4: [1, 2, 3][3]
e5: [1, 2, 3][-1]
e6: (*[] | {})[1]
e7: [1, 2, 3][3]
e8: [1, 2, 3][-1]
e9: (*[] | {})[1]

def: {
	a:  1
	#b: 3
}
e10: def["b"]
