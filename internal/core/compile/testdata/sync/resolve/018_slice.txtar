-- in.cue --
a:  [2][0:0]   @test(eq, [])
b:  [0][1:1]   @test(eq, [])
e1: [][1:1]    @test(err, code=eval, contains="index 1 out of range", pos=[0:5])
e2: [0][-1:0]  @test(err, code=eval, contains="cannot convert negative number", pos=[0:5])
e3: [0][1:0]   @test(err, code=eval, contains="invalid slice index", pos=[0:5])
e4: [0][1:2]   @test(err, code=eval, contains="index 2 out of range", pos=[0:5])
e5: 4[1:2]     @test(err, code=eval, contains="cannot slice 4", pos=[0:5])
e6: [2]["":] @test(err, code=eval, contains="cannot use \"\"", pos=[0:5, 0:9])
e7: [2][:"9"]  @test(err, code=eval, contains="cannot use \"9\"", pos=[0:5, 0:10])
-- out/compile --
--- in.cue
{
  a: [
    2,
  ][0:0]
  b: [
    0,
  ][1:1]
  e1: [][1:1]
  e2: [
    0,
  ][-1:0]
  e3: [
    0,
  ][1:0]
  e4: [
    0,
  ][1:2]
  e5: 4[1:2]
  e6: [
    2,
  ]["":]
  e7: [
    2,
  ][:"9"]
}
