-- in.cue --
#Foo: {
	a: 1
	b: int
} @test(eq, {a: 1, b: int}) @test(closed)
"#Foo": #Foo & {b: 1} @test(eq, {b: 1, a: 1}) @test(closed)

bulk: {[string]: string} & {
	#def: 4 // Different namespace, so bulk option does not apply.
	_hid: 3
	a:    "foo"
} @test(eq, {#def: 4, _hid: 3, a: "foo"})
-- out/compile --
--- in.cue
{
  #Foo: {
    a: 1
    b: int
  }
  "#Foo": (〈0;#Foo〉 & {
    b: 1
  })
  bulk: ({
    [string]: string
  } & {
    #def: 4
    _hid: 3
    a: "foo"
  })
}
