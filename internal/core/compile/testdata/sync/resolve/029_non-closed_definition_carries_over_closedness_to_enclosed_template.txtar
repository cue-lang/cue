-- in.cue --
#S: {
	[string]: {a: int}
} @test(eq, {}) @test(closed)
a: #S & {
	v: {b: int}
} @test(err, code=eval, at=v.b, contains="field not allowed", pos=[1:6])
#Q: {
	[string]: {a: int} | {b: int}
} @test(eq, {}) @test(closed)
b: #Q & {
	w: {c: int}
} @test(err, code=eval, at=w, contains="field not allowed", pos=[1:6])
// NOTE: the above test is marked at w, not w.c, because it fails both
// disjunctions. We probably want to record it at c, or at least give a better
// error message.
@test(err:todo, code=eval, at=b.w.c, contains="field not allowed")

#R: {
	[string]: [{a: int}, {b: int}]
} @test(eq, {}) @test(closed)
c: #R & {
	w: [{d: int}, ...]
} @test(err, code=eval, at=w.0.d, contains="field not allowed", pos=[1:7])
-- out/compile --
--- in.cue
{
  #S: {
    [string]: {
      a: int
    }
  }
  a: (〈0;#S〉 & {
    v: {
      b: int
    }
  })
  #Q: {
    [string]: ({
      a: int
    }|{
      b: int
    })
  }
  b: (〈0;#Q〉 & {
    w: {
      c: int
    }
  })
  #R: {
    [string]: [
      {
        a: int
      },
      {
        b: int
      },
    ]
  }
  c: (〈0;#R〉 & {
    w: [
      {
        d: int
      },
      ...,
    ]
  })
}
