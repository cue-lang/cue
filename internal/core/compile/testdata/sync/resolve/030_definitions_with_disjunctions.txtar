-- in.cue --
#Foo: {
	field: int

	{a: 1} |
	{b: 2}
} @test(eq, {field: int, a: 1} | {field: int, b: 2})

foo: #Foo
foo: {a: 1} @test(eq, {a: 1, field: int})

bar: #Foo
bar: {c: 2} @test(err, code=eval, contains="field not allowed", pos=[0:7])

baz: #Foo
baz: {b: 2} @test(eq, {b: 2, field: int})
-- out/compile --
--- in.cue
{
  #Foo: {
    field: int
    ({
      a: 1
    }|{
      b: 2
    })
  }
  foo: 〈0;#Foo〉
  foo: {
    a: 1
  }
  bar: 〈0;#Foo〉
  bar: {
    c: 2
  }
  baz: 〈0;#Foo〉
  baz: {
    b: 2
  }
}
