-- in.cue --
#Foo: {
	x: {
		field: int

		{a: 1} |
		{b: 2}
	}
	x: c: 3
} @test(eq, {
	x: {field: int, c: 3, a: 1} | {field: int, c: 3, b: 2}
})
-- out/compile --
--- in.cue
{
  #Foo: {
    x: {
      field: int
      ({
        a: 1
      }|{
        b: 2
      })
    }
    x: {
      c: 3
    }
  }
}
