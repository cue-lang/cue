-- in.cue --
res: [t]
t: [X=string]: {
	a: c + b.str
	b: str: string
	c: "X"
}
t: x: {b: str: "DDDD"}

-- out/compile --
--- in.cue
{
  res: [
    〈1;t〉,
  ]
  t: {
    [string]: {
      a: (〈0;c〉 + 〈0;b〉.str)
      b: {
        str: string
      }
      c: "X"
    }
  }
  t: {
    x: {
      b: {
        str: "DDDD"
      }
    }
  }
}
