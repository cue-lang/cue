-- in.cue --
// When a field has the same name as a predeclared builtin, the
// exported reference to the builtin must be rewritten to its
// "__"-prefixed form to avoid binding to the field instead.
// Issue #3563.
"matchN"?: matchN(1, [string, bool])
-- out/definition --
// When a field has the same name as a predeclared builtin, the
// exported reference to the builtin must be rewritten to its
// "__"-prefixed form to avoid binding to the field instead.
// Issue #3563.
matchN?: matchN(1, [string, bool])
