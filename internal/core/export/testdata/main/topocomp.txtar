-- in.cue --
out: {
    for x in ["A", "B"] {
        top: "\(x)1": true
        top: "\(x)2": true
    }
}
view: {
    for k, _ in out.top {
        (k): k
    }
}
-- out/doc-v3 --
[]
[out]
[out top]
[out top A1]
[out top A2]
[out top B1]
[out top B2]
[view]
[view A1]
[view A2]
[view B1]
[view B2]
