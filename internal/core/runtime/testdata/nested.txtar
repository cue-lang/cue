-- cue.mod/modules.cue --
-- file1.cue --
@extern("testfn")

package foo


a: Foo: _ @testfn(file1.xx, abi=c, sig="func(int)int")

a: Rename: _ @testfn(file1.xx, name=Emaner, abi=c, sig="func(int)int")

-- file2.cue --
@extern("testfn")

package foo


a: foo: Bar: {
	@other()
	@testfn(file2.xx, abi=c, sig="func(int)int")
	_
}

-- extern/out --
-- out/extern --
{
	a: {
		Foo:    implFoo1
		Rename: implEmaner1
		foo: {
			Bar: implBar2
		}
	}
}
