// An injection attribute such as @testfn requires a matching file-level
// @extern declaration; without it the attribute would be silently ignored,
// so we report an error.
-- cue.mod/modules.cue --
-- in.cue --
// Missing @extern("testfn")
@dummy()

package foo


Foo: _ @testfn(file.xx, abi=c, sig="func(int)int")

-- extern/out --
-- out/extern --
@testfn attribute requires a file-level @extern(testfn) declaration:
    ./in.cue:7:8
