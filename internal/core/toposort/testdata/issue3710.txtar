-- input.cue --
package p

#Exporter: {
	_objects: {...}
	_imports: [...]

	objects: [
		for _, objs in _objects {
			objs
		}
		for import in _imports for obj in import._export.objects {
			obj
		}
	]
}

out: #Exporter & {
	_imports: [_app1]
}
_app1: {
	_export: #Exporter & {
		_imports: [_app2]
	}
}
_app2: {
	_export: #Exporter & {
		_objects: leaf: leafField: "leaf value"
	}
}
-- out/TestTopologicalSort/lexicographical=false --
{
	#Exporter: {
		objects: []
	}
	out: {
		objects: [{
			leafField: "leaf value"
		}]
	}
}
-- out/TestTopologicalSort/lexicographical=true-v3 --
{
	out: {
		objects: [{
			leafField: "leaf value"
		}]
	}
	#Exporter: {
		objects: []
	}
}
-- diff/-out/TestTopologicalSort/lexicographical=true-v3<==>+out/TestTopologicalSort/lexicographical=true --
diff old new
--- old
+++ new
@@ -1,10 +1,10 @@
 {
-	#Exporter: {
-		objects: []
-	}
 	out: {
 		objects: [{
 			leafField: "leaf value"
 		}]
 	}
+	#Exporter: {
+		objects: []
+	}
 }
-- out/TestTopologicalSort/lexicographical=true --
{
	#Exporter: {
		objects: []
	}
	out: {
		objects: [{
			leafField: "leaf value"
		}]
	}
}
