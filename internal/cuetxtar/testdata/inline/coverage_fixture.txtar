# Tests that fixture files (no @test) with fields reachable from tested fields
# pass coverage checks without needing @test directives of their own.
# base in fixture.cue is referenced by result in test.cue, so it is covered.
-- in/fixture.cue --
package p

// Pure fixture — no @test anywhere; its fields need not be individually tested.
base: 100

-- in/test.cue --
package p

// test.cue has @test attributes, so it is a test file.
// References base from fixture.cue to exercise coverage propagation.
result: base + 1 @test(eq, 101)
-- out/status.txt --
update: identical to input
force:  identical to update
