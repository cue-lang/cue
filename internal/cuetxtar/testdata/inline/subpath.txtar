# Tests that #subpath restricts the inline runner to the named test only.
# The "first" field has a wrong eq (1 != 999) but is skipped entirely.
# The "second" field passes normally.
#subpath: second
-- in/test.cue --
first: 1 @test(eq, 999)
second: 2 @test(eq, 2)
-- out/status.txt --
update: identical to input
-- out/run/errors.txt --
path first: expected 999, got 1
-- out/force/test.cue --
first: 1 @test(eq, 1)
second: 2 @test(eq, 2)
