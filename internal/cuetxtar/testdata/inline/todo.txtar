// @test(eq:todo, X) where value != X: silent non-failure
eqTodoStillFailing: 42 @test(eq, 42) @test(eq:todo, 99)

// @test(eq:todo, X) where value == X: warning logged, no failure
eqTodoPassing: 42 @test(eq, 42) @test(eq:todo, 42)

// @test(eq, ...) and @test(eq:todo, ...) coexist independently
eqAndEqTodoCoexist: 42 @test(eq, 42) @test(eq:todo, 99)

// @test(err:todo) where value is not an error: silent non-failure
