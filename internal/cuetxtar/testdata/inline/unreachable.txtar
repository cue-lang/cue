# Tests valid @test placement positions relative to conjunction expressions.
# Invalid placements (inside X & {...} operands) fail immediately via t.Errorf
# and cannot be expressed as txtar.
#
# Valid positions demonstrated here:
#   - Field attr on the whole conjunction: f: X & {} @test(...)
#   - Decl attr inside a plain struct (not a binary operand): f: { @test(...); ... }
-- in/test.cue --
base: {v: 1}

// Field attr placed after the whole conjunction expression: valid.
afterConj: base & {} @test(eq, {v: 1})

// Decl attr inside a plain (non-conjunction) struct: valid.
plainStruct: {
	@test(eq, {v: 1})
	v: 1
}
-- out/status.txt --
update: identical to input
force:  identical to update
