# A struct-valued field is interspersed among simple fields but does
# not participate in column width calculation. All simple field values
# are aligned to the widest key across the whole struct.
-- config --
width: 25
-- in.cue --
{
	short: 1
longname: 2
	mid: {inner: true}
a: 3
	bc: 4
}
-- out/relpos --
{
	short:    1
	longname: 2
	mid: {inner: true}
	a:        3
	bc:       4
}
-- out/norelpos --
{
	short:    1
	longname: 2
	mid: {inner: true}
	a:        3
	bc:       4
}
