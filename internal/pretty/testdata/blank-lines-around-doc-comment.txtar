# Blank lines around a doc comment inside a list or struct must be
# preserved. The parser attaches the blank-line signal via
# NewSection RelPos: on the comment (blank line before the comment)
# and on the node the comment documents (blank line between comment
# and body). The opening '[' or '{' uses effectiveRel (max of first
# element's own RelPos and its doc comment's RelPos) so the first
# blank is emitted; withComments / applyBeforeAfter use the body's
# RelPos for the separator between the last doc comment and the body.
-- in.cue --
x: [

	// comment

	{},
]

y: {

	// comment

	z
}
-- out/relpos --
x: [

	// comment

	{},
]

y: {

	// comment

	z
}
-- out/norelpos --
x: [
	// comment
	{},
]
y: {
	// comment
	z
}
