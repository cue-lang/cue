# When a braceless chain key breaks across lines (e.g. `g:\n abcde:`)
# and the leaf value is wrappable (struct, list, call, etc.), the value's
# caller-indent must match the chain's deepest broken line - not the
# row's own indent. Otherwise any HardLine the value emits internally
# (struct body break, list explode, ...) lands at the wrong column and
# the closing bracket ends up flush-left instead of aligned with the
# inner chain field.
#
# r.lastIndent already tracks the most recent newline's level, so
# renderTableSegment promotes cellIndent for cell 1 when it is deeper
# than the row's indent.
-- config --
width: 8
-- in.cue --
g: abcde: {x}
-- out/relpos --
g: abcde: {x}
-- out/norelpos --
g:
	abcde: {
		x
	}
