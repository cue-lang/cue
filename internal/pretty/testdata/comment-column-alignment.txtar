{
	x:     "hello"   // greeting
	y:     "goodbye" // farewell
	zebra: "hi"      // short
}
-- out/norelpos --
{
	x:     "hello"   // greeting
	y:     "goodbye" // farewell
	zebra: "hi"      // short
}
