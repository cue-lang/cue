# A comment written on the same line as the "{" of a conjunction's
# RHS struct. The parser attaches it to the enclosing BinaryExpr at
# Position=1 Line=true (not to the empty StructLit), but it is
# logically interior to the struct: structLitInjected pushes it back
# inside the braces. Because the user wrote the comment trailing `{`
# on the same line, the formatter keeps it there (with a single
# space, matching structLit's own Line=true prefix-comment handling).
-- in.cue --
foo: #X & {//a: 5
}
-- out/relpos --
foo: #X & { //a: 5
}
-- out/norelpos --
foo: #X & { //a: 5
}
