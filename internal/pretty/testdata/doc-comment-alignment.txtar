# A doc comment on a field should not disable padding for that field.
# The comment appears before the field, and the field still aligns.
# The doc comment forces the struct to break (so it's not lost).
-- in.cue --
{
	// doc comment
	x: 1
	longname: 2
}
-- out/relpos --
{
	// doc comment
	x:        1
	longname: 2
}
-- out/norelpos --
{
	// doc comment
	x:        1
	longname: 2
}
