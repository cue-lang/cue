# A line comment on a short-key field should not affect alignment.
# The // comment forces the struct to break (even without RelPos)
# because a line comment would swallow subsequent tokens in flat mode.
-- in.cue --
{
	x: 1           // comment
	longname: 2
}
-- out/relpos --
{
	x:        1 // comment
	longname: 2
}
-- out/norelpos --
{
	x:        1 // comment
	longname: 2
}
