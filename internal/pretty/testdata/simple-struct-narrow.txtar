# Single-line input at narrow width: parsed source is preserved as-is
# (the user wrote everything on one line, so the formatter does not
# add width-driven newlines). Only when RelPos is stripped - the
# programmatic-AST case - does the width limit drive a break.
-- config --
width: 8
-- in.cue --
{a: 1, b: 2}
-- out/relpos --
{a: 1, b: 2}
-- out/norelpos --
{
	a: 1
	b: 2
}
