Value aliases on non-struct values are wrapped in a struct with an
embedding to hold the inserted "let X = self". References to the
enclosing field from elsewhere in the file must keep resolving to the
field as-is.

TODO: the wrapping currently breaks the node identity that references
to the field were resolved against, so Sanitize preserves their binding
through a spurious unique-name let indirection (dd_9, #pair_B below).
The output should reference the fields directly.

#exp:aliasv2
#no-coverage

-- cue.mod/module.cue --
module: "test.example"

language: version: "v0.15.0"

-- a.cue --
package foo

// Value alias on a parenthesized disjunction.
dd: D=(*{a: 1, a2: D.a} | {b: 2})
ddref: dd.a @test(eq, 1)

// Value alias on a list, referenced from another field.
#pair: P=[{x: int}, {y: P[0].x}]
pref: #pair & [{x: 1}, _]
pval: pref[1].y @test(eq, 1)
-- out/fixmod --
--- cue.mod/module.cue
module: "test.example"
language: version: "v0.15.0"
--- a.cue
@experiment(aliasv2)

package foo

// Value alias on a parenthesized disjunction.
dd:    {let D = self, (*{a: 1, a2: D.a} | {b: 2})}
ddref: dd_9.a @test(eq, 1)

// Value alias on a list, referenced from another field.
#pair: {let P = self, [{x: int}, {y: P[0].x}]}
pref:  #pair_B & [{x: 1}, _]
pval:  pref[1].y @test(eq, 1)

let dd_9 = dd

let #pair_B = #pair
