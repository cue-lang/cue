-- out/fixmod --
--- cue.mod/module.cue
module: "early.test"
language: {
	version: "v0.15.0"
}
--- a.cue
@experiment(explicitopen)

package foo

#A: a: int

X: {
	#A
}
str: "bar"
Y: {
	// Do not add ellipsis where unnecessary.
	[1, 2]
	1
	"foo"
	"foo\(str)"
	<=10
	{b: int}
	_
}

_repo: {}
inClose: {
	workflows: close({
		_repo
	})
}
nestedStruct: {
	containsTrybotTrailer: {
		{#foo...}
	}
}
nestedStructWithEmbed: {
	a: __closeAll({
		{#Def...} // doesn't count as single.
		b: int
	})
}
--- b.cue
