
#exp:explicitopen

# Test __closeAll vs __reclose wrapper selection for various embedding patterns:
# close() variants, conjunctions, disjunctions, and combinations with fields.

#no-coverage

-- cue.mod/module.cue --
module: "builtins.test"

language: version: "v0.15.0"

-- in.cue --
package foo

#A: a: int
#D: x: int
_repo: {}

// close()-oAnd indeed, the post-fix is incorrect. nly embedding → no change needed.
closeOnly: {
	v: {
		close({a: int})
		b: int
	}
	t1: v & {c: int} @test(err, code=eval, path=c, contains="field not allowed")
	t2: v & {b: 1}   @test(eq, {b: 1, a: int})
}



// close() + non-def reference → __reclose wraps struct, close() left as-is.
closeAndRef: {
	v: {
		close({a: int})
		_repo
	}

	t1: v & {c: int} @test(err, code=eval, path=c, contains="field not allowed")
	t2: v & {a: 1}   @test(eq, {a: 1})
}



// Mixed definition + close() → __closeAll wraps struct, close() left as-is.
mixedDefClose: {
	#E: x: y: {}
	v: {
		#E
		close({b: c: {}})
	}

	t1: v & {c: 1}       @test(err, code=eval, path=c, contains="field not allowed")
	t2: v & {b: d: 1}    @test(err, code=eval, contains="field not allowed")
	t3: v & {b: c: d: 1} @test(err, code=eval, contains="field not allowed")
	t4: v & {b: c: {}}   @test(eq, {b: {c: {}}, x: {y: {}}})
	t5: v & {x: y: {}}   @test(eq, {x: {y: {}}, b: {c: {}}})

}


// Conjunct → single embed, simplified.
conjunct: {
	#A: a: int
	_repo: {}

	v: {
		#A & _repo
	}

	t1: v & {a: 1} @test(eq, {a: 1})
	t2: v & {b: 1} @test(err, code=eval)
}

conjunctComplex: {
	#C1: {a?: int, c: int}
	#C2: {b?: int, c: int}
	v: {
		#C1 & #C2
		d: int
	}
	t1: v & {a: 1} @test(err, code=eval)
	t2: v & {b: 1} @test(err, code=eval)
	t3: v & {c: 1} @test(eq, { c: 1, d: int })
	t4: v & {d: 1} @test(eq, { d: 1, c: int })
	t5: v & {e: 1} @test(err, code=eval)

	#C: #C1 & #C2
	vb: {
		#C
		d: int
	}
	tb1: vb & {a: 1} @test(err, code=eval)
	tb2: vb & {b: 1} @test(err, code=eval)
	tb3: vb & {c: 1} @test(eq, { c: 1, d: int })
	tb5: vb & {e: 1} @test(err, code=eval)
}


// Disjunct → single embed, simplified.
disjunct: {
	#A | _repo
}

// Parenthesized conjunct.
parenConj: {
	(#A & _repo)
}

// Embedded close() with def arg → __closeAll wraps, close() left as-is.
embeddedCloseOnly: {
	close(#A)
}

// Embedded close() with def arg + extra field → __closeAll wraps.
embeddedCloseField: {
	#A: a: int
	v: {
		close(#A)
		b: int
	}

	t1: v & {a: 1} @test(eq, {a: 1, b: int})
	t2: v & {b: 1} @test(eq, {b: 1, a: int})
	t3: v & {c: 1} @test(err, code=eval, path=c, contains="field not allowed")
}

// Conjunction with extra field → not simplified, __closeAll wraps.
conjunctField: {
	#A & _repo
	b: int
}

// Disjunction with extra field → not simplified, __reclose wraps.
disjunctField: {
	#A | _repo
	b: int
}

// Pure-definition disjunction → __closeAll (all operands are defs).
disjunctDefs: {
	#A | #D
}

// Disjunction with a defaulted definition operand → __reclose wraps,
// and the comprehension field value is opened.
defaultDisjunct: {
	#A: {a: int}
	v: {
		*#A | {}
		b: int
	}

	t1: {w: v & {a: 1}} @test(eq, {w: {a: 1, b: int} @test(final)})

	// TODO: the new semantics is more permissive here; under the old
	// semantics the defaulted branch is closed, so unifying v with
	// {c: 1} eliminates it and resolves to the empty branch.

	#S: {
		enable: bool
		x?: {...}
		if enable {
			x: *#A | {}
		}
	}
	t3: #S & {enable: true, x: {extra: 1}} @test(eq,
		{enable: true, x: {a: int, extra: 1} @test(final)})
}

// and() with extra field → not simplified, __reclose wraps.
andField: {
	#A: {a: int, b?: int}
	#D: {a: int, c?: int}
	v: {
		and([#A, #D])
		b: int
	}

	t1: v & {a: 1} @test(eq, {a: 1, b: int, c?: _|_})
	t2: v & {b: 1} @test(eq, {a: int, b: 1, c?: _|_})

	// TODO: the new semantics is more permissive here:
	// t3: v & {c: 1} @test(err, code=eval, path=c, contains="field not allowed")
}

// or() with extra field → not simplified, __reclose wraps.
orField: {
	or([#A, #D])
	b: int
}

// Conjunction with a selector operand → __reclose wraps.
selConjField: {
	#A: a: int
	h: inner: #A
	v: {
		h.inner & {a: 1}
		b: int
	}

	t1: v & {b: 1} @test(eq, {a: 1, b: 1})
	t2: v & {c: 1} @test(err, code=eval, path=c, contains="field not allowed")
}

// Comprehension field values with a selector conjunction or an and()
// call do not close their field against a sibling pattern constraint;
// entries added elsewhere remain allowed.
compCallField: {
	#HC: hc: {port: 1}
	lib: v: #HC
	#S: {
		enable: bool
		egress?: [string]: {...}
		egress2?: [string]: {...}
		if enable {
			egress: lib.v & {hc: port: 1}
		}
		if enable {
			egress2: and([lib.v])
		}
	}

	t1: #S & {enable: true, egress: {extra: {}}, egress2: {extra: {}}} @test(eq,
		{enable: true, egress: {hc: {port: 1}, extra: {}}, egress2: {hc: {port: 1}, extra: {}}})
}

// Struct literal field values inside comprehensions get no wrapper;
// entries added elsewhere remain allowed.
compLiteralField: {
	#A: a: int
	#S: {
		enable: bool
		egress?: {...}
		if enable {
			egress: {#A, extra: 1}
		}
	}

	t1: #S & {enable: true, egress: {a: 1, extra2: 2}} @test(eq,
		{enable: true, egress: {a: 1, extra: 1, extra2: 2}})
}

