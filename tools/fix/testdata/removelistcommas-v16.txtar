#removelistcommas

# With v0.16.0, --remove-list-commas is a no-op because the language
# version does not yet support comma-free lists.

-- cue.mod/module.cue --
module: "example.com"
language: version: "v0.16.0"

-- a.cue --
package a

a: [
	1,
	2,
	3,
]
-- out/fixmod --
--- cue.mod/module.cue
module: "example.com"
language: {
	version: "v0.16.0"
}
--- a.cue
package a

a: [
	1,
	2,
	3,
]
