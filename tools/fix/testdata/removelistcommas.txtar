#removelistcommas

-- cue.mod/module.cue --
module: "example.com"
language: version: "v0.17.0"

-- a.cue --
package a

// Multiline list with commas: commas are removed.
a: [
	1,
	2,
	3,
]

// Same-line list: not affected.
b: [1, 2, 3]

// Already no commas: unchanged.
c: [
	1
	2
	3
]

// Mixed commas: all removed.
d: [
	1,
	2
	3,
]

// Single element with comma: removed.
e: [
	"foo",
]

// Single element without comma: unchanged.
f: [
	"foo"
]

// Trailing line comments: commas removed.
g: [
	1, // first
	2, // second
	3, // third
]

// Nested lists.
h: [
	[1, 2, 3],
	[
		4,
		5,
	],
]
-- out/fixmod --
--- cue.mod/module.cue
module: "example.com"
language: {
	version: "v0.17.0"
}
--- a.cue
package a

// Multiline list with commas: commas are removed.
a: [
	1
	2
	3
]

// Same-line list: not affected.
b: [1, 2, 3]

// Already no commas: unchanged.
c: [
	1
	2
	3
]

// Mixed commas: all removed.
d: [
	1
	2
	3
]

// Single element with comma: removed.
e: [
	"foo"
]

// Single element without comma: unchanged.
f: [
	"foo"
]

// Trailing line comments: commas removed.
g: [
	1 // first
	2 // second
	3 // third
]

// Nested lists.
h: [
	[1, 2, 3]
	[
		4
		5
	]
]
